---
const lang = Astro.currentLocale === 'en' ? 'en' : 'id';

const content = {
  id: {
    sectionTag: "/ LUMOVELO_SITE_AUDIT_CORE",
    nodeId: "NODE_ID: AUDIT_V3_ACTIVE",
    auditHeader: "Web Kamu Lemot? Kita Buktikan di Sini.",
    auditDesc: "Input URL dan lihat sendiri kenapa visitor kamu kabur. No fancy words, just facts.",
    quickRun: "QUICK RUN DEMO:",
    runBtn: "RUN INSTANT AUDIT",
    ctaTitle: "REKOMENDASI: OPTIMASI LUMOVELO ENGINE",
    ctaDesc: "Hubungi tim kami untuk menaikkan skor Lighthouse ke 100/100 dan menghentikan kebocoran Leads Anda.",
    ctaBtn: "Klaim Solusi Anda",
    cardSpeedTitle: "Lighthouse Speed Score",
    cardSeoTitle: "SEO Visibility Index",
    cardLossTitle: "Est. Conversion Loss",
  },
  en: {
    sectionTag: "/ LUMOVELO_SITE_AUDIT_CORE",
    nodeId: "NODE_ID: AUDIT_V3_ACTIVE",
    auditHeader: "Is Your Web Slow? Let's Prove It Here.",
    auditDesc: "Input URL and see for yourself why your visitors run away. No fancy words, just facts.",
    quickRun: "QUICK RUN DEMO:",
    runBtn: "RUN INSTANT AUDIT",
    ctaTitle: "RECOMMENDATION: OPTIMIZE LUMOVELO ENGINE",
    ctaDesc: "Contact our team to increase your Lighthouse score to 100/100 and stop your Leads leakage.",
    ctaBtn: "Claim Your Solution",
    cardSpeedTitle: "Lighthouse Speed Score",
    cardSeoTitle: "SEO Visibility Index",
    cardLossTitle: "Est. Conversion Loss",
  }
}[lang];

const contactLink = lang === 'en' ? '/en/#konsultasi' : '#konsultasi';
---
<section class="py-24 border-y-2 border-slate-200 bg-slate-50 relative overflow-hidden">
  <!-- Interactive Grid Background -->
  <div class="absolute inset-0 bg-[linear-gradient(to_right,rgba(37,99,235,0.015)_1px,transparent_1px),linear-gradient(to_bottom,rgba(37,99,235,0.015)_1px,transparent_1px)] bg-[size:2rem_2rem] pointer-events-none"></div>

  <!-- Hidden i18n data tag for client script -->
  <div id="audit-i18n"
    data-run-btn-auditing={lang === 'en' ? "AUDITING SITE..." : "AUDITING SITE..."}
    data-run-btn-rerun={lang === 'en' ? "RE-RUN AUDIT" : "RE-RUN AUDIT"}
    data-status-scanning={lang === 'en' ? "STATUS: SCANNING..." : "STATUS: SCANNING..."}
    data-status-critical={lang === 'en' ? "STATUS: CRITICAL ISSUES FOUND" : "STATUS: CRITICAL ISSUES FOUND"}
    data-start-audit={lang === 'en' ? "Starting LUMOVELO Audit Agent for domain: " : "Memulai LUMOVELO Audit Agent untuk domain: "}
    data-log-0={lang === 'en' ? "Performing DNS lookup and target IP verification..." : "Melakukan lookup DNS dan IP target..."}
    data-log-1={lang === 'en' ? "Measuring response latency (TTFB: Time To First Byte)..." : "Mengukur respon latency (TTFB: Time To First Byte)..."}
    data-log-2={lang === 'en' ? "WARNING: Slow TTFB detected (842ms)! Target is < 150ms." : "PERINGATAN: TTFB terdeteksi lambat (842ms)! Target < 150ms."}
    data-log-3={lang === 'en' ? "Scanning HTML DOM architecture & JavaScript asset payload..." : "Memindai arsitektur DOM HTML & payload asset JavaScript..."}
    data-log-4={lang === 'en' ? "Analyzing image compression & cache control headers..." : "Menganalisis kompresi gambar & cache control headers..."}
    data-log-5={lang === 'en' ? "WARNING: 24 large image files are uncompressed." : "PERINGATAN: 24 file gambar berukuran besar belum dikompresi."}
    data-log-6={lang === 'en' ? "Checking SEO structure: Meta tags, schema markup, & sitemap..." : "Mengecek struktur SEO: Meta tags, schema markup, & sitemap..."}
    data-log-7={lang === 'en' ? "WARNING: SEO meta description is empty on some key pages." : "PERINGATAN: Deskripsi meta SEO kosong pada beberapa halaman penting."}
    data-log-8={lang === 'en' ? "Estimating percentage of traffic & lead conversion loss..." : "Mengestimasi persentase hilangnya traffic & konversi leads..."}
    data-log-9={lang === 'en' ? "Audit data compilation complete. Uploading report to dashboard..." : "Penyusunan data audit selesai. Mengunggah laporan ke dashboard..."}
    data-complete-audit={lang === 'en' ? "> AUDIT COMPLETE FOR " : "> AUDIT SELESAI UNTUK "}
    data-complete-bottleneck={lang === 'en' ? ". Critical bottlenecks found!" : ". Ditemukan bottleneck kritis!"}
  ></div>

  <div class="max-w-7xl mx-auto px-6 relative z-10 reveal-on-scroll">
    
    <!-- Pulse signal header -->
    <div class="flex items-center justify-between mb-10">
      <div class="flex items-center gap-2.5">
        <span class="relative flex h-3 w-3">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-600 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-3 w-3 bg-blue-600"></span>
        </span>
        <span class="text-xs font-black tracking-widest text-slate-500 uppercase font-mono">{content.sectionTag}</span>
      </div>
      <div class="text-[10px] font-mono text-slate-600 bg-white border border-slate-200 px-3 py-1 rounded-md font-bold">
        {content.nodeId}
      </div>
    </div>

    <!-- The Interactive HUD Console -->
    <div class="brutalist-glass rounded-3xl p-6 sm:p-10 border-2 border-blue-600 bg-white shadow-[6px_6px_0px_#2563eb] flex flex-col gap-6 items-stretch justify-between">
      
      <div class="flex flex-col lg:flex-row gap-8 items-stretch justify-between w-full">
        <!-- Control Panel (Left Column - Website Auditor Input) -->
        <div class="w-full lg:w-1/3 flex flex-col justify-between gap-6 bg-slate-50 p-6 rounded-2xl border-2 border-blue-600 shadow-[4px_4px_0px_#2563eb]">
          <div>
            <span class="text-[9px] font-mono text-slate-440 block mb-2 font-bold">/ WEB_PERFORMANCE_AUDIT</span>
            <h4 class="font-display font-black text-xl text-slate-900 uppercase tracking-tight mb-2">{content.auditHeader}</h4>
            <p class="text-xs text-slate-600 leading-relaxed mb-4">
              {content.auditDesc}
            </p>
            
            <!-- URL Input Field -->
            <div class="space-y-4">
              <div class="relative">
                <input 
                  type="text" 
                  id="audit-url-input" 
                  placeholder="domain-kamu.com" 
                  class="w-full bg-white border-2 border-slate-200 focus:border-blue-600 text-slate-900 text-xs px-4 py-3 rounded-lg font-mono placeholder-slate-400 outline-none transition-all duration-200"
                />
                <span class="absolute right-3 top-3.5 text-[9px] text-slate-400 font-mono select-none font-bold">HTTPS</span>
              </div>
              
              <!-- Quick Chips for default demo -->
              <div>
                <span class="text-[8px] font-mono text-slate-440 block mb-2 font-bold">{content.quickRun}</span>
                <div class="flex flex-wrap gap-3">
                  <button type="button" class="quick-chip-btn text-[9px] font-mono px-3 py-1.5 rounded-lg bg-white border-2 border-blue-600 hover:bg-blue-600 hover:text-white text-blue-600 transition-all duration-150 cursor-pointer font-bold shadow-[2px_2px_0px_#2563eb] active:translate-x-[1px] active:translate-y-[1px] active:shadow-[1px_1px_0px_#2563eb]" data-url="toko-online-lambat.com">
                    toko-lambat.com
                  </button>
                  <button type="button" class="quick-chip-btn text-[9px] font-mono px-3 py-1.5 rounded-lg bg-white border-2 border-blue-600 hover:bg-blue-600 hover:text-white text-blue-600 transition-all duration-150 cursor-pointer font-bold shadow-[2px_2px_0px_#2563eb] active:translate-x-[1px] active:translate-y-[1px] active:shadow-[1px_1px_0px_#2563eb]" data-url="company-profile.id">
                    comp-profile.id
                  </button>
                </div>
              </div>
            </div>
          </div>

          <!-- The Interactive Audit Button -->
          <button 
            id="audit-button"
            class="w-full py-4 rounded-xl border-2 border-blue-600 bg-blue-600 hover:bg-blue-700 text-white font-display font-black text-xs uppercase tracking-widest transition-all duration-200 cursor-pointer shadow-[3px_3px_0px_#0f172a] hover:shadow-[0_0_15px_rgba(59,130,246,0.4)] active:scale-98 select-none"
          >
            {content.runBtn}
          </button>
        </div>

        <!-- Real-Time Log Terminal (Middle Column) -->
        <div class="w-full lg:w-1/3 flex flex-col gap-3 bg-slate-950 p-5 rounded-2xl border-2 border-blue-600 shadow-[4px_4px_0px_#2563eb]">
          <div class="flex items-center justify-between text-[9px] font-mono text-slate-400">
            <span class="font-bold text-slate-500">AUDIT_LOG_STREAM</span>
            <span id="audit-status-indicator" class="text-blue-400 font-bold transition-colors duration-300">STATUS: STANDBY</span>
          </div>
          
          <!-- Log Output Box -->
          <div id="log-output-box" class="h-44 font-mono text-[10px] text-slate-400 overflow-y-auto space-y-1.5 scrollbar-thin flex flex-col justify-end">
            <!-- Animated logs inject on mount -->
          </div>
        </div>

        <!-- Live Statistics (Right Column) -->
        <div class="w-full lg:w-1/3 flex flex-col justify-between gap-4">
          
          <!-- Speed score card -->
          <div class="p-5 bg-slate-50 border-2 border-blue-600 shadow-[4px_4px_0px_#2563eb] rounded-2xl flex-1 flex flex-col justify-center transition-all duration-300" id="card-speed">
            <span class="text-[8px] font-bold uppercase tracking-widest text-slate-440 mb-1 font-mono">{content.cardSpeedTitle}</span>
            <div class="flex items-baseline justify-between overflow-hidden">
              <span id="speed-score-val" class="font-display font-black text-xl sm:text-2xl lg:text-3xl text-slate-400 tracking-tight tabular-nums truncate transition-colors duration-300">
                --
              </span>
              <span id="speed-badge" class="text-[8px] font-mono font-bold px-2 py-0.5 rounded border border-transparent hidden uppercase"></span>
            </div>
          </div>

          <!-- SEO score card -->
          <div class="p-5 bg-slate-50 border-2 border-blue-600 shadow-[4px_4px_0px_#2563eb] rounded-2xl flex-1 flex flex-col justify-center transition-all duration-300" id="card-seo">
            <span class="text-[8px] font-bold uppercase tracking-widest text-slate-440 mb-1 font-mono">{content.cardSeoTitle}</span>
            <div class="flex items-baseline justify-between overflow-hidden">
              <span id="seo-score-val" class="font-display font-black text-xl sm:text-2xl lg:text-3xl text-slate-400 tracking-tight tabular-nums truncate transition-colors duration-300">
                --
              </span>
              <span id="seo-badge" class="text-[8px] font-mono font-bold px-2 py-0.5 rounded border border-transparent hidden uppercase"></span>
            </div>
          </div>

          <!-- Conversion loss card -->
          <div class="p-5 bg-slate-50 border-2 border-blue-600 shadow-[4px_4px_0px_#2563eb] rounded-2xl flex-1 flex flex-col justify-center transition-all duration-300" id="card-conversion">
            <span class="text-[8px] font-bold uppercase tracking-widest text-slate-440 mb-1 font-mono">{content.cardLossTitle}</span>
            <div class="flex items-baseline justify-between overflow-hidden">
              <span id="conversion-loss-val" class="font-display font-black text-xl sm:text-2xl lg:text-3xl text-slate-400 tracking-tight tabular-nums truncate transition-colors duration-300">
                --
              </span>
              <span id="conversion-badge" class="text-[8px] font-mono font-bold px-2 py-0.5 rounded border border-transparent hidden uppercase"></span>
            </div>
          </div>

        </div>
      </div>

      <!-- CTA Banner (Revealed after audit completes) -->
      <div 
        id="audit-cta-container" 
        class="w-full bg-rose-50 border-2 border-rose-600 rounded-2xl p-5 flex flex-col md:flex-row items-center justify-between gap-4 hidden opacity-0 transition-all duration-500 ease-out shadow-[4px_4px_0px_#e11d48]"
      >
        <div class="flex items-center gap-3">
          <span class="flex h-3.5 w-3.5 relative">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-rose-600 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-3.5 w-3.5 bg-rose-600"></span>
          </span>
          <div>
            <h5 class="text-sm font-display font-black text-slate-900 uppercase tracking-wider font-bold">{content.ctaTitle}</h5>
            <p class="text-[11px] text-slate-600 font-semibold">{content.ctaDesc}</p>
          </div>
        </div>
        <a 
          href={contactLink} 
          id="audit-cta-link"
          class="px-6 py-3 bg-rose-600 hover:bg-rose-700 text-white font-display font-black text-xs uppercase tracking-widest rounded-xl transition-all duration-200 hover:shadow-[0_0_20px_rgba(225,29,72,0.3)] active:scale-95 text-center cursor-pointer whitespace-nowrap animate-pulse"
        >
          {content.ctaBtn}
        </a>
      </div>

    </div>
  </div>
</section>

<script>
  function initInteractiveConsole() {
    const i18nEl = document.getElementById('audit-i18n');
    const runBtnAuditingText = i18nEl?.getAttribute('data-run-btn-auditing') || "AUDITING SITE...";
    const runBtnRerunText = i18nEl?.getAttribute('data-run-btn-rerun') || "RE-RUN AUDIT";
    const statusScanningText = i18nEl?.getAttribute('data-status-scanning') || "STATUS: SCANNING...";
    const statusCriticalText = i18nEl?.getAttribute('data-status-critical') || "STATUS: CRITICAL ISSUES FOUND";
    const startAuditText = i18nEl?.getAttribute('data-start-audit') || "Starting LUMOVELO Audit Agent for domain: ";
    const completeAuditText = i18nEl?.getAttribute('data-complete-audit') || "AUDIT COMPLETE FOR ";
    const completeBottleneckText = i18nEl?.getAttribute('data-complete-bottleneck') || ". Critical bottlenecks found!";

    const input = document.getElementById('audit-url-input') as HTMLInputElement;
    const button = document.getElementById('audit-button') as HTMLButtonElement;
    const logBox = document.getElementById('log-output-box');
    const statusIndicator = document.getElementById('audit-status-indicator');
    const quickChips = document.querySelectorAll('.quick-chip-btn');
    
    const speedScoreVal = document.getElementById('speed-score-val');
    const speedBadge = document.getElementById('speed-badge');
    const cardSpeed = document.getElementById('card-speed');
    
    const seoScoreVal = document.getElementById('seo-score-val');
    const seoBadge = document.getElementById('seo-badge');
    const cardSeo = document.getElementById('card-seo');
    
    const conversionLossVal = document.getElementById('conversion-loss-val');
    const conversionBadge = document.getElementById('conversion-badge');
    const cardConversion = document.getElementById('card-conversion');
    
    const ctaContainer = document.getElementById('audit-cta-container');

    let isScanning = false;
    let spinnerInterval: number | undefined;

    function printLog(text: string, colorClass = "text-slate-400") {
      if (!logBox) return;
      const logLine = document.createElement('div');
      logLine.className = `${colorClass} transition-opacity duration-300`;
      logLine.innerText = `> [${new Date().toLocaleTimeString()}] ${text}`;
      logBox.appendChild(logLine);
      
      // Keep only last 10 logs visible
      while (logBox.children.length > 8) {
        logBox.removeChild(logBox.firstChild!);
      }
      logBox.scrollTop = logBox.scrollHeight;
    }

    function clearLogs() {
      if (!logBox) return;
      logBox.innerHTML = '';
    }

    // Initial typing simulation on mount
    if (logBox) {
      logBox.innerHTML = '';
      const initialLogs = [
        "Connecting to LUMOVELO_SITE_AUDIT_CORE...",
        "Establishing handshake with serverless node...",
        "STATUS: READY. Waiting for domain input..."
      ];
      initialLogs.forEach((msg, idx) => {
        setTimeout(() => {
          if (!isScanning) {
            printLog(msg, "text-slate-500");
          }
        }, idx * 350);
      });
    }

    // Handle Quick Chips click
    quickChips.forEach(chip => {
      chip.addEventListener('click', (e) => {
        const target = e.currentTarget as HTMLButtonElement;
        const url = target.getAttribute('data-url');
        if (url && input && !isScanning) {
          input.value = url;
          runAudit(url);
        }
      });
    });

    if (button) {
      button.addEventListener('click', () => {
        if (isScanning) return;
        const url = input?.value.trim() || 'domain-kamu.com';
        if (input && !input.value.trim()) {
          input.value = 'domain-kamu.com';
        }
        runAudit(url);
      });
    }

    if (input) {
      input.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Enter' && !isScanning) {
          const url = input.value.trim() || 'domain-kamu.com';
          if (!input.value.trim()) {
            input.value = 'domain-kamu.com';
          }
          runAudit(url);
        }
      });
    }

    function runAudit(domain: string) {
      isScanning = true;
      
      // UI Disable
      if (input) input.disabled = true;
      if (button) {
        button.disabled = true;
        button.innerText = runBtnAuditingText;
        button.className = "w-full py-4 rounded-xl border-2 border-slate-300 bg-slate-100 text-slate-400 font-display font-black text-xs uppercase tracking-widest cursor-not-allowed select-none";
      }

      // Reset score displays to loading state
      resetCardStates();

      // Dispatch event to make background warp speed!
      window.dispatchEvent(new CustomEvent('warp-speed-event', { detail: { active: true } }));

      // Set scanning status
      if (statusIndicator) {
        statusIndicator.innerText = statusScanningText;
        statusIndicator.className = "text-blue-400 font-bold animate-pulse";
      }

      // Clear logs and print start
      clearLogs();
      printLog(`${startAuditText}${domain}...`, "text-blue-400 font-bold");

      // Set up audit log timeline
      const timeline = [
        { time: 400, text: i18nEl?.getAttribute('data-log-0') || "", color: "text-slate-500" },
        { time: 800, text: i18nEl?.getAttribute('data-log-1') || "", color: "text-slate-500" },
        { time: 1200, text: i18nEl?.getAttribute('data-log-2') || "", color: "text-rose-400 font-bold" },
        { time: 1600, text: i18nEl?.getAttribute('data-log-3') || "", color: "text-slate-500" },
        { time: 2000, text: i18nEl?.getAttribute('data-log-4') || "", color: "text-slate-500" },
        { time: 2400, text: i18nEl?.getAttribute('data-log-5') || "", color: "text-rose-400" },
        { time: 2800, text: i18nEl?.getAttribute('data-log-6') || "", color: "text-slate-500" },
        { time: 3200, text: i18nEl?.getAttribute('data-log-7') || "", color: "text-rose-400" },
        { time: 3600, text: i18nEl?.getAttribute('data-log-8') || "", color: "text-slate-500" },
        { time: 4000, text: i18nEl?.getAttribute('data-log-9') || "", color: "text-emerald-400 font-bold" }
      ];

      timeline.forEach(step => {
        setTimeout(() => {
          if (isScanning) {
            printLog(step.text, step.color);
          }
        }, step.time);
      });

      // Spin numbers in the meantime (glitchy style effect)
      if (spinnerInterval) clearInterval(spinnerInterval);
      spinnerInterval = setInterval(() => {
        if (speedScoreVal) speedScoreVal.innerText = Math.floor(Math.random() * 40 + 20) + "%";
        if (seoScoreVal) seoScoreVal.innerText = Math.floor(Math.random() * 40 + 30) + "%";
        if (conversionLossVal) conversionLossVal.innerText = Math.floor(Math.random() * 50 + 20) + "%";
      }, 80) as unknown as number;

      // Finish audit
      setTimeout(() => {
        completeAudit(domain);
      }, 4400);
    }

    function resetCardStates() {
      // Hide badges
      if (speedBadge) speedBadge.classList.add('hidden');
      if (seoBadge) seoBadge.classList.add('hidden');
      if (conversionBadge) conversionBadge.classList.add('hidden');

      // Reset values
      if (speedScoreVal) {
        speedScoreVal.innerText = "--";
        speedScoreVal.className = "font-display font-black text-xl sm:text-2xl lg:text-3xl text-slate-400 tracking-tight tabular-nums truncate transition-colors duration-300";
      }
      if (seoScoreVal) {
        seoScoreVal.innerText = "--";
        seoScoreVal.className = "font-display font-black text-xl sm:text-2xl lg:text-3xl text-slate-400 tracking-tight tabular-nums truncate transition-colors duration-300";
      }
      if (conversionLossVal) {
        conversionLossVal.innerText = "--";
        conversionLossVal.className = "font-display font-black text-xl sm:text-2xl lg:text-3xl text-slate-400 tracking-tight tabular-nums truncate transition-colors duration-300";
      }

      // Reset cards borders / shadow classes if any
      if (cardSpeed) cardSpeed.className = "p-5 bg-slate-50 border-2 border-blue-600 shadow-[4px_4px_0px_#2563eb] rounded-2xl flex-1 flex flex-col justify-center transition-all duration-300";
      if (cardSeo) cardSeo.className = "p-5 bg-slate-50 border-2 border-blue-600 shadow-[4px_4px_0px_#2563eb] rounded-2xl flex-1 flex flex-col justify-center transition-all duration-300";
      if (cardConversion) cardConversion.className = "p-5 bg-slate-50 border-2 border-blue-600 shadow-[4px_4px_0px_#2563eb] rounded-2xl flex-1 flex flex-col justify-center transition-all duration-300";

      // Hide CTA banner
      if (ctaContainer) {
        ctaContainer.classList.add('hidden');
        ctaContainer.classList.add('opacity-0');
      }
    }

    function completeAudit(domain: string) {
      isScanning = false;
      if (spinnerInterval) clearInterval(spinnerInterval);

      // Re-enable UI
      if (input) input.disabled = false;
      if (button) {
        button.disabled = false;
        button.innerText = runBtnRerunText;
        button.className = "w-full py-4 rounded-xl border-2 border-blue-600 bg-blue-600 hover:bg-blue-700 text-white font-display font-black text-xs uppercase tracking-widest transition-all duration-200 cursor-pointer shadow-[3px_3px_0px_#0f172a] hover:shadow-[0_0_15px_rgba(59,130,246,0.4)] active:scale-98 select-none";
      }

      // Stop warp speed
      window.dispatchEvent(new CustomEvent('warp-speed-event', { detail: { active: false } }));

      // Set complete status
      if (statusIndicator) {
        statusIndicator.innerText = statusCriticalText;
        statusIndicator.className = "text-rose-600 font-bold animate-pulse";
      }

      printLog(`${completeAuditText}${domain}${completeBottleneckText}`, "text-rose-400 font-bold");

      // Settle scores
      const finalSpeed = Math.floor(Math.random() * 10) + 32;
      const finalSeo = Math.floor(Math.random() * 8) + 48;
      const finalLoss = Math.floor(Math.random() * 12) + 62;

      // Update Speed Score Card
      if (speedScoreVal) {
        speedScoreVal.innerText = finalSpeed + "%";
        speedScoreVal.className = "font-display font-black text-xl sm:text-2xl lg:text-3xl text-rose-600 tracking-tight tabular-nums truncate font-bold animate-[glitch_0.5s_ease-in-out]";
      }
      if (speedBadge) {
        speedBadge.innerText = "SLOW";
        speedBadge.className = "text-[8px] font-mono font-bold px-2 py-0.5 rounded border border-rose-200 bg-rose-100 text-rose-600 uppercase block";
        speedBadge.classList.remove('hidden');
      }
      if (cardSpeed) {
        cardSpeed.className = "p-5 bg-white border-2 border-rose-600 rounded-2xl flex-1 flex flex-col justify-center transition-all duration-300 shadow-[4px_4px_0px_#e11d48]";
      }

      // Update SEO Score Card
      if (seoScoreVal) {
        seoScoreVal.innerText = finalSeo + "%";
        seoScoreVal.className = "font-display font-black text-xl sm:text-2xl lg:text-3xl text-teal-600 tracking-tight tabular-nums truncate font-bold animate-[glitch_0.5s_ease-in-out]";
      }
      if (seoBadge) {
        seoBadge.innerText = "POOR";
        seoBadge.className = "text-[8px] font-mono font-bold px-2 py-0.5 rounded border border-teal-200 bg-teal-100 text-teal-600 uppercase block";
        seoBadge.classList.remove('hidden');
      }
      if (cardSeo) {
        cardSeo.className = "p-5 bg-white border-2 border-teal-600 rounded-2xl flex-1 flex flex-col justify-center transition-all duration-300 shadow-[4px_4px_0px_#0d9488]";
      }

      // Update Conversion Loss Card
      if (conversionLossVal) {
        conversionLossVal.innerText = finalLoss + "% LOST";
        conversionLossVal.className = "font-display font-black text-xl sm:text-2xl lg:text-3xl text-rose-600 tracking-tight tabular-nums truncate font-bold animate-[glitch_0.5s_ease-in-out_infinite]";
      }
      if (conversionBadge) {
        conversionBadge.innerText = "CRITICAL";
        conversionBadge.className = "text-[8px] font-mono font-bold px-2 py-0.5 rounded border border-rose-300 bg-rose-100 text-rose-600 uppercase block";
        conversionBadge.classList.remove('hidden');
      }
      if (cardConversion) {
        cardConversion.className = "p-5 bg-white border-2 border-rose-600 rounded-2xl flex-1 flex flex-col justify-center transition-all duration-300 shadow-[4px_4px_0px_#e11d48]";
      }

      // Reveal CTA Banner
      if (ctaContainer) {
        ctaContainer.classList.remove('hidden');
        setTimeout(() => {
          ctaContainer.classList.remove('opacity-0');
        }, 50);
      }
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initInteractiveConsole);
  } else {
    initInteractiveConsole();
  }
</script>
