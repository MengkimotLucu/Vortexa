---
// Component: AIChatWidget.astro
// UI Chat Widget interaktif berbasis AI Gemini di sudut kanan bawah.
const lang = Astro.currentLocale === 'en' ? 'en' : 'id';

const content = {
  id: {
    welcome: "Halo! Selamat datang di LUMOVELO. Kami siap membantu mengembangkan bisnis Anda melalui website, SEO, otomatisasi AI, atau video promosi. Boleh tahu, fokus utama atau kebutuhan yang sedang ingin Anda tingkatkan saat ini?",
    quickReplies: [
      { label: "🌐 Jasa Website", value: "Jasa Pembuatan Website" },
      { label: "🧪 Software QA", value: "Tanya Jasa Software QA & Testing" },
      { label: "📈 Paket Growth Scale", value: "Tanya Paket Growth Scale" },
      { label: "🔒 Keamanan Jaringan", value: "Tanya Jasa Keamanan Jaringan & Pentest B2B" },
      { label: "📊 Audit SEO Gratis", value: "Tanya Audit SEO & Performa Website Gratis" },
      { label: "🤖 Otomatisasi AI", value: "Otomatisasi Sistem AI" }
    ],
    statusOnline: "ONLINE",
    statusManual: "HANDOVER WA",
    statusManualBadge: "⚠️ Hubungan dialihkan ke Admin Manual",
    inputPlaceholder: "Tulis pesan Anda...",
    closeBtnLabel: "Tutup Chat",
    toggleBtnLabel: "Tanya AI"
  },
  en: {
    welcome: "Hello! Welcome to LUMOVELO. We are here to help scale your business through custom web dev, SEO, AI automation, or video ads. What is the primary goal or challenge you are looking to address right now?",
    quickReplies: [
      { label: "🌐 Web Development", value: "Web Development Services" },
      { label: "🧪 Software QA", value: "Tell me about Software QA & Testing Services" },
      { label: "📈 Growth Scale Pack", value: "Tell me about the Growth Scale Package" },
      { label: "🔒 Network Security", value: "Tell me about B2B Network Security & Pentest Services" },
      { label: "📊 Free SEO Audit", value: "How can I run a Free SEO & Speed Audit?" },
      { label: "🤖 AI Automation", value: "AI Automation Services" }
    ],
    statusOnline: "ONLINE",
    statusManual: "HANDOVER WA",
    statusManualBadge: "⚠️ Connection routed to Manual Admin",
    inputPlaceholder: "Type your message...",
    closeBtnLabel: "Close Chat",
    toggleBtnLabel: "Ask AI"
  }
}[lang];
---

<div id="ai-chat-container" class="fixed bottom-24 right-2 sm:right-4 z-[99] select-none font-sans">
  <!-- 1. Floating Action Button (Glow Effect) -->
  <button
    id="ai-chat-toggle-btn"
    class="w-14 h-14 rounded-full bg-blue-600 hover:bg-blue-700 text-white flex items-center justify-center cursor-pointer transition-all duration-300 shadow-[0_8px_30px_rgba(37,99,235,0.4)] hover:shadow-[0_8px_35px_rgba(37,99,235,0.6)] hover:-translate-y-1 active:translate-y-0 relative group"
    aria-label={content.toggleBtnLabel}
  >
    <!-- Glow Ring Animation -->
    <span class="absolute -inset-1 rounded-full bg-blue-600/30 opacity-75 animate-ping -z-10 group-hover:bg-blue-700/30"></span>

    <!-- Message Icon SVG -->
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6 shrink-0 transition-transform duration-300 group-hover:scale-110">
      <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z" />
    </svg>
    
    <!-- Notification badge -->
    <span id="chat-badge" class="absolute top-0 right-0 w-3 h-3 bg-rose-500 border border-white rounded-full hidden"></span>
  </button>

  <!-- 2. Chat Window (Solid Opaque Window & Hidden by Default) -->
  <div id="ai-chat-window" data-size-state="normal" class="fixed bottom-16 right-2 left-2 sm:bottom-24 sm:right-6 sm:left-auto sm:w-[360px] md:right-auto md:left-1/2 md:-translate-x-1/2 md:w-[460px] h-[calc(100vh-100px)] max-h-[580px] sm:h-[550px] md:h-[650px] bg-[#090d16] border border-slate-800 rounded-2xl shadow-2xl flex flex-col transition-all duration-300 transform scale-95 opacity-0 pointer-events-none z-[9999] overflow-hidden select-none font-sans">

    <!-- Custom Reset Confirmation Modal -->
    <div id="ai-chat-reset-modal" class="absolute inset-0 bg-[#090d16]/95 backdrop-blur-md z-50 flex items-center justify-center p-4 opacity-0 pointer-events-none transition-all duration-300">
      <div class="bg-slate-900 border border-slate-800/80 p-5 rounded-2xl max-w-[280px] w-full text-center shadow-2xl transform scale-95 transition-all duration-300">
        <div class="w-11 h-11 rounded-full bg-red-500/10 border border-red-500/20 flex items-center justify-center mx-auto mb-3 text-red-500 text-lg">
          ⚠️
        </div>
        <h5 class="text-sm font-bold text-white mb-1.5">Reset Obrolan?</h5>
        <p class="text-[11px] text-slate-400 mb-4 leading-relaxed">Semua riwayat chat Anda saat ini akan dihapus dan Anda bisa memilih layanan lainnya.</p>
        <div class="flex gap-2">
          <button type="button" id="ai-chat-reset-cancel" class="flex-1 py-2 px-3 rounded-xl bg-slate-800 hover:bg-slate-700 text-slate-300 text-xs font-semibold cursor-pointer transition-colors">
            Batal
          </button>
          <button type="button" id="ai-chat-reset-confirm" class="flex-1 py-2 px-3 rounded-xl bg-red-600 hover:bg-red-500 text-white text-xs font-semibold cursor-pointer transition-colors shadow-lg shadow-red-600/20">
            Reset
          </button>
        </div>
      </div>
    </div>

    <!-- Header (Solid 100% Background) -->
    <div class="p-4 border-b border-slate-800 bg-[#0f172a] rounded-t-2xl flex items-center justify-between z-10">
      <div class="flex items-center gap-2.5">
        <div class="w-8 h-8 rounded-lg bg-blue-600/10 border border-blue-500/20 flex items-center justify-center">
          🤖
        </div>
        <div>
          <h4 class="text-xs font-black uppercase tracking-widest text-white">LUMOVELO AI</h4>
          <div class="flex items-center gap-1.5 mt-0.5">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
            <span id="ai-chat-status" class="text-[9px] font-mono text-slate-400">{content.statusOnline}</span>
          </div>
        </div>
      </div>
      <div class="flex items-center gap-2">
        <button id="ai-chat-reset-btn" class="text-slate-400 hover:text-white transition-colors cursor-pointer p-1" title={lang === 'en' ? 'Reset Chat / Change Topic' : 'Ganti Topik / Reset Chat'}>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99" />
          </svg>
        </button>
        <button id="ai-chat-maximize-btn" class="text-slate-400 hover:text-white transition-colors cursor-pointer p-1" title={lang === 'en' ? 'Enlarge Chat Window' : 'Perbesar Jendela Chat'}>
          <svg id="ai-icon-maximize" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75v4.5m0-4.5h-4.5m4.5 0L15 9M20.25 20.25v-4.5m0 4.5h-4.5m4.5 0L15 15" />
          </svg>
          <svg id="ai-icon-minimize" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4 hidden">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 9V4.5M9 9H4.5M9 9L3.75 3.75M9 15v4.5M9 15H4.5M9 15l-5.25 5.25M15 9V4.5M15 9h4.5M15 9l5.25-5.25M15 15v4.5M15 15h4.5M15 15l5.25 5.25" />
          </svg>
        </button>
        <button id="ai-chat-close-btn" class="text-slate-400 hover:text-white transition-colors cursor-pointer p-1" aria-label={content.closeBtnLabel}>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Chat Main Wrapper -->
    <div class="flex-1 flex overflow-hidden bg-[#090d16]">
      
      <!-- Right Panel: Actual Chat interface (Solid Background & Full Width) -->
      <div class="flex-1 flex flex-col overflow-hidden relative bg-[#090d16]">
        <!-- Lead Form Banner -->
        <div id="ai-chat-lead-banner" class="bg-[#0f172a] border-b border-slate-800 p-3 flex flex-col gap-2 transition-all duration-300">
          <div class="flex items-center justify-between">
            <span class="text-[10px] font-bold text-blue-400 uppercase tracking-wider">📝 Konsultasi Prioritas</span>
            <button type="button" id="btn-toggle-lead-form" class="text-[9px] text-slate-400 hover:text-white transition-colors cursor-pointer underline">Sembunyikan</button>
          </div>
          <div id="lead-form-fields" class="grid grid-cols-2 gap-2">
            <input
              type="text"
              id="lead-input-name"
              placeholder="Nama Anda..."
              autocomplete="off"
              class="bg-slate-900 border border-slate-800 focus:border-blue-500 focus:outline-none rounded-lg px-2.5 py-1 text-[11px] text-white placeholder-slate-500 transition-colors"
            />
            <input
              type="text"
              id="lead-input-whatsapp"
              placeholder="WhatsApp (e.g. 0812...)"
              autocomplete="off"
              class="bg-slate-900 border border-slate-800 focus:border-blue-500 focus:outline-none rounded-lg px-2.5 py-1 text-[11px] text-white placeholder-slate-500 transition-colors"
            />
          </div>
          <button
            type="button"
            id="btn-submit-lead-form"
            class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-1.5 rounded-lg text-[9px] transition-all uppercase tracking-wider cursor-pointer text-center"
          >
            Kirim Data Kontak
          </button>
        </div>

        <!-- Messages Container (Solid Opaque Background) -->
        <div id="ai-chat-messages-container" class="flex-1 p-4 overflow-y-auto space-y-4 text-xs scrollbar-thin scrollbar-thumb-slate-800 bg-[#090d16]">
          <!-- Welcome message -->
          <div class="flex items-start gap-2.5">
            <div class="w-6 h-6 rounded-full bg-blue-600/10 border border-blue-500/20 flex items-center justify-center shrink-0">🤖</div>
            <div class="bg-slate-900 text-slate-200 border border-slate-800 p-3 rounded-2xl rounded-tl-none max-w-[80%] leading-relaxed shadow-sm">
              <span>{content.welcome}</span>
              
              <!-- Quick Reply Buttons -->
              <div id="ai-quick-replies" class="flex flex-wrap gap-2 mt-3">
                {content.quickReplies.map((reply) => (
                  <button type="button" class="btn-quick bg-blue-600/10 hover:bg-blue-600/20 text-blue-400 hover:text-blue-300 border border-blue-500/20 px-2.5 py-1.5 rounded-xl cursor-pointer transition-all text-[10px] font-semibold" data-value={reply.value}>
                    {reply.label}
                  </button>
                ))}
              </div>
            </div>
          </div>
        </div>

        <!-- Mode manual indicator -->
        <div id="manual-mode-badge" class="bg-amber-500/10 border-t border-b border-amber-500/20 py-2 px-4 text-center hidden">
          <span class="text-[10px] font-mono text-amber-400 font-bold uppercase tracking-wider">{content.statusManualBadge}</span>
        </div>

        <!-- Quick Action Chips (Tombol Pilihan Cepat) -->
        <div id="ai-chat-quick-chips" class="px-3 py-2 bg-[#090d16] border-t border-slate-800/80 flex flex-wrap items-center gap-1.5 no-scrollbar">
          <button type="button" class="quick-chip-btn flex-1 min-w-[45%] sm:flex-initial px-2.5 py-1.5 rounded-xl bg-slate-800/80 hover:bg-blue-600/20 hover:border-blue-500/50 border border-slate-700/60 text-[10.5px] font-medium text-slate-300 hover:text-blue-300 transition-all cursor-pointer flex items-center justify-center gap-1.5 shadow-sm" data-prompt={lang === 'en' ? 'What is the estimated cost of web development?' : 'Berapa estimasi biaya pembuatan website?'}>
            <span>💰</span> {lang === 'en' ? 'Web Cost' : 'Estimasi Biaya Web'}
          </button>
          <button type="button" class="quick-chip-btn flex-1 min-w-[45%] sm:flex-initial px-2.5 py-1.5 rounded-xl bg-slate-800/80 hover:bg-blue-600/20 hover:border-blue-500/50 border border-slate-700/60 text-[10.5px] font-medium text-slate-300 hover:text-blue-300 transition-all cursor-pointer flex items-center justify-center gap-1.5 shadow-sm" data-prompt={lang === 'en' ? 'I want to build a custom AI Chatbot for my business' : 'Saya ingin buat AI Chatbot kustom untuk bisnis'}>
            <span>🤖</span> {lang === 'en' ? 'AI Chatbot' : 'Jasa AI Chatbot'}
          </button>
          <button type="button" class="quick-chip-btn flex-1 min-w-[45%] sm:flex-initial px-2.5 py-1.5 rounded-xl bg-slate-800/80 hover:bg-blue-600/20 hover:border-blue-500/50 border border-slate-700/60 text-[10.5px] font-medium text-slate-300 hover:text-blue-300 transition-all cursor-pointer flex items-center justify-center gap-1.5 shadow-sm" data-prompt={lang === 'en' ? 'How to get a free 15-minute consultation?' : 'Bagaimana cara konsultasi gratis 15 menit?'}>
            <span>⚡</span> {lang === 'en' ? 'Free Consultation' : 'Konsultasi Gratis'}
          </button>
          <button type="button" class="quick-chip-btn flex-1 min-w-[45%] sm:flex-initial px-2.5 py-1.5 rounded-xl bg-slate-800/80 hover:bg-blue-600/20 hover:border-blue-500/50 border border-slate-700/60 text-[10.5px] font-medium text-slate-300 hover:text-blue-300 transition-all cursor-pointer flex items-center justify-center gap-1.5 shadow-sm" data-prompt={lang === 'en' ? 'Show me your portfolio and recent projects' : 'Lihat portofolio dan proyek terbaru Lumovelo'}>
            <span>📂</span> {lang === 'en' ? 'Portfolio' : 'Lihat Portofolio'}
          </button>
        </div>

        <!-- Input Form (Solid Opaque Footer) -->
        <form id="ai-chat-form" class="p-3 border-t border-slate-800 bg-[#0f172a] flex items-center gap-2">
          <input
            type="text"
            id="ai-chat-input"
            placeholder={content.inputPlaceholder}
            autocomplete="off"
            class="flex-1 bg-slate-900 border border-slate-800 focus:border-blue-500 focus:outline-none rounded-xl px-4 py-2.5 text-xs text-white placeholder-slate-500 transition-colors"
          />
          <button
            type="submit"
            id="ai-chat-send-btn"
            class="bg-blue-600 hover:bg-blue-700 text-white p-2.5 rounded-xl transition-all shadow-[0_4px_12px_rgba(37,99,235,0.2)] hover:shadow-[0_4px_15px_rgba(37,99,235,0.3)] shrink-0 cursor-pointer"
          >
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" />
            </svg>
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

<style>
  /* Hide Scrollbar Utility */
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  /* Custom Elegant Scrollbar */
  .scrollbar-thin::-webkit-scrollbar {
    width: 4px;
  }
  .scrollbar-thin::-webkit-scrollbar-track {
    background: transparent;
  }
  .scrollbar-thin::-webkit-scrollbar-thumb {
    background: #1e293b;
    border-radius: 999px;
  }
  .scrollbar-thin::-webkit-scrollbar-thumb:hover {
    background: #334155;
  }
  #ai-chat-toggle-btn {
    display: none !important;
  }

  /* Transition sizes dynamically */
  #ai-chat-window {
    transition: width 0.25s cubic-bezier(0.4, 0, 0.2, 1), 
                height 0.25s cubic-bezier(0.4, 0, 0.2, 1), 
                opacity 0.2s ease, 
                transform 0.05s ease-out; /* Super responsive drag transform */
    will-change: transform, width, height;
  }

  /* Half-Page State (1/2 Halaman) */
  #ai-chat-window[data-size-state="half"] {
    width: 620px !important;
    height: 700px !important;
    bottom: 24px !important;
    right: 24px !important;
    left: auto !important;
    top: auto !important;
    transform: none !important;
  }

  /* Full-Page State (Full Halaman) */
  #ai-chat-window[data-size-state="full"] {
    width: calc(100% - 48px) !important;
    max-width: 1160px !important;
    height: calc(100vh - 80px) !important;
    max-height: 820px !important;
    bottom: 24px !important;
    right: 24px !important;
    left: auto !important;
    top: auto !important;
    transform: none !important;
  }



  @media (max-width: 768px) {
    /* Mobile styles for half state */
    #ai-chat-window[data-size-state="half"] {
      width: calc(100% - 24px) !important;
      height: 70vh !important;
      bottom: 12px !important;
      right: 12px !important;
      left: 12px !important;
      top: auto !important;
      transform: none !important;
    }

    /* Mobile styles for full state */
    #ai-chat-window[data-size-state="full"] {
      width: 100% !important;
      height: 100% !important;
      bottom: 0 !important;
      right: 0 !important;
      left: 0 !important;
      top: 0 !important;
      border-radius: 0 !important;
      max-width: none !important;
      max-height: none !important;
      transform: none !important;
    }
  }
</style>

<script>
  let isOpen = false;
  
  // Custom Toast Notification System
  function showNotification(message: string, type = 'error') {
    let container = document.getElementById('ai-chat-toast-container');
    if (!container) {
      container = document.createElement('div');
      container.id = 'ai-chat-toast-container';
      container.className = 'fixed top-6 left-1/2 -translate-x-1/2 z-[9999] flex flex-col gap-2 pointer-events-none w-full max-w-[320px] px-4';
      document.body.appendChild(container);
    }

    const toast = document.createElement('div');
    toast.className = 'p-3.5 rounded-xl border text-[11px] font-semibold shadow-2xl transition-all duration-300 transform translate-y-2 opacity-0 flex items-center gap-2.5 pointer-events-auto backdrop-blur-md';
    
    if (type === 'error') {
      toast.className += ' bg-slate-900/95 border-red-500/30 text-red-400';
    } else {
      toast.className += ' bg-slate-900/95 border-emerald-500/30 text-emerald-400';
    }

    const icon = type === 'error' ? '⚠️' : '✓';
    toast.innerHTML = `
      <span class="text-[14px] leading-none shrink-0">${icon}</span>
      <span class="flex-1 leading-normal">${message}</span>
    `;

    container.appendChild(toast);

    setTimeout(() => {
      toast.classList.remove('translate-y-2', 'opacity-0');
      toast.classList.add('translate-y-0', 'opacity-100');
    }, 10);

    setTimeout(() => {
      toast.classList.remove('translate-y-0', 'opacity-100');
      toast.classList.add('translate-y-2', 'opacity-0');
      setTimeout(() => {
        toast.remove();
      }, 300);
    }, 4000);
  }
  


  // Cek masa kedaluwarsa sesi (30 menit)
  const lastActive = localStorage.getItem('ai_chat_last_active');
  let sessionId = localStorage.getItem('ai_chat_session_id');
  if (lastActive && sessionId) {
    const elapsed = Date.now() - parseInt(lastActive, 10);
    if (elapsed > 30 * 60 * 1000) {
      localStorage.removeItem('ai_chat_session_id');
      localStorage.removeItem('ai_chat_last_active');
      localStorage.removeItem('ai_chat_message_count');
      localStorage.removeItem('lead_submitted');
      localStorage.removeItem('lead_name');
      localStorage.removeItem('lead_whatsapp');
      sessionId = null;
    }
  }
  if (!sessionId) {
    localStorage.removeItem('ai_chat_message_count');
    localStorage.removeItem('lead_submitted');
    localStorage.removeItem('lead_name');
    localStorage.removeItem('lead_whatsapp');
  }

  function updateLastActive() {
    localStorage.setItem('ai_chat_last_active', Date.now().toString());
  }

  let isAiEnabled = true;
  let loadedMessagesCount = 0;
  let pollInterval: any = null;

  const toggleBtn = document.getElementById('ai-chat-toggle-btn')!;
  const chatWindow = document.getElementById('ai-chat-window')!;
  const closeBtn = document.getElementById('ai-chat-close-btn')!;
  const chatForm = document.getElementById('ai-chat-form') as HTMLFormElement;
  const chatInput = document.getElementById('ai-chat-input') as HTMLInputElement;
  const messagesContainer = document.getElementById('ai-chat-messages-container')!;
  const chatStatus = document.getElementById('ai-chat-status')!;
  const manualBadge = document.getElementById('manual-mode-badge')!;
  const badge = document.getElementById('chat-badge')!;

  // DOM Form Lead baru
  const leadBanner = document.getElementById('ai-chat-lead-banner')!;
  const btnToggleLeadForm = document.getElementById('btn-toggle-lead-form')!;
  const btnSubmitLeadForm = document.getElementById('btn-submit-lead-form')!;
  const leadInputName = document.getElementById('lead-input-name') as HTMLInputElement;
  const leadInputWhatsapp = document.getElementById('lead-input-whatsapp') as HTMLInputElement;

  // Client-side translations based on document language
  const clientLang = document.documentElement.lang === 'en' ? 'en' : 'id';
  const translations = {
    id: {
      placeholderWa: "AI dialihkan ke WhatsApp...",
      placeholderText: "Tulis pesan Anda...",
      statusOnline: "ONLINE",
      statusManual: "HANDOVER WA",
      redirectText: "Sistem AI kami sedang sibuk atau obrolan Anda perlu diarahkan ke WhatsApp Admin. Silakan klik tombol di bawah untuk lanjut berkonsultasi.",
      redirectBtn: "Hubungi Admin di WhatsApp",
      waMessage: "Halo Lumovelo, saya ingin berkonsultasi mengenai proyek website/AI.",
      networkError: "Terjadi kesalahan jaringan. Silakan coba kembali."
    },
    en: {
      placeholderWa: "AI routed to WhatsApp...",
      placeholderText: "Type your message...",
      statusOnline: "ONLINE",
      statusManual: "HANDOVER WA",
      redirectText: "Our AI system is currently busy or your chat needs to be routed to WhatsApp Admin. Please click the button below to continue.",
      redirectBtn: "Contact Admin on WhatsApp",
      waMessage: "Hello Lumovelo, I'd like to consult on a web/AI project.",
      networkError: "Network error. Please try again."
    }
  }[clientLang];

  // Quick Action Chips Click Handler
  const quickChipsContainer = document.getElementById('ai-chat-quick-chips');
  if (quickChipsContainer) {
    quickChipsContainer.addEventListener('click', async (e) => {
      const target = e.target as HTMLElement;
      const chip = target?.closest('.quick-chip-btn');
      if (chip) {
        const prompt = chip.getAttribute('data-prompt');
        if (prompt && chatInput) {
          chatInput.value = prompt;
          chatForm.dispatchEvent(new Event('submit'));
        }
      }
    });
