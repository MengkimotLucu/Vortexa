---
// Component: AIChatWidget.astro
// UI Chat Widget interaktif berbasis AI Gemini di sudut kanan bawah.
const lang = Astro.currentLocale === 'en' ? 'en' : 'id';

const content = {
  id: {
    welcome: "Halo! Saya Asisten AI LUMOVELO. Ada yang bisa saya bantu terkait jasa website, SEO, edit video, atau sistem AI? Silakan tanyakan di sini!",
    quickReplies: [
      { label: "🌐 Jasa Website", value: "Jasa Pembuatan Website" },
      { label: "📈 Paket Growth Scale", value: "Tanya Paket Growth Scale" },
      { label: "⏳ Lama Pengerjaan", value: "Berapa lama proses pengerjaan website?" },
      { label: "🤖 Otomatisasi AI", value: "Otomatisasi Sistem AI" }
    ],
    statusOnline: "ONLINE",
    statusManual: "HANDOVER WA",
    statusManualBadge: "⚠️ Hubungan dialihkan ke Admin Manual",
    inputPlaceholder: "Tulis pesan Anda...",
    closeBtnLabel: "Tutup Chat",
    toggleBtnLabel: "Tanya AI"
  },
  en: {
    welcome: "Hello! I am the LUMOVELO AI Assistant. How can I help you with web development, SEO, video editing, or AI systems? Feel free to ask!",
    quickReplies: [
      { label: "🌐 Web Development", value: "Web Development Services" },
      { label: "📈 Growth Scale Pack", value: "Tell me about the Growth Scale Package" },
      { label: "⏳ Project Timeline", value: "How long does a web project take?" },
      { label: "🤖 AI Automation", value: "AI Automation Services" }
    ],
    statusOnline: "ONLINE",
    statusManual: "HANDOVER WA",
    statusManualBadge: "⚠️ Connection routed to Manual Admin",
    inputPlaceholder: "Type your message...",
    closeBtnLabel: "Close Chat",
    toggleBtnLabel: "Ask AI"
  }
}[lang];
---

<div id="ai-chat-container" class="fixed bottom-24 right-2 sm:right-4 z-[99] select-none font-sans">
  <!-- 1. Floating Action Button (Glow Effect) -->
  <button
    id="ai-chat-toggle-btn"
    class="w-14 h-14 rounded-full bg-blue-600 hover:bg-blue-700 text-white flex items-center justify-center cursor-pointer transition-all duration-300 shadow-[0_8px_30px_rgba(37,99,235,0.4)] hover:shadow-[0_8px_35px_rgba(37,99,235,0.6)] hover:-translate-y-1 active:translate-y-0 relative group"
    aria-label={content.toggleBtnLabel}
  >
    <!-- Glow Ring Animation -->
    <span class="absolute -inset-1 rounded-full bg-blue-600/30 opacity-75 animate-ping -z-10 group-hover:bg-blue-700/30"></span>

    <!-- Message Icon SVG -->
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6 shrink-0 transition-transform duration-300 group-hover:scale-110">
      <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z" />
    </svg>
    
    <!-- Notification badge -->
    <span id="chat-badge" class="absolute top-0 right-0 w-3 h-3 bg-rose-500 border border-white rounded-full hidden"></span>
  </button>

  <!-- 2. Chat Window (Glassmorphism & Hidden by Default) -->
  <div id="ai-chat-window" class="fixed bottom-24 right-4 left-4 w-auto sm:right-6 sm:left-auto sm:w-[360px] md:right-auto md:left-1/2 md:-translate-x-1/2 md:w-[460px] h-[550px] md:h-[650px] bg-slate-900/95 border border-slate-800 rounded-2xl shadow-2xl flex flex-col transition-all duration-300 transform scale-95 opacity-0 pointer-events-none z-50 overflow-hidden select-none font-sans">

    <!-- Custom Reset Confirmation Modal -->
    <div id="ai-chat-reset-modal" class="absolute inset-0 bg-slate-950/80 backdrop-blur-sm z-50 flex items-center justify-center p-4 opacity-0 pointer-events-none transition-all duration-300">
      <div class="bg-slate-900 border border-slate-800/80 p-5 rounded-2xl max-w-[280px] w-full text-center shadow-2xl transform scale-95 transition-all duration-300">
        <div class="w-11 h-11 rounded-full bg-red-500/10 border border-red-500/20 flex items-center justify-center mx-auto mb-3 text-red-500 text-lg">
          ⚠️
        </div>
        <h5 class="text-sm font-bold text-white mb-1.5">Reset Obrolan?</h5>
        <p class="text-[11px] text-slate-400 mb-4 leading-relaxed">Semua riwayat chat Anda saat ini akan dihapus dan Anda bisa memilih layanan lainnya.</p>
        <div class="flex gap-2">
          <button type="button" id="ai-chat-reset-cancel" class="flex-1 py-2 px-3 rounded-xl bg-slate-800 hover:bg-slate-700 text-slate-300 text-xs font-semibold cursor-pointer transition-colors">
            Batal
          </button>
          <button type="button" id="ai-chat-reset-confirm" class="flex-1 py-2 px-3 rounded-xl bg-red-600 hover:bg-red-500 text-white text-xs font-semibold cursor-pointer transition-colors shadow-lg shadow-red-600/20">
            Reset
          </button>
        </div>
      </div>
    </div>

    <!-- Header -->
    <div class="p-4 border-b border-slate-800 bg-slate-950/40 rounded-t-2xl flex items-center justify-between">
      <div class="flex items-center gap-2.5">
        <div class="w-8 h-8 rounded-lg bg-blue-600/10 border border-blue-500/20 flex items-center justify-center">
          🤖
        </div>
        <div>
          <h4 class="text-xs font-black uppercase tracking-widest text-white">LUMOVELO AI</h4>
          <div class="flex items-center gap-1.5 mt-0.5">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
            <span id="ai-chat-status" class="text-[9px] font-mono text-slate-400">{content.statusOnline}</span>
          </div>
        </div>
      </div>
      <div class="flex items-center gap-2">
        <button id="ai-chat-reset-btn" class="text-slate-400 hover:text-white transition-colors cursor-pointer p-1" title={lang === 'en' ? 'Reset Chat / Change Topic' : 'Ganti Topik / Reset Chat'}>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99" />
          </svg>
        </button>
        <button id="ai-chat-close-btn" class="text-slate-400 hover:text-white transition-colors cursor-pointer p-1" aria-label={content.closeBtnLabel}>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Lead Form Banner -->
    <div id="ai-chat-lead-banner" class="bg-blue-950/40 border-b border-slate-800/80 p-3 flex flex-col gap-2 transition-all duration-300">
      <div class="flex items-center justify-between">
        <span class="text-[10px] font-bold text-blue-400 uppercase tracking-wider">📝 Konsultasi Prioritas</span>
        <button type="button" id="btn-toggle-lead-form" class="text-[9px] text-slate-400 hover:text-white transition-colors cursor-pointer underline">Sembunyikan</button>
      </div>
      <div id="lead-form-fields" class="grid grid-cols-2 gap-2">
        <input
          type="text"
          id="lead-input-name"
          placeholder="Nama Anda..."
          autocomplete="off"
          class="bg-slate-900/60 border border-slate-800 focus:border-blue-500 focus:outline-none rounded-lg px-2.5 py-1 text-[11px] text-white placeholder-slate-500 transition-colors"
        />
        <input
          type="text"
          id="lead-input-whatsapp"
          placeholder="WhatsApp (e.g. 0812...)"
          autocomplete="off"
          class="bg-slate-900/60 border border-slate-800 focus:border-blue-500 focus:outline-none rounded-lg px-2.5 py-1 text-[11px] text-white placeholder-slate-500 transition-colors"
        />
      </div>
      <button
        type="button"
        id="btn-submit-lead-form"
        class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-1.5 rounded-lg text-[9px] transition-all uppercase tracking-wider cursor-pointer text-center"
      >
        Kirim Data Kontak
      </button>
    </div>

    <!-- Messages Container -->
    <div id="ai-chat-messages-container" class="flex-1 p-4 overflow-y-auto space-y-4 text-xs scrollbar-thin scrollbar-thumb-slate-800">
      <!-- Welcome message -->
      <div class="flex items-start gap-2.5">
        <div class="w-6 h-6 rounded-full bg-blue-600/10 border border-blue-500/20 flex items-center justify-center shrink-0">🤖</div>
        <div class="bg-slate-800/50 text-slate-200 border border-slate-800/80 p-3 rounded-2xl rounded-tl-none max-w-[80%] leading-relaxed">
          <span>{content.welcome}</span>
          
          <!-- Quick Reply Buttons -->
          <div id="ai-quick-replies" class="flex flex-wrap gap-2 mt-3">
            {content.quickReplies.map((reply) => (
              <button type="button" class="btn-quick bg-blue-600/10 hover:bg-blue-600/20 text-blue-400 hover:text-blue-300 border border-blue-500/20 px-2.5 py-1.5 rounded-xl cursor-pointer transition-all text-[10px] font-semibold" data-value={reply.value}>
                {reply.label}
              </button>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- Mode manual indicator -->
    <div id="manual-mode-badge" class="bg-amber-500/10 border-t border-b border-amber-500/20 py-2 px-4 text-center hidden">
      <span class="text-[10px] font-mono text-amber-400 font-bold uppercase tracking-wider">{content.statusManualBadge}</span>
    </div>

    <!-- Input Form -->
    <form id="ai-chat-form" class="p-3 border-t border-slate-800 bg-slate-950/20 flex items-center gap-2">
      <input
        type="text"
        id="ai-chat-input"
        placeholder={content.inputPlaceholder}
        autocomplete="off"
        class="flex-1 bg-slate-800/40 border border-slate-800 focus:border-blue-500 focus:outline-none rounded-xl px-4 py-2.5 text-xs text-white placeholder-slate-500 transition-colors"
      />
      <button
        type="submit"
        id="ai-chat-send-btn"
        class="bg-blue-600 hover:bg-blue-700 text-white p-2.5 rounded-xl transition-all shadow-[0_4px_12px_rgba(37,99,235,0.2)] hover:shadow-[0_4px_15px_rgba(37,99,235,0.3)] shrink-0 cursor-pointer"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" />
        </svg>
      </button>
    </form>
  </div>
</div>

<style>
  /* Custom Elegant Scrollbar */
  .scrollbar-thin::-webkit-scrollbar {
    width: 4px;
  }
  .scrollbar-thin::-webkit-scrollbar-track {
    background: transparent;
  }
  .scrollbar-thin::-webkit-scrollbar-thumb {
    background: #1e293b;
    border-radius: 999px;
  }
  .scrollbar-thin::-webkit-scrollbar-thumb:hover {
    background: #334155;
  }
  #ai-chat-toggle-btn {
    display: none !important;
  }
</style>

<script>
  let isOpen = false;
  


  // Cek masa kedaluwarsa sesi (30 menit)
  const lastActive = localStorage.getItem('ai_chat_last_active');
  let sessionId = localStorage.getItem('ai_chat_session_id');
  if (lastActive && sessionId) {
    const elapsed = Date.now() - parseInt(lastActive, 10);
    if (elapsed > 30 * 60 * 1000) {
      localStorage.removeItem('ai_chat_session_id');
      localStorage.removeItem('ai_chat_last_active');
      localStorage.removeItem('ai_chat_message_count');
      localStorage.removeItem('lead_submitted');
      localStorage.removeItem('lead_name');
      localStorage.removeItem('lead_whatsapp');
      sessionId = null;
    }
  }
  if (!sessionId) {
    localStorage.removeItem('ai_chat_message_count');
    localStorage.removeItem('lead_submitted');
    localStorage.removeItem('lead_name');
    localStorage.removeItem('lead_whatsapp');
  }

  function updateLastActive() {
    localStorage.setItem('ai_chat_last_active', Date.now().toString());
  }

  let isAiEnabled = true;
  let pollInterval = null;

  const toggleBtn = document.getElementById('ai-chat-toggle-btn');
  const chatWindow = document.getElementById('ai-chat-window');
  const closeBtn = document.getElementById('ai-chat-close-btn');
  const chatForm = document.getElementById('ai-chat-form');
  const chatInput = document.getElementById('ai-chat-input');
  const messagesContainer = document.getElementById('ai-chat-messages-container');
  const chatStatus = document.getElementById('ai-chat-status');
  const manualBadge = document.getElementById('manual-mode-badge');
  const badge = document.getElementById('chat-badge');

  // DOM Form Lead baru
  const leadBanner = document.getElementById('ai-chat-lead-banner');
  const btnToggleLeadForm = document.getElementById('btn-toggle-lead-form');
  const btnSubmitLeadForm = document.getElementById('btn-submit-lead-form');
  const leadInputName = document.getElementById('lead-input-name');
  const leadInputWhatsapp = document.getElementById('lead-input-whatsapp');

  // Client-side translations based on document language
  const clientLang = document.documentElement.lang === 'en' ? 'en' : 'id';
  const translations = {
    id: {
      placeholderWa: "AI dialihkan ke WhatsApp...",
      placeholderText: "Tulis pesan Anda...",
      statusOnline: "ONLINE",
      statusManual: "HANDOVER WA",
      redirectText: "Sistem AI kami sedang sibuk atau obrolan Anda perlu diarahkan ke WhatsApp Admin. Silakan klik tombol di bawah untuk lanjut berkonsultasi.",
      redirectBtn: "Hubungi Admin di WhatsApp",
      waMessage: "Halo Lumovelo, saya ingin berkonsultasi mengenai proyek website/AI.",
      networkError: "Terjadi kesalahan jaringan. Silakan coba kembali."
    },
    en: {
      placeholderWa: "AI routed to WhatsApp...",
      placeholderText: "Type your message...",
      statusOnline: "ONLINE",
      statusManual: "HANDOVER WA",
      redirectText: "Our AI system is currently busy or your chat needs to be routed to WhatsApp Admin. Please click the button below to continue.",
      redirectBtn: "Contact Admin on WhatsApp",
      waMessage: "Hello Lumovelo, I'd like to consult on a web/AI project.",
      networkError: "Network error. Please try again."
    }
  }[clientLang];

  // Quick Replies Click Handler
  const quickRepliesContainer = document.getElementById('ai-quick-replies');
  if (quickRepliesContainer) {
    quickRepliesContainer.addEventListener('click', async (e) => {
      const btn = e.target.closest('.btn-quick');
      if (btn) {
        const text = btn.getAttribute('data-value') || btn.textContent.trim();
        // Sembunyikan quick replies
        quickRepliesContainer.style.display = 'none';
        // Kirim pesan otomatis
        if (chatInput) {
          chatInput.value = text;
          chatForm.dispatchEvent(new Event('submit'));
        }
      }
    });
  }

  // 1. Toggle Chat Window
  toggleBtn.addEventListener('click', () => {
    isOpen = !isOpen;
    if (isOpen) {
      chatWindow.classList.remove('scale-95', 'opacity-0', 'pointer-events-none');
      chatWindow.classList.add('scale-100', 'opacity-100', 'pointer-events-auto');
      badge.classList.add('hidden');
      scrollToBottom();
      chatInput.focus();
      
      // Jika session sudah ada, muat riwayat pesan
      if (sessionId) {
        loadChatHistory();
      }
    } else {
      chatWindow.classList.remove('scale-100', 'opacity-100', 'pointer-events-auto');
      chatWindow.classList.add('scale-95', 'opacity-0', 'pointer-events-none');
    }
  });

  closeBtn.addEventListener('click', () => {
    isOpen = false;
    chatWindow.classList.remove('scale-100', 'opacity-100', 'pointer-events-auto');
    chatWindow.classList.add('scale-95', 'opacity-0', 'pointer-events-none');
  });

  const resetBtn = document.getElementById('ai-chat-reset-btn');
  const resetModal = document.getElementById('ai-chat-reset-modal');
  const resetConfirmBtn = document.getElementById('ai-chat-reset-confirm');
  const resetCancelBtn = document.getElementById('ai-chat-reset-cancel');

  if (resetBtn && resetModal && resetConfirmBtn && resetCancelBtn) {
    // Set dynamic text translation
    const titleEl = resetModal.querySelector('h5');
    const descEl = resetModal.querySelector('p');
    if (titleEl && descEl) {
      titleEl.textContent = clientLang === 'en' ? 'Reset Chat?' : 'Reset Obrolan?';
      descEl.textContent = clientLang === 'en' 
        ? 'Your current chat history will be deleted so you can consult on other services.' 
        : 'Semua riwayat chat Anda saat ini akan dihapus dan Anda bisa memilih layanan lainnya.';
      resetCancelBtn.textContent = clientLang === 'en' ? 'Cancel' : 'Batal';
      resetConfirmBtn.textContent = clientLang === 'en' ? 'Reset' : 'Reset';
    }

    resetBtn.addEventListener('click', () => {
      resetModal.classList.remove('opacity-0', 'pointer-events-none');
      resetModal.classList.add('opacity-100', 'pointer-events-auto');
      const innerCard = resetModal.querySelector('div');
      if (innerCard) {
        innerCard.classList.remove('scale-95');
        innerCard.classList.add('scale-100');
      }
    });

    resetCancelBtn.addEventListener('click', () => {
      resetModal.classList.remove('opacity-100', 'pointer-events-auto');
      resetModal.classList.add('opacity-0', 'pointer-events-none');
      const innerCard = resetModal.querySelector('div');
      if (innerCard) {
        innerCard.classList.remove('scale-100');
        innerCard.classList.add('scale-95');
      }
    });

    resetConfirmBtn.addEventListener('click', () => {
      resetModal.classList.remove('opacity-100', 'pointer-events-auto');
      resetModal.classList.add('opacity-0', 'pointer-events-none');
      const innerCard = resetModal.querySelector('div');
      if (innerCard) {
        innerCard.classList.remove('scale-100');
        innerCard.classList.add('scale-95');
      }
      resetChatSession();
    });
  }

  // 2. Load Chat History
  async function loadChatHistory() {
    try {
      const response = await fetch(`/api/chat?sessionId=${sessionId}`);
      if (!response.ok) {
        if (response.status === 404) {
          localStorage.removeItem('ai_chat_session_id');
          sessionId = null;
          return;
        }
        throw new Error('Gagal memuat riwayat.');
      }

      const data = await response.json();
      isAiEnabled = data.is_ai_enabled;

      // Hapus pesan lama kecuali welcome message
      const welcome = messagesContainer.firstElementChild;
      messagesContainer.innerHTML = '';
      if (welcome) messagesContainer.appendChild(welcome);

      const quickReplies = document.getElementById('ai-quick-replies');
      if (quickReplies) {
        if (data.messages && data.messages.length > 0) {
          quickReplies.style.display = 'none';
        } else {
          quickReplies.style.display = 'flex';
        }
      }

      // Render pesan
      let userMsgCount = 0;
      data.messages.forEach(msg => {
        appendMessage(msg.sender, msg.message_content);
        if (msg.sender === 'user' && !msg.message_content.startsWith('[System Info:')) {
          userMsgCount++;
        }
      });

      // Sinkronkan hitungan lokal dengan data server
      localStorage.setItem('ai_chat_message_count', userMsgCount.toString());

      const isSubmitted = localStorage.getItem('lead_submitted') === 'true';
      if (userMsgCount >= 5 && !isSubmitted) {
        appendInlineLeadForm();
      }

      updateStatus(data.status, isAiEnabled);
      scrollToBottom();
      updateLastActive();
      checkAndApplyMessageLimit();

      // Kelola polling jika mode manual
      if (!isAiEnabled) {
        startPolling();
      } else {
        stopPolling();
      }

    } catch (err) {
      console.error('Error loading history:', err);
    }
  }

  // 3. Update Status UI & WA Redirect
  function handleAiLimitOrManual(isAi) {
    const chatInput = document.getElementById('ai-chat-input');
    const sendBtn = document.getElementById('ai-chat-send-btn');
    if (!chatInput) return;

    if (!isAi) {
      // Soft handover: input tetap aktif agar bisa terus chatting ke manual admin
      chatInput.disabled = false;
      chatInput.placeholder = translations.placeholderText;
      if (sendBtn) sendBtn.style.display = 'block';

      // Tampilkan tombol WA di dalam chat stream jika belum ada
      if (!document.getElementById('ai-wa-redirect-btn')) {
        const waDiv = document.createElement('div');
        waDiv.id = 'ai-wa-redirect-btn';
        waDiv.className = 'flex flex-col items-center gap-2.5 mt-4 p-4 bg-emerald-500/10 border border-emerald-500/20 rounded-2xl w-full';

        const waNumber = "6285624353611"; // Nomor WA agensi
        const waMessage = encodeURIComponent(translations.waMessage);
        const waUrl = `https://wa.me/${waNumber}?text=${waMessage}`;

        waDiv.innerHTML = `
          <p class="text-center text-slate-300 font-medium leading-relaxed mb-2 text-[11px]">
            ${translations.redirectText}
          </p>
          <a
            href="${waUrl}"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center gap-2 px-5 py-3 rounded-xl bg-emerald-500 hover:bg-emerald-600 text-white font-bold w-full transition-all text-center text-[11px] uppercase tracking-wider cursor-pointer"
          >
            ${translations.redirectBtn}
          </a>
        `;
        messagesContainer.appendChild(waDiv);
        scrollToBottom();
      }
    } else {
      const waBtn = document.getElementById('ai-wa-redirect-btn');
      if (waBtn) waBtn.remove();
    }
  }

  function updateStatus(status, isAi) {
    if (!isAi) {
      chatStatus.textContent = translations.statusManual;
      chatStatus.className = "text-[9px] font-mono text-amber-500 font-bold";
      manualBadge.classList.remove('hidden');
      handleAiLimitOrManual(false);
    } else {
      chatStatus.textContent = translations.statusOnline;
      chatStatus.className = "text-[9px] font-mono text-slate-400";
      manualBadge.classList.add('hidden');
      handleAiLimitOrManual(true);
    }
  }

  // 4. Send Message
  chatForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const text = chatInput.value.trim();
    if (!text) return;

    // Intercept perintah reset/ganti topik
    const normalizedText = text.toLowerCase();
    const resetCommands = ['/stop', '/ganti', '/reset', 'ganti topik', 'reset chat', 'reset obrolan'];
    if (resetCommands.includes(normalizedText)) {
      resetChatSession();
      chatInput.value = '';
      return;
    }

    chatInput.value = '';
    appendMessage('user', text);
    scrollToBottom();

    // Increment message count if lead not submitted yet
    const isSubmitted = localStorage.getItem('lead_submitted') === 'true';
    if (!isSubmitted) {
      let count = parseInt(localStorage.getItem('ai_chat_message_count') || '0', 10);
      count += 1;
      localStorage.setItem('ai_chat_message_count', count.toString());
      checkAndApplyMessageLimit();
    }

    // Tampilkan indikator mengetik
    const typingId = showTypingIndicator();

    try {
      const response = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: text, sessionId, lang: clientLang })
      });

      removeTypingIndicator(typingId);

      if (!response.ok) throw new Error('Gagal mengirim pesan.');

      const data = await response.json();

      // Simpan session ID jika baru
      if (data.sessionId && data.sessionId !== sessionId) {
        sessionId = data.sessionId;
        localStorage.setItem('ai_chat_session_id', sessionId);
      }
      updateLastActive();

      isAiEnabled = data.is_ai_enabled;

      // Jika ada balasan dari AI
      if (data.reply) {
        appendMessage('assistant', data.reply);
        scrollToBottom();
      }

      // Cek dynamic limit dari backend
      if (data.limit_reached) {
        appendInlineLeadForm();
      }

      checkAndApplyMessageLimit();

      updateStatus(isAiEnabled ? 'active' : 'need_admin', isAiEnabled);

      if (!isAiEnabled) {
        startPolling();
      }

    } catch (err) {
      console.error(err);
      removeTypingIndicator(typingId);
      appendMessage('assistant', translations.networkError);
      scrollToBottom();
    }
  });

  // 5. Polling Manual Messages (Setiap 5 Detik jika mode manual)
  function startPolling() {
    if (pollInterval) return;
    pollInterval = setInterval(async () => {
      if (!sessionId) return;
      try {
        const response = await fetch(`/api/chat?sessionId=${sessionId}`);
        if (response.ok) {
          const data = await response.json();
          
          // Hitung jumlah pesan saat ini
          const currentMsgs = messagesContainer.querySelectorAll('.bg-slate-800\\/50, .bg-blue-600\\/20, .bg-slate-800').length;
          const newMsgs = data.messages.length;

          if (newMsgs > currentMsgs) {
            // Muat ulang pesan untuk menampilkan balasan admin baru
            loadChatHistory();
            if (!isOpen) {
              badge.classList.remove('hidden'); // Tampilkan titik merah jika ditutup
            }
          }

          isAiEnabled = data.is_ai_enabled;
          updateStatus(data.status, isAiEnabled);

          if (isAiEnabled) {
            stopPolling();
          }
        }
      } catch (err) {
        console.error('Polling error:', err);
      }
    }, 5000);
  }

  function stopPolling() {
    if (pollInterval) {
      clearInterval(pollInterval);
      pollInterval = null;
    }
  }

  // 6. UI Helpers
  function appendMessage(sender, content) {
    const isUser = sender === 'user';
    const msgDiv = document.createElement('div');
    msgDiv.className = `flex items-start gap-2.5 ${isUser ? 'justify-end' : ''}`;

    // Format bold markdown sederhana
    const formattedContent = content
      .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
      .replace(/\*(.*?)\*/g, '<em>$1</em>')
      .replace(/\n/g, '<br/>');

    msgDiv.innerHTML = isUser
      ? `
        <div class="bg-blue-600/20 text-blue-200 border border-blue-500/20 p-3 rounded-2xl rounded-tr-none max-w-[85%] leading-relaxed">
          ${formattedContent}
        </div>
      `
      : `
        <div class="w-6 h-6 rounded-full bg-blue-600/10 border border-blue-500/20 flex items-center justify-center shrink-0">🤖</div>
        <div class="bg-slate-800/50 text-slate-200 border border-slate-800/80 p-3 rounded-2xl rounded-tl-none max-w-[85%] leading-relaxed">
          ${formattedContent}
        </div>
      `;

    messagesContainer.appendChild(msgDiv);
  }

  function showTypingIndicator() {
    const typingId = 'typing-' + Date.now();
    const typingDiv = document.createElement('div');
    typingDiv.id = typingId;
    typingDiv.className = 'flex items-start gap-2.5';
    typingDiv.innerHTML = `
      <div class="w-6 h-6 rounded-full bg-blue-600/10 border border-blue-500/20 flex items-center justify-center shrink-0">🤖</div>
      <div class="bg-slate-800/50 text-slate-400 border border-slate-800/80 px-4 py-3 rounded-2xl rounded-tl-none flex items-center gap-1">
        <span class="w-1.5 h-1.5 rounded-full bg-slate-500 animate-bounce" style="animation-delay: 0ms"></span>
        <span class="w-1.5 h-1.5 rounded-full bg-slate-500 animate-bounce" style="animation-delay: 150ms"></span>
        <span class="w-1.5 h-1.5 rounded-full bg-slate-500 animate-bounce" style="animation-delay: 300ms"></span>
      </div>
    `;
    messagesContainer.appendChild(typingDiv);
    scrollToBottom();
    return typingId;
  }

  function removeTypingIndicator(id) {
    const el = document.getElementById(id);
    if (el) el.remove();
  }

  function scrollToBottom() {
    messagesContainer.scrollTop = messagesContainer.scrollHeight;
  }

  function appendInlineLeadForm() {
    if (document.getElementById('inline-lead-box')) return;

    const formDiv = document.createElement('div');
    formDiv.id = 'inline-lead-box';
    formDiv.className = 'p-4 bg-slate-900/80 border border-blue-500/20 rounded-2xl flex flex-col gap-3 my-3';

    formDiv.innerHTML = `
      <div class="text-[10px] font-black text-blue-400 uppercase tracking-wider">📝 Buka Kunci Konsultasi</div>
      <p class="text-slate-300 text-[11px] leading-relaxed">
        ${clientLang === 'en' ? 'You have reached the limit of 5 free messages. Fill in your details to continue.' : 'Anda telah mencapai batas 5 pesan gratis. Silakan isi data diri untuk membuka kunci obrolan.'}
      </p>
      <div class="grid grid-cols-2 gap-2">
        <input
          type="text"
          id="inline-lead-name"
          placeholder="${clientLang === 'en' ? 'Your Name...' : 'Nama Anda...'}"
          class="bg-slate-950 border border-slate-800 focus:border-blue-500 focus:outline-none rounded-lg px-2.5 py-1.5 text-[11px] text-white placeholder-slate-500 transition-colors"
        />
        <input
          type="text"
          id="inline-lead-whatsapp"
          placeholder="${clientLang === 'en' ? 'WhatsApp...' : 'WhatsApp (e.g. 0812...)'}"
          class="bg-slate-950 border border-slate-800 focus:border-blue-500 focus:outline-none rounded-lg px-2.5 py-1.5 text-[11px] text-white placeholder-slate-500 transition-colors"
        />
      </div>
      <button
        type="button"
        id="btn-submit-inline-lead"
        class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 rounded-lg text-[9px] transition-all uppercase tracking-wider cursor-pointer text-center"
      >
        ${clientLang === 'en' ? 'Unlock Chat' : 'Buka Kunci Obrolan'}
      </button>
    `;

    messagesContainer.appendChild(formDiv);
    scrollToBottom();

    const btnSubmit = formDiv.querySelector('#btn-submit-inline-lead');
    if (btnSubmit) {
      btnSubmit.addEventListener('click', async () => {
        const nameInput = formDiv.querySelector('#inline-lead-name');
        const waInput = formDiv.querySelector('#inline-lead-whatsapp');
        const name = nameInput.value.trim();
        const whatsapp = waInput.value.trim();

        if (!name || !whatsapp) {
          alert(clientLang === 'en' ? 'Please fill in both name and WhatsApp.' : 'Mohon isi nama dan nomor WhatsApp Anda.');
          return;
        }

        localStorage.setItem('lead_submitted', 'true');
        localStorage.setItem('lead_name', name);
        localStorage.setItem('lead_whatsapp', whatsapp);

        formDiv.innerHTML = `
          <div class="text-emerald-400 font-semibold text-center text-[10px] py-1 w-full">
            ✓ ${clientLang === 'en' ? 'Unlock successful! Continuing chat...' : 'Buka kunci berhasil! Melanjutkan obrolan...'}
          </div>
        `;
        setTimeout(() => {
          formDiv.remove();
        }, 3000);

        if (leadBanner) leadBanner.style.display = 'none';

        checkAndApplyMessageLimit();

        try {
          const response = await fetch('/api/chat', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              message: `[System Info: Client submitted lead form - Name: ${name}, WA: ${whatsapp}]`,
              sessionId,
              lang: clientLang,
              clientName: name,
              whatsappNumber: whatsapp
            })
          });
          if (response.ok) {
            const data = await response.json();
            if (data.sessionId && data.sessionId !== sessionId) {
              sessionId = data.sessionId;
              localStorage.setItem('ai_chat_session_id', sessionId);
            }
            updateLastActive();
          }
        } catch (err) {
          console.error('Error submitting lead info inline:', err);
        }
      });
    }
  }

  // --- LOGIKA FORM LEAD, MESSAGE LIMIT & INACTIVITY TIMEOUT ---

  function initLeadBanner() {
    if (!leadBanner) return;
    const isSubmitted = localStorage.getItem('lead_submitted') === 'true';
    if (isSubmitted) {
      leadBanner.style.display = 'none';
    } else {
      leadBanner.style.display = 'flex';
    }
  }

  function checkAndApplyMessageLimit() {
    if (!chatInput) return;
    
    const hasSession = !!localStorage.getItem('ai_chat_session_id');
    const isSubmitted = localStorage.getItem('lead_submitted') === 'true';
    const msgCount = parseInt(localStorage.getItem('ai_chat_message_count') || '0', 10);

    // 1. Guided funnel: jika belum ada sesi (klien baru), paksa klik Quick Replies
    if (!hasSession) {
      chatInput.disabled = true;
      chatInput.placeholder = clientLang === 'en' ? "Select a topic above to start..." : "Pilih salah satu menu di atas untuk memulai...";
      const sendBtn = document.getElementById('ai-chat-send-btn');
      if (sendBtn) sendBtn.style.display = 'none';
      return;
    }

    // 2. Lock jika sudah mencapai 5 pesan dan belum submit lead
    if (msgCount >= 5 && !isSubmitted) {
      chatInput.disabled = true;
      chatInput.placeholder = clientLang === 'en' ? "Locked. Please fill out contact form." : "Terkunci. Mohon isi form data diri.";
      const sendBtn = document.getElementById('ai-chat-send-btn');
      if (sendBtn) sendBtn.style.display = 'none';
      return;
    }

    // Jika bebas lock
    chatInput.disabled = false;
    chatInput.placeholder = translations.placeholderText;
    const sendBtn = document.getElementById('ai-chat-send-btn');
    if (sendBtn) sendBtn.removeAttribute('style');
  }

  function resetChatSession() {
    localStorage.removeItem('ai_chat_session_id');
    localStorage.removeItem('ai_chat_last_active');
    localStorage.removeItem('ai_chat_message_count');
    localStorage.removeItem('lead_submitted');
    localStorage.removeItem('lead_name');
    localStorage.removeItem('lead_whatsapp');
    sessionId = null;
    isAiEnabled = true;

    // Reset UI to welcome state
    const welcome = messagesContainer.firstElementChild;
    messagesContainer.innerHTML = '';
    if (welcome) {
      messagesContainer.appendChild(welcome);
      const quickReplies = document.getElementById('ai-quick-replies');
      if (quickReplies) quickReplies.style.display = 'flex';
    }

    // Reset input
    chatInput.removeAttribute('disabled');
    chatInput.placeholder = translations.placeholderText;
    const sendBtn = document.getElementById('ai-chat-send-btn');
    if (sendBtn) sendBtn.removeAttribute('style');

    // Show lead form again
    initLeadBanner();
    
    // Stop polling
    stopPolling();
    
    // Update status
    updateStatus('active', true);
  }

  if (btnToggleLeadForm) {
    btnToggleLeadForm.addEventListener('click', () => {
      const fields = document.getElementById('lead-form-fields');
      const submitBtn = document.getElementById('btn-submit-lead-form');
      if (fields && submitBtn) {
        if (fields.style.display === 'none') {
          fields.style.display = 'grid';
          submitBtn.style.display = 'block';
          btnToggleLeadForm.textContent = 'Sembunyikan';
        } else {
          fields.style.display = 'none';
          submitBtn.style.display = 'none';
          btnToggleLeadForm.textContent = 'Tampilkan';
        }
      }
    });
  }

  if (btnSubmitLeadForm) {
    btnSubmitLeadForm.addEventListener('click', async () => {
      const name = leadInputName.value.trim();
      const whatsapp = leadInputWhatsapp.value.trim();
      if (!name || !whatsapp) {
        alert('Mohon isi nama dan nomor WhatsApp Anda.');
        return;
      }

      localStorage.setItem('lead_submitted', 'true');
      localStorage.setItem('lead_name', name);
      localStorage.setItem('lead_whatsapp', whatsapp);

      if (leadBanner) {
        leadBanner.innerHTML = `
          <div class="text-emerald-400 font-semibold text-center text-[10px] py-1 w-full">
            ✓ Data kontak berhasil dikirim! Konsultasi tanpa batas diaktifkan.
          </div>
        `;
        setTimeout(() => {
          leadBanner.style.display = 'none';
        }, 3000);
      }

      checkAndApplyMessageLimit();

      try {
        const response = await fetch('/api/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            message: `[System Info: Client submitted lead form - Name: ${name}, WA: ${whatsapp}]`,
            sessionId,
            lang: clientLang,
            clientName: name,
            whatsappNumber: whatsapp
          })
        });
        if (response.ok) {
          const data = await response.json();
          if (data.sessionId && data.sessionId !== sessionId) {
            sessionId = data.sessionId;
            localStorage.setItem('ai_chat_session_id', sessionId);
          }
          updateLastActive();
        }
      } catch (err) {
        console.error('Error submitting lead info:', err);
      }
    });
  }

  // Panggil init pada awal load
  initLeadBanner();
  checkAndApplyMessageLimit();

  // Jika session ID ada di page load, cek status AI untuk menyalakan polling di background
  if (sessionId) {
    fetch(`/api/chat?sessionId=${sessionId}`)
      .then(res => {
        if (res.ok) return res.json();
        throw new Error('Gagal memuat status sesi awal.');
      })
      .then(data => {
        isAiEnabled = data.is_ai_enabled;
        updateStatus(data.status, isAiEnabled);
        if (!isAiEnabled) {
          startPolling();
        }
      })
      .catch(err => console.error('Error auto-checking session on load:', err));
  }

  // Jalankan background checker untuk inactivity timeout (30 menit)
  setInterval(() => {
    const lastAct = localStorage.getItem('ai_chat_last_active');
    if (lastAct && sessionId) {
      const elapsed = Date.now() - parseInt(lastAct, 10);
      if (elapsed > 30 * 60 * 1000) {
        resetChatSession();
      }
    }
  }, 10000);
</script>
