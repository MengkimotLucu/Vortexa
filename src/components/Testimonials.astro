---

<section id={lang === 'en' ? 'testimonials' : 'testimoni'} class="py-12 lg:py-16 bg-white relative overflow-hidden">
  <!-- Glowing Background Orbs -->
  <div class="absolute top-1/4 left-[-10%] w-[600px] h-[600px] bg-blue-600/[0.08] rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-1/4 right-[-10%] w-[600px] h-[600px] bg-teal-500/[0.07] rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute inset-0 bg-[radial-gradient(rgba(37,99,235,0.012)_1px,transparent_1px)] bg-[size:1.5rem_1.5rem] pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-6 relative z-10 reveal-on-scroll">
    
    <!-- Section Header -->
    <div class="max-w-3xl mb-10 lg:mb-12 mx-auto text-center">
      <h2 class="font-mono font-bold text-xs tracking-widest text-blue-600 uppercase">{content.sectionHeader}</h2>
      <h3 class="font-display font-black text-4xl sm:text-5xl text-slate-900 uppercase tracking-tight leading-[1.05] mt-3">
        {content.title1}<br/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-teal-500">{content.title2}</span>
      </h3>
      <p class="text-slate-500 mt-6 text-sm sm:text-base leading-relaxed font-semibold">
        {content.desc}
      </p>
    </div>

    <!-- Testimonials Carousel Container -->
    <div class="relative w-full">
      <!-- Carousel Track -->
      <div 
        id="reviews-track" 
        class="flex gap-6 overflow-x-auto snap-x snap-mandatory scrollbar-none pb-6 scroll-smooth select-none cursor-grab active:cursor-grabbing"
      >
        {reviews.map((item) => (
          <div class="testimonial-card snap-start shrink-0 w-full md:w-[calc((100%-48px)/3)] p-8 bg-white/80 backdrop-blur-xl border border-slate-200/50 rounded-3xl shadow-xl shadow-slate-100/40 hover:shadow-2xl hover:shadow-blue-500/10 hover:border-blue-500/30 transition-all duration-500 flex flex-col justify-between min-h-[280px] relative overflow-hidden group">
            <!-- Mouse Spotlight Overlay -->
            <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none bg-[radial-gradient(var(--spotlight-size,_400px)_circle_at_var(--mouse-x,_0px)_var(--mouse-y,_0px),rgba(37,99,235,0.06),transparent_80%)]"></div>
            
            <div class="space-y-5 relative z-10">
              <!-- Review Stars & Tag -->
              <div class="flex items-center justify-between">
                <div class="flex gap-0.5 text-amber-400">
                  {[...Array(5)].map(() => (
                    <svg class="w-4 h-4 fill-current drop-shadow-[0_2px_4px_rgba(245,158,11,0.2)] transition-transform duration-300 hover:scale-125 hover:rotate-12" viewBox="0 0 24 24">
                      <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" />
                    </svg>
                  ))}
                </div>
                <span class="px-2.5 py-0.5 rounded-full border border-blue-500/15 bg-blue-500/5 text-[8px] font-mono font-bold text-blue-600 uppercase tracking-widest transition-colors duration-300 group-hover:border-blue-500/30">
                  {item.tag}
                </span>
              </div>
              
              <!-- Content -->
              <p class="text-xs sm:text-[13px] text-slate-650 leading-relaxed font-semibold italic">
                "{item.content}"
              </p>
            </div>

            <!-- Client Profile -->
            <div class="flex items-center gap-3.5 border-t border-slate-100/80 pt-5 mt-6 relative z-10">
              <div class="relative">
                <div class="absolute -inset-1 rounded-full bg-gradient-to-r from-blue-600 to-teal-400 opacity-20 blur-sm group-hover:opacity-60 group-hover:scale-110 transition duration-500"></div>
                <div class="relative w-10 h-10 rounded-full bg-gradient-to-tr from-blue-600 to-teal-500 flex items-center justify-center font-display font-black text-white text-xs shadow-inner">
                  {item.avatar}
                </div>
              </div>
              <div>
                <h5 class="text-xs font-display font-black text-slate-800 uppercase tracking-wide transition-colors duration-300 group-hover:text-blue-600">{item.name}</h5>
                <p class="text-[9px] text-slate-400 font-mono font-bold uppercase tracking-wider mt-0.5">{item.role}</p>
              </div>
            </div>
          </div>
        ))}
      </div>


    </div>



