</section>

<style>
  .scrollbar-none::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-none {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  
  #reviews-track.active {
    cursor: grabbing;
    user-select: none;
  }

  .testimonial-card {
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1), 
                box-shadow 0.5s cubic-bezier(0.16, 1, 0.3, 1), 
                border-color 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    transform-style: preserve-3d;
  }
</style>

<script>
  function initReviews() {
    const track = document.getElementById('reviews-track') as HTMLDivElement;
    const cards = document.querySelectorAll('.testimonial-card') as NodeListOf<HTMLDivElement>;

    if (!track) return;

    // 1. Mouse Spotlight and 3D Tilt Effect
    cards.forEach((card) => {
      card.addEventListener('mousemove', (e) => {
        const rect = card.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        
        card.style.setProperty('--mouse-x', `${x}px`);
        card.style.setProperty('--mouse-y', `${y}px`);

        // 3D Tilt calculations
        const width = rect.width;
        const height = rect.height;
        const mouseX = x - width / 2;
        const mouseY = y - height / 2;
        
        // Calculate rotation angles (max 6 degrees tilt for elegance)
        const rX = -(mouseY / (height / 2)) * 6;
        const rY = (mouseX / (width / 2)) * 6;

        card.style.transform = `perspective(1000px) rotateX(${rX}deg) rotateY(${rY}deg) scale3d(1.015, 1.015, 1.015)`;
      });

      card.addEventListener('mouseleave', () => {
        // Smooth reset
        card.style.transform = 'perspective(1000px) rotateX(0deg) rotateY(0deg) scale3d(1, 1, 1)';
      });
    });

    // 2. Drag & Swipe Functionality
    let isDown = false;
    let startX: number;
    let scrollLeft: number;

    track.addEventListener('mousedown', (e) => {
      isDown = true;
      track.classList.add('active');
      track.style.scrollSnapType = 'none'; // Disable snap to avoid jerkiness
      startX = e.pageX - track.offsetLeft;
      scrollLeft = track.scrollLeft;
      track.style.scrollBehavior = 'auto'; // Immediate scroll response
      stopAutoPlay();
    });

    track.addEventListener('mouseleave', () => {
      if (isDown) {
        isDown = false;
        track.classList.remove('active');
        track.style.scrollSnapType = 'x mandatory';
        track.style.scrollBehavior = 'smooth';
      }
      startAutoPlay();
    });

    track.addEventListener('mouseup', () => {
      if (isDown) {
        isDown = false;
        track.classList.remove('active');
        track.style.scrollSnapType = 'x mandatory';
        track.style.scrollBehavior = 'smooth';
      }
      startAutoPlay();
    });

    track.addEventListener('mousemove', (e) => {
      if (!isDown) return;
      e.preventDefault();
      const x = e.pageX - track.offsetLeft;
      const walk = (x - startX) * 1.5; // Drag sensitivity
      track.scrollLeft = scrollLeft - walk;
    });

    // 3. Auto-play Carousel (Slow & smooth slide)
    let autoPlayInterval: any;

    function getCardWidth() {
      const card = track.firstElementChild;
      if (!card) return 0;
      const cardWidth = card.getBoundingClientRect().width;
      const parentStyle = window.getComputedStyle(track);
      const gap = parseFloat(parentStyle.columnGap) || 0;
      return cardWidth + gap;
    }

    function startAutoPlay() {
      stopAutoPlay();
      autoPlayInterval = setInterval(() => {
        if (isDown) return;
        const cardWidth = getCardWidth();
        if (cardWidth > 0) {
          const maxScrollLeft = track.scrollWidth - track.clientWidth;
          if (track.scrollLeft + 15 >= maxScrollLeft) {
            track.scrollTo({ left: 0, behavior: 'smooth' });
          } else {
            track.scrollBy({ left: cardWidth, behavior: 'smooth' });
          }
        }
      }, 5000); // 5 seconds delay between transitions
    }

    function stopAutoPlay() {
      if (autoPlayInterval) {
        clearInterval(autoPlayInterval);
      }
    }

    // Pause on hover
    track.addEventListener('mouseenter', stopAutoPlay);
    track.addEventListener('mouseleave', startAutoPlay);

    // Initial start
    startAutoPlay();
  }

  // Initialize
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initReviews);
  } else {
    initReviews();
  }
  document.addEventListener('astro:page-load', initReviews);
</script>

