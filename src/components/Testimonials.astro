---

<section id="testimoni" class="py-24 bg-slate-50 relative overflow-hidden border-t-2 border-slate-200">
  <div class="absolute inset-0 bg-[radial-gradient(rgba(37,99,235,0.015)_1px,transparent_1px)] bg-[size:1.5rem_1.5rem] pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-6 relative z-10 reveal-on-scroll">
    
    <!-- Section Header -->
    <div class="max-w-3xl mb-16">
      <h2 class="font-mono font-bold text-xs tracking-widest text-blue-600 uppercase">{content.sectionHeader}</h2>
      <h3 class="font-display font-black text-4xl sm:text-5xl text-slate-900 uppercase tracking-tight leading-[1.0] mt-3">
        {content.title1}<br/>
        <span class="text-stroke-neon">{content.title2}</span>
      </h3>
      <p class="text-slate-500 mt-6 text-sm sm:text-base leading-relaxed font-semibold">
        {content.desc}
      </p>
    </div>

    <!-- Testimonials Carousel Container -->
    <div class="relative w-full">
      <!-- Carousel Track -->
      <div 
        id="reviews-track" 
        class="flex gap-6 overflow-x-auto snap-x snap-mandatory scrollbar-none pb-4 scroll-smooth"
      >
        {reviews.map((item) => (
          <div class="snap-start shrink-0 w-full md:w-[calc((100%-48px)/3)] p-8 bg-white border-2 border-blue-600 rounded-3xl shadow-[4px_4px_0px_#2563eb] hover:shadow-[6px_6px_0px_#1d4ed8] hover:-translate-y-1 transition-all duration-300 flex flex-col justify-between min-h-[260px] select-none">
            <div class="space-y-4">
              <!-- Review Stars & Tag -->
              <div class="flex items-center justify-between">
                <div class="flex gap-1 text-blue-600">
                  {"★".repeat(5)}
                </div>
                <span class="px-2 py-0.5 rounded border border-blue-200 bg-blue-50 text-[8px] font-mono font-bold text-blue-700 uppercase tracking-wider">
                  {item.tag}
                </span>
              </div>
              
              <!-- Content -->
              <p class="text-xs text-slate-600 leading-relaxed font-semibold">
                "{item.content}"
              </p>
            </div>

            <!-- Client Profile -->
            <div class="flex items-center gap-3 border-t border-slate-100 pt-4 mt-6">
              <div class="w-10 h-10 rounded-full bg-gradient-to-tr from-blue-600 to-blue-400 flex items-center justify-center font-display font-black text-white text-xs shadow-md">
                {item.avatar}
              </div>
              <div>
                <h5 class="text-xs font-display font-black text-slate-900 uppercase">{item.name}</h5>
                <p class="text-[10px] text-slate-400 font-mono font-bold">{item.role}</p>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Navigation Panel -->
      <div class="flex justify-center items-center gap-6 mt-8">
        <button 
          id="btn-prev-review" 
          class="p-3 rounded-xl border-2 border-blue-600 bg-white hover:bg-slate-50 text-blue-600 active:translate-y-0.5 active:shadow-[1px_1px_0px_#2563eb] shadow-[3px_3px_0px_#2563eb] transition-all cursor-pointer select-none"
          aria-label="Ulasan Sebelumnya"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        
        <!-- Dot Indicators -->
        <div id="reviews-dots" class="flex items-center gap-2">
          {reviews.map((_, i) => (
            <button 
              class={`review-dot w-2.5 h-2.5 rounded-full border border-blue-600 transition-all duration-300 cursor-pointer ${i === 0 ? 'bg-blue-600 w-6' : 'bg-white'}`} 
              data-index={i} 
              aria-label={`Ke slide ${i + 1}`}
            ></button>
          ))}
        </div>

        <button 
          id="btn-next-review" 
          class="p-3 rounded-xl border-2 border-blue-600 bg-white hover:bg-slate-50 text-blue-600 active:translate-y-0.5 active:shadow-[1px_1px_0px_#2563eb] shadow-[3px_3px_0px_#2563eb] transition-all cursor-pointer select-none"
          aria-label="Ulasan Berikutnya"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>
    </div>

    <!-- CTA Section -->
    <div class="mt-16 p-8 border-2 border-blue-600 bg-white rounded-3xl shadow-[6px_6px_0px_#2563eb] flex flex-col md:flex-row items-center justify-between gap-6 reveal-on-scroll">
      <div class="space-y-2">
        <h4 class="font-display font-black text-lg text-slate-900 uppercase">Ingin Menjadi Cerita Sukses Berikutnya?</h4>
        <p class="text-xs text-slate-500 font-semibold max-w-xl">
          Konsultasikan konsep bisnis Anda bersama kami untuk membangun kehadiran web dengan performa optimal.
        </p>
      </div>
      <a 
        href="#konsultasi" 
        class="inline-flex items-center justify-center px-6 py-3.5 rounded-xl border-2 border-blue-600 bg-blue-600 hover:bg-blue-700 text-white font-black text-xs uppercase tracking-widest transition-all duration-200 shadow-[3px_3px_0px_#0f172a] active:translate-y-0.5 active:shadow-[1px_1px_0px_#0f172a] cursor-pointer"
      >
        Amankan Slot Konsultasi
      </a>
    </div>

  </div>
</section>

<style>
  .scrollbar-none::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-none {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>

<script>
  function initReviews() {
    const track = document.getElementById('reviews-track');
    const btnPrev = document.getElementById('btn-prev-review');
    const btnNext = document.getElementById('btn-next-review');
    const dots = document.querySelectorAll('.review-dot');

    if (!track || !btnPrev || !btnNext) return;

    function getCardWidth() {
      const card = track.firstElementChild;
      if (!card) return 0;
      const cardStyles = window.getComputedStyle(card);
      const cardWidth = card.getBoundingClientRect().width;
      const marginRight = parseFloat(cardStyles.marginRight) || 0;
      const marginLeft = parseFloat(cardStyles.marginLeft) || 0;
      const parentStyle = window.getComputedStyle(track);
      const gap = parseFloat(parentStyle.columnGap) || 0;
      return cardWidth + gap;
    }

    btnNext.addEventListener('click', () => {
      const cardWidth = getCardWidth();
      if (cardWidth > 0) {
        track.scrollBy({ left: cardWidth, behavior: 'smooth' });
      }
    });

    btnPrev.addEventListener('click', () => {
      const cardWidth = getCardWidth();
      if (cardWidth > 0) {
        track.scrollBy({ left: -cardWidth, behavior: 'smooth' });
      }
    });

    function updateActiveDot() {
      const scrollLeft = track.scrollLeft;
      const cardWidth = getCardWidth();
      if (cardWidth <= 0) return;

      const scrollIndex = Math.round(scrollLeft / cardWidth);

      dots.forEach((dot, idx) => {
        if (idx === scrollIndex) {
          dot.classList.add('bg-blue-600', 'w-6');
          dot.classList.remove('bg-white');
        } else {
          dot.classList.add('bg-white');
          dot.classList.remove('bg-blue-600', 'w-6');
        }
      });
    }

    track.addEventListener('scroll', updateActiveDot);
    updateActiveDot();

    dots.forEach((dot, idx) => {
      dot.addEventListener('click', () => {
        const cardWidth = getCardWidth();
        if (cardWidth > 0) {
          track.scrollTo({ left: idx * cardWidth, behavior: 'smooth' });
        }
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initReviews);
  } else {
    initReviews();
  }
</script>

