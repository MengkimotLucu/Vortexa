<script>
  function initInteractivePortfolio() {
    // 1. FILTERING SYSTEM
    const filterButtons = document.querySelectorAll('.portfolio-filter-btn');
    const portfolioCards = document.querySelectorAll('.portfolio-card') as NodeListOf<HTMLDivElement>;

    filterButtons.forEach(btn => {
      btn.addEventListener('click', (e) => {
        const clickedBtn = e.currentTarget as HTMLButtonElement;
        const filter = clickedBtn.getAttribute('data-filter');

        // Update active class on buttons to Neo-brutalist white/blue states
        filterButtons.forEach(b => {
          b.className = "portfolio-filter-btn px-4 py-2 border-2 border-slate-200 bg-white text-[10px] font-bold text-slate-500 uppercase tracking-wider rounded-lg transition-all hover:border-blue-600 hover:text-blue-600 cursor-pointer";
        });
        clickedBtn.className = "portfolio-filter-btn px-4 py-2 border-2 border-blue-600 bg-blue-600 text-[10px] font-bold text-white uppercase tracking-wider rounded-lg transition-all hover:bg-blue-700 shadow-[2px_2px_0px_#0f172a] cursor-pointer";

        // Filter cards with animations
        portfolioCards.forEach(card => {
          const category = card.getAttribute('data-category');
          if (filter === 'all' || category === filter) {
            card.classList.remove('hidden');
            setTimeout(() => {
              card.style.opacity = '1';
              card.style.transform = 'scale(1)';
            }, 50);
          } else {
            card.style.opacity = '0';
            card.style.transform = 'scale(0.95)';
            setTimeout(() => {
              card.classList.add('hidden');
            }, 300);
          }
        });
      });
    });

    // 2. CARD 1: AETHERIA TERMINAL SIMULATION
    const runAetheriaBtn = document.getElementById('run-aetheria-btn');
    const aetheriaLogBox = document.getElementById('aetheria-log-box');
    let aetheriaRunning = false;

    if (runAetheriaBtn && aetheriaLogBox) {
      const logs = [
        { text: "> Inisialisasi Aetheria AI pipeline...", color: "text-blue-400" },
        { text: "> Menghubungkan ke node otonom...", color: "text-slate-500" },
        { text: "> Sinkronisasi LLM model: Llama-3-Groq [READY]", color: "text-teal-400" },
        { text: "> Mendeteksi peluang kata kunci bernilai tinggi...", color: "text-slate-500" },
        { text: "> Menulis konten teroptimasi SEO (+450% reach)", color: "text-emerald-400" },
        { text: "> Deploy artikel ke CDN Edge... [SUCCESS]", color: "text-teal-400 font-bold" },
        { text: "> AI Agent otonom berjalan di background. Latensi: 6ms.", color: "text-white" }
      ];

      runAetheriaBtn.addEventListener('click', () => {
        if (aetheriaRunning) return;
        aetheriaRunning = true;
        runAetheriaBtn.innerText = "RUNNING...";
        runAetheriaBtn.className = "px-3 py-1.5 rounded-lg border-2 border-rose-600 bg-rose-50 text-rose-600 font-mono text-[10px] font-bold uppercase tracking-wider transition-all cursor-not-allowed animate-pulse shadow-[2px_2px_0px_#e11d48]";
        
        aetheriaLogBox.innerHTML = '';
        
        logs.forEach((log, index) => {
          setTimeout(() => {
            const div = document.createElement('div');
            div.className = `${log.color} transition-all duration-300 opacity-0 translate-y-1`;
            div.innerText = log.text;
            aetheriaLogBox.appendChild(div);
            
            setTimeout(() => {
              div.classList.remove('opacity-0', 'translate-y-1');
            }, 50);

            aetheriaLogBox.scrollTop = aetheriaLogBox.scrollHeight;

            if (index === logs.length - 1) {
              aetheriaRunning = false;
              runAetheriaBtn.innerText = "RUN AGENT ⚡";
              runAetheriaBtn.className = "px-3 py-1.5 rounded-lg border-2 border-blue-600 bg-blue-50 text-blue-600 font-mono text-[10px] font-bold uppercase tracking-wider transition-all hover:bg-blue-600 hover:text-white cursor-pointer shadow-[2px_2px_0px_#2563eb]";
            }
          }, index * 600);
        });
      });
    }

    // 3. CARD 2: VELOCE SPEED RACE SIMULATION
    const runVeloceBtn = document.getElementById('run-veloce-btn');
    const slowVal = document.getElementById('veloce-slow-val');
    const fastVal = document.getElementById('veloce-fast-val');
    const slowBar = document.getElementById('veloce-slow-bar');
    const fastBar = document.getElementById('veloce-fast-bar');
    let veloceRunning = false;

    if (runVeloceBtn && slowVal && fastVal && slowBar && fastBar) {
      runVeloceBtn.addEventListener('click', () => {
        if (veloceRunning) return;
        veloceRunning = true;
        runVeloceBtn.innerText = "RACING...";
        runVeloceBtn.className = "px-3 py-1.5 rounded-lg border-2 border-rose-600 bg-rose-50 text-rose-600 font-mono text-[10px] font-bold uppercase tracking-wider transition-all cursor-not-allowed animate-pulse shadow-[2px_2px_0px_#e11d48]";

        // Reset
        slowBar.style.width = '0%';
        fastBar.style.width = '0%';
        slowVal.innerText = "LOADING...";
        slowVal.className = "font-bold text-slate-400";
        fastVal.innerText = "LOADING...";
        fastVal.className = "font-bold text-slate-400";

        // Fast Load (Vortexa Astro Stack)
        setTimeout(() => {
          fastBar.style.width = '100%';
          fastVal.innerText = "0.24s (100/100) 🏆";
          fastVal.className = "font-bold text-teal-600 animate-bounce";
        }, 300);

        // Slow Load (Standard Monolithic)
        setTimeout(() => {
          slowBar.style.width = '100%';
          slowVal.innerText = "2.68s (39/100)";
          slowVal.className = "font-bold text-rose-600";
          
          runVeloceBtn.innerText = "RUN SPEED TEST 🔄";
          runVeloceBtn.className = "px-3 py-1.5 rounded-lg border-2 border-blue-600 bg-blue-50 text-blue-600 font-mono text-[10px] font-bold uppercase tracking-wider transition-all hover:bg-blue-600 hover:text-white cursor-pointer shadow-[2px_2px_0px_#2563eb]";
          veloceRunning = false;
        }, 2200);
      });
    }

    // 4. CARD 3: APEX SEO GRAPH SELECTOR
    const apexTabs = document.querySelectorAll('.apex-tab-btn');
    const apexBars = [
      document.getElementById('apex-bar-1'),
      document.getElementById('apex-bar-2'),
      document.getElementById('apex-bar-3'),
      document.getElementById('apex-bar-4'),
      document.getElementById('apex-bar-5')
    ];
    const apexTooltips = [
      document.getElementById('apex-tooltip-1'),
      document.getElementById('apex-tooltip-2'),
      document.getElementById('apex-tooltip-3'),
      document.getElementById('apex-tooltip-4'),
      document.getElementById('apex-tooltip-5')
    ];

    const dataSet: Record<string, { heights: string[], tooltips: string[] }> = {
      weekly: {
        heights: ['30%', '45%', '60%', '75%', '95%'],
        tooltips: ['+40k', '+80k', '+120k', '+210k', '+480k 🔥']
      },
      monthly: {
        heights: ['20%', '35%', '50%', '65%', '88%'],
        tooltips: ['+180k', '+320k', '+480k', '+750k', '+1.8M 🔥']
      },
      yearly: {
        heights: ['15%', '28%', '40%', '62%', '80%'],
        tooltips: ['+2.1M', '+3.8M', '+5.2M', '+8.9M', '+22M 🔥']
      }
    };

    apexTabs.forEach(tab => {
      tab.addEventListener('click', (e) => {
        const clickedTab = e.currentTarget as HTMLButtonElement;
        const period = clickedTab.getAttribute('data-period');
        if (!period) return;

        // Button styling active
        apexTabs.forEach(t => {
          t.className = "apex-tab-btn px-2 py-1 rounded text-slate-400 hover:text-slate-900 cursor-pointer";
        });
        clickedTab.className = "apex-tab-btn px-2 py-1 rounded bg-white border border-slate-200 text-slate-800 cursor-pointer";

        // Animate bars & change tooltip content
        const config = dataSet[period];
        apexBars.forEach((bar, idx) => {
          if (bar) bar.style.height = config.heights[idx];
        });
        apexTooltips.forEach((tip, idx) => {
          if (tip) tip.innerText = config.tooltips[idx];
        });
      });
    });

    // 5. CARD 4: LUMINA THEME SWITCHER
    const themeChips = document.querySelectorAll('.lumina-theme-chip');
    const mockWidget = document.getElementById('lumina-mock-widget');
    const mockCircle = document.getElementById('lumina-mock-circle');
    const mockBar = document.getElementById('lumina-mock-bar');
    const ctaLink = document.getElementById('lumina-cta-link');

    const themeColors: Record<string, { circleBorder: string, circleText: string, barBg: string, ctaText: string, borderTint: string }> = {
      'neon-green': {
        circleBorder: 'border-t-teal-600',
        circleText: 'text-teal-600',
        barBg: 'bg-teal-600',
        ctaText: 'text-teal-600',
        borderTint: 'border-teal-600/20'
      },
      'neon-cyan': {
        circleBorder: 'border-t-blue-500',
        circleText: 'text-blue-500',
        barBg: 'bg-blue-500',
        ctaText: 'text-blue-500',
        borderTint: 'border-blue-500/20'
      },
      'neon-pink': {
        circleBorder: 'border-t-rose-600',
        circleText: 'text-rose-600',
        barBg: 'bg-rose-600',
        ctaText: 'text-rose-600',
        borderTint: 'border-rose-600/20'
      }
    };

    themeChips.forEach(chip => {
      chip.addEventListener('click', (e) => {
        const clickedChip = e.currentTarget as HTMLButtonElement;
        const color = clickedChip.getAttribute('data-color');
        if (!color || !themeColors[color]) return;

        // Chip scaling highlight
        themeChips.forEach(c => {
          c.className = "lumina-theme-chip w-3.5 h-3.5 rounded-full border-2 border-transparent cursor-pointer shadow-sm";
        });
        clickedChip.className = "lumina-theme-chip w-3.5 h-3.5 rounded-full border-2 border-white scale-125 cursor-pointer shadow-md";

        // Apply theme mapping dynamically using explicit strings
        const mapping = themeColors[color];
        
        if (mockWidget && mockCircle && mockBar && ctaLink) {
          // Remove all possible Tailwind theme classes to prevent conflicts
          Object.values(themeColors).forEach(c => {
            mockCircle.classList.remove(c.circleBorder, c.circleText);
            mockBar.classList.remove(c.barBg);
            ctaLink.classList.remove(c.ctaText);
            mockWidget.classList.remove(c.borderTint);
          });

          // Add new selected classes
          mockCircle.classList.add(mapping.circleBorder, mapping.circleText);
          mockBar.classList.add(mapping.barBg);
          ctaLink.classList.add(mapping.ctaText);
          mockWidget.classList.add(mapping.borderTint);
        }
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initInteractivePortfolio);
  } else {
    initInteractivePortfolio();
  }
</script>
