---
import { Image } from 'astro:assets';
import imgFasteat from '../assets/portfolio-fasteat-mockup.png';
import imgCompanyProfile from '../assets/portfolio-company-profile.png';
import imgBuah from '../assets/portfolio-buah-mockup.png';
import imgRedesignWeb from '../assets/portfolio-redesign-web.png';
import imgXplored from '../assets/portfolio-xplored.png';
import imgBelanjahub from '../assets/portfolio-belanjahub.png';
import imgMaintenance from '../assets/portfolio-maintenance.png';

const lang = Astro.currentLocale === 'en' ? 'en' : 'id';
const waNumber = import.meta.env.PUBLIC_WHATSAPP_NUMBER || '6285624353611';


const content = {
  id: {
    sectionHeader: "Portofolio Karya",
    title1: "Bukti Nyata.",
    title2: "Bukan Sekadar Kata.",
    desc: "Kami tidak sekadar menulis kode. Kami menciptakan solusi digital eksklusif yang dirancang khusus untuk meningkatkan performa bisnis Anda secara masif.",
    fAll: "[ SEMUA ]",
    fLanding: "[ LANDING PAGE ]",
    fProfile: "[ COMPANY PROFILE ]",
    fEcom: "[ TOKO ONLINE ]",
    fRedesign: "[ REDESIGN WEB ]",
    btnView: "Lihat Mockup",
    btnWa: "Konsultasi Layanan Ini",
    titleLightbox: "Detail Desain",
    techHeader: "Teknologi yang Digunakan"
  },
  en: {
    sectionHeader: "Work Portfolio",
    title1: "Real Proof.",
    title2: "Not Just Words.",
    desc: "We do not just write code. We create exclusive digital solutions custom-tailored to massively boost your business performance.",
    fAll: "[ ALL ]",
    fLanding: "[ LANDING PAGE ]",
    fProfile: "[ COMPANY PROFILE ]",
    fEcom: "[ E-COMMERCE ]",
    fRedesign: "[ WEB REDESIGN ]",
    btnView: "View Mockup",
    btnWa: "Inquire about Service",
    titleLightbox: "Design Details",
    techHeader: "Technologies Used"
  }
}[lang];

// 6 Projects representing the 6 core services from Services.astro
const projects = [
  {
    id: 'fasteat-cafe',
    category: 'landing-page',
    categoryLabel: lang === 'en' ? 'Landing Page' : 'Landing Page',
    filePath: '~/lumovelo/portfolio/fasteat-cafe.png',
    title: 'FastEat Cafe & Restaurant',
    image: imgFasteat,
    tech: ['React', 'Vite', 'Tailwind CSS'],
    desc: lang === 'en' 
      ? 'A sleek and modern F&B landing page for FastEat Cafe & Restaurant featuring interactive menus, fast responsiveness, and smooth layouts.' 
      : 'Landing Page F&B moderen dan elegan untuk FastEat Cafe & Restaurant dengan menu interaktif, responsivitas tinggi, dan tata letak halus.',
    metric: lang === 'en' ? 'Design: 10/10' : 'Desain: 10/10',
    altText: lang === 'en' 
      ? "FastEat Cafe & Restaurant high converting landing page development"
      : "Jasa pembuatan landing page F&B FastEat Cafe & Restaurant konversi tinggi",
    spanClass: 'md:col-span-8',
    heightClass: 'h-[380px]',
    waUrl: `https://api.whatsapp.com/send?phone=${waNumber}&text=${encodeURIComponent(
      lang === 'en' 
        ? 'Hello Lumovelo, I am interested in inquiring about the Cafe/Restaurant Landing Page (FastEat project) I saw in your portfolio.' 
        : 'Halo Lumovelo, saya tertarik untuk berkonsultasi mengenai jasa pembuatan Landing Page Cafe/Restoran (proyek FastEat) yang saya lihat di portofolio.'
    )}`,
    demoUrl: 'https://fasteat-theta.vercel.app/'
  },
  {
    id: 'company-profile',
    category: 'company-profile',
    categoryLabel: lang === 'en' ? 'Company Profile' : 'Company Profile',
    filePath: '~/lumovelo/portfolio/corp-profile.png',
    title: 'Apex Corp Global Profile',
    image: imgCompanyProfile,
    tech: ['Astro', 'Bento UI', 'Framer Motion'],
    desc: lang === 'en' 
      ? 'Multinational company profile website featuring an exclusive bento layout style, modern minimal graphics, and interactive elements.' 
      : 'Website profil perusahaan multinasional dengan gaya tata letak bento eksklusif, grafis minimalis modern, dan elemen interaktif.',
    metric: lang === 'en' ? 'Premium Bento Layout' : 'Desain Bento Eksklusif',
    altText: lang === 'en' 
      ? "Apex Corp Global Profile corporate website design & development"
      : "Jasa pembuatan website company profile perusahaan multinasional - Apex Corp",
    spanClass: 'md:col-span-4',
    heightClass: 'h-[380px]',
    waUrl: `https://api.whatsapp.com/send?phone=${waNumber}&text=${encodeURIComponent(
      lang === 'en' 
        ? 'Hello Lumovelo, I am interested in inquiring about the Company Profile service (Apex Corp project) I saw in your portfolio.' 
        : 'Halo Lumovelo, saya tertarik untuk berkonsultasi mengenai jasa pembuatan Company Profile (proyek Apex Corp) yang saya lihat di portofolio.'
    )}`,
    demoUrl: ''
  },
  {
    id: 'ecommerce-buah',
    category: 'toko-online',
    categoryLabel: lang === 'en' ? 'E-Commerce' : 'Toko Online',
    filePath: '~/lumovelo/portfolio/ecommerce-buah.png',
    title: 'FruitFresh Organic Store',
    image: imgBuah,
    tech: ['Next.js', 'React', 'Tailwind CSS'],
    desc: lang === 'en' 
      ? 'A vibrant fruit e-commerce shop with smooth item grid selection, clean cart management, and modern minimalist design.' 
      : 'Toko online e-commerce buah organik segar dengan seleksi grid produk yang mulus, pengelolaan keranjang bersih, dan desain minimalis modern.',
    metric: lang === 'en' ? 'Uptime: 100%' : 'Uptime: 100%',
    altText: lang === 'en' 
      ? "FruitFresh Organic Store custom e-commerce website development"
      : "Jasa pembuatan toko online e-commerce buah organik - FruitFresh",
    spanClass: 'md:col-span-4',
    heightClass: 'h-[380px]',
    waUrl: `https://api.whatsapp.com/send?phone=${waNumber}&text=${encodeURIComponent(
      lang === 'en' 
        ? 'Hello Lumovelo, I am interested in inquiring about the E-Commerce fruit store (FruitFresh project) I saw in your portfolio.' 
        : 'Halo Lumovelo, saya tertarik untuk berkonsultasi mengenai jasa Toko Online buah (proyek FruitFresh) yang saya lihat di portofolio.'
    )}`,
    demoUrl: 'https://ecommercebuah.vercel.app/'
  },
  {
    id: 'redesign',
    category: 'redesign',
    categoryLabel: lang === 'en' ? 'Web Redesign' : 'Redesign Web',
    filePath: '~/lumovelo/portfolio/redesign.png',
    title: 'Lumina Dashboard Redesign',
    image: imgRedesignWeb,
    tech: ['Tailwind CSS', 'Astro', 'React'],
    desc: lang === 'en' 
      ? 'Complete visual overhaul converting a legacy website into a fast, high-performance, and modern responsive dashboard.' 
      : 'Overhaul visual total situs web lama menjadi dasbor responsif modern yang cepat dan dioptimalkan secara penuh.',
    metric: lang === 'en' ? 'Conversion +45%' : 'Laju Konversi +45%',
    altText: lang === 'en' 
      ? "Lumina Dashboard website overhaul and redesign service"
      : "Jasa redesign website dasbor responsif modern - Lumina Dashboard",
    spanClass: 'md:col-span-4',
    heightClass: 'h-[380px]',
    waUrl: `https://api.whatsapp.com/send?phone=${waNumber}&text=${encodeURIComponent(
      lang === 'en' 
        ? 'Hello Lumovelo, I am interested in inquiring about the Web Redesign service (Lumina Dashboard project) I saw in your portfolio.' 
        : 'Halo Lumovelo, saya tertarik untuk berkonsultasi mengenai jasa Redesign Web (proyek Lumina Dashboard) yang saya lihat di portofolio.'
    )}`,
    demoUrl: ''
  },
  {
    id: 'xplored-agency',
    category: 'company-profile',
    categoryLabel: lang === 'en' ? 'Company Profile' : 'Company Profile',
    filePath: '~/lumovelo/portfolio/xplored-agency.png',
    title: 'Xplored UI Agency',
    image: imgXplored,
    tech: ['HTML', 'CSS', 'JavaScript'],
    desc: lang === 'en' 
      ? 'A modern UI/UX design agency website mockup featuring interactive features, clean responsive layout, and beautiful bento grid sections.' 
      : 'Website profil perusahaan agensi desain UI/UX modern dengan fitur interaktif, tata letak responsif bersih, dan bagian bento grid yang indah.',
    metric: lang === 'en' ? 'Interactive UI' : 'UI Interaktif',
    altText: lang === 'en' 
      ? "Xplored UI Agency corporate website design and development"
      : "Jasa pembuatan website company profile agensi desain UI/UX - Xplored",
    spanClass: 'md:col-span-8',
    heightClass: 'h-[380px]',
    waUrl: `https://api.whatsapp.com/send?phone=${waNumber}&text=${encodeURIComponent(
      lang === 'en' 
        ? 'Hello Lumovelo, I am interested in inquiring about the UI Agency Website (Xplored project) I saw in your portfolio.' 
        : 'Halo Lumovelo, saya tertarik untuk berkonsultasi mengenai jasa pembuatan Website Agensi UI (proyek Xplored) yang saya lihat di portofolio.'
    )}`,
    demoUrl: 'https://xplored-zeta.vercel.app/'
  },
  {
    id: 'belanjahub-marketing',
    category: 'company-profile',
    categoryLabel: lang === 'en' ? 'Company Profile' : 'Company Profile',
    filePath: '~/lumovelo/portfolio/belanjahub-marketing.png',
    title: 'BelanjaHub Marketing',
    image: imgBelanjahub,
    tech: ['HTML', 'CSS', 'JavaScript'],
    desc: lang === 'en' 
      ? 'A sleek digital marketing agency landing page featuring service grids, animated stats, and modern illustrations.' 
      : 'Landing page agensi pemasaran digital elegan yang dilengkapi grid layanan, animasi statistik, dan ilustrasi modern.',
    metric: lang === 'en' ? 'SEO Optimized' : 'Teroptimasi SEO',
    altText: lang === 'en' 
      ? "BelanjaHub digital marketing agency landing page and SEO"
      : "Jasa pembuatan website agensi pemasaran digital teroptimasi SEO - BelanjaHub",
    spanClass: 'md:col-span-4',
    heightClass: 'h-[380px]',
    waUrl: `https://api.whatsapp.com/send?phone=${waNumber}&text=${encodeURIComponent(
      lang === 'en' 
        ? 'Hello Lumovelo, I am interested in inquiring about the Digital Marketing Website (BelanjaHub project) I saw in your portfolio.' 
        : 'Halo Lumovelo, saya tertarik untuk berkonsultasi mengenai jasa pembuatan Website Pemasaran Digital (proyek BelanjaHub) yang saya lihat di portofolio.'
    )}`,
    demoUrl: 'https://belanjahub.vercel.app/'
  }
];
---
<section id="portofolio" class="py-12 lg:py-16 bg-white relative overflow-hidden">
  <!-- Grid backdrop -->
  <div class="absolute inset-0 bg-[radial-gradient(rgba(37,99,235,0.02)_1px,transparent_1px)] bg-[size:1.5rem_1.5rem] pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-6 relative z-10 reveal-on-scroll">
    
    <!-- Centered Section Header -->
    <div class="max-w-3xl mx-auto text-center mb-10 lg:mb-14 reveal-on-scroll">
      <h2 class="font-mono font-bold text-xs tracking-widest text-blue-600 uppercase mb-3">{content.sectionHeader}</h2>
      <h3 class="font-display font-black text-4xl sm:text-6xl text-slate-900 tracking-tight leading-[1.0] uppercase">
        {content.title1}<br/>
        <span class="text-stroke-neon">{content.title2}</span>
      </h3>
      <p class="text-slate-600 mt-6 text-sm sm:text-base leading-relaxed font-semibold">
        {content.desc}
      </p>

      <!-- Centered Category Filter Tabs (Mapped exactly to the 6 services) -->
      <div class="mt-8 flex flex-wrap justify-center gap-2.5 select-none font-mono">
        <button type="button" class="portfolio-filter-btn px-4 py-2 border-2 border-slate-900 bg-slate-900 text-[10px] font-bold text-white uppercase tracking-wider rounded-lg transition-all hover:bg-slate-800 shadow-[2px_2px_0px_#000] cursor-pointer" data-filter="all">
          {content.fAll}
        </button>
        <button type="button" class="portfolio-filter-btn px-4 py-2 border-2 border-slate-200 bg-white text-[10px] font-bold text-slate-500 uppercase tracking-wider rounded-lg transition-all hover:border-slate-900 hover:text-slate-900 cursor-pointer" data-filter="landing-page">
          {content.fLanding}
        </button>
        <button type="button" class="portfolio-filter-btn px-4 py-2 border-2 border-slate-200 bg-white text-[10px] font-bold text-slate-500 uppercase tracking-wider rounded-lg transition-all hover:border-slate-900 hover:text-slate-900 cursor-pointer" data-filter="company-profile">
          {content.fProfile}
        </button>
        <button type="button" class="portfolio-filter-btn px-4 py-2 border-2 border-slate-200 bg-white text-[10px] font-bold text-slate-500 uppercase tracking-wider rounded-lg transition-all hover:border-slate-900 hover:text-slate-900 cursor-pointer" data-filter="toko-online">
          {content.fEcom}
        </button>
        <button type="button" class="portfolio-filter-btn px-4 py-2 border-2 border-slate-200 bg-white text-[10px] font-bold text-slate-500 uppercase tracking-wider rounded-lg transition-all hover:border-slate-900 hover:text-slate-900 cursor-pointer" data-filter="redesign">
          {content.fRedesign}
        </button>

      </div>
    </div>

    <!-- OS Window Bento Grid Layout -->
    <div id="portfolio-grid" class="grid grid-cols-1 md:grid-cols-12 gap-6 reveal-on-scroll">
      {projects.map((project) => (
        <div 
          class={`portfolio-card group relative overflow-hidden rounded-2xl border-2 border-slate-900 bg-white shadow-[4px_4px_0px_#000] hover:shadow-[6px_6px_0px_#000] hover:-translate-x-0.5 hover:-translate-y-0.5 transition-all duration-300 flex flex-col cursor-pointer ${project.spanClass} ${project.heightClass}`}
          data-category={project.category}
          data-image={project.image.src}
          data-title={project.title}
          data-desc={project.desc}
          data-tech={project.tech.join(' • ')}
          data-metric={project.metric}
          data-wa-url={project.waUrl}
          data-category-label={project.categoryLabel}
          data-span-class={project.spanClass}
          data-demo-url={project.demoUrl || ''}
        >
          <!-- OS Window Header -->
          <div class="flex items-center justify-between px-4 py-2.5 bg-slate-50 border-b-2 border-slate-900 select-none">
            <div class="flex items-center gap-1.5">
              <span class="w-2.5 h-2.5 rounded-full bg-rose-500 border border-slate-950"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-amber-400 border border-slate-950"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-emerald-500 border border-slate-950"></span>
            </div>
            <span class="text-[9px] font-mono text-slate-500 font-bold tracking-wider">{project.filePath}</span>
            <div class="w-10"></div>
          </div>

          <!-- Image Area / Card Body -->
          <div class="relative flex-1 overflow-hidden min-h-[220px]">
            <Image 
              src={project.image} 
              alt={project.altText}
              class="w-full h-full object-cover object-top group-hover:scale-[1.03] transition-transform duration-700 ease-out"
              loading="lazy"
            />

            <!-- Default visible metadata footer for premium styling -->
            <div class="absolute bottom-0 inset-x-0 bg-gradient-to-t from-slate-950 via-slate-950/80 to-transparent p-4 flex flex-col justify-end text-white select-none">
              <div class="flex justify-between items-end">
                <div>
                  <span class="text-[8px] font-mono font-bold tracking-widest text-blue-400 bg-blue-950/80 border border-blue-800/50 px-2 py-0.5 rounded uppercase mb-1.5 inline-block">{project.categoryLabel}</span>
                  <h4 class="font-display font-black text-lg sm:text-xl tracking-tight uppercase leading-none">{project.title}</h4>
                </div>
                <!-- Interactive visual marker -->
                <span class="text-[9px] font-mono font-bold text-emerald-400 bg-emerald-950/60 border border-emerald-800/40 px-2 py-0.5 rounded uppercase shrink-0 whitespace-nowrap">{project.metric}</span>
              </div>
            </div>

            <!-- Glassmorphism overlay on hover -->
            <div class="absolute inset-0 bg-slate-950/90 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-between p-6 text-white z-20">
              <div>
                <div class="flex justify-between items-center mb-3">
                  <span class="text-[9px] font-mono font-bold tracking-wider text-blue-400 border border-blue-500/40 px-2 py-0.5 rounded bg-blue-950/40 uppercase">{project.categoryLabel}</span>
                  <span class="text-[9px] font-mono font-bold text-emerald-400 border border-emerald-500/40 px-2 py-0.5 rounded bg-emerald-950/40 uppercase">{project.metric}</span>
                </div>
                <h4 class="font-display font-black text-2xl uppercase tracking-tight mb-2 text-white">{project.title}</h4>
                <p class="text-xs text-slate-355 leading-relaxed font-semibold mb-4">{project.desc}</p>
              </div>

              <div class="flex flex-col gap-2.5">
                <!-- Tech stack indicators -->
                <div class="flex flex-wrap gap-1.5 text-[8px] font-mono text-slate-400 font-bold uppercase mb-2">
                  {project.tech.map(tag => (
                    <span class="bg-slate-900 border border-slate-800 px-1.5 py-0.5 rounded">{tag}</span>
                  ))}
                </div>
                               <!-- CTAs -->
                <div class="flex gap-2 w-full">
                  {project.demoUrl ? (
                    <a 
                      href={project.demoUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="flex-1 py-2.5 text-center rounded-lg border border-slate-800 bg-white text-slate-950 font-mono text-[10px] font-bold uppercase tracking-wider hover:bg-slate-100 transition-all cursor-pointer select-none flex items-center justify-center gap-1.5"
                    >
                      Demo Live
                      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                      </svg>
                    </a>
                  ) : (
                    <button 
                      type="button" 
                      class="view-mockup-btn flex-1 py-2.5 text-center rounded-lg border border-slate-800 bg-white text-slate-950 font-mono text-[10px] font-bold uppercase tracking-wider hover:bg-slate-100 transition-all cursor-pointer select-none"
                    >
                      {content.btnView}
                    </button>
                  )}
                  <a 
                    href={project.waUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="px-3.5 py-2.5 flex items-center justify-center rounded-lg bg-emerald-500 hover:bg-emerald-600 border border-transparent text-white transition-all cursor-pointer"
                    aria-label={lang === 'en' ? 'Inquire on WhatsApp' : 'Konsultasi di WhatsApp'}
                  >
                    <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24">
                      <path d="M19.001 4.908A9.817 9.817 0 0 0 11.992 2C6.534 2 2.085 6.448 2.08 11.91c0 1.748.458 3.45 1.321 4.956L2 22l5.255-1.377a9.831 9.831 0 0 0 4.73 1.206h.005c5.46 0 9.908-4.448 9.913-9.91a9.825 9.825 0 0 0-2.892-6.911zm-7.01 15.396h-.004a8.17 8.17 0 0 1-4.167-1.14l-.299-.178-3.1 1.01L5.47 16.92l-.195-.31a8.196 8.196 0 0 1-1.258-4.385C4.02 7.7 7.594 4.12 12.002 4.12a8.18 8.18 0 0 1 5.792 2.399 8.192 8.192 0 0 1 2.396 5.8c-.004 4.527-3.578 8.207-7.98 8.207l-.219-.022zm4.505-6.16c-.247-.124-1.464-.722-1.692-.806-.228-.083-.393-.124-.559.124-.166.248-.641.806-.786.97-.145.166-.29.187-.537.063a6.786 6.786 0 0 1-1.996-1.229 7.487 7.487 0 0 1-1.38-1.716c-.146-.248-.016-.381.109-.504.113-.11.248-.29.373-.435.124-.145.166-.248.249-.414.083-.166.04-.31-.02-.435-.062-.124-.559-1.347-.766-1.848-.201-.484-.406-.418-.559-.425-.145-.007-.31-.007-.476-.007a.918.918 0 0 0-.663.31c-.228.248-.87.85-8.7 2.07 0 1.22.89 2.4 1.162 2.766.27.366 1.753 2.678 4.248 3.754.593.256 1.058.41 1.419.525.597.19 1.14.163 1.57.1.48-.07 1.465-.6 1.67-.18.206-.418.206-.78 0-.965-.125-.187-.249-.247-.497-.37z"/>
                    </svg>
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Centered Pagination Controls -->
    <div id="portfolio-pagination" class="mt-12 flex justify-center items-center gap-2 select-none font-mono">
      <!-- Generated dynamically in script -->
    </div>
  </div>
</section>

<!-- Fullscreen Lightbox Modal -->
<div id="portfolio-lightbox" class="fixed inset-0 z-50 bg-slate-950/95 flex flex-col items-center justify-center p-4 opacity-0 pointer-events-none transition-all duration-300">
  <!-- Close Button -->
  <button 
    type="button" 
    id="lightbox-close" 
    class="absolute top-6 right-6 p-3 rounded-full border-2 border-slate-700 bg-slate-900 text-slate-400 hover:text-white hover:border-white transition-all cursor-pointer shadow-md select-none"
    aria-label="Close"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <line x1="18" y1="6" x2="6" y2="18"/>
      <line x1="6" y1="6" x2="18" y2="18"/>
    </svg>
  </button>

  <!-- Modal Content Card -->
  <div class="w-full max-w-5xl flex flex-col md:flex-row bg-slate-900 rounded-3xl border border-slate-800 overflow-hidden shadow-2xl scale-95 transition-transform duration-300" id="lightbox-card">
    <!-- Image Preview Area -->
    <div class="flex-1 bg-slate-950 p-4 flex items-center justify-center min-h-[250px] md:min-h-[450px] max-h-[50vh] md:max-h-[70vh]">
      <img 
        id="lightbox-image" 
        src="" 
        alt="Pratinjau Portofolio & Mockup Desain Web LUMOVELO" 
        class="max-w-full max-h-[45vh] md:max-h-[65vh] object-contain rounded-xl shadow-lg border border-slate-800/50"
      />
    </div>

    <!-- Metadata Sidebar -->
    <div class="w-full md:w-80 p-6 flex flex-col justify-between border-t md:border-t-0 md:border-l border-slate-800 text-white">
      <div>
        <div class="flex justify-between items-center mb-4">
          <span id="lightbox-tag" class="text-[9px] font-mono font-bold tracking-wider text-blue-400 border border-blue-500/40 px-2 py-0.5 rounded bg-blue-950/40 uppercase"></span>
          <span id="lightbox-metric" class="text-[9px] font-mono font-bold text-emerald-400 border border-emerald-500/40 px-2 py-0.5 rounded bg-emerald-950/40 uppercase"></span>
        </div>
        <h4 id="lightbox-title" class="font-display font-black text-xl md:text-2xl uppercase tracking-tight mb-3"></h4>
        <p id="lightbox-desc" class="text-xs text-slate-350 leading-relaxed font-semibold mb-6"></p>
        
        <div class="mb-6">
          <div class="text-[8px] font-mono text-slate-400 font-bold uppercase tracking-wider mb-2">{content.techHeader}</div>
          <div id="lightbox-tech" class="flex flex-wrap gap-1.5 text-[8px] font-mono text-slate-400 font-bold uppercase">
          </div>
        </div>
      </div>

      <div class="flex flex-col gap-2.5">
        <!-- Live Demo Button -->
        <a 
          id="lightbox-demo-btn" 
          href="" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="w-full inline-flex items-center justify-center py-3.5 rounded-2xl bg-white hover:bg-slate-100 text-slate-950 font-black text-xs uppercase tracking-wider transition-all duration-300 gap-2 border border-slate-800 shadow-md hidden"
        >
          Kunjungi Website
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>

        <!-- Primary Action -->
        <a 
          id="lightbox-wa-btn" 
          href="" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="w-full inline-flex items-center justify-center py-3.5 rounded-2xl bg-emerald-500 hover:bg-emerald-600 text-white font-black text-xs uppercase tracking-wider transition-all duration-300 gap-2 border border-transparent shadow-[0_4px_12px_rgba(16,185,129,0.2)]"
        >
          <!-- WhatsApp Icon -->
          <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24">
            <path d="M19.001 4.908A9.817 9.817 0 0 0 11.992 2C6.534 2 2.085 6.448 2.08 11.91c0 1.748.458 3.45 1.321 4.956L2 22l5.255-1.377a9.831 9.831 0 0 0 4.73 1.206h.005c5.46 0 9.908-4.448 9.913-9.91a9.825 9.825 0 0 0-2.892-6.911zm-7.01 15.396h-.004a8.17 8.17 0 0 1-4.167-1.14l-.299-.178-3.1 1.01L5.47 16.92l-.195-.31a8.196 8.196 0 0 1-1.258-4.385C4.02 7.7 7.594 4.12 12.002 4.12a8.18 8.18 0 0 1 5.792 2.399 8.192 8.192 0 0 1 2.396 5.8c-.004 4.527-3.578 8.207-7.98 8.207l-.219-.022zm4.505-6.16c-.247-.124-1.464-.722-1.692-.806-.228-.083-.393-.124-.559.124-.166.248-.641.806-.786.97-.145.166-.29.187-.537.063a6.786 6.786 0 0 1-1.996-1.229 7.487 7.487 0 0 1-1.38-1.716c-.146-.248-.016-.381.109-.504.113-.11.248-.29.373-.435.124-.145.166-.248.249-.414.083-.166.04-.31-.02-.435-.062-.124-.559-1.347-.766-1.848-.201-.484-.406-.418-.559-.425-.145-.007-.31-.007-.476-.007a.918.918 0 0 0-.663.31c-.228.248-.87.85-8.7 2.07 0 1.22.89 2.4 1.162 2.766.27.366 1.753 2.678 4.248 3.754.593.256 1.058.41 1.419.525.597.19 1.14.163 1.57.1.48-.07 1.465-.6 1.67-.18.206-.418.206-.78 0-.965-.125-.187-.249-.247-.497-.37z"/>
          </svg>
          {content.btnWa}
        </a>
      </div>
    </div>
  </div>
</div>

<script>
  function initInteractivePortfolio() {
    // State variables
    const ITEMS_PER_PAGE = 4;
    let currentPage = 1;
    let activeFilter = 'all';

    // 1. FILTERING & PAGINATION SYSTEM
    const filterButtons = document.querySelectorAll('.portfolio-filter-btn');
    const portfolioCards = document.querySelectorAll('.portfolio-card') as NodeListOf<HTMLDivElement>;
    const gridContainer = document.getElementById('portfolio-grid');
    const paginationContainer = document.getElementById('portfolio-pagination');

    function updatePagination() {
      if (!gridContainer || !paginationContainer) return;

      // Toggle grid container layout based on current filter state
      if (activeFilter === 'all') {
        gridContainer.classList.add('md:grid-cols-12');
        gridContainer.classList.remove('md:grid-cols-2', 'lg:grid-cols-3');
      } else {
        gridContainer.classList.remove('md:grid-cols-12');
        gridContainer.classList.add('md:grid-cols-2', 'lg:grid-cols-3');
      }

      // 1. Build list of candidates matching the active filter
      const candidates: HTMLDivElement[] = [];
      portfolioCards.forEach(card => {
        const category = card.getAttribute('data-category');
        if (activeFilter === 'all' || category === activeFilter) {
          candidates.push(card);
        } else {
          // Hide cards not belonging to the current filter
          card.classList.add('hidden');
          card.style.opacity = '0';
          card.style.transform = 'scale(0.95)';
        }
      });

      // 2. Calculate pagination metrics
      const totalItems = candidates.length;
      const totalPages = Math.ceil(totalItems / ITEMS_PER_PAGE);

      // Boundaries correction
      if (currentPage > totalPages) currentPage = totalPages;
      if (currentPage < 1) currentPage = 1;

      // 3. Show/hide items matching page range & toggle span styles
      candidates.forEach((card, index) => {
        const startIndex = (currentPage - 1) * ITEMS_PER_PAGE;
        const endIndex = currentPage * ITEMS_PER_PAGE - 1;
        const spanClass = card.getAttribute('data-span-class') || '';

        if (index >= startIndex && index <= endIndex) {
          // Display
          card.classList.remove('hidden');
          
          // Adjust span classes
          if (activeFilter === 'all') {
            if (spanClass) {
              spanClass.split(' ').forEach(cls => {
                if (cls) card.classList.add(cls);
              });
            }
          } else {
            if (spanClass) {
              spanClass.split(' ').forEach(cls => {
                if (cls) card.classList.remove(cls);
              });
            }
          }

          setTimeout(() => {
            card.style.opacity = '1';
            card.style.transform = 'scale(1)';
          }, 50);
        } else {
          // Hide items belonging to other pages
          card.classList.add('hidden');
          card.style.opacity = '0';
          card.style.transform = 'scale(0.95)';
        }
      });

      // 4. Render pagination controls
      paginationContainer.innerHTML = '';
      if (totalPages <= 1) {
        paginationContainer.classList.add('hidden');
        return;
      }
      paginationContainer.classList.remove('hidden');

      // Helper to generate a button
      const createBtn = (label: string, pageTarget: number, disabled = false, active = false) => {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.innerText = label;

        if (disabled) {
          btn.className = "px-3.5 py-1.5 border-2 border-slate-100 bg-slate-50 text-slate-300 rounded-lg font-bold text-xs cursor-not-allowed";
          btn.disabled = true;
        } else if (active) {
          btn.className = "px-3.5 py-1.5 border-2 border-slate-900 bg-slate-900 text-white rounded-lg font-bold shadow-[2px_2px_0px_#000] text-xs cursor-pointer";
        } else {
          btn.className = "px-3.5 py-1.5 border-2 border-slate-200 bg-white text-slate-500 rounded-lg hover:border-slate-900 hover:text-slate-900 transition-all font-bold text-xs cursor-pointer";
          btn.addEventListener('click', () => {
            currentPage = pageTarget;
            updatePagination();
            // Scroll smoothly back to section top
            const section = document.getElementById('portofolio');
            if (section) {
              section.scrollIntoView({ behavior: 'smooth' });
            }
          });
        }

        return btn;
      };

      // Add Prev button
      paginationContainer.appendChild(createBtn('[ < ]', currentPage - 1, currentPage === 1));

      // Add Page Number buttons
      for (let i = 1; i <= totalPages; i++) {
        paginationContainer.appendChild(createBtn(String(i), i, false, i === currentPage));
      }

      // Add Next button
      paginationContainer.appendChild(createBtn('[ > ]', currentPage + 1, currentPage === totalPages));
    }

    // Attach click events on filter buttons
    filterButtons.forEach(btn => {
      btn.addEventListener('click', (e) => {
        const clickedBtn = e.currentTarget as HTMLButtonElement;
        const filter = clickedBtn.getAttribute('data-filter');
        if (!filter) return;

        // Toggle active filter tab UI styling
        filterButtons.forEach(b => {
          b.className = "portfolio-filter-btn px-4 py-2 border-2 border-slate-200 bg-white text-[10px] font-bold text-slate-500 uppercase tracking-wider rounded-lg transition-all hover:border-slate-900 hover:text-slate-900 cursor-pointer";
        });
        clickedBtn.className = "portfolio-filter-btn px-4 py-2 border-2 border-slate-900 bg-slate-900 text-[10px] font-bold text-white uppercase tracking-wider rounded-lg transition-all hover:bg-slate-800 shadow-[2px_2px_0px_#000] cursor-pointer";

        // Reset to page 1 on filter switch
        activeFilter = filter;
        currentPage = 1;
        updatePagination();
      });
    });

    // Initialize pagination load state
    updatePagination();

    // 2. LIGHTBOX MODAL CONTROLS
    const lightbox = document.getElementById('portfolio-lightbox');
    const lightboxCard = document.getElementById('lightbox-card');
    const lightboxClose = document.getElementById('lightbox-close');
    const lightboxImage = document.getElementById('lightbox-image') as HTMLImageElement;
    const lightboxTag = document.getElementById('lightbox-tag');
    const lightboxMetric = document.getElementById('lightbox-metric');
    const lightboxTitle = document.getElementById('lightbox-title');
    const lightboxDesc = document.getElementById('lightbox-desc');
    const lightboxTech = document.getElementById('lightbox-tech');
    const lightboxWaBtn = document.getElementById('lightbox-wa-btn') as HTMLAnchorElement;
    const lightboxDemoBtn = document.getElementById('lightbox-demo-btn') as HTMLAnchorElement;

    function openLightbox(card: HTMLDivElement) {
      if (!lightbox || !lightboxCard || !lightboxImage || !lightboxTag || !lightboxMetric || !lightboxTitle || !lightboxDesc || !lightboxTech || !lightboxWaBtn) return;

      const image = card.getAttribute('data-image') || '';
      const title = card.getAttribute('data-title') || '';
      const desc = card.getAttribute('data-desc') || '';
      const tag = card.getAttribute('data-category-label') || '';
      const metric = card.getAttribute('data-metric') || '';
      const techStr = card.getAttribute('data-tech') || '';
      const waUrl = card.getAttribute('data-wa-url') || '';
      const demoUrl = card.getAttribute('data-demo-url') || '';

      // Set lightbox data
      lightboxImage.src = image;
      lightboxImage.alt = title;
      lightboxTitle.innerText = title;
      lightboxDesc.innerText = desc;
      lightboxTag.innerText = tag;
      lightboxMetric.innerText = metric;
      lightboxWaBtn.href = waUrl;

      // Handle demo button visibility
      if (lightboxDemoBtn) {
        if (demoUrl) {
          lightboxDemoBtn.href = demoUrl;
          lightboxDemoBtn.classList.remove('hidden');
        } else {
          lightboxDemoBtn.classList.add('hidden');
        }
      }

      // Set tech list tags
      lightboxTech.innerHTML = '';
      if (techStr) {
        techStr.split(' • ').forEach(t => {
          const span = document.createElement('span');
          span.className = 'bg-slate-800 border border-slate-700 px-2 py-0.5 rounded';
          span.innerText = t;
          lightboxTech.appendChild(span);
        });
      }

      // Show lightbox modal
      lightbox.classList.remove('opacity-0', 'pointer-events-none');
      setTimeout(() => {
        lightboxCard.classList.remove('scale-95');
        lightboxCard.classList.add('scale-100');
      }, 50);

      // Disable page body scroll
      document.body.style.overflow = 'hidden';
    }

    function closeLightbox() {
      if (!lightbox || !lightboxCard) return;

      lightboxCard.classList.remove('scale-100');
      lightboxCard.classList.add('scale-95');
      
      lightbox.classList.add('opacity-0', 'pointer-events-none');

      // Enable page body scroll
      document.body.style.overflow = '';
    }

    // Attach click events on portfolio cards
    portfolioCards.forEach(card => {
      // Clicking the card itself (except clicking the direct whatsapp icon inside the hover overlay)
      card.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        // Don't open lightbox if clicking the actual WhatsApp redirect anchor inside hover overlay
        if (target.closest('a[target="_blank"]')) return;
        
        openLightbox(card);
      });
    });

    // Close lightbox events
    if (lightboxClose) {
      lightboxClose.addEventListener('click', closeLightbox);
    }

    if (lightbox) {
      lightbox.addEventListener('click', (e) => {
        // Close if clicking outside the card content
        if (e.target === lightbox) {
          closeLightbox();
        }
      });
    }

    // Close on Escape key
    window.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        closeLightbox();
      }
    });
  }

  // Load hooks
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initInteractivePortfolio);
  } else {
    initInteractivePortfolio();
  }
</script>
