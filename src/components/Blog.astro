---
const lang = Astro.currentLocale === 'en' ? 'en' : 'id';

const content = {
  id: {
    sectionHeader: "/ Wawasan & Edukasi",
    title1: "Wacana Teknologi.",
    title2: "Edukasi Tanpa Omong Kosong.",
    desc: "Kami menulis artikel teknis terarah untuk membagi wawasan optimasi web performa tinggi, automasi AI otonom, dan taktik SEO yang bekerja nyata.",
    readMore: "/ BACA SELENGKAPNYA",
    posts: [
      {
        slug: 'otomatisasi-leads-ai-whatsapp',
        title: 'Cara Praktis Menggunakan AI Chatbot untuk Menjawab Pelanggan WhatsApp 24/7',
        date: '05 JULI 2026',
        category: 'AI & OTOMATISASI',
        bgCategory: 'bg-indigo-105 text-indigo-700 border-indigo-200',
        description: 'Menghemat waktu operasional customer service dengan integrasi agen AI pintar pada chat WhatsApp bisnis Anda secara otonom.'
      },
      {
        slug: 'keunggulan-website-headless-modern',
        title: 'Mengapa Website Headless Serverless Jauh Lebih Cepat dan Aman Dibanding WordPress Tradisional',
        date: '02 JULI 2026',
        category: 'IT & WEB DEVELOP',
        bgCategory: 'bg-teal-100 text-teal-700 border-teal-200',
        description: 'Mengenal arsitektur website modern tanpa database tradisional untuk kecepatan loading maksimal di bawah 1 detik dan bebas retasan.'
      },
      {
        slug: 'strategi-technical-seo-lokal',
        title: 'Panduan Memulai Technical SEO untuk Meningkatkan Peringkat Bisnis Anda di Google Search',
        date: '28 JUNI 2026',
        category: 'SEO & MARKETING',
        bgCategory: 'bg-blue-100 text-blue-650 border-blue-200',
        description: 'Langkah-langkah praktis mengoptimasi struktur website, sitemap, dan meta tag agar bisnis Anda mudah ditemukan pelanggan di Google.'
      },
      {
        slug: 'peran-video-creative-landing-page',
        title: 'Cara Video Creative Menarik Perhatian Pengunjung dan Menaikkan Konversi Penjualan Hingga 40%',
        date: '25 JUNI 2026',
        category: 'VIDEO & CREATIVE',
        bgCategory: 'bg-purple-100 text-purple-700 border-purple-200',
        description: 'Mengapa menyertakan konten video pendek berkualitas sangat berdampak pada penurunan bounce rate website produk dan meyakinkan calon pelanggan.'
      }
    ]
  },
  en: {
    sectionHeader: "/ Insights & Education",
    title1: "Tech Discourses.",
    title2: "No BS Education.",
    desc: "We write technical articles to share insights on high-performance web optimization, autonomous AI automation, and SEO tactics that actually work.",
    readMore: "/ READ MORE",
    posts: [
      {
        slug: 'otomatisasi-leads-ai-whatsapp',
        title: 'How to Use AI Chatbots to Automatically Answer WhatsApp Customers 24/7',
        date: '05 JULY 2026',
        category: 'AI & AUTOMATION',
        bgCategory: 'bg-indigo-100 text-indigo-750 border-indigo-200',
        description: 'Save customer service operational time with smart autonomous AI agent integration on your business WhatsApp chat.'
      },
      {
        slug: 'keunggulan-website-headless-modern',
        title: 'Why Headless Serverless Websites Are Blazing Fast and Highly Secure Compared to WordPress',
        date: '02 JULY 2026',
        category: 'IT & WEB DEV',
        bgCategory: 'bg-teal-100 text-teal-700 border-teal-200',
        description: 'Understand modern database-free website architectures for maximum loading speed under 1 second and high resistance to hacking.'
      },
      {
        slug: 'strategi-technical-seo-lokal',
        title: 'Beginner\'s Guide to Technical SEO: Boosting Your Business Ranking on Google Search',
        date: '28 JUNE 2026',
        category: 'SEO & MARKETING',
        bgCategory: 'bg-blue-100 text-blue-650 border-blue-200',
        description: 'Practical steps to optimize website structure, sitemap, and meta tags so your business is easily discovered by customers on Google.'
      },
      {
        slug: 'peran-video-creative-landing-page',
        title: 'How Creative Video Assets Hook Visitors and Increase Sales Conversion by Up to 40%',
        date: '25 JUNE 2026',
        category: 'VIDEO & CREATIVE',
        bgCategory: 'bg-purple-100 text-purple-700 border-purple-200',
        description: 'Why high-quality short video assets dramatically decrease bounce rates and convince potential customers on your landing page.'
      }
    ]
  }
}[lang];

const posts = content.posts;
---
<section id="blog" class="py-24 bg-white relative overflow-hidden border-t-2 border-slate-100">
  <div class="absolute inset-0 bg-[radial-gradient(rgba(37,99,235,0.015)_1px,transparent_1px)] bg-[size:1.5rem_1.5rem] pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-6 relative z-10">
    
    <!-- Section Header -->
    <div class="max-w-3xl mb-20 reveal-on-scroll mx-auto text-center">
      <h2 class="font-mono font-bold text-xs tracking-widest text-blue-600 uppercase">{content.sectionHeader}</h2>
      <h3 class="font-display font-black text-4xl sm:text-5xl text-slate-900 uppercase tracking-tight leading-[1.0] mt-3">
        {content.title1}<br/>
        <span class="text-stroke-neon">{content.title2}</span>
      </h3>
      <p class="text-slate-500 mt-6 text-sm sm:text-base leading-relaxed font-semibold max-w-xl mx-auto">
        {content.desc}
      </p>
    </div>

    <!-- Blog Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto">
      {posts.map((post) => (
        <article class="p-8 bg-white border-2 border-slate-900 rounded-3xl shadow-[5px_5px_0px_#0f172a] hover:shadow-[2px_2px_0px_#0f172a] hover:translate-x-0.5 hover:translate-y-0.5 transition-all flex flex-col justify-between h-full reveal-on-scroll">
          <div class="space-y-4">
            <div class="flex items-center justify-between text-[10px] font-mono font-bold text-slate-400">
              <span>{post.date}</span>
              <span class={`px-2.5 py-0.5 rounded-full border text-[9px] uppercase tracking-wider ${post.bgCategory}`}>{post.category}</span>
            </div>
            <h4 class="font-display font-black text-xl text-slate-900 uppercase hover:text-blue-600 transition-colors leading-tight">
              <a href={`/blog/${post.slug}/`}>{post.title}</a>
            </h4>
            <p class="text-xs text-slate-500 font-semibold leading-relaxed">
              {post.description}
            </p>
          </div>
          <div class="border-t border-slate-100 pt-5 mt-6">
            <a href={`/blog/${post.slug}/`} class="text-[10px] font-mono font-bold text-blue-600 hover:text-blue-800 flex items-center gap-1.5 uppercase tracking-wider">
              {content.readMore} 
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
