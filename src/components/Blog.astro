const posts = content.posts;
---
<section id="blog" class="py-24 bg-white relative overflow-hidden border-t-2 border-slate-200">
  <div class="absolute inset-0 bg-[radial-gradient(rgba(37,99,235,0.015)_1px,transparent_1px)] bg-[size:1.5rem_1.5rem] pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-6 relative z-10">
    
    <!-- Section Header -->
    <div class="max-w-2xl mb-20 reveal-on-scroll">
      <h2 class="font-mono font-bold text-xs tracking-widest text-blue-600 uppercase">{content.sectionHeader}</h2>
      <h3 class="font-display font-black text-4xl sm:text-5xl text-slate-900 uppercase tracking-tight leading-[1.0] mt-3">
        {content.title1}<br/>
        <span class="text-stroke-neon">{content.title2}</span>
      </h3>
      <p class="text-slate-500 mt-6 text-sm sm:text-base leading-relaxed font-semibold">
        {content.desc}
      </p>
    </div>

    <!-- Blog Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {posts.map((post) => (
        <article class="p-6 bg-slate-50 border-2 border-blue-600 rounded-2xl shadow-[4px_4px_0px_#2563eb] hover:shadow-[6px_6px_0px_#1d4ed8] hover:-translate-y-0.5 transition-all flex flex-col justify-between h-full reveal-on-scroll">
          <div class="space-y-4">
            <div class="flex items-center justify-between text-[9px] font-mono font-bold text-slate-400">
              <span>{post.date}</span>
              <span class={`px-2 py-0.5 rounded border uppercase ${post.bgCategory}`}>{post.category}</span>
            </div>
            <h4 class="font-display font-black text-lg text-slate-900 uppercase hover:text-blue-600 transition-colors">
              <a href={`/blog/${post.slug}/`}>{post.title}</a>
            </h4>
            <p class="text-[11px] text-slate-600 leading-relaxed">
              {post.description}
            </p>
          </div>
          <div class="border-t border-slate-200 pt-4 mt-6">
            <a href={`/blog/${post.slug}/`} class="text-[10px] font-mono font-bold text-blue-600 hover:text-blue-800 flex items-center gap-1.5 uppercase">
              {content.readMore} 
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
