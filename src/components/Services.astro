          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  @keyframes scroll-track {
    0% {
      transform: translate3d(0, 0, 0);
    }
    100% {
      transform: translate3d(-50%, 0, 0);
    }
  }
</style>

<script>
  function initMovingGrid() {
    const cards = document.querySelectorAll('.tilt-card');
    if (cards.length > 0) {
      cards.forEach((card: any) => {
        card.addEventListener('mousemove', (e: MouseEvent) => {
          const rect = card.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          card.style.setProperty('--x', `${x}px`);
          card.style.setProperty('--y', `${y}px`);

          const width = rect.width;
          const height = rect.height;
          const rotateX = -((e.clientY - rect.top - height / 2) / height) * 8;
          const rotateY = ((e.clientX - rect.left - width / 2) / width) * 8;

          card.style.transform = `rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale(1.02)`;
          card.style.borderColor = '#2563eb';
          card.style.boxShadow = `4px 4px 0px #2563eb`;
        });

        card.addEventListener('mouseleave', () => {
          card.style.transform = 'rotateX(0deg) rotateY(0deg) scale(1)';
          card.style.borderColor = '#2563eb';
          card.style.boxShadow = `4px 4px 0px #2563eb`;
        });
      });
    }

    // Blueprint hover micro-simulations
    const blueprintCards = document.querySelectorAll('.blueprint-card');
    blueprintCards.forEach((card: any, idx) => {
      card.addEventListener('mouseenter', () => {
        card.style.transform = 'translateY(-6px)';
        card.style.boxShadow = '6px 6px 0px #2563eb';

        if (idx === 0) {
          const statusText = card.querySelector('.audit-state-text');
          const statusHeader = card.querySelector('.blueprint-status');
          if (statusText) {
            statusText.innerText = 'OPTIMIZING...';
            statusText.className = 'text-blue-600 font-bold uppercase audit-state-text';
          }
          if (statusHeader) {
            statusHeader.innerText = 'TUNING SPEED...';
            statusHeader.className = 'text-blue-600 font-bold uppercase font-mono tracking-wider blueprint-status';
          }
          const circle = card.querySelector('.progress-circle') as HTMLDivElement;
          if (circle) {
            circle.style.borderColor = '#2563eb';
            circle.style.color = '#2563eb';
            let count = 99;
            const timer = setInterval(() => {
              count = (count === 99) ? 100 : 99;
              circle.innerText = count.toString();
            }, 300);
            card._timer = timer;
          }
        } else if (idx === 1) {
          const statusText = card.querySelector('.pipeline-status-text');
          const statusHeader = card.querySelector('.blueprint-status');
          if (statusText) {
            statusText.innerText = 'TRANSMITTING';
            statusText.className = 'text-blue-500 font-bold uppercase pipeline-status-text animate-pulse';
          }
          if (statusHeader) {
            statusHeader.innerText = 'DATA_SYNC';
            statusHeader.className = 'text-blue-500 font-bold uppercase font-mono tracking-wider blueprint-status';
          }
          const steps = card.querySelectorAll('.flow-steps span:last-child');
          if (steps.length === 3) {
            let activeIdx = 0;
            const flash = setInterval(() => {
              steps.forEach((step: any, sIdx) => {
                if (sIdx === activeIdx) {
                  step.innerText = '● SEND';
                  step.className = 'text-blue-600 font-bold animate-ping';
                } else {
                  step.innerText = '✓ SUCCESS';
                  step.className = 'text-teal-600 font-bold';
                }
              });
              activeIdx = (activeIdx + 1) % 3;
            }, 400);
            card._flash = flash;
          }
        } else if (idx === 2) {
          const statusText = card.querySelector('.firewall-status-text');
          const statusHeader = card.querySelector('.blueprint-status');
          if (statusText) {
            statusText.innerText = 'BEST RATE';
            statusText.className = 'text-blue-600 font-bold uppercase firewall-status-text animate-pulse';
          }
          if (statusHeader) {
            statusHeader.innerText = 'FAIR BUDGET';
            statusHeader.className = 'text-blue-600 font-bold uppercase font-mono tracking-wider blueprint-status';
          }
          const filter = card.querySelector('.firewall-status') as HTMLDivElement;
          if (filter) {
            filter.className = 'p-2.5 bg-blue-50 border border-blue-200 rounded flex justify-between items-center firewall-status';
            const text = filter.querySelector('.label-text') as HTMLSpanElement;
            const badge = filter.querySelector('.badge-text') as HTMLSpanElement;
            if (text) text.innerText = 'PROFESSIONAL_WORK';
            if (badge) {
              badge.innerText = 'GUARANTEED 100%';
              badge.className = 'px-2 py-0.5 rounded text-[8px] bg-blue-600 text-white font-bold badge-text';
            }
          }
        }
      });

      card.addEventListener('mouseleave', () => {
        card.style.transform = 'translateY(0px)';
        card.style.boxShadow = '4px 4px 0px #2563eb';

        if (idx === 0) {
          if (card._timer) clearInterval(card._timer);
          const statusText = card.querySelector('.audit-state-text');
          const statusHeader = card.querySelector('.blueprint-status');
          if (statusText) {
            statusText.innerText = 'OPTIMIZED';
            statusText.className = 'text-teal-600 font-bold uppercase audit-state-text';
          }
          if (statusHeader) {
            statusHeader.innerText = 'PERFORMA MAKSIMAL';
            statusHeader.className = 'text-teal-600 font-bold uppercase font-mono tracking-wider blueprint-status';
          }
          const circle = card.querySelector('.progress-circle') as HTMLDivElement;
          if (circle) {
            circle.style.borderColor = '#0d9488';
            circle.style.color = '#0d9488';
            circle.innerText = '99';
          }
        } else if (idx === 1) {
          if (card._flash) clearInterval(card._flash);
          const statusText = card.querySelector('.pipeline-status-text');
          const statusHeader = card.querySelector('.blueprint-status');
          if (statusText) {
            statusText.innerText = 'CONNECTED';
            statusText.className = 'text-teal-600 font-bold uppercase pipeline-status-text';
          }
          if (statusHeader) {
            statusHeader.innerText = 'SIAP JUALAN 24/7';
            statusHeader.className = 'text-blue-500 font-bold uppercase font-mono tracking-wider blueprint-status';
          }
          const steps = card.querySelectorAll('.flow-steps span:last-child');
          steps.forEach((step: any) => {
            step.innerText = '✓ SUCCESS';
            step.className = 'text-teal-600 font-bold';
          });
        } else if (idx === 2) {
          const statusText = card.querySelector('.firewall-status-text');
          const statusHeader = card.querySelector('.blueprint-status');
          if (statusText) {
            statusText.innerText = 'TRANSPARENT';
            statusText.className = 'text-teal-600 font-bold uppercase firewall-status-text';
          }
          if (statusHeader) {
            statusHeader.innerText = 'HARGA BERSAHABAT';
            statusHeader.className = 'text-teal-600 font-bold uppercase font-mono tracking-wider blueprint-status';
          }
          const filter = card.querySelector('.firewall-status') as HTMLDivElement;
          if (filter) {
            filter.className = 'p-2.5 bg-white border border-slate-200 rounded flex justify-between items-center firewall-status border-teal-200 bg-teal-50/20';
            const text = filter.querySelector('.label-text') as HTMLSpanElement;
            const badge = filter.querySelector('.badge-text') as HTMLSpanElement;
            if (text) text.innerText = 'FAIR PRICING GUARANTEE';
            if (badge) {
              badge.innerText = 'GUARANTEED ✔';
              badge.className = 'px-2 py-0.5 rounded text-[8px] bg-teal-600 text-white font-bold badge-text';
            }
          }
        }
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMovingGrid);
  } else {
    initMovingGrid();
  }
</script>
