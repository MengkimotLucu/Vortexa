---

<section id={lang === 'en' ? 'services' : 'layanan'} class="py-12 lg:py-16 bg-white relative overflow-hidden">
  <!-- Subtle decorative light gradients -->
  <div class="absolute right-[-10%] top-[20%] w-[600px] h-[600px] bg-blue-600/[0.08] rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute left-[-10%] bottom-[10%] w-[600px] h-[600px] bg-cyan-500/[0.07] rounded-full blur-3xl pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-6 relative z-10">
    
    <!-- Section Header -->
    <div class="max-w-4xl mx-auto text-center mb-16 reveal-on-scroll">
      <h2 class="font-mono font-bold text-xs tracking-widest text-blue-600 uppercase mb-3">{content.sectionHeader}</h2>
      <h3 class="font-display font-black text-3xl sm:text-5xl text-slate-900 tracking-tight leading-[1.15] uppercase font-sans">
        {content.title1} <span class="text-blue-600">{content.title2}</span>
      </h3>
      <p class="text-slate-500 mt-4 text-sm sm:text-base leading-relaxed font-semibold max-w-2xl mx-auto">
        {content.desc}
      </p>
    </div>

    <!-- Category Selector Tabs (Screenshot 1 navigation style) -->
    <div class="mb-10 overflow-x-auto scrollbar-none border-b border-slate-100 flex lg:justify-center gap-2 pb-1 reveal-on-scroll">
      {categories.map((cat, idx) => (
        <button
          data-category-id={cat.id}
          class={`pricing-tab-btn px-5 py-3 text-xs font-extrabold tracking-wider uppercase whitespace-nowrap rounded-t-xl transition-all duration-200 cursor-pointer border-b-2 ${
            idx === 0 
              ? 'border-blue-600 text-blue-600 bg-blue-50/10' 
              : 'border-transparent text-slate-400 hover:text-slate-700'
          }`}
        >
          {cat.label}
        </button>
      ))}
    </div>

    <!-- Tab Panels Container -->
    <div class="reveal-on-scroll">
      {categories.map((cat, idx) => (
        <div 
          id={`panel-${cat.id}`} 
          class={`pricing-panel ${idx === 0 ? '' : 'hidden'}`}
        >
          <!-- Grid wrapper that morphs into a swipeable carousel on mobile -->
          <div class="flex md:grid overflow-x-auto md:overflow-x-visible gap-[2rem] pb-6 md:pb-0 snap-x snap-mandatory scrollbar-none w-full" style="grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));">
            {packages[cat.id].map((pkg) => {
              const waText = encodeURIComponent(
                `Halo Tim Lumovelo, saya tertarik untuk berkonsultasi mengenai paket "${pkg.title}" (${pkg.price}) yang tertera di website.`
              );
              const waUrl = `${waBaseUrl}${waText}`;
              
              return (
                <div 
                  class={`pricing-card w-[85vw] sm:w-[320px] md:w-auto shrink-0 snap-center p-6 flex flex-col justify-between min-h-[460px] transition-all duration-300 relative border ${
                    pkg.popular 
                      ? 'bestseller-glow shadow-lg shadow-blue-500/[0.02] border-transparent' 
                      : 'border-slate-200/80 bg-white shadow-sm hover:border-slate-300 hover:shadow-md'
                  }`}
                >
                  <!-- Best seller tag -->
                  {pkg.popular && (
                    <div class="absolute top-0 right-6 -translate-y-1/2 px-3 py-1 rounded-full bg-rose-500 text-[8px] font-mono font-black text-white uppercase tracking-widest shadow-sm">
                      {content.bestSeller}
                    </div>
                  )}

                  <div>
                    <div class="flex justify-between items-start mb-6">
                      <span class="text-[9px] font-mono text-slate-400 bg-slate-50 border border-slate-200/50 px-2.5 py-1 rounded-lg font-black uppercase tracking-wider">{pkg.tier}</span>
                    </div>
                    
                    <h4 class="font-display font-black text-lg text-slate-900 leading-snug">{pkg.title}</h4>
                    <div class="my-4 pb-4 border-b border-slate-100">
                      <div class="text-[10px] font-mono text-slate-400 font-bold uppercase tracking-widest">Mulai Dari</div>
                      <div class="text-3xl font-display font-black text-blue-600 mt-1">{pkg.price}</div>
                    </div>

                    <ul class="space-y-3.5 text-xs text-slate-600 font-semibold mb-6">
                      {pkg.features.map((feature) => (
                        <li class="flex items-start gap-2.5 leading-relaxed">
                          <div class="w-4 h-4 rounded-full bg-blue-50 flex items-center justify-center shrink-0 mt-0.5">
                            <svg class="w-2.5 h-2.5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3.5">
                              <polyline points="20 6 9 17 4 12"/>
                            </svg>
                          </div>
                          <span set:html={feature}></span>
                        </li>
                      ))}
                    </ul>
                  </div>

                  <div class="flex flex-col gap-2.5 mt-auto w-full">
                    {cat.id === 'product-catalog' && (
                      <a 
                        href={pkg.themeUrl || '#'}
                        class="w-full inline-flex items-center justify-center py-3 rounded-2xl font-bold text-xs uppercase tracking-wider transition-all duration-300 gap-2 border border-slate-200/80 hover:border-slate-350 hover:bg-slate-50 text-slate-700 shadow-sm cursor-pointer"
                      >
                        👁️ {lang === 'en' ? 'View Themes' : 'Lihat Tema'}
                      </a>
                    )}
                    <a 
                      href={waUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      class={`w-full inline-flex items-center justify-center py-3.5 rounded-2xl font-black text-xs uppercase tracking-wider transition-all duration-300 gap-2 cursor-pointer border ${
                        pkg.popular 
                          ? 'bg-emerald-500 hover:bg-emerald-600 text-white border-transparent shadow-[0_4px_12px_rgba(16,185,129,0.25)] hover:shadow-[0_4px_12px_rgba(16,185,129,0.4)] hover:-translate-y-0.5' 
                          : 'bg-white hover:bg-slate-50 text-slate-700 border-slate-200/80 hover:border-slate-300 shadow-sm'
                      }`}
                    >
                      <!-- WhatsApp Icon -->
                      <svg class="w-4 h-4 shrink-0 fill-current" viewBox="0 0 24 24">
                        <path d="M19.001 4.908A9.817 9.817 0 0 0 11.992 2C6.534 2 2.085 6.448 2.08 11.91c0 1.748.458 3.45 1.321 4.956L2 22l5.255-1.377a9.831 9.831 0 0 0 4.73 1.206h.005c5.46 0 9.908-4.448 9.913-9.91a9.825 9.825 0 0 0-2.892-6.911zm-7.01 15.396h-.004a8.17 8.17 0 0 1-4.167-1.14l-.299-.178-3.1 1.01L5.47 16.92l-.195-.31a8.196 8.196 0 0 1-1.258-4.385C4.02 7.7 7.594 4.12 12.002 4.12a8.18 8.18 0 0 1 5.792 2.399 8.192 8.192 0 0 1 2.396 5.8c-.004 4.527-3.578 8.207-7.98 8.207l-.219-.022zm4.505-6.16c-.247-.124-1.464-.722-1.692-.806-.228-.083-.393-.124-.559.124-.166.248-.641.806-.786.97-.145.166-.29.187-.537.063a6.786 6.786 0 0 1-1.996-1.229 7.487 7.487 0 0 1-1.38-1.716c-.146-.248-.016-.381.109-.504.113-.11.248-.29.373-.435.124-.145.166-.248.249-.414.083-.166.04-.31-.02-.435-.062-.124-.559-1.347-.766-1.848-.201-.484-.406-.418-.559-.425-.145-.007-.31-.007-.476-.007a.918.918 0 0 0-.663.31c-.228.248-.87.85-8.7 2.07 0 1.22.89 2.4 1.162 2.766.27.366 1.753 2.678 4.248 3.754.593.256 1.058.41 1.419.525.597.19 1.14.163 1.57.1.48-.07 1.465-.6 1.67-.18.206-.418.206-.78 0-.965-.125-.187-.249-.247-.497-.37z"/>
                      </svg>
