---
---
<section id="portofolio-preview" class="py-24 bg-slate-50 relative overflow-hidden border-t-2 border-slate-200">
  <!-- Grid backdrop -->
  <div class="absolute inset-0 bg-[radial-gradient(rgba(37,99,235,0.02)_1px,transparent_1px)] bg-[size:1.5rem_1.5rem] pointer-events-none"></div>

  <div class="max-w-6xl mx-auto px-6 relative z-10 reveal-on-scroll">
    
    <!-- Section Header -->
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-16">
      <div class="max-w-2xl">
        <h2 class="font-mono font-bold text-xs tracking-widest text-blue-600 uppercase mb-3">/ Featured Projects</h2>
        <h3 class="font-display font-black text-3xl sm:text-5xl text-slate-900 tracking-tight leading-[1.0] uppercase">
          Karya Pilihan.<br/>
          <span class="text-stroke-neon">Bukan Sekadar Janji.</span>
        </h3>
        <p class="text-slate-600 mt-4 text-xs sm:text-sm leading-relaxed font-semibold">
          Intip dua proyek unggulan kami yang menggabungkan kecerdasan buatan otonom dan arsitektur web berkecepatan tinggi.
        </p>
      </div>

      <div class="mt-6 md:mt-0">
        <a 
          href="/portofolio/" 
          class="inline-flex items-center gap-2 px-6 py-3 border-2 border-blue-600 bg-white hover:bg-blue-50 text-blue-600 font-mono text-xs font-bold uppercase tracking-wider rounded-xl transition-all shadow-[4px_4px_0px_#2563eb] hover:shadow-[2px_2px_0px_#2563eb] hover:translate-x-0.5 active:translate-y-0.5"
        >
          Semua Portofolio ➔
        </a>
      </div>
    </div>

    <!-- 2 Featured Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 mb-16">
      
      <!-- Project 1: Aetheria AI -->
      <div class="group relative flex flex-col border-2 border-blue-600 bg-white rounded-2xl overflow-hidden hover:shadow-[8px_8px_0px_#2563eb] transition-all duration-300">
        <!-- OS Window Header -->
        <div class="flex items-center justify-between px-5 py-3.5 bg-slate-100 border-b-2 border-blue-600 select-none">
          <div class="flex items-center gap-2">
            <span class="w-2.5 h-2.5 rounded-full bg-rose-500"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-blue-500"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-teal-500"></span>
          </div>
          <span class="text-[9px] font-mono text-slate-500 tracking-wider font-bold">~/lumovelo/highlights/aetheria.ai</span>
          <div class="w-10"></div>
        </div>

        <!-- Body -->
        <div class="p-8 flex-1 flex flex-col justify-between">
          <div>
            <!-- Abstract Graphic (AI Nodes) -->
            <div class="h-32 bg-slate-950 border-2 border-blue-600 rounded-xl mb-6 relative overflow-hidden flex items-center justify-center">
              <div class="absolute inset-0 opacity-20 bg-[radial-gradient(#2563eb_1px,transparent_1px)] bg-[size:10px_10px]"></div>
              
              <!-- Animated SVG Neural Net -->
              <svg class="w-48 h-20 text-blue-500 relative z-10" viewBox="0 0 200 80" fill="none" xmlns="http://www.w3.org/2000/svg">
                <!-- Connections -->
                <line x1="20" y1="40" x2="60" y2="20" stroke="currentColor" stroke-width="1" stroke-dasharray="2 2" class="animate-[pulse_1.5s_infinite]"></line>
                <line x1="20" y1="40" x2="60" y2="60" stroke="currentColor" stroke-width="1" stroke-dasharray="2 2"></line>
                <line x1="60" y1="20" x2="110" y2="40" stroke="currentColor" stroke-width="1.5"></line>
                <line x1="60" y1="60" x2="110" y2="40" stroke="currentColor" stroke-width="1.5"></line>
                <line x1="110" y1="40" x2="160" y2="40" stroke="currentColor" stroke-width="2" class="animate-pulse"></line>
                
                <!-- Nodes -->
                <circle cx="20" cy="40" r="4" fill="#ef4444" class="animate-ping"></circle>
                <circle cx="20" cy="40" r="3" fill="#ef4444"></circle>
                
                <circle cx="60" cy="20" r="5" fill="#3b82f6"></circle>
                <circle cx="60" cy="60" r="5" fill="#3b82f6"></circle>
                
                <circle cx="110" cy="40" r="6" fill="#14b8a6"></circle>
                <circle cx="160" cy="40" r="8" fill="#10b981" class="animate-pulse"></circle>
                
                <text x="160" y="43" fill="#ffffff" font-family="monospace" font-size="8" font-weight="bold" text-anchor="middle">AI</text>
              </svg>
              
              <div class="absolute bottom-2 right-3 font-mono text-[8px] text-teal-400 font-bold uppercase tracking-widest">
                [ Autonomous Agent Running ]
              </div>
            </div>

            <div class="flex items-center justify-between mb-3">
              <h4 class="font-display font-black text-xl text-slate-900 uppercase">Aetheria AI</h4>
              <span class="px-2 py-0.5 text-[8px] font-mono font-bold uppercase tracking-wider text-rose-600 bg-rose-50 border border-rose-200 rounded">
                AI & Agent
              </span>
            </div>
            
            <p class="text-slate-600 text-xs leading-relaxed mb-6 font-semibold">
              Platform otonom cerdas untuk otomatisasi penulisan konten web berindeks tinggi dan manajemen optimasi backend yang transparan.
            </p>
          </div>

          <div class="flex items-center justify-between border-t border-slate-100 pt-6">
            <div class="flex items-center gap-1.5 text-[9px] font-mono text-slate-400 uppercase font-bold">
              <span>NextJS</span> • <span>LLM</span> • <span>Serverless</span>
            </div>
            <a href="/portofolio/" class="inline-flex items-center gap-1 text-[10px] font-bold text-blue-600 hover:underline uppercase tracking-wider">
              UJI DEMO INTERAKTIF ➔
            </a>
          </div>
        </div>
      </div>

      <!-- Project 2: Veloce Commerce -->
      <div class="group relative flex flex-col border-2 border-blue-600 bg-white rounded-2xl overflow-hidden hover:shadow-[8px_8px_0px_#2563eb] transition-all duration-300">
        <!-- OS Window Header -->
        <div class="flex items-center justify-between px-5 py-3.5 bg-slate-100 border-b-2 border-blue-600 select-none">
          <div class="flex items-center gap-2">
            <span class="w-2.5 h-2.5 rounded-full bg-rose-500"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-blue-500"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-teal-500"></span>
          </div>
          <span class="text-[9px] font-mono text-slate-500 tracking-wider font-bold">~/lumovelo/highlights/veloce.xml</span>
          <div class="w-10"></div>
        </div>

        <!-- Body -->
        <div class="p-8 flex-1 flex flex-col justify-between">
          <div>
            <!-- Abstract Graphic (Speed Dial) -->
            <div class="h-32 bg-slate-950 border-2 border-blue-600 rounded-xl mb-6 relative overflow-hidden flex items-center justify-center">
              <div class="absolute inset-0 opacity-20 bg-[radial-gradient(#2563eb_1px,transparent_1px)] bg-[size:10px_10px]"></div>
              
              <!-- speed dial graphic -->
              <div class="relative flex items-center justify-center w-24 h-24">
                <!-- Circular Track -->
                <div class="absolute inset-0 rounded-full border-4 border-slate-800 border-t-teal-500 border-r-teal-500 animate-[spin_3s_linear_infinite]"></div>
                <!-- Core score -->
                <div class="flex flex-col items-center justify-center font-mono relative z-10">
                  <span class="text-2xl font-black text-white">100</span>
                  <span class="text-[7px] text-teal-400 font-bold tracking-widest uppercase">LIGHTHOUSE</span>
                </div>
              </div>

              <!-- Sparkles -->
              <div class="absolute top-4 right-10 text-teal-400 animate-bounce">⚡</div>
              <div class="absolute bottom-4 left-10 text-teal-400 animate-pulse">⚡</div>

              <div class="absolute bottom-2 right-3 font-mono text-[8px] text-teal-400 font-bold uppercase tracking-widest">
                [ SPEED RATING: 100/100 ]
              </div>
            </div>

            <div class="flex items-center justify-between mb-3">
              <h4 class="font-display font-black text-xl text-slate-900 uppercase">Veloce Commerce</h4>
              <span class="px-2 py-0.5 text-[8px] font-mono font-bold uppercase tracking-wider text-teal-700 bg-teal-50 border border-teal-200 rounded">
                High-Speed Web
              </span>
            </div>
            
            <p class="text-slate-600 text-xs leading-relaxed mb-6 font-semibold">
              Sistem e-commerce headless modern dengan optimasi loading sub-detik terintegrasi langsung dengan API toko Shopify.
            </p>
          </div>

          <div class="flex items-center justify-between border-t border-slate-100 pt-6">
            <div class="flex items-center gap-1.5 text-[9px] font-mono text-slate-400 uppercase font-bold">
              <span>Astro</span> • <span>Shopify</span> • <span>FastEdge</span>
            </div>
            <a href="/portofolio/" class="inline-flex items-center gap-1 text-[10px] font-bold text-blue-600 hover:underline uppercase tracking-wider">
              UJI DEMO INTERAKTIF ➔
            </a>
          </div>
        </div>
      </div>

    </div>

    <!-- Bottom Action CTA -->
    <div class="text-center">
      <p class="text-xs text-slate-400 font-semibold mb-4 uppercase tracking-wider">
        Butuh performa yang disesuaikan khusus untuk pasar lokal Anda?
      </p>
      <a 
        href="/portofolio/" 
        class="inline-flex items-center justify-center px-10 py-5 rounded-2xl border-2 border-blue-600 bg-blue-600 hover:bg-blue-700 text-white font-display font-black text-xs uppercase tracking-widest transition-all duration-200 shadow-[4px_4px_0px_#0f172a] hover:shadow-[0_0_20px_rgba(37,99,235,0.3)] active:translate-y-0.5 cursor-pointer"
      >
        Eksplorasi Semua Studi Kasus & Demo Live ⚡
      </a>
    </div>

  </div>
</section>
