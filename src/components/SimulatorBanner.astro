---
---
<section class="py-16 bg-white relative overflow-hidden border-t-2 border-slate-100">
  <!-- Glowing gradient background decoration -->
  <div class="absolute inset-0 bg-[radial-gradient(rgba(37,99,235,0.015)_1px,transparent_1px)] bg-[size:1.5rem_1.5rem] pointer-events-none"></div>

  <div class="max-w-6xl mx-auto px-6 relative z-10 reveal-on-scroll">
    <div class="border-2 border-blue-600 bg-slate-50 p-8 md:p-12 rounded-3xl shadow-[6px_6px_0px_#2563eb] flex flex-col lg:flex-row items-center justify-between gap-8 hover:shadow-[8px_8px_0px_#1d4ed8] hover:-translate-y-0.5 transition-all duration-300">
      
      <!-- Copy Info -->
      <div class="space-y-4 max-w-2xl">
        <div class="flex items-center gap-2">
          <span class="relative flex h-2.5 w-2.5">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-rose-600 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-rose-600"></span>
          </span>
          <span class="text-[9px] font-mono text-rose-600 font-bold uppercase tracking-wider">/ WEB PERFORMANCE AUDIT</span>
        </div>
        
        <h4 class="font-display font-black text-2xl sm:text-3xl text-slate-900 uppercase tracking-tight leading-tight">
          Website Bisnis Anda Lambat?<br/>
          <span class="text-blue-600">Calon Pelanggan Tidak Akan Menunggu.</span>
        </h4>
        
        <p class="text-xs sm:text-sm text-slate-500 font-semibold leading-relaxed">
          Tahukah Anda bahwa penundaan pemuatan halaman bahkan beberapa detik saja dapat memicu kebocoran prospek (*leads*) secara masif? Jalankan audit instan gratis untuk mendeteksi latensi DNS, ukuran gambar berlebih, dan skor visibilitas SEO Anda sekarang.
        </p>
      </div>

      <!-- Button CTA -->
      <div class="w-full lg:w-auto shrink-0 text-center">
        <a 
          href="/audit/" 
          class="inline-flex items-center justify-center w-full lg:w-auto px-8 py-5 rounded-2xl border-2 border-blue-600 bg-blue-600 hover:bg-blue-700 text-white font-display font-black text-xs uppercase tracking-widest transition-all duration-200 shadow-[4px_4px_0px_#0f172a] hover:shadow-[0_0_20px_rgba(37,99,235,0.3)] active:translate-y-0.5 active:shadow-[2px_2px_0px_#0f172a] cursor-pointer"
        >
          Uji Performa Web Anda ⚡
        </a>
      </div>

    </div>
  </div>
</section>
