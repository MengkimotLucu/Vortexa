---
import Logo from './Logo.astro';
const lang = Astro.currentLocale === 'en' ? 'en' : 'id';

const content = {
  id: {
    desc: "Mitra strategis dalam transformasi digital. Kami merancang website berkinerja tinggi dengan sistem otomatisasi AI dan WhatsApp untuk mengamankan pertumbuhan bisnis Anda secara nyata.",
    col1Title: "PEMBUATAN WEBSITE",
    col1: [
      ["Situs Web Profil Perusahaan", "/#layanan"],
      ["Landing Page Konversi Tinggi", "/#layanan"],
      ["Kustomisasi Web Headless", "/#layanan"],
      ["Website Bisnis UMKM", "/#layanan"],
      ["Web E-Commerce Cepat", "/#layanan"]
    ],
    col2Title: "LAYANAN UTAMA",
    col2: [
      ["Integrasi Agen AI", "/layanan/ai/"],
      ["Mendesain Ulang Situs Web", "/#layanan"],
      ["Jasa Technical SEO", "/layanan/seo/"],
      ["Penyuntingan Video Kreatif", "/layanan/video/"]
    ],
    col3Title: "INFORMASI UMUM",
    col3: [
      ["Tentang Kami", "/tentang/"],
      ["Portofolio", "/portofolio/"],
      ["Hubungi Kami", "/kontak/"]
    ]
  },
  en: {
    desc: "Strategic partner in digital transformation. We design high-performance websites with AI and WhatsApp automation systems to secure your real business growth.",
    col1Title: "WEBSITE CREATION",
    col1: [
      ["Company Profile Website", "/en/#services"],
      ["High-Converting Landing Page", "/en/#services"],
      ["Headless Web Customization", "/en/#services"],
      ["SME Business Website", "/en/#services"],
      ["Fast E-Commerce Web", "/en/#services"]
    ],
    col2Title: "CORE SERVICES",
    col2: [
      ["AI Agent Integration", "/en/layanan/ai/"],
      ["Website Redesign", "/en/#services"],
      ["Technical SEO Service", "/en/layanan/seo/"],
      ["Creative Video Editing", "/en/layanan/video/"]
    ],
    col3Title: "GENERAL INFO",
    col3: [
      ["About Us", "/en/about-us/"],
      ["Portfolio", "/en/portfolio/"],
      ["Contact Us", "/en/contact/"]
    ]
  }
}[lang];

// For brand link
const homeLink = lang === 'en' ? '/en/' : '/';
const privacyLink = lang === 'en' ? '/en/privacy-policy/' : '/privacy-policy/';
const termsLink = lang === 'en' ? '/en/terms-of-service/' : '/terms-of-service/';
---
<footer class="bg-white text-slate-600 py-20 border-t border-slate-100 relative overflow-hidden">
  <!-- Soft accent light overlay -->
  <div class="absolute left-[-10%] top-0 w-[450px] h-[450px] bg-blue-600/[0.015] rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute right-[-10%] bottom-0 w-[450px] h-[450px] bg-teal-600/[0.015] rounded-full blur-3xl pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <!-- Main Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-12 pb-16 border-b border-slate-100">
      
      <!-- Column 1: Brand Info (6 cols width) -->
      <div class="lg:col-span-6 space-y-6">
        <a href={homeLink} class="flex items-center gap-3 group w-fit">
          <div class="w-10 h-10 rounded-xl border border-blue-100 bg-white flex items-center justify-center shadow-sm group-hover:scale-105 group-hover:border-blue-500 transition-all duration-300">
            <Logo class="w-5 h-5 text-blue-600" />
          </div>
          <span class="font-display font-black text-xl tracking-widest text-slate-900 group-hover:text-blue-600 transition-colors">LUMOVELO</span>
        </a>
        <p class="text-xs sm:text-sm text-slate-500 leading-relaxed max-w-md font-medium">
          {content.desc}
        </p>
        
        <!-- Social Icons -->
        <div class="flex items-center gap-4">
          <a href="https://x.com/lumovelo" target="_blank" rel="noopener noreferrer" class="w-8 h-8 rounded-full border border-slate-200 bg-white flex items-center justify-center text-slate-400 hover:text-blue-600 hover:border-blue-600 hover:bg-blue-50 transition-all duration-200" aria-label="Twitter">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="https://www.linkedin.com/in/lumovelo" target="_blank" rel="noopener noreferrer" class="w-8 h-8 rounded-full border border-slate-200 bg-white flex items-center justify-center text-slate-400 hover:text-blue-600 hover:border-blue-600 hover:bg-blue-50 transition-all duration-200" aria-label="LinkedIn">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.779-1.75-1.75s.784-1.75 1.75-1.75 1.75.779 1.75 1.75-.784 1.75-1.75 1.75zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" clip-rule="evenodd"/></svg>
          </a>
          <a href="https://www.instagram.com/lumoveloagency/" target="_blank" rel="noopener noreferrer" class="w-8 h-8 rounded-full border border-slate-200 bg-white flex items-center justify-center text-slate-400 hover:text-blue-600 hover:border-blue-600 hover:bg-blue-50 transition-all duration-200" aria-label="Instagram">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
          </a>
        </div>
      </div>

      <!-- Column 2: Web Dev Services (2 cols width) -->
      <div class="lg:col-span-2 space-y-4">
        <h4 class="font-mono text-[9px] font-bold tracking-widest text-blue-600 uppercase">{content.col1Title}</h4>
        <ul class="space-y-2.5 text-xs font-semibold text-slate-500">
          {content.col1.map(([text, href]) => (
            <li><a href={href} class="hover:text-blue-600 transition-colors">{text}</a></li>
          ))}
        </ul>
      </div>

      <!-- Column 3: Core Services (2 cols width) -->
      <div class="lg:col-span-2 space-y-4">
        <h4 class="font-mono text-[9px] font-bold tracking-widest text-blue-600 uppercase">{content.col2Title}</h4>
        <ul class="space-y-2.5 text-xs font-semibold text-slate-500">
          {content.col2.map(([text, href]) => (
            <li><a href={href} class="hover:text-blue-600 transition-colors">{text}</a></li>
          ))}
        </ul>
      </div>

      <!-- Column 4: Info (2 cols width) -->
      <div class="lg:col-span-2 space-y-4">
        <h4 class="font-mono text-[9px] font-bold tracking-widest text-blue-600 uppercase">{content.col3Title}</h4>
        <ul class="space-y-2.5 text-xs font-semibold text-slate-500">
          {content.col3.map(([text, href]) => (
            <li><a href={href} class="hover:text-blue-600 transition-colors">{text}</a></li>
          ))}
        </ul>
      </div>

    </div>

    <!-- Bottom copyright / Legal -->
    <div class="pt-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs font-semibold">
      <div class="flex flex-wrap items-center gap-6 font-mono text-[9px] font-bold tracking-widest uppercase">
        <a href={privacyLink} class="text-slate-500 hover:text-blue-600 transition-colors">Privacy Policy</a>
        <a href={termsLink} class="text-slate-500 hover:text-blue-600 transition-colors">Terms of Service</a>
      </div>
      <p class="text-slate-400 font-mono text-[9px]">© {new Date().getFullYear()} LUMOVELO. Developed for ultimate growth.</p>
    </div>

  </div>
</footer>
