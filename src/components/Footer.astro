          </a>
          <a href="https://instagram.com" target="_blank" rel="noopener noreferrer" class="w-8 h-8 rounded-full border border-slate-800 bg-slate-900/50 flex items-center justify-center text-slate-400 hover:text-white hover:border-blue-500 hover:bg-blue-600/10 transition-all duration-200" aria-label="Instagram">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
          </a>
        </div>
      </div>

      <!-- Column 2: Web Dev Services (2 cols width) -->
      <div class="lg:col-span-2 space-y-4">
        <h4 class="font-mono text-[10px] font-bold tracking-widest text-blue-500 uppercase">PEMBUATAN WEBSITE</h4>
        <ul class="space-y-2.5 text-xs font-semibold">
          <li><a href="#layanan" class="hover:text-white hover:underline transition-colors">Situs Web Profil Perusahaan</a></li>
          <li><a href="#layanan" class="hover:text-white hover:underline transition-colors">Landing Page Konversi Tinggi</a></li>
          <li><a href="#layanan" class="hover:text-white hover:underline transition-colors">Kustomisasi Web Headless</a></li>
          <li><a href="#layanan" class="hover:text-white hover:underline transition-colors">Website Bisnis UMKM</a></li>
          <li><a href="#layanan" class="hover:text-white hover:underline transition-colors">Web E-Commerce Cepat</a></li>
        </ul>
      </div>

      <!-- Column 3: AI & Growth (2 cols width) -->
      <div class="lg:col-span-2 space-y-4">
        <h4 class="font-mono text-[10px] font-bold tracking-widest text-blue-500 uppercase">LAYANAN PROFESIONAL</h4>
        <ul class="space-y-2.5 text-xs font-semibold">
          <li><a href="#layanan" class="hover:text-white hover:underline transition-colors">Integrasi Agen AI</a></li>
          <li><a href="#layanan" class="hover:text-white hover:underline transition-colors">Mendesain Ulang Situs Web</a></li>
          <li><a href="#layanan" class="hover:text-white hover:underline transition-colors">Otomatisasi Admin WhatsApp</a></li>
          <li><a href="#layanan" class="hover:text-white hover:underline transition-colors">Iklan Google Ads (SEM)</a></li>
          <li><a href="#layanan" class="hover:text-white hover:underline transition-colors">Jasa Technical SEO</a></li>
        </ul>
      </div>

      <!-- Column 4: Core Tech (2 cols width) -->
      <div class="lg:col-span-2 space-y-4">
        <h4 class="font-mono text-[10px] font-bold tracking-widest text-blue-500 uppercase">TEKNOLOGI UTAMA</h4>
        <ul class="space-y-2.5 text-xs font-semibold">
          <li><a href="#layanan" class="hover:text-white hover:underline transition-colors">Astro Framework</a></li>
          <li><a href="#layanan" class="hover:text-white hover:underline transition-colors">Next.js Platform</a></li>
          <li><a href="#layanan" class="hover:text-white hover:underline transition-colors">Tailwind CSS</a></li>
          <li><a href="#layanan" class="hover:text-white hover:underline transition-colors">Headless Shopify</a></li>
          <li><a href="#layanan" class="hover:text-white hover:underline transition-colors">Serverless APIs</a></li>
        </ul>
      </div>

      <!-- Column 5: Info (2 cols width) -->
      <div class="lg:col-span-2 space-y-4">
        <h4 class="font-mono text-[10px] font-bold tracking-widest text-blue-500 uppercase">INFORMASI UMUM</h4>
        <ul class="space-y-2.5 text-xs font-semibold">
          <li><a href="#tentang-kami" class="hover:text-white hover:underline transition-colors">Tentang Kami</a></li>
          <li><a href="#portofolio" class="hover:text-white hover:underline transition-colors">Portofolio</a></li>
          <li><a href="#blog" class="hover:text-white hover:underline transition-colors">Blog Wawasan</a></li>
          <li><a href="#konsultasi" class="hover:text-white hover:underline transition-colors">Cara Pemesanan</a></li>
          <li><a href="#konsultasi" class="hover:text-white hover:underline transition-colors">Hubungi Kami</a></li>
        </ul>
      </div>

    </div>

    <!-- Bottom copyright / Legal -->
    <div class="pt-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs font-semibold">
      <div class="flex flex-wrap items-center gap-6 font-mono text-[10px] font-bold tracking-widest uppercase">
        <a href="#konsultasi" class="hover:text-blue-500 transition-colors">Privacy Policy</a>
        <a href="#konsultasi" class="hover:text-blue-500 transition-colors">Terms of Service</a>
      </div>
      <p class="text-slate-500 font-mono text-[10px]">© {new Date().getFullYear()} VORTEXA. Developed for ultimate growth.</p>
    </div>

  </div>
</footer>
