---
const lang = Astro.currentLocale === 'en' ? 'en' : 'id';

const tags = {
  id: [
    "Creative Agency",
    "Otomatisasi AI",
    "Optimasi SEO",
    "Web Development",
    "Funnel Konversi"
  ],
  en: [
    "Creative Agency",
    "AI Automation",
    "SEO Optimization",
    "Web Development",
    "Conversion Funnel"
  ]
}[lang];
---

<div class="w-full bg-slate-50/60 border-y border-slate-100/80 py-5 relative z-20 select-none">
  <div class="max-w-5xl mx-auto px-6">
    <div class="flex flex-wrap items-center justify-center gap-3 md:gap-5">
      {tags.map((tag, idx) => (
        <>
          <span class="px-4 py-2 rounded-full border border-slate-200/70 bg-white text-[10px] md:text-xs font-mono font-black tracking-wider text-slate-700 uppercase shadow-[0_1px_2px_rgba(0,0,0,0.02)] transition-colors hover:border-blue-300 hover:text-blue-600 hover:shadow-sm">
            {tag}
          </span>
          {idx < tags.length - 1 && (
            <span class="text-slate-300 font-bold hidden sm:inline select-none">•</span>
          )}
        </>
      ))}
    </div>
  </div>
</div>
