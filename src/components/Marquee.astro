---
interface Props {
  texts: string[];
  speed?: 'slow' | 'medium' | 'fast';
  direction?: 'left' | 'right';
  reverse?: boolean;
}

const { 
  texts = [], 
  speed = 'medium', 
  direction = 'left',
  reverse = false 
} = Astro.props;
---

<!-- Parent container is transparent with no borders, allowing text to float cleanly on the canvas -->
<div class="w-full overflow-hidden bg-transparent py-1 select-none pointer-events-none relative">
  <!-- Glowing gradient overlay on edges for premium visual fade (blends into white page bg) -->
  <div class="absolute left-0 top-0 bottom-0 w-32 bg-gradient-to-r from-white to-transparent z-10"></div>
  <div class="absolute right-0 top-0 bottom-0 w-32 bg-gradient-to-l from-white to-transparent z-10"></div>

  <!-- Continuous Scrolling Container: Flex with max-content and flex-shrink-0 -->
  <div class={`marquee-track ${reverse ? 'animate-reverse' : 'animate-forward'} speed-${speed}`}>
    <!-- Loop 1 -->
    <div class="marquee-items">
      {texts.map((t) => (
        <span class="marquee-text">
          {t}
        </span>
      ))}
    </div>
    
    <!-- Loop 2 -->
    <div class="marquee-items">
      {texts.map((t) => (
        <span class="marquee-text">
          {t}
        </span>
      ))}
    </div>

    <!-- Loop 3 -->
    <div class="marquee-items">
      {texts.map((t) => (
        <span class="marquee-text">
          {t}
        </span>
      ))}
    </div>

    <!-- Loop 4 -->
    <div class="marquee-items">
      {texts.map((t) => (
        <span class="marquee-text">
          {t}
        </span>
      ))}
    </div>

    <!-- Loop 5 -->
    <div class="marquee-items">
      {texts.map((t) => (
        <span class="marquee-text">
          {t}
        </span>
      ))}
    </div>

    <!-- Loop 6 -->
    <div class="marquee-items">
      {texts.map((t) => (
        <span class="marquee-text">
          {t}
        </span>
      ))}
    </div>
  </div>
</div>

<style is:global>
  /* Import Google Font fallbacks (Syne & Plus Jakarta Sans) for premium agency look */
  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@800&family=Syne:wght@800&display=swap');

  /* Global marquee layout to bypass Astro scoping issues with dynamic template strings */
  .marquee-track {
    display: flex !important;
    flex-direction: row !important;
    flex-wrap: nowrap !important;
    width: max-content !important;
    flex-shrink: 0 !important;
    flex: none !important;
  }
  
  .marquee-items {
    display: flex !important;
    flex-direction: row !important;
    align-items: center !important;
    flex-wrap: nowrap !important;
    gap: 6rem !important; /* Spacing between texts inside loop */
    padding-right: 6rem !important; /* Trailing padding acts as seamless gap between loops */
    flex-shrink: 0 !important;
    flex: none !important;
  }

  .marquee-text {
    /* Premium Font Stack: Syne is a wide, bold, high-end display font */
    font-family: 'High Cruiser', 'Syne', 'Plus Jakarta Sans', sans-serif !important;
    font-weight: 800 !important;
    font-size: 2.25rem !important; /* Massive font size on mobile (text-4xl) */
    color: #0f172a !important; /* Premium deep slate-900 */
    text-transform: uppercase !important;
    white-space: nowrap !important;
    letter-spacing: -0.03em !important; /* Tight letter-spacing for premium editorial aesthetic */
    display: inline-block !important;
  }

  /* Massive font sizes on larger desktop viewports for impact and readability */
  @media (min-width: 1024px) {
    .marquee-text {
      font-size: 4.5rem !important; /* text-7xl equivalent */
    }
  }

  /* Global Animations and Keyframes: Translate by exactly 1/6 (calc(-100% / 6)) for seamless loop */
  .animate-forward {
    animation: marquee-forward 30s linear infinite !important;
  }

  .animate-reverse {
    animation: marquee-reverse 30s linear infinite !important;
  }

  .speed-slow {
    animation-duration: 52s !important;
  }
  
  .speed-medium {
    animation-duration: 35s !important;
  }
  
  .speed-fast {
    animation-duration: 22s !important;
  }

  @keyframes marquee-forward {
    0% {
      transform: translate3d(0, 0, 0);
    }
    100% {
      transform: translate3d(calc(-100% / 6), 0, 0);
    }
  }

  @keyframes marquee-reverse {
    0% {
      transform: translate3d(calc(-100% / 6), 0, 0);
    }
    100% {
      transform: translate3d(0, 0, 0);
    }
  }
</style>
