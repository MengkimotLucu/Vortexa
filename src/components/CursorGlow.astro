<!-- Cursor Glow Aura element -->
<div id="cursor-aura" class="hidden md:block"></div>

<script>
  function initCursorAura() {
    if (window.matchMedia('(pointer: coarse)').matches) return;
    if (window.innerWidth < 768) return;
    
    const aura = document.getElementById('cursor-aura')!;

    let posX = 0, posY = 0;
    let mouseX = 0, mouseY = 0;
    let isAnimating = false;
    let firstMove = true;

    // Smooth follow logic using lerp (linear interpolation)
    function animate() {
      const lerp = 0.08;
      posX += (mouseX - posX) * lerp;
      posY += (mouseY - posY) * lerp;

      aura.style.transform = `translate3d(${posX}px, ${posY}px, 0) translate(-50%, -50%)`;
      
      const distance = Math.hypot(mouseX - posX, mouseY - posY);
      if (distance > 0.2) {
        requestAnimationFrame(animate);
      } else {
        isAnimating = false;
      }
    }

    window.addEventListener('mousemove', (e) => {
      mouseX = e.clientX;
      mouseY = e.clientY;
      
      if (firstMove) {
        firstMove = false;
        posX = mouseX;
        posY = mouseY;
        aura.style.opacity = '1';
      }

      if (!isAnimating) {
        isAnimating = true;
        requestAnimationFrame(animate);
      }
    }, { passive: true });

    // Expand on mouse click
    window.addEventListener('mousedown', () => {
      aura.style.width = '380px';
      aura.style.height = '380px';
      aura.style.background = 'radial-gradient(circle, rgba(244,63,94,0.15) 0%, rgba(139,92,246,0.05) 50%, transparent 70%)';
    });

    window.addEventListener('mouseup', () => {
      aura.style.width = '300px';
      aura.style.height = '300px';
      aura.style.background = 'radial-gradient(circle, rgba(139,92,246,0.1) 0%, rgba(6,182,212,0.02) 50%, transparent 70%)';
    });
  }

  // Bind to DOM
  document.addEventListener('DOMContentLoaded', initCursorAura);
</script>
