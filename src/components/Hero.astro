---
import VortexBackground from './VortexBackground.astro';
---

<header class="absolute top-0 left-0 w-full z-50 border-b border-slate-200/50 bg-white/70 backdrop-blur-md">
  <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
    <a href="#" class="flex items-center gap-2 group">
      <div class="w-10 h-10 rounded-lg bg-gradient-to-tr from-blue-600 to-blue-400 flex items-center justify-center font-display font-black text-white text-xl tracking-wider shadow-lg shadow-blue-600/10 group-hover:rotate-6 transition-transform">
        V
      </div>
      <span class="font-display font-black text-xl tracking-widest text-slate-900 group-hover:text-blue-600 transition-colors">VORTEXA</span>
    </a>

    <!-- Full Navigation Menu matching sitemap -->
    <nav class="hidden lg:flex items-center gap-8 font-mono">
      <a href="#" class="text-xs font-extrabold tracking-wider uppercase text-slate-500 hover:text-blue-600 transition-colors">Home</a>
      <a href="#tentang-kami" class="text-xs font-extrabold tracking-wider uppercase text-slate-500 hover:text-blue-600 transition-colors">Tentang Kami</a>
      <a href="#layanan" class="text-xs font-extrabold tracking-wider uppercase text-slate-500 hover:text-blue-600 transition-colors">Layanan</a>
      <a href="#portofolio" class="text-xs font-extrabold tracking-wider uppercase text-slate-500 hover:text-blue-600 transition-colors">Portofolio</a>
      <a href="#blog" class="text-xs font-extrabold tracking-wider uppercase text-slate-500 hover:text-blue-600 transition-colors">Blog</a>
      <a href="#konsultasi" class="text-xs font-extrabold tracking-wider uppercase text-slate-500 hover:text-blue-600 transition-colors">Hubungi Kami</a>
    </nav>

    <div>
      <a href="#konsultasi" class="inline-flex items-center justify-center px-5 py-2.5 rounded-lg border-2 border-blue-600 bg-blue-600/5 text-blue-600 hover:bg-blue-600/15 text-xs font-black uppercase tracking-wider transition-all hover:-translate-y-0.5 hover:shadow-[3px_3px_0px_rgba(37,99,235,1)]">
        Mulai Diskusi
      </a>
    </div>
  </div>
</header>

<section class="relative min-h-screen flex items-center justify-center pt-28 pb-20 overflow-hidden bg-white">
  <!-- Dynamic particle warp tunnel background (Blue particles on white) -->
  <VortexBackground />

  <!-- Interactive Floating Stickers (Gen Z Branding in Neo-Brutalist White & Blue) -->
  <div class="absolute inset-0 z-10 pointer-events-none hidden md:block">
    <!-- Sticker 1 -->
    <div class="absolute top-[30%] left-[8%] floating-sticker select-none">
      <div class="px-4 py-2 bg-white border-2 border-blue-600 text-blue-600 font-display font-black text-xs uppercase tracking-widest rounded-xl shadow-[4px_4px_0px_#2563eb] -rotate-6">
        FAST AF 🚀
      </div>
    </div>

    <!-- Sticker 2 -->
    <div class="absolute top-[25%] right-[10%] floating-sticker-delayed select-none">
      <div class="px-4 py-2 bg-white border-2 border-blue-400 text-blue-500 font-display font-black text-xs uppercase tracking-widest rounded-xl shadow-[4px_4px_0px_#3b82f6] rotate-12">
        AI INTEGRATED 🧠
      </div>
    </div>

    <!-- Sticker 3 -->
    <div class="absolute bottom-[28%] left-[12%] floating-sticker-fast select-none">
      <div class="px-4 py-2 bg-white border-2 border-blue-700 text-blue-700 font-display font-black text-xs uppercase tracking-widest rounded-xl shadow-[4px_4px_0px_#1d4ed8] -rotate-3">
        100% STATIC HEADLESS 💻
      </div>
    </div>

    <!-- Sticker 4 -->
    <div class="absolute bottom-[22%] right-[12%] floating-sticker select-none">
      <div class="px-4 py-2 bg-white border-2 border-teal-600 text-teal-600 font-display font-black text-xs uppercase tracking-widest rounded-xl shadow-[4px_4px_0px_#0d9488] rotate-6">
        ZERO DB SERVER ⚡
      </div>
    </div>
  </div>

  <div class="relative max-w-6xl mx-auto px-6 text-center z-20">
    
    <!-- Pulse badge -->
    <div class="inline-flex items-center gap-2.5 px-4 py-2 rounded-xl border border-slate-200 bg-slate-50 text-[10px] font-black tracking-widest text-blue-600 uppercase mb-10 hover:border-blue-600/30 transition-colors">
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-600 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-blue-600"></span>
      </span>
      Konektivitas Digital • Indonesia • Global
    </div>

    <!-- Main Headline with Outlines and Gradients -->
    <h1 class="font-display font-black text-5xl sm:text-7xl md:text-8xl text-slate-900 tracking-tight leading-[0.95] mb-10 select-none uppercase">
      <span class="block">REKAYASA</span>
      <span class="block text-stroke-neon tracking-tighter">PERFORMA &</span>
      <span class="block bg-gradient-to-r from-blue-600 via-blue-500 to-blue-700 bg-[length:200%_auto] bg-clip-text text-transparent animate-[gradient-shift_6s_linear_infinite] glitch-hover cursor-pointer py-2">PERTUMBUHAN.</span>
    </h1>

    <!-- Sub-headline (Jargon-free explaining the main business) -->
    <p class="max-w-3xl mx-auto text-base sm:text-lg text-slate-600 font-semibold leading-relaxed mb-14">
      Kami merancang sistem kecerdasan buatan, website headless super cepat, dan optimasi SEO terarah langsung dari Bandung untuk membantu startup maupun UMKM lokal menguasai pasar nasional dan bersaing di kancah global.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
      <a 
        href="#konsultasi" 
        class="w-full sm:w-auto inline-flex items-center justify-center px-10 py-5 rounded-2xl bg-blue-600 hover:bg-blue-700 text-white font-black text-sm uppercase tracking-wider shadow-[4px_4px_0px_#0f172a] hover:shadow-[0_0_20px_rgba(37,99,235,0.4)] hover:-translate-y-0.5 transition-all duration-300 cursor-pointer"
      >
        Konsultasi Proyek Gratis 🚀
      </a>
      <a 
        href="#layanan" 
        class="w-full sm:w-auto inline-flex items-center justify-center px-10 py-5 rounded-2xl border-2 border-slate-200 hover:border-slate-400 bg-white text-slate-900 font-black text-sm uppercase tracking-wider transition-all duration-300 cursor-pointer"
      >
        Eksplorasi Layanan
      </a>
    </div>
  </div>

  <!-- Animated bottom hint -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-slate-400 text-[10px] font-bold tracking-widest uppercase">
    <span>Scroll Down</span>
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><polyline points="7 13 12 18 17 13"/><polyline points="7 6 12 11 17 6"/></svg>
  </div>
</section>

<style>
  @keyframes gradient-shift {
    0% {
      background-position: 0% center;
    }
    50% {
      background-position: 100% center;
    }
    100% {
      background-position: 0% center;
    }
  }
</style>
