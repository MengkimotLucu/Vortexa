---
import LanguageSwitcher from './LanguageSwitcher.astro';
import Logo from './Logo.astro';

const lang = Astro.currentLocale === 'en' ? 'en' : 'id';

const content = {
  id: {
    nav: {
      home: "Home",
      about: "Tentang Kami",
      services: "Layanan",
      careers: "Karir",
      contact: "Hubungi Kami",
      discussion: "Mulai Diskusi",
      consultation: "Mulai Konsultasi"
    },
    tag: "REKAYASA DIGITAL PERTUMBUHAN BISNIS • PREMIUM & TRANSPARAN",
    headline: {
      part1: "We Engineer",
      part2: "Digital Growth"
    },
    desc: "Kami merancang website kustom berkinerja tinggi, otomatisasi AI cerdas, dan video kreatif yang dirancang khusus untuk meningkatkan konversi dan penjualan bisnis Anda.",
    cta: "Lihat Paket Harga",
    promo: "🔥 Promo Peluncuran: Diskon 20% untuk 5 Klien Pertama Bulan Ini!",
    trust: "✓ Konsultasi Gratis • Tanpa Kontrak Awal • Sisa 2 Slot Proyek Bulan Ini"
  },
  en: {
    nav: {
      home: "Home",
      about: "About Us",
      services: "Services",
      careers: "Careers",
      contact: "Contact Us",
      discussion: "Start Discussion",
      consultation: "Start Consultation"
    },
    tag: "ENGINEERING DIGITAL BUSINESS GROWTH • PREMIUM & TRANSPARENT",
    headline: {
      part1: "We Engineer",
      part2: "Digital Growth"
    },
    desc: "We design high-performance custom websites, smart AI automations, and creative assets engineered to increase your conversions and scale your brand revenue.",
    cta: "View Pricing Packages",
    promo: "🔥 Launch Promo: Get 20% Off for the First 5 Clients This Month!",
    trust: "✓ Free Consultation • No Initial Contract • Only 2 Project Slots Left This Month"
  }
}[lang];

const homeLink = lang === 'en' ? '/en/' : '/';
const aboutLink = lang === 'en' ? '/en/about-us/' : '/tentang/';
const servicesLink = lang === 'en' ? '/en/#services' : '#layanan';
const portfolioLink = lang === 'en' ? '/en/portfolio/' : '/portofolio/';
const careersLink = lang === 'en' ? '/en/careers/' : '/karir/';
const contactLink = lang === 'en' ? '/en/contact/' : '/kontak/';
const blogLink = lang === 'en' ? '/en/blog/' : '/blog/';
---

<header 
  id="main-header" 
  class="fixed top-4 left-0 w-full z-50 transition-all duration-300 py-5 px-4 md:px-8"
>
  <div 
    id="header-container" 
    class="max-w-5xl mx-auto px-6 h-20 flex items-center justify-between transition-all duration-300 bg-slate-950/90 border border-slate-800/80 shadow-2xl rounded-full backdrop-blur-md"
  >
    <!-- Brand Logo -->
    <a href={homeLink} class="flex items-center gap-3 group">
      <div class="w-10 h-10 rounded-full bg-white flex items-center justify-center shadow-sm group-hover:scale-105 transition-all duration-300">
        <Logo class="w-5 h-5 text-blue-600" />
      </div>
      <span id="brand-name" class="font-display font-black text-xl tracking-widest text-white group-hover:text-blue-400 transition-colors">LUMOVELO</span>
    </a>

    <!-- Navigation Menu with Hover Dropdowns -->
    <nav class="hidden lg:flex items-center gap-8 font-sans">
      <a href={homeLink} class="nav-link relative py-2 text-xs font-extrabold tracking-wider uppercase text-slate-300 hover:text-white transition-colors group">
        {content.nav.home}
        <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-blue-500 group-hover:w-full transition-all duration-300"></span>
      </a>
      
      <!-- Dropdown Menu Layanan -->
      <div class="relative group py-2">
        <button class="nav-link flex items-center gap-1 text-xs font-extrabold tracking-wider uppercase text-slate-300 hover:text-white transition-colors focus:outline-none cursor-pointer">
          {content.nav.services}
          <svg class="w-3.5 h-3.5 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <!-- Dropdown Menu Panel -->
        <div class="absolute left-0 mt-2 w-56 rounded-2xl bg-white border border-slate-100 shadow-xl opacity-0 scale-95 pointer-events-none group-hover:opacity-100 group-hover:scale-100 group-hover:pointer-events-auto transition-all duration-200 origin-top-left p-2 z-50">
          <a href={servicesLink} class="flex flex-col p-2.5 rounded-xl hover:bg-blue-50/50 transition-colors">
            <span class="text-xs font-bold text-slate-800">Website & Web Apps</span>
            <span class="text-[9px] text-slate-400 mt-0.5">Landing page & profile penunjang konversi.</span>
          </a>
          <a href={lang === 'en' ? '/en/layanan/ai/' : '/layanan/ai/'} class="flex flex-col p-2.5 rounded-xl hover:bg-blue-50/50 transition-colors">
            <span class="text-xs font-bold text-slate-800">AI Integration</span>
            <span class="text-[9px] text-slate-400 mt-0.5">Otomatisasi alur kerja dan agen chatbot.</span>
          </a>
          <a href={lang === 'en' ? '/en/layanan/seo/' : '/layanan/seo/'} class="flex flex-col p-2.5 rounded-xl hover:bg-blue-50/50 transition-colors">
            <span class="text-xs font-bold text-slate-800">Advanced SEO</span>
            <span class="text-[9px] text-slate-400 mt-0.5">Optimasi traffic dan funnel pemasaran digital.</span>
          </a>
          <a href={lang === 'en' ? '/en/layanan/video/' : '/layanan/video/'} class="flex flex-col p-2.5 rounded-xl hover:bg-blue-50/50 transition-colors">
            <span class="text-xs font-bold text-slate-800">Video & Creative Assets</span>
            <span class="text-[9px] text-slate-400 mt-0.5">Penyuntingan video kreatif & media visual.</span>
          </a>
        </div>
      </div>

      <a href={portfolioLink} class="nav-link relative py-2 text-xs font-extrabold tracking-wider uppercase text-slate-300 hover:text-white transition-colors group">
        Portofolio
        <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-blue-500 group-hover:w-full transition-all duration-300"></span>
      </a>
      
      <!-- Dropdown Menu Informasi -->
      <div class="relative group py-2">
        <button class="nav-link flex items-center gap-1 text-xs font-extrabold tracking-wider uppercase text-slate-300 hover:text-white transition-colors focus:outline-none cursor-pointer">
          {lang === 'en' ? 'Information' : 'Informasi'}
          <svg class="w-3.5 h-3.5 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <!-- Dropdown Menu Panel -->
        <div class="absolute left-0 mt-2 w-56 rounded-2xl bg-white border border-slate-100 shadow-xl opacity-0 scale-95 pointer-events-none group-hover:opacity-100 group-hover:scale-100 group-hover:pointer-events-auto transition-all duration-200 origin-top-left p-2 z-50">
          <a href={aboutLink} class="flex flex-col p-2.5 rounded-xl hover:bg-blue-50/50 transition-colors">
            <span class="text-xs font-bold text-slate-800">{content.nav.about}</span>
            <span class="text-[9px] text-slate-400 mt-0.5">{lang === 'en' ? 'Learn about our digital collective mission.' : 'Pelajari misi kolektif digital kami.'}</span>
          </a>
          <a href={careersLink} class="flex flex-col p-2.5 rounded-xl hover:bg-blue-50/50 transition-colors">
            <span class="text-xs font-bold text-slate-800">{content.nav.careers}</span>
            <span class="text-[9px] text-slate-400 mt-0.5">{lang === 'en' ? 'Explore job & collaboration opportunities.' : 'Temukan peluang kerja & kolaborasi.'}</span>
          </a>
          <a href={contactLink} class="flex flex-col p-2.5 rounded-xl hover:bg-blue-50/50 transition-colors">
            <span class="text-xs font-bold text-slate-800">{lang === 'en' ? 'Contact Us' : 'Hubungi Kami'}</span>
            <span class="text-[9px] text-slate-400 mt-0.5">{lang === 'en' ? 'Get in touch for free consultation.' : 'Hubungi kami untuk konsultasi gratis.'}</span>
          </a>
          <a href={blogLink} class="flex flex-col p-2.5 rounded-xl hover:bg-blue-50/50 transition-colors">
            <span class="text-xs font-bold text-slate-800">Blog</span>
            <span class="text-[9px] text-slate-400 mt-0.5">{lang === 'en' ? 'Read tech, SEO & AI insights.' : 'Baca wawasan teknologi, SEO & AI.'}</span>
          </a>
        </div>
      </div>
    </nav>
        <div class="flex items-center gap-4">
      <LanguageSwitcher />
      <a 
        href={contactLink} 
        class="hidden sm:inline-flex items-center justify-center px-6 py-2.5 rounded-full bg-white text-slate-950 hover:bg-slate-100 text-xs font-bold uppercase tracking-wider transition-all duration-300 shadow-md"
      >
        {content.nav.discussion}
      </a>
 
      <!-- Mobile Hamburger Button -->
      <button 
        type="button" 
        id="hamburger-btn" 
        class="lg:hidden p-2 rounded-full border border-slate-800 bg-slate-900/50 text-slate-300 hover:border-blue-500 hover:text-white backdrop-blur-sm transition-colors focus:outline-none cursor-pointer"
        aria-label="Open Menu"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <line x1="4" y1="6" x2="20" y2="6"></line>
          <line x1="4" y1="12" x2="20" y2="12"></line>
          <line x1="4" y1="18" x2="20" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>
</header>

<!-- Mobile Navigation Drawer Overlay -->
<div 
  id="mobile-drawer" 
  class="fixed inset-0 z-[100] bg-slate-900/60 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300 lg:hidden"
>
  <!-- Drawer Panel -->
  <div 
    id="mobile-drawer-panel" 
    class="absolute right-0 top-0 bottom-0 w-4/5 max-w-sm bg-white border-l border-slate-100 p-6 flex flex-col justify-between translate-x-full transition-transform duration-300 shadow-2xl"
  >
    <div class="space-y-8">
      <!-- Drawer Header -->
      <div class="flex items-center justify-between">
        <a href={homeLink} class="flex items-center gap-2.5 group">
          <div class="w-8 h-8 rounded-lg border border-slate-200 bg-white flex items-center justify-center shadow-sm">
            <Logo class="w-4 h-4 text-blue-600" />
          </div>
          <span class="font-display font-black text-base tracking-widest text-slate-900">LUMOVELO</span>
        </a>
        <div class="flex items-center gap-3">
          <LanguageSwitcher />
          <button 
            type="button" 
            id="close-drawer-btn" 
            class="p-2 rounded-lg border border-slate-200 hover:border-rose-600 hover:text-rose-600 transition-colors focus:outline-none cursor-pointer"
            aria-label="Close Menu"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <line x1="18" y1="6" x2="6" y2="18"></line>
              <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </button>
        </div>
      </div>

      <!-- Drawer Nav Links -->
      <nav class="flex flex-col gap-5 font-sans">
        <a href={homeLink} class="mobile-drawer-link text-xs font-bold tracking-wider uppercase text-slate-700 hover:text-blue-600 transition-colors py-1.5 border-b border-slate-100">{content.nav.home}</a>
        
        <!-- Layanan sublinks in mobile menu -->
        <div class="flex flex-col gap-2.5 py-1">
          <span class="text-[10px] font-black tracking-widest text-slate-400 uppercase">Layanan</span>
          <a href={servicesLink} class="mobile-drawer-link text-xs font-bold text-slate-600 hover:text-blue-600 transition-colors pl-2">Website & Pricing</a>
          <a href={lang === 'en' ? '/en/layanan/ai/' : '/layanan/ai/'} class="mobile-drawer-link text-xs font-bold text-slate-600 hover:text-blue-600 transition-colors pl-2">AI Integration</a>
          <a href={lang === 'en' ? '/en/layanan/seo/' : '/layanan/seo/'} class="mobile-drawer-link text-xs font-bold text-slate-600 hover:text-blue-600 transition-colors pl-2">Advanced SEO</a>
          <a href={lang === 'en' ? '/en/layanan/video/' : '/layanan/video/'} class="mobile-drawer-link text-xs font-bold text-slate-600 hover:text-blue-600 transition-colors pl-2">Video Editing</a>
        </div>

        <a href={portfolioLink} class="mobile-drawer-link text-xs font-bold tracking-wider uppercase text-slate-700 hover:text-blue-600 transition-colors py-1.5 border-b border-slate-100">Portofolio</a>
        
        <!-- Informasi sublinks in mobile menu -->
        <div class="flex flex-col gap-2.5 py-1">
          <span class="text-[10px] font-black tracking-widest text-slate-400 uppercase">{lang === 'en' ? 'Information' : 'Informasi'}</span>
          <a href={aboutLink} class="mobile-drawer-link text-xs font-bold text-slate-600 hover:text-blue-600 transition-colors pl-2">{content.nav.about}</a>
          <a href={careersLink} class="mobile-drawer-link text-xs font-bold text-slate-600 hover:text-blue-600 transition-colors pl-2">{content.nav.careers}</a>
          <a href={contactLink} class="mobile-drawer-link text-xs font-bold text-slate-600 hover:text-blue-600 transition-colors pl-2">{lang === 'en' ? 'Contact Us' : 'Hubungi Kami'}</a>
          <a href={blogLink} class="mobile-drawer-link text-xs font-bold text-slate-600 hover:text-blue-600 transition-colors pl-2">Blog</a>
        </div>
      </nav>
    </div>

    <!-- Drawer Footer / CTA -->
    <div class="space-y-4">
      <a 
        href={contactLink} 
        id="drawer-cta-btn"
        class="mobile-drawer-link w-full inline-flex items-center justify-center py-3.5 rounded-xl bg-blue-600 hover:bg-blue-700 text-white text-xs font-bold uppercase tracking-widest transition-all shadow-md hover:shadow-lg"
      >
        {content.nav.discussion}
      </a>
    </div>
  </div>
</div>

<section class="relative min-h-0 lg:min-h-0 flex flex-col items-center justify-center pt-28 pb-20 lg:pt-36 lg:pb-28 overflow-hidden bg-slate-950 bg-[url('/hero-bg.jpg')] bg-cover bg-center">
  <!-- Dark overlay to ensure text contrast -->
  <div class="absolute inset-0 bg-slate-950/40 z-10 pointer-events-none"></div>

  <!-- Hero Content Wrapper -->
  <div class="relative max-w-7xl mx-auto px-6 z-20 flex-1 flex flex-col justify-center items-center w-full">
    
    <!-- Centered Content Wrapper -->
    <div class="flex flex-col items-center text-center w-full max-w-4xl mx-auto mt-6 space-y-6">
      <!-- Small category tag -->
      <span class="text-xs sm:text-sm font-extrabold tracking-[0.2em] text-white uppercase font-sans">
        {content.tag}
      </span>
      
      <!-- Headline with dynamic vertical text rotator -->
      <h1 class="font-display font-black text-3xl sm:text-4xl md:text-5xl lg:text-[3.2rem] xl:text-[3.6rem] leading-[1.25] text-white tracking-tight font-sans uppercase">
        {content.headline.part1}<br>
        {content.headline.part2}<br>
        <span class="text-blue-400 text-rotate-container font-black">
          <span class="text-rotate-list">
            <span class="h-[1.25em] flex items-center justify-center">{lang === 'en' ? 'Custom Websites' : 'Website Custom'}</span>
            <span class="h-[1.25em] flex items-center justify-center">{lang === 'en' ? 'AI Automations' : 'Otomatisasi AI'}</span>
            <span class="h-[1.25em] flex items-center justify-center">{lang === 'en' ? 'SEO Strategies' : 'Strategi SEO'}</span>
            <span class="h-[1.25em] flex items-center justify-center">{lang === 'en' ? 'Creative Assets' : 'Aset Kreatif'}</span>
          </span>
        </span>
      </h1>
      
      <!-- Description -->
      <p class="text-white/90 font-medium text-xs sm:text-sm md:text-base leading-relaxed max-w-2xl font-sans mx-auto">
        {content.desc}
      </p>
      
      <!-- CTA buttons & Trust indicators -->
      <div class="flex flex-col items-center gap-4 pt-4">
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-6">
          <a 
            href={servicesLink} 
            class="w-full sm:w-auto inline-flex items-center justify-center px-6 py-3.5 rounded-xl bg-blue-600 hover:bg-blue-700 text-white font-bold text-sm sm:text-base uppercase tracking-wider transition-all duration-300 hover:shadow-[0_10px_20px_rgba(37,99,235,0.15)] hover:-translate-y-0.5 gap-2 cursor-pointer"
          >
            {content.cta}
            <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </a>
          
          <a 
            href={contactLink} 
            class="w-full sm:w-auto inline-flex items-center gap-2 sm:gap-3 text-sm sm:text-base font-bold uppercase tracking-wider text-white hover:text-white/80 transition-colors py-2 cursor-pointer"
          >
            <div class="w-10 h-10 rounded-full border-2 border-white/20 flex items-center justify-center text-white bg-white/10 hover:bg-white hover:text-slate-950 hover:border-white transition-all hover:scale-105 shrink-0">
              <svg class="w-3.5 h-3.5 fill-current ml-0.5" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z" />
              </svg>
            </div>
            {content.nav.consultation}
          </a>
        </div>
        
        <!-- Trust Guarantee Checklist -->
        <p class="text-[10px] sm:text-xs font-mono font-bold text-white/70 tracking-wider">
          {content.trust}
        </p>
        
        <!-- Launching Promo Banner (Dark mode styled) -->
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-blue-500/30 bg-blue-500/10 backdrop-blur-sm text-[10px] sm:text-xs font-mono font-bold text-blue-300 uppercase tracking-wider shadow-inner select-none">
          {content.promo}
        </div>
      </div>
    </div>
  </div> <!-- Closes the max-w-7xl content wrapper -->

  <!-- SVG Wave transition at bottom of Hero -->
  <div class="absolute -bottom-[3px] sm:-bottom-[1px] inset-x-0 w-full overflow-hidden leading-none z-20 select-none pointer-events-none">
    <svg viewBox="0 0 1200 120" preserveAspectRatio="none" class="relative block w-full h-[50px] md:h-[80px] lg:h-[110px] scale-y-105 origin-bottom">
      <defs>
        <linearGradient id="hero-wave-grad-1" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="#1d4ed8" />
          <stop offset="50%" stop-color="#3b82f6" />
          <stop offset="100%" stop-color="#06b6d4" />
        </linearGradient>
        <linearGradient id="hero-wave-grad-2" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="#1e3a8a" />
          <stop offset="50%" stop-color="#2563eb" />
          <stop offset="100%" stop-color="#00f2fe" />
        </linearGradient>
      </defs>
      <!-- Wave 1 (Back wave, deep blue gradient with opacity) -->
      <path d="M0,30 C150,90 350,50 500,70 C650,90 850,10 1000,20 C1100,26 1150,60 1200,40 L1200,125 L0,125 Z" fill="url(#hero-wave-grad-1)" opacity="0.3" stroke="none"></path>
      <!-- Wave 2 (Middle wave, royal blue-cyan gradient with opacity) -->
      <path d="M0,50 C200,80 300,95 480,80 C660,65 780,30 930,35 C1080,40 1150,75 1200,60 L1200,125 L0,125 Z" fill="url(#hero-wave-grad-2)" opacity="0.45" stroke="none"></path>
      <!-- Wave 3 (Front wave, solid white to merge with services background) -->
      <path d="M0,70 C250,110 450,110 600,90 C750,70 850,50 1000,50 C1100,50 1150,85 1200,80 L1200,125 L0,125 Z" fill="#ffffff" stroke="none"></path>
    </svg>
  </div>
</section>


<script>
  function initMobileMenu() {
    const hamburgerBtn = document.getElementById('hamburger-btn');
    const closeDrawerBtn = document.getElementById('close-drawer-btn');
    const mobileDrawer = document.getElementById('mobile-drawer');
    const mobileDrawerPanel = document.getElementById('mobile-drawer-panel');
    const drawerLinks = document.querySelectorAll('.mobile-drawer-link');

    if (!hamburgerBtn || !closeDrawerBtn || !mobileDrawer || !mobileDrawerPanel) return;

    function openMenu() {
      mobileDrawer.classList.remove('opacity-0', 'pointer-events-none');
      mobileDrawer.classList.add('opacity-100');
      mobileDrawerPanel.classList.remove('translate-x-full');
      document.body.classList.add('overflow-hidden');
    }

    function closeMenu() {
      mobileDrawer.classList.add('opacity-0', 'pointer-events-none');
      mobileDrawer.classList.remove('opacity-100');
      mobileDrawerPanel.classList.add('translate-x-full');
      document.body.classList.remove('overflow-hidden');
    }

    hamburgerBtn.addEventListener('click', openMenu);
    closeDrawerBtn.addEventListener('click', closeMenu);
    
    mobileDrawer.addEventListener('click', (e) => {
      if (e.target === mobileDrawer) {
        closeMenu();
      }
    });

    drawerLinks.forEach(link => {
      link.addEventListener('click', closeMenu);
    });
  }

  function initHeaderScroll() {
    const header = document.getElementById('main-header');
    const container = document.getElementById('header-container');
    if (!header || !container) return;

    function checkScroll() {
      if (window.scrollY > 50) {
        header.classList.remove('py-5', 'top-4');
        header.classList.add('py-2', 'top-2');
        container.classList.remove('h-20');
        container.classList.add('h-16');
      } else {
        header.classList.remove('py-2', 'top-2');
        header.classList.add('py-5', 'top-4');
        container.classList.remove('h-16');
        container.classList.add('h-20');
      }
    }

    window.addEventListener('scroll', checkScroll);
    checkScroll();
  }

  function initAll() {
    initMobileMenu();
    initHeaderScroll();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAll);
  } else {
    initAll();
  }
</script>
