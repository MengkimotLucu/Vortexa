---
const lang = Astro.currentLocale === 'en' ? 'en' : 'id';

const content = {
  id: {
    sectionHeader: "HUBUNGI KAMI",
    title1: "Siap Naik Kelas?",
    title2: "Mulai Hari Ini.",
    desc: "Jangan biarkan website lambat dan pengelolaan operasional secara manual membatasi potensi keuntungan bisnis Anda. Konsultasikan ide digital Anda bersama tim Lumovelo secara gratis dan temukan solusi performa tinggi yang disesuaikan khusus untuk Anda.",
    v1: {
      title: "Konsultasi Tanpa Syarat",
      desc: "Diskusikan kebutuhan teknologi Anda secara gratis tanpa ada ikatan kontrak awal."
    },
    v2: {
      title: "Estimasi Transparan",
      desc: "Dapatkan rincian lingkup kerja dan investasi proyek tanpa ada biaya tersembunyi."
    },
    v3: {
      title: "Garansi Performa",
      desc: "Uji coba performa dan optimasi kecepatan langsung di depan Anda sebelum website diluncurkan."
    },
    urgencyTitle: "Slot Terbatas:",
    urgencyText: "Sisa 1 slot konsultasi gratis tersedia untuk bulan ini.",
    form: {
      stepTracker: "STAGE_TRACKER",
      s1: {
        label: "/ Siapa nama Anda?",
        placeholder: "Ketik nama lengkap Anda di sini..."
      },
      s2: {
        label: "/ Nama bisnis / perusahaan Anda?",
        placeholder: "Masukkan nama brand atau startup..."
      },
      s3: {
        label: "/ Layanan apa yang Anda cari?",
        placeholder: "Pilih kebutuhan utama Anda",
        opts: [
          ["Pembuatan Website", "Pembuatan Website (Landing Page, Toko Online, Web Kustom)"],
          ["Jasa SEO", "Jasa SEO (Optimisasi Pencarian Google)"],
          ["AI & Otomatisasi Bisnis", "AI & Otomatisasi Bisnis (WhatsApp Auto-responder, Chatbot)"],
          ["Layanan Lengkap (Semua Layanan)", "Layanan Lengkap (Website + SEO + AI)"]
        ]
      },
      s4: {
        label: "/ Berapa estimasi budget proyek?",
        placeholder: "Pilih kisaran budget proyek Anda",
        opts: [
          ["Di bawah Rp 2 Juta (Landing Page / Profil Bisnis)", "Di bawah Rp 2 Juta (Landing Page / Profil Bisnis)"],
          ["Rp 2 Juta - Rp 5 Juta (Toko Online / E-Commerce)", "Rp 2 Juta - Rp 5 Juta (Toko Online / E-Commerce)"],
          ["Rp 5 Juta - Rp 10 Juta (Web Kustom / SEO / AI)", "Rp 5 Juta - Rp 10 Juta (Web Kustom / SEO / AI)"],
          ["Di atas Rp 10 Juta (Sistem Kustom / Enterprise)", "Di atas Rp 10 Juta (Sistem Kustom / Enterprise)"]
        ]
      },
      btnBack: "Kembali",
      btnNext: "Lanjutkan",
      btnSubmit: "Submit & Konsultasi"
    }
  },
  en: {
    sectionHeader: "CONTACT US",
    title1: "Ready to Level Up?",
    title2: "Start Today.",
    desc: "Don't let a slow website and manual operations limit your business profits. Consult your digital ideas with the Lumovelo team for free and find high-performance solutions custom-tailored for you.",
    v1: {
      title: "No-Strings-Attached Consultation",
      desc: "Discuss your technology needs for free without any initial contract obligations."
    },
    v2: {
      title: "Transparent Estimation",
      desc: "Get details of work scope and project investment with no hidden fees."
    },
    v3: {
      title: "Performance Guarantee",
      desc: "Test performance and speed optimization right in front of you before the website launches."
    },
    urgencyTitle: "Limited Slot:",
    urgencyText: "Only 1 free consultation slot available for this month.",
    form: {
      stepTracker: "STAGE_TRACKER",
      s1: {
        label: "/ What is your name?",
        placeholder: "Type your full name here..."
      },
      s2: {
        label: "/ What is your business / company name?",
        placeholder: "Enter brand or startup name..."
      },
      s3: {
        label: "/ What services are you looking for?",
        placeholder: "Select your main need",
        opts: [
          ["Website Development", "Website Development (Landing Page, Online Store, Custom Web)"],
          ["SEO Services", "SEO Services (Google Search Optimization)"],
          ["AI & Business Automation", "AI & Business Automation (WhatsApp Auto-responder, Chatbot)"],
          ["Full Services (All Services)", "Full Services (Website + SEO + AI)"]
        ]
      },
      s4: {
        label: "/ What is the estimated project budget?",
        placeholder: "Select your project budget range",
        opts: [
          ["Under $150 / Rp 2 Million (Landing Page)", "Under $150 / Rp 2 Million (Landing Page)"],
          ["$150 - $350 / Rp 2M - Rp 5M (Online Store)", "$150 - $350 / Rp 2M - Rp 5M (Online Store)"],
          ["$350 - $700 / Rp 5M - Rp 10M (Custom Web/SEO/AI)", "$350 - $700 / Rp 5M - Rp 10M (Custom Web/SEO/AI)"],
          ["Over $700 / Rp 10M (Enterprise / Custom System)", "Over $700 / Rp 10M (Enterprise / Custom System)"]
        ]
      },
      btnBack: "Back",
      btnNext: "Continue",
      btnSubmit: "Submit & Consult"
    }
  }
}[lang];
---
<section id="konsultasi" class="py-8 lg:py-10 bg-white relative overflow-hidden">
  <!-- Decorative background colors -->
  <div class="absolute left-[-10%] bottom-[-10%] w-[600px] h-[600px] bg-blue-500/[0.03] rounded-full blur-[100px] pointer-events-none"></div>
  <div class="absolute right-[-10%] top-[10%] w-[600px] h-[600px] bg-cyan-500/[0.03] rounded-full blur-[100px] pointer-events-none"></div>

  <div class="max-w-5xl mx-auto px-6 relative z-10 reveal-on-scroll">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-center">
      
      <!-- Left Column: Copy & Value Proposition (5 columns) -->
      <div class="lg:col-span-5 space-y-8">
        <div class="space-y-3">
          <span class="font-mono font-bold text-xs tracking-widest text-blue-600 uppercase">{content.sectionHeader}</span>
          <h3 class="font-display font-black text-4xl sm:text-5xl text-slate-900 uppercase tracking-tight leading-[1.1]">
            {content.title1}<br/>
            <span class="text-blue-600">{content.title2}</span>
          </h3>
        </div>
        
        <p class="text-slate-600 text-sm sm:text-base leading-relaxed font-semibold">
          {content.desc}
        </p>

        <!-- Dynamic value bullet points without numbers/percentages -->
        <div class="space-y-4 pt-2">
          <div class="flex items-start gap-3">
            <div class="w-6 h-6 rounded bg-blue-50 flex items-center justify-center text-blue-600 shrink-0 font-mono text-xs font-bold">✓</div>
            <div>
              <h5 class="text-xs font-mono font-bold text-slate-900 uppercase">{content.v1.title}</h5>
              <p class="text-[11px] text-slate-500 font-semibold leading-relaxed">{content.v1.desc}</p>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <div class="w-6 h-6 rounded bg-blue-50 flex items-center justify-center text-blue-600 shrink-0 font-mono text-xs font-bold">✓</div>
            <div>
              <h5 class="text-xs font-mono font-bold text-slate-900 uppercase">{content.v2.title}</h5>
              <p class="text-[11px] text-slate-500 font-semibold leading-relaxed">{content.v2.desc}</p>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <div class="w-6 h-6 rounded bg-blue-50 flex items-center justify-center text-blue-600 shrink-0 font-mono text-xs font-bold">✓</div>
            <div>
              <h5 class="text-xs font-mono font-bold text-slate-900 uppercase">{content.v3.title}</h5>
              <p class="text-[11px] text-slate-500 font-semibold leading-relaxed">{content.v3.desc}</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Right Column: Interactive Multi-Step Form (7 columns) -->
      <div class="lg:col-span-7 space-y-8">
        <div class="border border-teal-200 bg-teal-50/20 p-5 rounded-2xl shadow-sm flex items-center justify-between gap-4">
          <div class="flex items-center gap-3">
            <span class="relative flex h-2.5 w-2.5">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-teal-600 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-teal-600"></span>
            </span>
            <div class="text-xs font-semibold text-slate-800">
              <span class="text-slate-900 font-extrabold uppercase tracking-wide">{content.urgencyTitle}</span> 
              {content.urgencyText}
            </div>
          </div>
        </div>

        <!-- Conversational Multi-Step Form Container -->
        <div class="border border-slate-200 bg-white rounded-3xl p-6 sm:p-8 md:p-10 relative shadow-xl shadow-slate-100/70 overflow-hidden">
          <!-- Glow strip -->
          <div class="absolute top-0 left-0 w-full h-1.5 bg-gradient-to-r from-blue-600 via-blue-500 to-teal-600"></div>

          <!-- Header Info -->
          <div class="mb-8">
            <div class="flex justify-between items-center text-[10px] font-mono text-slate-500 mb-2 uppercase tracking-wider">
              <span>/ {content.form.stepTracker}: <span id="form-step-num">1</span>_OF_4</span>
              <span id="form-step-percent">25%</span>
            </div>
            <div class="w-full h-1.5 bg-slate-100 rounded-full overflow-hidden">
              <div id="form-progress-bar" class="h-full bg-gradient-to-r from-blue-600 to-blue-400 w-[25%] transition-all duration-300"></div>
            </div>
          </div>

          <!-- Form Pane Viewport -->
          <form id="multistep-project-form" class="relative min-h-[220px]" onsubmit="return false;" data-lang={lang}>
            
            <!-- STEP 1: Name -->
            <div id="step-1" class="form-step-pane transition-all duration-300 space-y-4">
              <label for="client-name" class="block font-display font-black text-xl sm:text-2xl text-slate-900 uppercase tracking-tight">
                {content.form.s1.label}
              </label>
              <input 
                type="text" 
                id="client-name" 
                name="name" 
                placeholder={content.form.s1.placeholder} 
                required
                class="w-full bg-slate-50 border border-slate-200 focus:border-blue-600 focus:bg-white focus:ring-4 focus:ring-blue-500/10 rounded-xl px-5 py-4 text-slate-900 text-sm outline-none transition-all placeholder:text-slate-400 font-semibold shadow-sm"
              />
            </div>

            <!-- STEP 2: Company -->
            <div id="step-2" class="form-step-pane hidden transition-all duration-300 space-y-4">
              <label for="client-company" class="block font-display font-black text-xl sm:text-2xl text-slate-900 uppercase tracking-tight">
                {content.form.s2.label}
              </label>
              <input 
                type="text" 
                id="client-company" 
                name="company" 
                placeholder={content.form.s2.placeholder} 
                required
                class="w-full bg-slate-50 border border-slate-200 focus:border-blue-500 focus:bg-white focus:ring-4 focus:ring-blue-500/10 rounded-xl px-5 py-4 text-slate-900 text-sm outline-none transition-all placeholder:text-slate-400 font-semibold shadow-sm"
              />
            </div>

            <!-- STEP 3: Needs -->
            <div id="step-3" class="form-step-pane hidden transition-all duration-300 space-y-4">
              <label for="client-service" class="block font-display font-black text-xl sm:text-2xl text-slate-900 uppercase tracking-tight">
                {content.form.s3.label}
              </label>
              <div class="relative">
                <select 
                  id="client-service" 
                  name="service"
                  required
                  class="w-full bg-slate-50 border border-slate-200 focus:border-blue-700 focus:bg-white focus:ring-4 focus:ring-blue-500/10 rounded-xl px-5 py-4 text-slate-900 text-sm outline-none transition-all appearance-none cursor-pointer font-semibold shadow-sm"
                >
                  <option value="" disabled selected class="text-slate-400">{content.form.s3.placeholder}</option>
                  {content.form.s3.opts.map(([val, label]) => (
                    <option value={val} class="text-slate-900">{label}</option>
                  ))}
                </select>
                <div class="absolute inset-y-0 right-5 flex items-center pointer-events-none text-slate-400">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
                </div>
              </div>
            </div>

            <!-- STEP 4: Budget -->
            <div id="step-4" class="form-step-pane hidden transition-all duration-300 space-y-4">
              <label for="client-budget" class="block font-display font-black text-xl sm:text-2xl text-slate-900 uppercase tracking-tight">
                {content.form.s4.label}
              </label>
              <div class="relative">
                <select 
                  id="client-budget" 
                  name="budget"
                  required
                  class="w-full bg-slate-50 border border-slate-200 focus:border-teal-600 focus:bg-white focus:ring-4 focus:ring-teal-500/10 rounded-xl px-5 py-4 text-slate-900 text-sm outline-none transition-all appearance-none cursor-pointer font-semibold shadow-sm"
                >
                  <option value="" disabled selected class="text-slate-400">{content.form.s4.placeholder}</option>
                  {content.form.s4.opts.map(([val, label]) => (
                    <option value={val} class="text-slate-900">{label}</option>
                  ))}
                </select>
                <div class="absolute inset-y-0 right-5 flex items-center pointer-events-none text-slate-400">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
                </div>
              </div>
            </div>

            <!-- Navigation Buttons -->
            <div class="flex items-center justify-between border-t border-slate-100 pt-6 mt-8">
              <button 
                type="button" 
                id="form-prev-btn" 
                class="px-5 py-3 rounded-xl border border-slate-200 bg-white hover:bg-slate-50 text-slate-500 hover:text-slate-800 font-bold text-xs uppercase tracking-wider transition-all duration-200 shadow-sm active:scale-[0.98] invisible cursor-pointer"
              >
                {content.form.btnBack}
              </button>
              
              <button 
                type="button" 
                id="form-next-btn" 
                class="px-6 py-3.5 rounded-xl bg-blue-600 hover:bg-blue-700 text-white font-bold text-xs uppercase tracking-wider shadow-lg shadow-blue-600/10 hover:shadow-xl hover:shadow-blue-600/20 hover:-translate-y-0.5 active:scale-[0.98] transition-all duration-200 cursor-pointer"
              >
                {content.form.btnNext}
              </button>

              <button 
                type="submit" 
                id="form-submit-btn" 
                class="px-6 py-3.5 rounded-xl bg-teal-600 hover:bg-teal-700 text-white font-bold text-xs uppercase tracking-wider shadow-lg shadow-teal-600/10 hover:shadow-xl hover:shadow-teal-600/20 hover:-translate-y-0.5 active:scale-[0.98] transition-all duration-200 hidden cursor-pointer"
              >
                {content.form.btnSubmit}
              </button>
            </div>

          </form>
        </div>
      </div>
      
    </div>
  </div>
</section>

<script>
  function initForm() {
    let currentStep = 1;
    const totalSteps = 4;

    const form = document.getElementById('multistep-project-form') as HTMLFormElement;
    const prevBtn = document.getElementById('form-prev-btn') as HTMLButtonElement;
    const nextBtn = document.getElementById('form-next-btn') as HTMLButtonElement;
    const submitBtn = document.getElementById('form-submit-btn') as HTMLButtonElement;
    const progressBar = document.getElementById('form-progress-bar') as HTMLDivElement;
    const stepNumEl = document.getElementById('form-step-num') as HTMLSpanElement;
    const stepPercentEl = document.getElementById('form-step-percent') as HTMLSpanElement;

    function updateFormUI() {
      for (let i = 1; i <= totalSteps; i++) {
        const pane = document.getElementById(`step-${i}`);
        if (pane) {
          if (i === currentStep) {
            pane.classList.remove('hidden');
            pane.classList.add('animate-[slideIn_0.3s_ease-out]');
          } else {
            pane.classList.add('hidden');
            pane.classList.remove('animate-[slideIn_0.3s_ease-out]');
          }
        }
      }

      const percent = (currentStep / totalSteps) * 100;
      if (progressBar) progressBar.style.width = `${percent}%`;
      if (stepNumEl) stepNumEl.innerText = currentStep.toString();
      if (stepPercentEl) stepPercentEl.innerText = `${percent}%`;

      if (currentStep === 1) {
        if (prevBtn) prevBtn.classList.add('invisible');
      } else {
        if (prevBtn) prevBtn.classList.remove('invisible');
      }

      if (currentStep === totalSteps) {
        if (nextBtn) nextBtn.classList.add('hidden');
        if (submitBtn) submitBtn.classList.remove('hidden');
      } else {
        if (nextBtn) nextBtn.classList.remove('hidden');
        if (submitBtn) submitBtn.classList.add('hidden');
      }
    }

    function validateStep(step: number): boolean {
      const pane = document.getElementById(`step-${step}`);
      if (!pane) return false;
      
      const inputs = pane.querySelectorAll('input, select');
      let isValid = true;

      inputs.forEach((input: any) => {
        if (!input.checkValidity()) {
          input.reportValidity();
          isValid = false;
        }
      });

      return isValid;
    }

    if (nextBtn) {
      nextBtn.onclick = () => {
        if (validateStep(currentStep)) {
          if (currentStep < totalSteps) {
            currentStep++;
            updateFormUI();
          }
        }
      };
    }

    if (prevBtn) {
      prevBtn.onclick = () => {
        if (currentStep > 1) {
          currentStep--;
          updateFormUI();
        }
      };
    }

    if (form) {
      form.onsubmit = (e) => {
        e.preventDefault();
        if (!validateStep(currentStep)) return;

        const nameVal = (document.getElementById('client-name') as HTMLInputElement).value;
        const companyVal = (document.getElementById('client-company') as HTMLInputElement).value;
        const serviceVal = (document.getElementById('client-service') as HTMLSelectElement).value;
        const budgetVal = (document.getElementById('client-budget') as HTMLSelectElement).value;
        const formLang = form.getAttribute('data-lang') || 'id';

        const targetPhone = "6285624353611";
        
        const messageText = formLang === 'en'
          ? `Hello Lumovelo Team, I would like to request a project consultation. Here are the details:\n\n- Name: ${nameVal}\n- Company: ${companyVal}\n- Requirements: ${serviceVal}\n- Estimated Budget: ${budgetVal}\n\nPlease schedule a time for discussion. Thank you!`
          : `Halo Tim Lumovelo, saya ingin mengajukan konsultasi proyek. Berikut detailnya:\n\n- Nama: ${nameVal}\n- Perusahaan: ${companyVal}\n- Kebutuhan: ${serviceVal}\n- Estimasi Budget: ${budgetVal}\n\nTolong jadwalkan waktu untuk diskusi ya. Terima kasih!`;

        const encodedMessage = encodeURIComponent(messageText);
        const whatsappUrl = `https://api.whatsapp.com/send?phone=${targetPhone}&text=${encodedMessage}`;

        window.open(whatsappUrl, '_blank');
      };
    }

    updateFormUI();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initForm);
  } else {
    initForm();
  }
</script>

<style>
  @keyframes slideIn {
    from {
      opacity: 0;
      transform: translateX(10px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }
</style>
