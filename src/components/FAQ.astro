---
const lang = Astro.currentLocale === 'en' ? 'en' : 'id';

const content = {
  id: {
    sectionHeader: "PERTANYAAN UMUM",
    title1: "F.A.Q.",
    title2: "Jawaban Singkat & Jelas.",
    desc: "Kami merangkum beberapa pertanyaan penting yang sering ditanyakan oleh calon mitra kami untuk mempermudah pemahaman Anda.",
    ctaTitle: "Konsultasi Kebutuhan Sistem Anda (100% Gratis)",
    ctaDesc: "Diskusikan ide otomatisasi AI, perbaikan SEO, atau kebutuhan custom website Anda bersama developer & analis kami via WhatsApp.",
    ctaBtn: "Mulai Konsultasi Gratis"
  },
  en: {
    sectionHeader: "F.A.Q.",
    title1: "F.A.Q.",
    title2: "Short & Clear Answers.",
    desc: "We summarize some important questions frequently asked by our potential partners to ease your understanding.",
    ctaTitle: "Consult Your System Needs (100% Free)",
    ctaDesc: "Discuss your AI automation ideas, SEO optimization, or custom web requirements directly with our developers and analysts on WhatsApp.",
    ctaBtn: "Start Free Consultation"
  }
}[lang];

const faqs = {
  id: [
    {
      q: "Apakah LUMOVELO menerapkan biaya langganan bulanan?",
      a: "Tidak. Kami hanya mengenakan biaya satu kali untuk jasa desain, koding, dan integrasi awal. Untuk penyimpanan file (hosting), kami merancang arsitektur serverless sehingga Anda bisa memanfaatkan kuota gratis serverless dari penyedia global seperti Vercel atau Netlify secara permanen untuk trafik normal bisnis Anda."
    },
    {
      q: "Berapa lama estimasi waktu pembuatan website?",
      a: "Untuk pengerjaan landing page konversi tinggi siap pakai biasanya memakan waktu antara 5 hingga 7 hari kerja. Sedangkan untuk aplikasi web kustom yang memerlukan visualisasi dasbor kompleks atau integrasi sistem otomatisasi AI membutuhkan waktu berkisar antara 2 hingga 4 minggu."
    },
    {
      q: "Bagaimana cara saya memperbarui konten website di kemudian hari?",
      a: "Kami mengintegrasikan dasbor manajemen konten (headless CMS) yang sangat praktis dan intuitif. Anda dapat mengganti teks, memperbarui harga produk, mengunggah foto, dan mempublikasikan tulisan blog baru secara mandiri melalui HP atau laptop tanpa harus menyentuh kode pemrograman."
    },
    {
      q: "Apakah website buatan LUMOVELO aman dari serangan hacker?",
      a: "Ya. Karena kami menggunakan struktur arsitektur statis serverless, website Anda tidak memiliki server database SQL yang rentan dibobol. Ini meminimalisir celah keamanan secara signifikan, menjadikannya sangat aman dan hampir tidak mungkin diretas dibanding website CMS konvensional."
    },
    {
      q: "Apakah website yang didesain sudah SEO-friendly?",
      a: "Tentu saja. Kami mengimplementasikan praktik terbaik SEO teknis (technical SEO), mulai dari tag heading semantik, optimasi metadata, kecepatan loading maksimal, hingga struktur sitemap dan robots.txt yang ramah mesin pencari Google."
    },
    {
      q: "Apakah saya akan mendapatkan file source code website?",
      a: "Ya, sepenuhnya. Setelah proyek selesai dan pelunasan dilakukan, seluruh kepemilikan source code dan aset digital akan diserahkan kepada Anda. Kami tidak mengunci kode Anda agar Anda memiliki fleksibilitas penuh di masa depan."
    },
    {
      q: "Apakah LUMOVELO menyediakan layanan maintenance website?",
      a: "Tidak perlu. Website buatan LUMOVELO dirancang bebas biaya pemeliharaan (maintenance) rutin karena berjalan di atas infrastruktur serverless modern yang stabil secara otomatis. Kami juga memberikan dukungan revisi gratis selama proses pengerjaan serta garansi bebas bug selama 1 bulan setelah peluncuran."
    },
    {
      q: "Bagaimana proses pembayaran di LUMOVELO?",
      a: "Kami menggunakan sistem pembayaran bertahap (termin). Biasanya dimulai dengan Down Payment (DP) sebesar 50% untuk memulai fase riset dan desain, dan sisa pelunasan 50% setelah website selesai diuji dan siap diluncurkan secara publik."
    },
    {
      q: "Metode pembayaran apa saja yang didukung oleh LUMOVELO?",
      a: "Kami mendukung transfer bank lokal (BCA, Mandiri, BNI, BRI), kartu kredit, dan metode pembayaran digital terverifikasi. Pembayaran dilakukan secara bertahap melalui sistem termin resmi dengan invoice dan kwitansi berstempel resmi."
    },
    {
      q: "Bagaimana cara mendapatkan diskon atau penawaran khusus?",
      a: "Kami menawarkan diskon khusus untuk startup tahap awal, yayasan nirlaba/sosial, serta paket bundling (seperti pembuatan website profil perusahaan sekaligus integrasi chatbot AI & setup SEO bulanan). Silakan diskusikan langsung dengan tim kami untuk mendapatkan penawaran terbaik."
    },
    {
      q: "Apakah ada garansi jika website mengalami error setelah diluncurkan?",
      a: "Ya, kami memberikan garansi bug-free penuh selama 1 bulan pertama setelah peluncuran. Jika terjadi kendala teknis atau error sistem, tim kami akan memperbaikinya segera tanpa biaya tambahan."
    },
    {
      q: "Apa perbedaan antara manual testing dan automation testing di LUMOVELO?",
      a: "Manual testing dilakukan oleh QA Engineer kami dengan mensimulasikan interaksi pengguna riil untuk menemukan bug kosmetik, kegunaan, atau logika. Sedangkan automation testing menggunakan skrip kode (seperti Playwright/Cypress) untuk menjalankan pengujian regresi berulang secara otomatis pada pipeline CI/CD, menghemat waktu rilis produk."
    },
    {
      q: "Perangkat dan OS apa saja yang digunakan untuk pengujian aplikasi mobile?",
      a: "Kami menggunakan perangkat fisik asli (real devices) Android & iOS dari berbagai merk populer (seperti Samsung, Xiaomi, Oppo, Vivo, & iPhone) dengan versi OS yang bervariasi. Hal ini memastikan aplikasi Anda kompatibel dan tidak mengalami crash saat diakses oleh pengguna dengan beragam spesifikasi HP."
    },
    {
      q: "Apakah LUMOVELO juga menyediakan pengujian beban (load testing) server?",
      a: "Ya. Di paket Elite dan Custom, kami melakukan load testing menggunakan k6 atau JMeter hingga simulasi 1.000 pengguna virtual bersamaan. Kami membantu Anda menganalisis waktu respons API, mendeteksi kebocoran memori (memory leak), dan mengoptimalkan konfigurasi server agar tahan banting terhadap lonjakan traffic mendadak."
    }
  ],
  en: [
    {
      q: "Does LUMOVELO charge a monthly subscription fee?",
      a: "No. We only charge a one-time fee for design, coding, and initial integration. For file storage (hosting), we design a serverless architecture so you can leverage the free permanent tier of global providers like Vercel or Netlify for your normal business traffic."
    },
    {
      q: "How long does it take to build a website?",
      a: "A high-converting, ready-to-use landing page typically takes 5 to 7 business days. Custom web applications requiring complex dashboard visualizations or AI automation integrations take between 2 to 4 weeks."
    },
    {
      q: "How do I update website content in the future?",
      a: "We integrate a practical and intuitive headless CMS. You can edit text, update product prices, upload photos, and publish new blog posts independently via mobile or laptop without touching any code."
    },
    {
      q: "Are websites built by LUMOVELO safe from hackers?",
      a: "Yes. Because we use a serverless static architecture, your website does not have an SQL database server that is vulnerable to SQL injection. This minimizes security vulnerabilities, making it extremely secure and nearly impossible to hack compared to conventional CMS websites."
    },
    {
      q: "Is the designed website SEO-friendly?",
      a: "Of course. We implement technical SEO best practices, including semantic heading tags, metadata optimization, maximum loading speed, and search engine friendly sitemap and robots.txt structures."
    },
    {
      q: "Will I get the website's source code files?",
      a: "Yes, completely. Once the project is finished and the final payment is cleared, all ownership of source code and digital assets will be handed over to you. We do not lock your code so you have full flexibility in the future."
    },
    {
      q: "Does LUMOVELO provide website maintenance services?",
      a: "No need. Websites built by LUMOVELO are designed to be maintenance-free as they run on modern serverless architecture that is automatically stable. We also provide free revision support during development and a full 1-month bug-free guarantee after launch."
    },
    {
      q: "How does the payment process work at LUMOVELO?",
      a: "We use a milestone-based payment system. It usually starts with a 50% Down Payment (DP) to begin the research and design phase, and the remaining 50% balance after the website is tested and ready to launch publicly."
    },
    {
      q: "What payment methods are supported by LUMOVELO?",
      a: "We support local bank transfers, credit cards, and verified digital payment methods. Payments are made in stages through an official milestone system with stamped invoices and receipts."
    },
    {
      q: "How do I get discounts or special offers?",
      a: "We offer special discounts for early-stage startups, non-profit/social foundations, and bundling packages (such as company profile website creation combined with AI chatbot integration & monthly SEO setup). Please discuss directly with our team to secure the best package deal."
    },
    {
      q: "Is there a warranty if the website encounters errors after launch?",
      a: "Yes, we provide a full bug-free warranty for the first 3 months post-launch. If any technical issues or system errors occur, our team will resolve them immediately at no extra charge."
    },
    {
      q: "What is the difference between manual and automated testing at LUMOVELO?",
      a: "Manual testing is performed by our QA Engineers mimicking real user interactions to catch UI/UX flaws and business logic bugs. Automated testing uses script suites (Cypress/Playwright) to run repetitive regression tests automatically in the CI/CD pipeline, reducing deployment release times."
    },
    {
      q: "What devices and OS versions are used for mobile app testing?",
      a: "We test on real physical Android & iOS devices across popular brands (Samsung, Xiaomi, Oppo, Vivo, & iPhone) on multiple OS versions. This guarantees your application remains compatible and stable without crashing across different screen sizes and device specifications."
    },
    {
      q: "Does LUMOVELO provide server load testing?",
      a: "Yes. In our Elite and Custom tiers, we conduct server load testing simulating up to 1,000 concurrent virtual users using k6 or JMeter. We help analyze API response times, detect memory leaks, and optimize your server configuration to handle sudden traffic spikes gracefully."
    }
  ]
}[lang];

const contactLink = lang === 'en' ? '/en/#konsultasi' : '#konsultasi';
---

<section id="faq" class="py-12 lg:py-16 bg-white relative overflow-hidden !pt-12 sm:!pt-14">
  <div class="absolute right-[-15%] top-[15%] w-[600px] h-[600px] bg-blue-600/[0.08] rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute left-[-15%] bottom-[15%] w-[600px] h-[600px] bg-cyan-500/[0.07] rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute inset-0 bg-[radial-gradient(rgba(37,99,235,0.015)_1px,transparent_1px)] bg-[size:1.5rem_1.5rem] pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-6 relative z-10 reveal-on-scroll">
    
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
      
      <!-- Left Column: Header & CTA (Sticky on Desktop) -->
      <div class="lg:col-span-5 lg:sticky lg:top-24 space-y-8">
        <div>
          <h2 class="font-mono font-bold text-xs tracking-widest text-blue-600 uppercase">{content.sectionHeader}</h2>
          <h3 class="font-display font-black text-4xl sm:text-5xl text-slate-900 uppercase tracking-tight leading-[1.0] mt-3">
            {content.title1}<br/>
            <span class="text-stroke-neon">{content.title2}</span>
          </h3>
          <p class="text-slate-500 mt-6 text-sm sm:text-base leading-relaxed font-semibold">
            {content.desc}
          </p>
        </div>

        <!-- CTA Area inside Left Column -->
        <div class="p-6 border-2 border-blue-600 bg-white rounded-3xl shadow-[4px_4px_0px_#2563eb] space-y-4">
          <h4 class="font-display font-black text-base text-slate-900 uppercase">{content.ctaTitle}</h4>
          <p class="text-xs text-slate-500 font-semibold leading-relaxed">
            {content.ctaDesc}
          </p>
          <a 
            href={contactLink} 
            class="inline-flex w-full items-center justify-center px-6 py-3.5 rounded-xl border-2 border-blue-600 bg-blue-600 hover:bg-blue-700 text-white font-black text-xs uppercase tracking-widest transition-all duration-200 shadow-[3px_3px_0px_#0f172a] active:translate-y-0.5 active:shadow-[1px_1px_0px_#0f172a] cursor-pointer"
          >
            {content.ctaBtn}
          </a>
        </div>
      </div>

      <!-- Right Column: Accordion Stack -->
      <div class="lg:col-span-7 space-y-4">
        {faqs.map((item) => (
          <div class="faq-item border-2 border-blue-600 rounded-2xl bg-white p-6 shadow-[3px_3px_0px_#2563eb] transition-all duration-300">
            <button type="button" class="faq-toggle w-full flex items-center justify-between text-left font-display font-black text-sm sm:text-base uppercase text-slate-900 tracking-tight cursor-pointer select-none">
              <span>{item.q}</span>
              <svg class="faq-chevron w-4 h-4 text-blue-600 transform transition-transform duration-300 shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="faq-answer grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 overflow-hidden">
              <div class="min-h-0">
                <p class="text-xs sm:text-sm text-slate-600 leading-relaxed font-semibold pt-4 border-t border-slate-200/50 mt-4">
                  {item.a}
                </p>
              </div>
            </div>
          </div>
        ))}
      </div>

    </div>

  </div>
</section>


<script>
  function initFaq() {
    const faqItems = document.querySelectorAll('.faq-item');
    
    faqItems.forEach(item => {
      const toggle = item.querySelector('.faq-toggle');
      const answer = item.querySelector('.faq-answer');
      const chevron = item.querySelector('.faq-chevron');
      
      if (toggle && answer && chevron) {
        toggle.addEventListener('click', () => {
          const isOpen = answer.classList.contains('grid-rows-[1fr]');
          
          // Close all other FAQs for clean single-accordion look
          faqItems.forEach(otherItem => {
            const otherAnswer = otherItem.querySelector('.faq-answer');
            const otherChevron = otherItem.querySelector('.faq-chevron');
            if (otherAnswer && otherChevron && otherAnswer !== answer) {
              otherAnswer.classList.remove('grid-rows-[1fr]');
              otherAnswer.classList.add('grid-rows-[0fr]');
              otherChevron.classList.remove('rotate-180');
              otherItem.classList.remove('bg-white');
              otherItem.classList.add('bg-slate-50');
            }
          });

          // Toggle current
          if (isOpen) {
            answer.classList.remove('grid-rows-[1fr]');
            answer.classList.add('grid-rows-[0fr]');
            chevron.classList.remove('rotate-180');
            item.classList.remove('bg-white');
            item.classList.add('bg-slate-50');
          } else {
            answer.classList.remove('grid-rows-[0fr]');
            answer.classList.add('grid-rows-[1fr]');
            chevron.classList.add('rotate-180');
            item.classList.remove('bg-slate-50');
            item.classList.add('bg-white');
          }
        });
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFaq);
  } else {
    initFaq();
  }
</script>
