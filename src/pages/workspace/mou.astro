    // Helper to get Indonesian day name from date string
    function getIndonesianDay(dateStr: string) {
      try {
        if (!dateStr) return 'Senin';
        // Parse simple Indonesian date e.g. "27 Juni 2026"
        const indonesianMonths: Record<string, number> = {
          'januari': 0, 'februari': 1, 'maret': 2, 'april': 3, 'mei': 4, 'juni': 5,
          'juli': 6, 'agustus': 7, 'september': 8, 'oktober': 9, 'november': 10, 'desember': 11
        };
        const parts = dateStr.toLowerCase().split(' ');
        if (parts.length >= 3) {
          const day = parseInt(parts[0], 10);
          const monthName = parts[1];
          const year = parseInt(parts[2], 10);
          const monthIndex = indonesianMonths[monthName] || 0;
          const d = new Date(year, monthIndex, day);
          const days = ['Minggu', 'Senin', 'Selasa', 'Rabu', 'Kamis', 'Jumat', 'Sabtu'];
          return days[d.getDay()] || 'Senin';
        }
      } catch (e) {
        // Fallback
      }
      return 'Sabtu';
    }

