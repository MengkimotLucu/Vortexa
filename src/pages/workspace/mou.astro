---
import Logo from '../../components/Logo.astro';
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Premium MoU Generator | LUMOVELO" description="Workspace pembuatan dokumen Memorandum of Understanding interaktif dengan ekspor PDF & Word." noindex={true}>
  <div class="min-h-screen bg-slate-950 text-slate-100 flex flex-col font-sans select-none">
    <!-- Header -->
    <header class="border-b border-slate-800 bg-slate-900/80 backdrop-blur-md sticky top-0 z-40 px-6 py-4 flex items-center justify-between no-print">
      <div class="flex items-center gap-3">
        <a href="/" class="flex items-center gap-2 group">
          <div class="w-8 h-8 rounded-lg border border-slate-700 bg-blue-600 flex items-center justify-center shadow-[2px_2px_0px_rgba(37,99,235,0.4)]">
            <Logo class="w-4 h-4 text-white" />
          </div>
          <span class="font-display font-black text-lg tracking-wider text-white">LUMOVELO</span>
        </a>
        <span class="text-xs font-mono px-2 py-1 rounded bg-slate-800 text-slate-400 uppercase tracking-widest">Workspace v1.0</span>
        <a href="/admin/dashboard/" class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-slate-800 hover:bg-slate-700 text-slate-300 hover:text-white text-[10px] font-bold uppercase tracking-wider transition-colors">
          📊 Dashboard
        </a>
      </div>
      
      <!-- Document Selector Dropdown -->
      <div class="relative inline-block text-left" id="doc-selector-dropdown-container">
        <button type="button" id="doc-selector-btn" class="inline-flex justify-between items-center gap-2 px-4 py-2 border border-slate-700 rounded-xl bg-slate-950 text-xs font-bold text-slate-300 hover:text-white hover:border-slate-650 transition-all cursor-pointer select-none">
          <span>📂 WORKSPACE: MOU PERJANJIAN</span>
          <svg class="w-3.5 h-3.5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div id="doc-selector-menu" class="absolute right-0 mt-2 w-56 rounded-xl border border-slate-800 bg-slate-900 shadow-2xl py-1.5 z-50 hidden transition-all">
          <a href="/workspace/mou/" class="block px-4 py-2 text-xs text-blue-400 bg-slate-800/40 font-bold border-b border-slate-800/30">📝 MoU Perjanjian</a>
          <a href="/workspace/spk/" class="block px-4 py-2 text-xs text-slate-300 hover:text-white hover:bg-slate-800/60 border-b border-slate-800/30">🤝 SPK / Kontrak Kerja</a>
          <a href="/workspace/rab/" class="block px-4 py-2 text-xs text-slate-300 hover:text-white hover:bg-slate-800/60 border-b border-slate-800/30">📊 RAB Anggaran Biaya</a>
          <a href="/workspace/srs/" class="block px-4 py-2 text-xs text-slate-300 hover:text-white hover:bg-slate-800/60 border-b border-slate-800/30">📋 SRS / Lampiran Scope</a>
          <a href="/workspace/invoice/" class="block px-4 py-2 text-xs text-slate-300 hover:text-white hover:bg-slate-800/60 border-b border-slate-800/30">💳 Invoice Penagihan</a>
          <a href="/workspace/kuitansi/" class="block px-4 py-2 text-xs text-slate-300 hover:text-white hover:bg-slate-800/60 border-b border-slate-800/30">🧾 Kuitansi Pembayaran</a>
          <a href="/workspace/bast/" class="block px-4 py-2 text-xs text-slate-300 hover:text-white hover:bg-slate-800/60">📦 BAST Serah Terima</a>
        </div>
      </div>
    </header>

    <!-- Main Workspace -->
    <div class="flex-1 flex flex-col lg:flex-row overflow-hidden">
      <!-- Tabs for Mobile View -->
      <div class="lg:hidden flex border-b border-slate-800 bg-slate-900 no-print">
        <button id="tab-editor" class="flex-1 py-3 text-center text-sm font-bold border-b-2 border-blue-500 text-white bg-slate-900">
          Form Editor
        </button>
        <button id="tab-preview" class="flex-1 py-3 text-center text-sm font-bold border-b-2 border-transparent text-slate-400 bg-slate-900">
          Pratinjau A4
        </button>
      </div>

      <!-- Left Panel: Editor Form -->
      <aside id="editor-panel" class="w-full lg:w-[45%] border-r border-slate-800 bg-slate-900/30 overflow-y-auto p-6 space-y-6 block no-print">
        <!-- Preset Selector -->
        <div class="bg-slate-900/80 border border-slate-800 rounded-xl p-4 space-y-3">
          <label class="block text-xs font-mono font-bold tracking-widest text-blue-400 uppercase">PILIH TEMPLATE PRESET</label>
          <div class="grid grid-cols-3 gap-2">
            <button type="button" id="preset-tech" class="px-3 py-2 rounded-lg bg-blue-600/10 hover:bg-blue-600/20 border border-blue-500/30 text-xs font-bold text-blue-400 transition-all hover:scale-[1.02] cursor-pointer">
              Kerjasama Tech
            </button>
            <button type="button" id="preset-business" class="px-3 py-2 rounded-lg bg-slate-800 hover:bg-slate-700/60 border border-slate-700 text-xs font-bold text-slate-300 transition-all hover:scale-[1.02] cursor-pointer">
              Bisnis Umum
            </button>
            <button type="button" id="preset-marketing" class="px-3 py-2 rounded-lg bg-slate-800 hover:bg-slate-700/60 border border-slate-700 text-xs font-bold text-slate-300 transition-all hover:scale-[1.02] cursor-pointer">
              SEO & Konten
            </button>
          </div>
        </div>

        <!-- Document Metadata -->
        <div class="space-y-4">
          <h3 class="text-sm font-mono font-bold text-slate-400 border-b border-slate-800 pb-2 uppercase tracking-wider">Info Dokumen</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="space-y-1.5">
              <label for="mou-title" class="text-xs font-semibold text-slate-400">Judul Perjanjian</label>
              <input type="text" id="mou-title" class="w-full bg-slate-900 border border-slate-800 focus:border-blue-500 rounded-lg px-3.5 py-2 text-sm text-white focus:outline-none transition-colors" placeholder="Masukkan judul MoU" />
            </div>
            <div class="space-y-1.5">
              <label for="mou-number" class="text-xs font-semibold text-slate-400">Nomor Perjanjian</label>
              <input type="text" id="mou-number" class="w-full bg-slate-900 border border-slate-800 focus:border-blue-500 rounded-lg px-3.5 py-2 text-sm text-white focus:outline-none transition-colors" placeholder="Masukkan nomor MoU" />
            </div>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="space-y-1.5">
              <label for="mou-city" class="text-xs font-semibold text-slate-400">Kota Penandatanganan</label>
              <input type="text" id="mou-city" class="w-full bg-slate-900 border border-slate-800 focus:border-blue-500 rounded-lg px-3.5 py-2 text-sm text-white focus:outline-none transition-colors" placeholder="Contoh: Bandung" />
            </div>
            <div class="space-y-1.5">
              <label for="mou-date" class="text-xs font-semibold text-slate-400">Tanggal Penandatanganan</label>
              <input type="text" id="mou-date" class="w-full bg-slate-900 border border-slate-800 focus:border-blue-500 rounded-lg px-3.5 py-2 text-sm text-white focus:outline-none transition-colors" placeholder="Contoh: 27 Juni 2026" />
            </div>
          </div>
        </div>

        <!-- Party 1 Details -->
        <div class="space-y-4">
          <h3 class="text-sm font-mono font-bold text-slate-400 border-b border-slate-800 pb-2 uppercase tracking-wider">PIHAK PERTAMA (PIHAK I)</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="space-y-1.5">
              <label for="p1-name" class="text-xs font-semibold text-slate-400">Nama Lengkap</label>
              <input type="text" id="p1-name" class="w-full bg-slate-900 border border-slate-800 focus:border-blue-500 rounded-lg px-3.5 py-2 text-sm text-white focus:outline-none transition-colors" placeholder="Nama perwakilan Pihak I" />
            </div>
            <div class="space-y-1.5">
              <label for="p1-position" class="text-xs font-semibold text-slate-400">Jabatan</label>
              <input type="text" id="p1-position" class="w-full bg-slate-900 border border-slate-800 focus:border-blue-500 rounded-lg px-3.5 py-2 text-sm text-white focus:outline-none transition-colors" placeholder="Contoh: Direktur Utama" />
            </div>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="space-y-1.5">
              <label for="p1-company" class="text-xs font-semibold text-slate-400">Perusahaan / Instansi</label>
              <input type="text" id="p1-company" class="w-full bg-slate-900 border border-slate-800 focus:border-blue-500 rounded-lg px-3.5 py-2 text-sm text-white focus:outline-none transition-colors" placeholder="Nama instansi Pihak I" />
            </div>
            <div class="space-y-1.5">
              <label for="p1-address" class="text-xs font-semibold text-slate-400">Alamat</label>
              <input type="text" id="p1-address" class="w-full bg-slate-900 border border-slate-800 focus:border-blue-500 rounded-lg px-3.5 py-2 text-sm text-white focus:outline-none transition-colors" placeholder="Alamat lengkap Pihak I" />
            </div>
          </div>
        </div>

        <!-- Party 2 Details -->
        <div class="space-y-4">
          <h3 class="text-sm font-mono font-bold text-slate-400 border-b border-slate-800 pb-2 uppercase tracking-wider">PIHAK KEDUA (PIHAK II)</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="space-y-1.5">
              <label for="p2-name" class="text-xs font-semibold text-slate-400">Nama Lengkap</label>
              <input type="text" id="p2-name" class="w-full bg-slate-900 border border-slate-800 focus:border-blue-500 rounded-lg px-3.5 py-2 text-sm text-white focus:outline-none transition-colors" placeholder="Nama perwakilan Pihak II" />
            </div>
            <div class="space-y-1.5">
              <label for="p2-position" class="text-xs font-semibold text-slate-400">Jabatan</label>
              <input type="text" id="p2-position" class="w-full bg-slate-900 border border-slate-800 focus:border-blue-500 rounded-lg px-3.5 py-2 text-sm text-white focus:outline-none transition-colors" placeholder="Contoh: Direktur Bisnis" />
            </div>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="space-y-1.5">
              <label for="p2-company" class="text-xs font-semibold text-slate-400">Perusahaan / Instansi</label>
              <input type="text" id="p2-company" class="w-full bg-slate-900 border border-slate-800 focus:border-blue-500 rounded-lg px-3.5 py-2 text-sm text-white focus:outline-none transition-colors" placeholder="Nama instansi Pihak II" />
            </div>
            <div class="space-y-1.5">
              <label for="p2-address" class="text-xs font-semibold text-slate-400">Alamat</label>
              <input type="text" id="p2-address" class="w-full bg-slate-950 border border-slate-800 focus:border-blue-500 rounded-lg px-3.5 py-2 text-sm text-white focus:outline-none transition-colors" placeholder="Alamat lengkap Pihak II" />
            </div>
          </div>
        </div>

        <!-- Clauses / Pasal-Pasal -->
        <div class="space-y-4">
          <div class="flex items-center justify-between border-b border-slate-800 pb-2">
            <h3 class="text-sm font-mono font-bold text-slate-400 uppercase tracking-wider">PASAL-PASAL PERJANJIAN</h3>
            <button type="button" id="btn-add-clause" class="px-2.5 py-1 rounded bg-blue-600 hover:bg-blue-700 text-white font-bold text-[10px] uppercase tracking-wider flex items-center gap-1 transition-colors cursor-pointer">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
              Tambah Pasal
            </button>
          </div>

          <!-- Clauses Container -->
          <div id="clauses-editor-container" class="space-y-3">
            <!-- Dynamic rows will be inserted here by JS -->
          </div>
        </div>

        <!-- Masa Berlaku Perjanjian -->
        <div class="space-y-1.5">
          <label for="mou-duration" class="text-xs font-semibold text-slate-400">Masa Berlaku Perjanjian</label>
          <input type="text" id="mou-duration" class="w-full bg-slate-900 border border-slate-800 focus:border-blue-500 rounded-lg px-3.5 py-2 text-sm text-white focus:outline-none transition-colors" placeholder="Contoh: 1 (satu) tahun sejak penandatanganan dokumen" />
        </div>

        <!-- Action Download Buttons -->
        <div class="pt-4 space-y-3">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <button type="button" id="btn-download-pdf" class="w-full flex items-center justify-center gap-2.5 py-4 rounded-xl border-2 border-blue-600 bg-blue-600 hover:bg-blue-700 text-white font-black text-sm uppercase tracking-wider shadow-[4px_4px_0px_#020617] transition-all duration-200 hover:-translate-y-0.5 active:translate-y-0 active:shadow-none cursor-pointer">
              Cetak / Simpan PDF
            </button>
            <button type="button" id="btn-download-word" class="w-full flex items-center justify-center gap-2.5 py-4 rounded-xl border-2 border-slate-700 bg-slate-800 hover:bg-slate-700 text-white font-black text-sm uppercase tracking-wider shadow-[4px_4px_0px_#020617] transition-all duration-200 hover:-translate-y-0.5 active:translate-y-0 active:shadow-none cursor-pointer">
              Unduh Word (.doc)
            </button>
          </div>
          <button type="button" id="btn-save-db" class="w-full flex items-center justify-center gap-2.5 py-4 rounded-xl border-2 border-emerald-600 bg-emerald-600 hover:bg-emerald-700 text-white font-black text-sm uppercase tracking-wider shadow-[4px_4px_0px_#020617] transition-all duration-200 hover:-translate-y-0.5 active:translate-y-0 active:shadow-none cursor-pointer">
            💾 Simpan Ke Database
          </button>
        </div>
      </aside>

      <!-- Right Panel: Live Document Preview (A4 representation) -->
      <section id="preview-panel" class="flex-1 bg-slate-900/20 overflow-y-auto p-4 md:p-8 flex justify-center items-start hidden lg:flex">
        <!-- Paper Container representing A4 -->
        <div id="paper-preview" class="w-full max-w-[210mm] min-h-[297mm] bg-white text-black p-[25mm] shadow-2xl rounded border border-slate-200/50 flex flex-col font-serif relative">
          <!-- Document Header -->
          <div class="text-center space-y-2 mb-8">
            <h1 id="preview-title-header" class="text-base md:text-lg font-bold uppercase tracking-wide leading-relaxed border-b-2 border-black pb-3">
              MEMORANDUM OF UNDERSTANDING (MoU)<br>
              <span id="p-title-main" class="text-base">KERJASAMA KEMITRAAN TEKNOLOGI</span>
            </h1>
            <p class="text-xs font-bold font-sans">
              Nomor: <span id="p-mou-number" class="underline">014/MOU-LUMOVELO/TECH/VI/2026</span>
            </p>
          </div>

          <!-- Document Body -->
          <div class="text-xs space-y-6 leading-relaxed text-justify flex-1">
            <p>
              Pada hari ini, <strong id="p-mou-day">Sabtu</strong> tanggal <strong id="p-mou-date-raw">27 Juni 2026</strong>, bertempat di <strong id="p-mou-city-raw">Bandung</strong>, telah disepakati suatu Nota Kesepahaman (Memorandum of Understanding) oleh dan di antara pihak-pihak di bawah ini:
            </p>

            <!-- Party 1 Details Block -->
            <div class="pl-4 space-y-1">
              <table class="w-full no-border font-serif text-xs">
                <tr>
                  <td class="w-[30%] font-bold">Nama</td>
                  <td class="w-[3%]">:</td>
                  <td><span id="p-p1-name" class="font-bold">Ahmad Rivaldi</span></td>
                </tr>
                <tr>
                  <td class="font-bold">Jabatan</td>
                  <td>:</td>
                  <td><span id="p-p1-position">CEO / Co-founder</span></td>
                </tr>
                <tr>
                  <td class="font-bold">Perusahaan</td>
                  <td>:</td>
                  <td><span id="p-p1-company" class="font-bold">LUMOVELO Agency</span></td>
                </tr>
                <tr>
                  <td class="font-bold">Alamat</td>
                  <td>:</td>
                  <td><span id="p-p1-address">Jl. Dipati Ukur No. 102, Bandung</span></td>
                </tr>
              </table>
              <p class="pt-2">
                Bertindak untuk dan atas nama <span id="p-p1-company-ref" class="font-semibold">LUMOVELO Agency</span> yang selanjutnya dalam Perjanjian ini disebut sebagai <strong>PIHAK PERTAMA (PIHAK I)</strong>.
              </p>
            </div>

            <!-- Party 2 Details Block -->
            <div class="pl-4 space-y-1">
              <table class="w-full no-border font-serif text-xs">
                <tr>
                  <td class="w-[30%] font-bold">Nama</td>
                  <td class="w-[3%]">:</td>
                  <td><span id="p-p2-name" class="font-bold">Budi Santoso</span></td>
                </tr>
                <tr>
                  <td class="font-bold">Jabatan</td>
                  <td>:</td>
                  <td><span id="p-p2-position">Direktur Utama</span></td>
                </tr>
                <tr>
                  <td class="font-bold">Perusahaan</td>
                  <td>:</td>
                  <td><span id="p-p2-company" class="font-bold">PT. Solusi Digital Abadi</span></td>
                </tr>
                <tr>
                  <td class="font-bold">Alamat</td>
                  <td>:</td>
                  <td><span id="p-p2-address">Gedung Cyber Lantai 4, Jakarta Selatan</span></td>
                </tr>
              </table>
              <p class="pt-2">
                Bertindak untuk dan atas nama <span id="p-p2-company-ref" class="font-semibold">PT. Solusi Digital Abadi</span> yang selanjutnya dalam Perjanjian ini disebut sebagai <strong>PIHAK KEDUA (PIHAK II)</strong>.
              </p>
            </div>

            <p>
              Secara bersama-sama <strong>PIHAK PERTAMA</strong> dan <strong>PIHAK KEDUA</strong> disebut sebagai <strong>PARA PIHAK</strong>. PARA PIHAK sepakat untuk mengadakan kerjasama kemitraan berdasarkan ketentuan dan syarat-syarat yang tertuang dalam pasal-pasal berikut:
            </p>

            <!-- Clauses List -->
            <div id="preview-clauses-container" class="space-y-4">
              <!-- Dynamic preview clauses will go here -->
            </div>

            <!-- Masa Berlaku Clause -->
            <div class="space-y-1">
              <h4 class="font-bold text-center uppercase font-sans text-xs">MASA BERLAKU PERJANJIAN</h4>
              <p>
                Perjanjian Nota Kesepahaman ini berlaku dan mengikat PARA PIHAK untuk jangka waktu selama <span id="p-mou-duration" class="font-semibold">1 (satu) tahun sejak penandatanganan dokumen</span>. Apabila PARA PIHAK ingin memperpanjang kerjasama, maka salah satu pihak wajib menyampaikan pemberitahuan tertulis sekurang-kurangnya 30 (tiga puluh) hari sebelum masa berlaku berakhir.
              </p>
            </div>

            <p>
              Demikian Nota Kesepahaman ini dibuat dan ditandatangani oleh PARA PIHAK pada hari dan tanggal tersebut di atas dalam rangkap 2 (dua) berhimpun materai cukup, yang masing-masing mempunyai kekuatan hukum yang sama.
            </p>
          </div>

          <!-- Signatures Section -->
          <div class="mt-14 text-xs font-serif">
            <div class="flex justify-between" id="p-signature-block">
              <!-- Pihak Pertama Signature Block -->
              <div class="w-[45%] text-center flex flex-col justify-between min-h-[140px]">
                <div>
                  <p class="uppercase font-bold">PIHAK PERTAMA</p>
                  <p id="p-sig-company1" class="font-semibold">LUMOVELO Agency</p>
                </div>
                <div>
                  <p class="font-bold text-blue-800 font-sans tracking-wide text-xs opacity-75 select-none" style="font-family: 'Times New Roman', serif; font-style: italic;">( Tanda Tangan Digital )</p>
                </div>
                <div>
                  <p class="font-bold underline uppercase" id="p-sig-name1">Ahmad Rivaldi</p>
                  <p id="p-sig-pos1">CEO / Co-founder</p>
                </div>
              </div>

              <!-- Pihak Kedua Signature Block -->
              <div class="w-[45%] text-center flex flex-col justify-between min-h-[140px]">
                <div>
                  <p class="uppercase font-bold">PIHAK KEDUA</p>
                  <p id="p-sig-company2" class="font-semibold">PT. Solusi Digital Abadi</p>
                </div>
                <div>
                  <p class="font-bold text-blue-800 font-sans tracking-wide text-xs opacity-75 select-none" style="font-family: 'Times New Roman', serif; font-style: italic;">( Tanda Tangan Digital )</p>
                </div>
                <div>
                  <p class="font-bold underline uppercase" id="p-sig-name2">Budi Santoso</p>
                  <p id="p-sig-pos2">Direktur Utama</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
    </div>
  </div>

  <!-- Print Isolation CSS Styling -->
  <style is:global>
    @media print {
      /* Hide workspace elements */
      .no-print, header, aside, .lg\:hidden {
        display: none !important;
      }
      
      body, html {
        background-color: white !important;
        color: black !important;
        height: auto !important;
        min-height: auto !important;
        overflow: visible !important;
      }

      #preview-panel {
        display: block !important;
        background: transparent !important;
        padding: 0 !important;
        margin: 0 !important;
        overflow: visible !important;
        position: static !important;
        width: 100% !important;
        max-width: 100% !important;
      }

      #paper-preview {
        border: none !important;
        box-shadow: none !important;
        margin: 0 !important;
        padding: 0 !important;
        width: 100% !important;
        max-width: 100% !important;
        min-height: auto !important;
        background: white !important;
        font-size: 11pt !important;
        position: relative !important;
        color: black !important;
      }

      /* Page margins for A4 printing */
      @page {
        size: A4;
        margin: 25mm 20mm 25mm 20mm;
      }
    }
  </style>

  <!-- Client-side Interactive Script -->
  <script>
    import { supabase } from '../../lib/supabase';
    // Templates Presets Data
    const PRESETS = {
      tech: {
        title: "PERJANJIAN KERJASAMA PENGEMBANGAN SOFTWARE DAN PLATFORM AI",
        number: "014/MOU-LUMOVELO/TECH/VI/2026",
        city: "Bandung",
        date: "27 Juni 2026",
        p1Name: "Ahmad Rivaldi",
        p1Pos: "CEO / Co-founder",
        p1Comp: "LUMOVELO Agency",
        p1Addr: "Jl. Dipati Ukur No. 102, Coblong, Kota Bandung",
        p2Name: "Budi Santoso",
        p2Pos: "Direktur Utama",
        p2Comp: "PT. Solusi Digital Abadi",
        p2Addr: "Gedung Cyber Lantai 4, Mampang Prapatan, Jakarta Selatan",
