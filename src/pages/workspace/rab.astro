---
import Logo from '../../components/Logo.astro';
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Premium RAB Builder | LUMOVELO" description="Workspace pembuatan Rencana Anggaran Biaya (RAB) interaktif dengan perhitungan PPN dan diskon otomatis." noindex={true}>
  <div class="min-h-screen bg-slate-950 text-slate-100 flex flex-col font-sans select-none">
    <!-- Header -->
    <header class="border-b border-slate-800 bg-slate-900/80 backdrop-blur-md sticky top-0 z-40 px-6 py-4 flex items-center justify-between no-print">
      <div class="flex items-center gap-3">
        <a href="/" class="flex items-center gap-2 group">
          <div class="w-8 h-8 rounded-lg border border-slate-700 bg-blue-600 flex items-center justify-center shadow-[2px_2px_0px_rgba(37,99,235,0.4)]">
            <Logo class="w-4 h-4 text-white" />
          </div>
          <span class="font-display font-black text-lg tracking-wider text-white">LUMOVELO</span>
        </a>
        <span class="text-xs font-mono px-2 py-1 rounded bg-slate-800 text-slate-400 uppercase tracking-widest">Workspace v1.0</span>
        <a href="/admin/dashboard/" class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-slate-800 hover:bg-slate-700 text-slate-300 hover:text-white text-[10px] font-bold uppercase tracking-wider transition-colors">
          📊 Dashboard
        </a>
      </div>
      
      <!-- Document Selector Dropdown -->
      <div class="relative inline-block text-left" id="doc-selector-dropdown-container">
        <button type="button" id="doc-selector-btn" class="inline-flex justify-between items-center gap-2 px-4 py-2 border border-slate-700 rounded-xl bg-slate-955 text-xs font-bold text-slate-300 hover:text-white hover:border-slate-650 transition-all cursor-pointer select-none">
          <span>📂 WORKSPACE: RAB ANGGARAN BIAYA</span>
          <svg class="w-3.5 h-3.5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div id="doc-selector-menu" class="absolute right-0 mt-2 w-56 rounded-xl border border-slate-800 bg-slate-900 shadow-2xl py-1.5 z-50 hidden transition-all">
          <a href="/workspace/mou/" class="block px-4 py-2 text-xs text-slate-300 hover:text-white hover:bg-slate-800/60 border-b border-slate-800/30">📝 MoU Perjanjian</a>
          <a href="/workspace/spk/" class="block px-4 py-2 text-xs text-slate-300 hover:text-white hover:bg-slate-800/60 border-b border-slate-800/30">🤝 SPK / Kontrak Kerja</a>
          <a href="/workspace/rab/" class="block px-4 py-2 text-xs text-blue-400 bg-slate-800/40 font-bold border-b border-slate-800/30">📊 RAB Anggaran Biaya</a>
          <a href="/workspace/srs/" class="block px-4 py-2 text-xs text-slate-300 hover:text-white hover:bg-slate-800/60 border-b border-slate-800/30">📋 SRS / Lampiran Scope</a>
          <a href="/workspace/invoice/" class="block px-4 py-2 text-xs text-slate-300 hover:text-white hover:bg-slate-800/60 border-b border-slate-800/30">💳 Invoice Penagihan</a>
          <a href="/workspace/kuitansi/" class="block px-4 py-2 text-xs text-slate-300 hover:text-white hover:bg-slate-800/60 border-b border-slate-800/30">🧾 Kuitansi Pembayaran</a>
          <a href="/workspace/bast/" class="block px-4 py-2 text-xs text-slate-300 hover:text-white hover:bg-slate-800/60">📦 BAST Serah Terima</a>
        </div>
      </div>
    </header>

    <!-- Main Workspace -->
    <div class="flex-1 flex flex-col lg:flex-row overflow-hidden">
      <!-- Tabs for Mobile View -->
      <div class="lg:hidden flex border-b border-slate-800 bg-slate-900 no-print">
        <button id="tab-editor" class="flex-1 py-3 text-center text-sm font-bold border-b-2 border-blue-500 text-white bg-slate-900">
          Form Editor
        </button>
        <button id="tab-preview" class="flex-1 py-3 text-center text-sm font-bold border-b-2 border-transparent text-slate-400 bg-slate-900">
          Pratinjau A4
        </button>
      </div>

      <!-- Left Panel: Sidebar Form Editors -->
      <aside id="editor-panel" class="w-full lg:w-[45%] border-r border-slate-800 bg-slate-900/30 overflow-y-auto p-6 space-y-6 block no-print">
        <!-- Preset Selector -->
        <div class="bg-slate-900/80 border border-slate-800 rounded-xl p-4 space-y-3">
          <label class="block text-xs font-mono font-bold tracking-widest text-blue-400 uppercase">PILIH PRESET PROYEK</label>
          <div class="grid grid-cols-3 gap-2">
            <button type="button" id="preset-landing" class="px-2 py-2 rounded-lg bg-blue-600/10 hover:bg-blue-600/20 border border-blue-500/30 text-xs font-bold text-blue-400 transition-all hover:scale-[1.01] cursor-pointer">
              Landing Page
            </button>
            <button type="button" id="preset-ecommerce" class="px-2 py-2 rounded-lg bg-slate-800 hover:bg-slate-700/60 border border-slate-700 text-xs font-bold text-slate-300 transition-all hover:scale-[1.01] cursor-pointer">
              Toko Headless
            </button>
            <button type="button" id="preset-custom" class="px-2 py-2 rounded-lg bg-slate-800 hover:bg-slate-700/60 border border-slate-700 text-xs font-bold text-slate-300 transition-all hover:scale-[1.01] cursor-pointer">
              Enterprise + AI
            </button>
          </div>
        </div>

        <!-- Document Metadata -->
        <div class="space-y-4">
          <h3 class="text-sm font-mono font-bold text-slate-400 border-b border-slate-800 pb-2 uppercase tracking-wider">Metadata Dokumen</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="space-y-1.5">
              <label for="rab-number" class="text-xs font-semibold text-slate-400">Nomor RAB</label>
              <input type="text" id="rab-number" class="w-full bg-slate-900 border border-slate-800 focus:border-blue-500 rounded-lg px-3.5 py-2 text-sm text-white focus:outline-none transition-colors" placeholder="Contoh: 021/RAB-LV/VI/2026" />
            </div>
            <div class="space-y-1.5">
              <label for="rab-date" class="text-xs font-semibold text-slate-400">Tanggal</label>
              <input type="text" id="rab-date" class="w-full bg-slate-900 border border-slate-800 focus:border-blue-500 rounded-lg px-3.5 py-2 text-sm text-white focus:outline-none transition-colors" placeholder="Contoh: 01 Juli 2026" />
            </div>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="space-y-1.5">
              <label for="client-name" class="text-xs font-semibold text-slate-400">Nama Klien</label>
              <input type="text" id="client-name" class="w-full bg-slate-900 border border-slate-800 focus:border-blue-500 rounded-lg px-3.5 py-2 text-sm text-white focus:outline-none transition-colors" placeholder="Nama perwakilan klien" />
            </div>
            <div class="space-y-1.5">
              <label for="client-company" class="text-xs font-semibold text-slate-400">Perusahaan Klien</label>
              <input type="text" id="client-company" class="w-full bg-slate-900 border border-slate-800 focus:border-blue-500 rounded-lg px-3.5 py-2 text-sm text-white focus:outline-none transition-colors" placeholder="Nama instansi klien" />
            </div>
          </div>
          <div class="space-y-1.5">
            <label for="project-name" class="text-xs font-semibold text-slate-400">Nama Proyek</label>
            <input type="text" id="project-name" class="w-full bg-slate-900 border border-slate-800 focus:border-blue-500 rounded-lg px-3.5 py-2 text-sm text-white focus:outline-none transition-colors" placeholder="Contoh: Pembuatan Website E-Commerce Headless" />
          </div>
        </div>

        <!-- Profil Perusahaan & Penandatangan -->
        <div class="space-y-4 bg-slate-900/50 border border-slate-800 rounded-2xl p-4">
          <h3 class="text-sm font-mono font-bold text-slate-400 pb-2 uppercase tracking-wider border-b border-slate-800">Profil Perusahaan & Penandatangan</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="space-y-1.5">
              <label for="comp-name" class="text-xs font-semibold text-slate-400">Nama Perusahaan</label>
              <input type="text" id="comp-name" class="w-full bg-slate-950 border border-slate-800 focus:border-blue-500 rounded-lg px-3.5 py-2 text-sm text-white focus:outline-none transition-colors" value="LUMOVELO" />
            </div>
            <div class="space-y-1.5">
              <label for="comp-ceo" class="text-xs font-semibold text-slate-400">Nama CEO / Penandatangan</label>
              <input type="text" id="comp-ceo" class="w-full bg-slate-950 border border-slate-800 focus:border-blue-500 rounded-lg px-3.5 py-2 text-sm text-white focus:outline-none transition-colors" value="Ahmad Rivaldi" />
            </div>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="space-y-1.5">
              <label for="comp-ceo-title" class="text-xs font-semibold text-slate-400">Jabatan Penandatangan</label>
              <input type="text" id="comp-ceo-title" class="w-full bg-slate-950 border border-slate-800 focus:border-blue-500 rounded-lg px-3.5 py-2 text-sm text-white focus:outline-none transition-colors" value="CEO / Co-founder" />
            </div>
            <div class="space-y-1.5">
              <label for="comp-services" class="text-xs font-semibold text-slate-400">Tagline / Bidang Jasa</label>
              <input type="text" id="comp-services" class="w-full bg-slate-950 border border-slate-800 focus:border-blue-500 rounded-lg px-3.5 py-2 text-sm text-white focus:outline-none transition-colors" value="Jasa Pembuatan Web Performa Tinggi, SEO & Integrasi AI" />
            </div>
          </div>
          <div class="space-y-1.5">
            <label for="comp-address" class="text-xs font-semibold text-slate-400">Alamat Perusahaan</label>
            <input type="text" id="comp-address" class="w-full bg-slate-950 border border-slate-800 focus:border-blue-500 rounded-lg px-3.5 py-2 text-sm text-white focus:outline-none transition-colors" value="Jl. Dipati Ukur No. 102, Coblong, Kota Bandung" />
          </div>
          <div class="space-y-1.5">
            <label for="comp-contact" class="text-xs font-semibold text-slate-400">Kontak (Email & Web)</label>
            <input type="text" id="comp-contact" class="w-full bg-slate-950 border border-slate-800 focus:border-blue-500 rounded-lg px-3.5 py-2 text-sm text-white focus:outline-none transition-colors" value="Email: hello@lumovelo.com | Web: lumovelo.com" />
          </div>
        </div>


        <!-- Budget Items -->
        <div class="space-y-4">
          <div class="flex items-center justify-between border-b border-slate-800 pb-2">
            <h3 class="text-sm font-mono font-bold text-slate-400 uppercase tracking-wider">Item Anggaran</h3>
            <button type="button" id="btn-add-item" class="px-2.5 py-1 rounded bg-blue-600 hover:bg-blue-700 text-white font-bold text-[10px] uppercase tracking-wider flex items-center gap-1 transition-colors cursor-pointer select-none">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
              Tambah Item
            </button>
          </div>

          <!-- Items Container -->
          <div id="items-editor-container" class="space-y-3">
            <!-- Dynamic rows injected here by JS -->
          </div>
        </div>

         <!-- Financial Parameters -->
        <div class="space-y-4 bg-slate-900/50 border border-slate-800 rounded-2xl p-4">
          <h3 class="text-sm font-mono font-bold text-slate-400 pb-2 uppercase tracking-wider border-b border-slate-800">Kalkulasi Tambahan</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="space-y-1.5">
              <label for="discount-percent" class="text-xs font-semibold text-slate-400">Diskon (%)</label>
              <input type="number" id="discount-percent" class="w-full bg-slate-950 border border-slate-800 focus:border-blue-500 rounded-lg px-3.5 py-2 text-sm text-white focus:outline-none transition-colors" value="0" min="0" max="100" />
            </div>
            <div class="space-y-1.5">
              <label for="tax-percent" class="text-xs font-semibold text-slate-400">PPN (%)</label>
              <input type="number" id="tax-percent" class="w-full bg-slate-950 border border-slate-800 focus:border-blue-500 rounded-lg px-3.5 py-2 text-sm text-white focus:outline-none transition-colors" value="0" min="0" max="100" />
            </div>
          </div>
          <div class="space-y-1.5 pt-2">
            <label for="rab-deposit" class="text-xs font-semibold text-slate-400">Sudah Dibayar / DP (Rp)</label>
            <input type="number" id="rab-deposit" class="w-full bg-slate-950 border border-slate-800 focus:border-blue-500 rounded-lg px-3.5 py-2 text-sm text-white focus:outline-none transition-colors" placeholder="Contoh: 500000" value="0" />
          </div>
        </div>

        <!-- Action Buttons -->
        <div class="pt-4 space-y-3">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <button type="button" id="btn-download-pdf" class="w-full flex items-center justify-center gap-2.5 py-4 rounded-xl border-2 border-blue-600 bg-blue-600 hover:bg-blue-700 text-white font-black text-sm uppercase tracking-wider shadow-[4px_4px_0px_#020617] transition-all duration-200 hover:-translate-y-0.5 active:translate-y-0 active:shadow-none cursor-pointer select-none">
              Cetak / Simpan PDF
            </button>
            <button type="button" id="btn-download-word" class="w-full flex items-center justify-center gap-2.5 py-4 rounded-xl border-2 border-slate-700 bg-slate-800 hover:bg-slate-700 text-white font-black text-sm uppercase tracking-wider shadow-[4px_4px_0px_#020617] transition-all duration-200 hover:-translate-y-0.5 active:translate-y-0 active:shadow-none cursor-pointer select-none">
              Unduh Word (.doc)
            </button>
          </div>
          <button type="button" id="btn-save-db" class="w-full flex items-center justify-center gap-2.5 py-4 rounded-xl border-2 border-emerald-600 bg-emerald-600 hover:bg-emerald-700 text-white font-black text-sm uppercase tracking-wider shadow-[4px_4px_0px_#020617] transition-all duration-200 hover:-translate-y-0.5 active:translate-y-0 active:shadow-none cursor-pointer select-none">
            💾 Simpan Ke Database
          </button>
        </div>
      </aside>

      <!-- Right Panel: Live Document Preview (A4 representation) -->
      <section id="preview-panel" class="flex-1 bg-slate-900/20 overflow-y-auto p-4 md:p-8 flex justify-center items-start hidden lg:flex">
        <!-- Paper Container representing A4 -->
        <div id="paper-preview" class="w-full max-w-[210mm] min-h-[297mm] bg-white text-black p-[25mm] shadow-2xl rounded border border-slate-200/50 flex flex-col font-serif relative">
          <!-- Document Header -->
          <div class="flex justify-between items-start border-b-2 border-slate-900 pb-5 mb-8" id="p-header-block">
            <div class="space-y-1">
              <h1 class="text-xl font-bold uppercase tracking-wide text-blue-600 font-sans" id="p-comp-name">LUMOVELO</h1>
              <p class="text-[9px] font-sans text-slate-500 font-semibold leading-relaxed">
                <span id="p-comp-services">Jasa Pembuatan Web Performa Tinggi, SEO & Integrasi AI</span><br>
                <span id="p-comp-address">Jl. Dipati Ukur No. 102, Coblong, Kota Bandung</span><br>
                <span id="p-comp-contact">Email: hello@lumovelo.com | Web: lumovelo.com</span>
              </p>
            </div>
            <div class="text-right">
              <h2 class="text-base font-bold uppercase tracking-widest text-slate-800 font-sans">RENCANA ANGGARAN BIAYA</h2>
              <p class="text-[10px] font-mono text-slate-600 mt-1">NO: <span id="p-rab-number" class="underline">--</span></p>
              <p class="text-[9px] font-mono text-slate-500 mt-0.5">Tanggal: <span id="p-rab-date">--</span></p>
            </div>
          </div>

          <!-- Document Body -->
          <div class="text-xs space-y-6 leading-relaxed text-justify flex-1">
            <!-- Client Info Block -->
            <div class="grid grid-cols-2 gap-4 pb-4 border-b border-slate-100" id="p-client-block">
              <div>
                <span class="text-[9px] font-mono text-slate-500 block uppercase tracking-wider font-bold">KLIEN TUJUAN:</span>
                <p class="font-bold font-sans text-xs mt-1"><span id="p-client-name">--</span></p>
                <p class="text-slate-500 mt-0.5"><span id="p-client-company">--</span></p>
              </div>
              <div class="text-right">
                <span class="text-[9px] font-mono text-slate-500 block uppercase tracking-wider font-bold">NAMA PROYEK:</span>
                <p class="font-bold text-xs mt-1 font-sans text-slate-900 uppercase"><span id="p-project-name">--</span></p>
              </div>
            </div>

            <!-- Budget Table -->
            <div class="pt-4">
              <table class="w-full text-left border-collapse border border-slate-300 text-xs font-sans">
                <thead>
                  <tr class="bg-slate-50 border-b border-slate-300">
                    <th class="p-2.5 border-r border-slate-300 w-8 text-center font-bold">NO</th>
                    <th class="p-2.5 border-r border-slate-300 font-bold">DESKRIPSI PEKERJAAN / LAYANAN</th>
                    <th class="p-2.5 border-r border-slate-300 w-12 text-center font-bold">QTY</th>
                    <th class="p-2.5 border-r border-slate-300 w-16 text-center font-bold">UNIT</th>
                    <th class="p-2.5 border-r border-slate-300 w-24 text-right font-bold">HARGA SATUAN</th>
                    <th class="p-2.5 w-28 text-right font-bold">TOTAL</th>
                  </tr>
                </thead>
                <tbody id="preview-items-body">
                  <!-- Injected via Javascript -->
                </tbody>
                <tfoot>
                  <tr class="border-t border-slate-300">
                    <td colspan="4" class="border-none"></td>
                    <td class="p-2.5 font-bold text-right border border-slate-300">SUBTOTAL</td>
                    <td class="p-2.5 text-right font-bold border border-slate-300" id="p-subtotal">Rp 0</td>
                  </tr>
                  <tr id="row-discount" class="hidden">
                    <td colspan="4" class="border-none"></td>
                    <td class="p-2.5 font-semibold text-right border border-slate-300 text-slate-600">DISKON (<span id="p-discount-percent">0</span>%)</td>
                    <td class="p-2.5 text-right font-semibold border border-slate-300 text-slate-600" id="p-discount-val">Rp 0</td>
                  </tr>
                  <tr id="row-tax" class="hidden">
                    <td colspan="4" class="border-none"></td>
                    <td class="p-2.5 font-semibold text-right border border-slate-300 text-slate-600">PPN (<span id="p-tax-percent">0</span>%)</td>
                    <td class="p-2.5 text-right font-semibold border border-slate-300 text-slate-600" id="p-tax-val">Rp 0</td>
                  </tr>
                  <tr id="row-deposit" class="hidden">
                    <td colspan="4" class="border-none"></td>
                    <td class="p-2.5 font-semibold text-right border border-slate-300 text-slate-600">Sudah Dibayar (DP)</td>
                    <td class="p-2.5 text-right font-semibold border border-slate-300 text-slate-600" id="p-deposit">-Rp 0</td>
                  </tr>
                  <tr class="bg-slate-50 border-t-2 border-slate-900">
                    <td colspan="4" class="border-none"></td>
                    <td class="p-2.5 font-bold text-right border border-slate-300 text-blue-700" id="p-total-label">TOTAL AKHIR</td>
                    <td class="p-2.5 text-right font-bold border border-slate-300 text-blue-700 text-sm font-mono" id="p-total">Rp 0</td>
                  </tr>
                </tfoot>
              </table>
            </div>

            <!-- Signatures Section -->
            <div class="pt-12">
              <div class="flex justify-between items-start mt-8" id="p-signature-block">
                <div class="w-[40%] text-center space-y-14">
                  <div>
                    <p class="text-slate-500 font-sans text-[10px] uppercase font-bold">Disetujui Oleh,</p>
                    <p class="font-bold font-sans text-xs uppercase mt-0.5"><span id="p-sign-client-company">--</span></p>
                  </div>
                  <div>
                    <div class="w-32 h-0.5 bg-black mx-auto"></div>
                    <p class="font-bold text-xs uppercase font-sans mt-1"><span id="p-sign-client-name">--</span></p>
                    <p class="text-[9px] text-slate-500 font-sans">Representatif Klien</p>
                  </div>
                </div>

                <div class="w-[40%] text-center space-y-14">
                  <div>
                    <p class="text-slate-500 font-sans text-[10px] uppercase font-bold">Diajukan Oleh,</p>
                    <p class="font-bold font-sans text-xs uppercase mt-0.5 text-blue-600" id="p-sign-comp-name">LUMOVELO Agency</p>
                  </div>
                  <div>
                    <div class="w-32 h-0.5 bg-black mx-auto"></div>
                    <p class="font-bold text-xs uppercase font-sans mt-1" id="p-sign-ceo-name">Ahmad Rivaldi</p>
                    <p class="text-[9px] text-slate-500 font-sans" id="p-sign-ceo-title">CEO / Co-founder</p>
                  </div>
                </div>
              </div>
            </div>

          </div>
        </div>
      </section>
    </div>
  </div>

  <style is:global>
    /* CSS Print Configurations */
    @media print {
      body * {
        visibility: hidden;
      }
      .no-print {
        display: none !important;
      }
      #preview-panel, #preview-panel * {
        visibility: visible;
      }
      #preview-panel {
        position: absolute;
        left: 0;
        top: 0;
        width: 100% !important;
        height: auto !important;
        padding: 0 !important;
        margin: 0 !important;
        background: white !important;
      }
      #paper-preview {
        box-shadow: none !important;
        border: none !important;
        padding: 0 !important;
        margin: 0 !important;
      }
    }
  </style>

  <script>
    import { supabase } from '../../lib/supabase';
    const presets = {
      landing: {
        number: '018/RAB-LV/VI/2026',
        clientName: 'Budi Santoso',
        clientCompany: 'HijabStyle Indonesia',
        projectName: 'Pembuatan Landing Page Penjualan Konversi Tinggi',
        tax: 0,
        discount: 10,
        deposit: 0,
        items: [
          { desc: 'Desain Wireframe & Layout UI/UX Prototyping Figma', qty: 1, unit: 'Paket', price: 500000 },
          { desc: 'Development Frontend Framework Astro (Sub-detik Loading)', qty: 1, unit: 'Paket', price: 1200000 },
          { desc: 'Integrasi Saluran Kontak Formulir ke API Chat WhatsApp', qty: 1, unit: 'Paket', price: 300000 },
          { desc: 'Setup Serverless Deployment CDN Edge (Vercel Permanent Free)', qty: 1, unit: 'Paket', price: 200000 }
        ]
      },
      ecommerce: {
        number: '019/RAB-LV/VI/2026',
        clientName: 'Anita Wijaya',
        clientCompany: 'PT. EduTech Nusantara',
        projectName: 'Website Toko Online Headless Terintegrasi Shopify',
        tax: 11,
        discount: 0,
        deposit: 0,
        items: [
          { desc: 'Desain Kustom E-Commerce Premium UI/UX (Mode Gelap)', qty: 1, unit: 'Paket', price: 1500000 },
          { desc: 'Koding Toko Online Kecepatan Tinggi (Astro + Tailwind CSS)', qty: 1, unit: 'Paket', price: 2500000 },
          { desc: 'Integrasi Headless API Keranjang Belanja Shopify Storefront', qty: 1, unit: 'Paket', price: 1000000 },
          { desc: 'Dashboard CMS Kustom (Sanity Studio) untuk Update Stok', qty: 1, unit: 'Paket', price: 800000 },
          { desc: 'Setup Domain, SSL Keamanan, & CDN Global (Cloudflare)', qty: 1, unit: 'Paket', price: 500000 }
        ]
      },
      custom: {
        number: '020/RAB-LV/VI/2026',
        clientName: 'Hendra Wijaya',
        clientCompany: 'AutoParts Indo Corp',
        projectName: 'Sistem Kustom Portal Klien + Integrasi Otomatisasi AI',
        tax: 11,
        discount: 5,
        deposit: 2000000,
        items: [
          { desc: 'Desain Sistem UI/UX Dashboard Panel & Portal Manajemen Klien', qty: 1, unit: 'Paket', price: 2500000 },
          { desc: 'Development Full-stack Web Portal App (NextJS / React / Node)', qty: 1, unit: 'Paket', price: 6500000 },
          { desc: 'Pembuatan Agen AI Otonom untuk Penulisan Konten Blog Otomatis', qty: 1, unit: 'Paket', price: 4000000 },
          { desc: 'Integrasi WhatsApp Auto-Responder & Bot CRM Terpadu', qty: 1, unit: 'Paket', price: 2500000 }
        ]
      }
    };

    let currentItems: { desc: string; qty: number; unit: string; price: number }[] = [];

    // Elements
    const rabNumInput = document.getElementById('rab-number') as HTMLInputElement;
    const rabDateInput = document.getElementById('rab-date') as HTMLInputElement;
    const clientNameInput = document.getElementById('client-name') as HTMLInputElement;
    const clientCompanyInput = document.getElementById('client-company') as HTMLInputElement;
    const projNameInput = document.getElementById('project-name') as HTMLInputElement;
    const discountInput = document.getElementById('discount-percent') as HTMLInputElement;
    const taxInput = document.getElementById('tax-percent') as HTMLInputElement;
    const rabDepositInput = document.getElementById('rab-deposit') as HTMLInputElement;
    const itemsContainer = document.getElementById('items-editor-container') as HTMLDivElement;
    const btnAddItem = document.getElementById('btn-add-item') as HTMLButtonElement;

    // Preview Elements
    const pRabNum = document.getElementById('p-rab-number') as HTMLSpanElement;
    const pRabDate = document.getElementById('p-rab-date') as HTMLSpanElement;
    const pClientName = document.getElementById('p-client-name') as HTMLSpanElement;
    const pClientCompany = document.getElementById('p-client-company') as HTMLSpanElement;
    const pProjName = document.getElementById('p-project-name') as HTMLSpanElement;
    const pSubtotal = document.getElementById('p-subtotal') as HTMLSpanElement;
    const pTotal = document.getElementById('p-total') as HTMLSpanElement;
    const pDiscountPercent = document.getElementById('p-discount-percent') as HTMLSpanElement;
    const pDiscountVal = document.getElementById('p-discount-val') as HTMLSpanElement;
    const pTaxPercent = document.getElementById('p-tax-percent') as HTMLSpanElement;
    const pTaxVal = document.getElementById('p-tax-val') as HTMLSpanElement;
    const pDeposit = document.getElementById('p-deposit') as HTMLSpanElement;
    const pTotalLabel = document.getElementById('p-total-label') as HTMLTableCellElement;
    const pSignClientCompany = document.getElementById('p-sign-client-company') as HTMLSpanElement;
    const pSignClientName = document.getElementById('p-sign-client-name') as HTMLSpanElement;

    // Company Profile Inputs
    const compNameInput = document.getElementById('comp-name') as HTMLInputElement;
    const compServicesInput = document.getElementById('comp-services') as HTMLInputElement;
    const compAddressInput = document.getElementById('comp-address') as HTMLInputElement;
    const compContactInput = document.getElementById('comp-contact') as HTMLInputElement;
    const compCeoInput = document.getElementById('comp-ceo') as HTMLInputElement;
    const compCeoTitleInput = document.getElementById('comp-ceo-title') as HTMLInputElement;

    // Company Profile Preview Spans
    const pCompName = document.getElementById('p-comp-name') as HTMLHeadingElement;
    const pCompServices = document.getElementById('p-comp-services') as HTMLSpanElement;
    const pCompAddress = document.getElementById('p-comp-address') as HTMLSpanElement;
    const pCompContact = document.getElementById('p-comp-contact') as HTMLSpanElement;
    const pSignCompName = document.getElementById('p-sign-comp-name') as HTMLSpanElement;
    const pSignCeoName = document.getElementById('p-sign-ceo-name') as HTMLSpanElement;
    const pSignCeoTitle = document.getElementById('p-sign-ceo-title') as HTMLSpanElement;

    const rowDiscount = document.getElementById('row-discount') as HTMLTableRowElement;
    const rowTax = document.getElementById('row-tax') as HTMLTableRowElement;
    const rowDeposit = document.getElementById('row-deposit') as HTMLTableRowElement;

    function formatRupiah(num: number): string {
      return 'Rp ' + num.toLocaleString('id-ID');
    }

    function calculateRAB() {
      let subtotal = 0;
      currentItems.forEach(item => {
        subtotal += item.qty * item.price;
      });

      const discPercent = parseFloat(discountInput.value) || 0;
      const discountVal = subtotal * (discPercent / 100);

      const subtotalAfterDisc = subtotal - discountVal;

      const taxPercent = parseFloat(taxInput.value) || 0;
      const taxVal = subtotalAfterDisc * (taxPercent / 100);

      const deposit = parseFloat(rabDepositInput.value) || 0;

      const total = subtotalAfterDisc + taxVal - deposit;

      // Update Preview Numbers
      pSubtotal.innerText = formatRupiah(subtotal);
      
      if (discPercent > 0) {
        rowDiscount.classList.remove('hidden');
        pDiscountPercent.innerText = discPercent.toString();
        pDiscountVal.innerText = formatRupiah(discountVal);
      } else {
        rowDiscount.classList.add('hidden');
      }

      if (taxPercent > 0) {
        rowTax.classList.remove('hidden');
        pTaxPercent.innerText = taxPercent.toString();
        pTaxVal.innerText = formatRupiah(taxVal);
      } else {
        rowTax.classList.add('hidden');
      }

      if (deposit > 0) {
        if (rowDeposit) rowDeposit.classList.remove('hidden');
        if (pDeposit) pDeposit.innerText = '- ' + formatRupiah(deposit);
        if (pTotalLabel) pTotalLabel.innerText = 'TOTAL SISA ANGGARAN';
      } else {
        if (rowDeposit) rowDeposit.classList.add('hidden');
        if (pTotalLabel) pTotalLabel.innerText = 'TOTAL AKHIR';
      }

      pTotal.innerText = formatRupiah(total);
    }

    function renderItemsEditor() {
      itemsContainer.innerHTML = '';
      currentItems.forEach((item, index) => {
        const row = document.createElement('div');
        row.className = "flex gap-2.5 items-center bg-slate-900/60 p-3 rounded-lg border border-slate-800 relative group";
        row.innerHTML = `
          <div class="flex-1 grid grid-cols-1 md:grid-cols-12 gap-2">
            <input type="text" class="item-desc bg-slate-950 border border-slate-800 rounded px-2.5 py-1 text-xs text-white focus:outline-none col-span-6" value="${item.desc}" placeholder="Deskripsi item pekerjaan" data-index="${index}" />
            <input type="number" class="item-qty bg-slate-950 border border-slate-800 rounded px-2.5 py-1 text-xs text-white focus:outline-none text-center col-span-2" value="${item.qty}" placeholder="Qty" data-index="${index}" min="1" />
            <input type="text" class="item-unit bg-slate-950 border border-slate-800 rounded px-2.5 py-1 text-xs text-white focus:outline-none text-center col-span-2" value="${item.unit}" placeholder="Unit" data-index="${index}" />
            <input type="number" class="item-price bg-slate-950 border border-slate-800 rounded px-2.5 py-1 text-xs text-white focus:outline-none text-right col-span-2" value="${item.price}" placeholder="Harga" data-index="${index}" />
          </div>
          <button type="button" class="btn-delete-item text-rose-500 hover:text-rose-400 p-1 cursor-pointer select-none" data-index="${index}">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
          </button>
        `;
        itemsContainer.appendChild(row);
      });

      // Bind Listeners
      document.querySelectorAll('.item-desc').forEach(el => {
        el.addEventListener('input', (e) => {
          const idx = parseInt((e.target as HTMLInputElement).getAttribute('data-index')!);
          currentItems[idx].desc = (e.target as HTMLInputElement).value;
          updatePreviewTable();
        });
      });
      document.querySelectorAll('.item-qty').forEach(el => {
        el.addEventListener('input', (e) => {
          const idx = parseInt((e.target as HTMLInputElement).getAttribute('data-index')!);
          currentItems[idx].qty = parseInt((e.target as HTMLInputElement).value) || 1;
          updatePreviewTable();
          calculateRAB();
        });
      });
      document.querySelectorAll('.item-unit').forEach(el => {
        el.addEventListener('input', (e) => {
          const idx = parseInt((e.target as HTMLInputElement).getAttribute('data-index')!);
          currentItems[idx].unit = (e.target as HTMLInputElement).value;
          updatePreviewTable();
        });
      });
      document.querySelectorAll('.item-price').forEach(el => {
        el.addEventListener('input', (e) => {
          const idx = parseInt((e.target as HTMLInputElement).getAttribute('data-index')!);
          currentItems[idx].price = parseFloat((e.target as HTMLInputElement).value) || 0;
          updatePreviewTable();
          calculateRAB();
        });
      });
      document.querySelectorAll('.btn-delete-item').forEach(el => {
        el.addEventListener('click', (e) => {
          const btn = e.currentTarget as HTMLButtonElement;
          const idx = parseInt(btn.getAttribute('data-index')!);
          currentItems.splice(idx, 1);
          renderItemsEditor();
          updatePreviewTable();
          calculateRAB();
        });
      });
    }

    function updatePreviewTable() {
      const tbody = document.getElementById('preview-items-body') as HTMLTableSectionElement;
      tbody.innerHTML = '';
      currentItems.forEach((item, idx) => {
        const row = document.createElement('tr');
        row.className = "border-b border-slate-200";
        row.innerHTML = `
          <td class="p-2.5 border-r border-slate-300 text-center font-mono text-[10px]">${idx + 1}</td>
          <td class="p-2.5 border-r border-slate-300 font-sans font-semibold text-slate-800">${item.desc || '--'}</td>
          <td class="p-2.5 border-r border-slate-300 text-center tabular-nums font-mono text-slate-800">${item.qty}</td>
          <td class="p-2.5 border-r border-slate-300 text-center text-slate-800">${item.unit || '--'}</td>
          <td class="p-2.5 border-r border-slate-300 text-right tabular-nums font-mono text-slate-800">${formatRupiah(item.price)}</td>
          <td class="p-2.5 text-right font-bold tabular-nums font-mono text-slate-800">${formatRupiah(item.qty * item.price)}</td>
        `;
        tbody.appendChild(row);
      });
    }

    function updateMetadataPreview() {
      pRabNum.innerText = rabNumInput.value || '--';
      pRabDate.innerText = rabDateInput.value || '--';
      pClientName.innerText = clientNameInput.value || '--';
      pClientCompany.innerText = clientCompanyInput.value || '--';
      pProjName.innerText = projNameInput.value || '--';
      pSignClientCompany.innerText = clientCompanyInput.value || 'Perusahaan Klien';
      pSignClientName.innerText = clientNameInput.value || 'Nama Representatif';

      // Update Company Profile
      if (pCompName) pCompName.innerText = compNameInput.value || '--';
      if (pCompServices) pCompServices.innerText = compServicesInput.value || '--';
      if (pCompAddress) pCompAddress.innerText = compAddressInput.value || '--';
      if (pCompContact) pCompContact.innerText = compContactInput.value || '--';
      if (pSignCompName) pSignCompName.innerText = compNameInput.value || '--';
      if (pSignCeoName) pSignCeoName.innerText = compCeoInput.value || '--';
      if (pSignCeoTitle) pSignCeoTitle.innerText = compCeoTitleInput.value || '--';
    }

    function loadPreset(key: 'landing' | 'ecommerce' | 'custom') {
      const config = presets[key];
      rabNumInput.value = config.number;
      clientNameInput.value = config.clientName;
      clientCompanyInput.value = config.clientCompany;
      projNameInput.value = config.projectName;
      discountInput.value = config.discount.toString();
      taxInput.value = config.tax.toString();
      rabDepositInput.value = (config.deposit !== undefined ? config.deposit : 0).toString();

      // Current Date
      const today = new Date();
      const monthNames = ["Januari", "Februari", "Maret", "April", "Mei", "Juni", "Juli", "Agustus", "September", "Oktober", "November", "Desember"];
      rabDateInput.value = `${today.getDate()} ${monthNames[today.getMonth()]} ${today.getFullYear()}`;

      currentItems = JSON.parse(JSON.stringify(config.items));

      renderItemsEditor();
      updatePreviewTable();
      updateMetadataPreview();
      calculateRAB();

      // Update Preset Button Active Styles
      const btnLanding = document.getElementById('preset-landing') as HTMLButtonElement;
      const btnEcommerce = document.getElementById('preset-ecommerce') as HTMLButtonElement;
      const btnCustom = document.getElementById('preset-custom') as HTMLButtonElement;
      [btnLanding, btnEcommerce, btnCustom].forEach(btn => {
        btn.className = "px-2 py-2 rounded-lg bg-slate-800 hover:bg-slate-700/60 border border-slate-700 text-xs font-bold text-slate-300 transition-all hover:scale-[1.01] cursor-pointer";
      });
      document.getElementById(`preset-${key}`)!.className = "px-2 py-2 rounded-lg bg-blue-600/10 hover:bg-blue-600/20 border border-blue-500/30 text-xs font-bold text-blue-400 transition-all hover:scale-[1.01] cursor-pointer";
    }

    // Bind Metadata Inputs
    [rabNumInput, rabDateInput, clientNameInput, clientCompanyInput, projNameInput, compNameInput, compServicesInput, compAddressInput, compContactInput, compCeoInput, compCeoTitleInput].forEach(inputEl => {
      inputEl.addEventListener('input', updateMetadataPreview);
    });

    [discountInput, taxInput, rabDepositInput].forEach(calcEl => {
      calcEl.addEventListener('input', calculateRAB);
    });

    btnAddItem.addEventListener('click', () => {
      currentItems.push({ desc: '', qty: 1, unit: 'Unit', price: 0 });
      renderItemsEditor();
      updatePreviewTable();
      calculateRAB();
    });

    // Preset Clicks
    document.getElementById('preset-landing')!.addEventListener('click', () => loadPreset('landing'));
    document.getElementById('preset-ecommerce')!.addEventListener('click', () => loadPreset('ecommerce'));
    document.getElementById('preset-custom')!.addEventListener('click', () => loadPreset('custom'));

    // Print PDF Action
    document.getElementById('btn-download-pdf')!.addEventListener('click', () => {
      window.print();
    });

    // Word Export Action (.doc)
    document.getElementById('btn-download-word')!.addEventListener('click', () => {
      const filename = `RAB-${clientCompanyInput.value.replace(/\s+/g, '_') || 'LUMOVELO'}.doc`;
      const content = document.getElementById('paper-preview')!.innerHTML;

      const tempDiv = document.createElement('div');
      tempDiv.innerHTML = content;

      // 1. Convert Header flex layout to table
      const headerBlock = tempDiv.querySelector('#p-header-block');
      if (headerBlock) {
        const leftCol = headerBlock.children[0]?.innerHTML || '';
        const rightCol = headerBlock.children[1]?.innerHTML || '';
        headerBlock.outerHTML = `
          <table style="width: 100%; border-bottom: 2px solid #000; padding-bottom: 15px; margin-bottom: 25px; border-collapse: collapse;">
            <tr style="border: none !important;">
              <td style="width: 50%; vertical-align: top; text-align: left; border: none !important;">${leftCol}</td>
              <td style="width: 50%; vertical-align: top; text-align: right; border: none !important;">${rightCol}</td>
            </tr>
          </table>
        `;
      }

      // 2. Convert Client block layout to table
      const clientBlock = tempDiv.querySelector('#p-client-block');
      if (clientBlock) {
        const leftCol = clientBlock.children[0]?.innerHTML || '';
        const rightCol = clientBlock.children[1]?.innerHTML || '';
        clientBlock.outerHTML = `
          <table style="width: 100%; border-bottom: 1px solid #cbd5e1; padding-bottom: 10px; margin-bottom: 20px; border-collapse: collapse;">
            <tr style="border: none !important;">
              <td style="width: 50%; vertical-align: top; text-align: left; border: none !important;">${leftCol}</td>
              <td style="width: 50%; vertical-align: top; text-align: right; border: none !important;">${rightCol}</td>
            </tr>
          </table>
        `;
      }

      // 3. Convert Signature block layout to table
      const signatureBlock = tempDiv.querySelector('#p-signature-block');
      if (signatureBlock) {
        const leftCol = signatureBlock.children[0]?.innerHTML || '';
        const rightCol = signatureBlock.children[1]?.innerHTML || '';
        signatureBlock.outerHTML = `
          <table style="width: 100%; margin-top: 30px; border-collapse: collapse;">
            <tr style="border: none !important;">
              <td style="width: 45%; text-align: center; vertical-align: top; border: none !important;">${leftCol}</td>
              <td style="width: 10%; border: none !important;"></td>
              <td style="width: 45%; text-align: center; vertical-align: top; border: none !important;">${rightCol}</td>
            </tr>
          </table>
        `;
      }

      const finalHtmlContent = tempDiv.innerHTML;

      const wordHtmlHeader = `<html xmlns:o='urn:schemas-microsoft-com:office:office' xmlns:w='urn:schemas-microsoft-com:office:word' xmlns='http://www.w3.org/TR/REC-html40'>
      <head>
      <title>Rencana Anggaran Biaya (RAB)</title>
      <!--[if gte mso 9]>
      <xml>
      <w:WordDocument>
        <w:View>Print</w:View>
        <w:Zoom>90</w:Zoom>
      </w:WordDocument>
      </xml>
      <![endif]-->
      <style>
        @page Section1 {
          size: 595.3pt 841.9pt; /* A4 size */
          margin: 72.0pt 72.0pt 72.0pt 72.0pt;
          mso-header-margin: 35.4pt;
          mso-footer-margin: 35.4pt;
          mso-paper-source: 0;
        }
        div.Section1 { page: Section1; }
        body { font-family: 'Times New Roman', serif; font-size: 11pt; line-height: 1.25; }
        table { width: 100%; border-collapse: collapse; margin-top: 10px; margin-bottom: 10px; }
        th, td { border: 1px solid #cbd5e1; padding: 6px; font-size: 10pt; vertical-align: top; }
        th { background-color: #f8fafc; font-weight: bold; }
        .text-center { text-align: center; }
        .text-right { text-align: right; }
        .font-sans { font-family: 'Arial', sans-serif; }
        .font-bold { font-weight: bold; }
        .underline { text-decoration: underline; }
        .uppercase { text-transform: uppercase; }
        .text-blue-600 { color: #2563eb; }
        .text-blue-700 { color: #1d4ed8; }
        .text-slate-500 { color: #64748b; }
        .text-slate-650 { color: #475569; }
        .bg-slate-50 { background-color: #f8fafc; }
        .border-b-2 { border-bottom: 2px solid #000; }
        .border-t-2 { border-top: 2px solid #000; }
      </style>
      </head>
      <body>
      <div class="Section1">
        ${finalHtmlContent}
      </div>
      </body>
      </html>`;

      const blob = new Blob(['\ufeff' + wordHtmlHeader], { type: 'application/msword' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = filename;
      a.click();
      URL.revokeObjectURL(url);
    });

    // Mobile View Tab Switching
    const tabEditor = document.getElementById('tab-editor');
    const tabPreview = document.getElementById('tab-preview');
    const editorPanel = document.getElementById('editor-panel');
    const previewPanel = document.getElementById('preview-panel');

    tabEditor.addEventListener('click', () => {
      tabEditor.classList.add('border-blue-500', 'text-white');
      tabEditor.classList.remove('border-transparent', 'text-slate-400');
      tabPreview.classList.add('border-transparent', 'text-slate-400');
      tabPreview.classList.remove('border-blue-500', 'text-white');
      
      editorPanel.classList.remove('hidden');
      editorPanel.classList.add('block');
      previewPanel.classList.add('hidden');
      previewPanel.classList.remove('flex');
    });

    tabPreview.addEventListener('click', () => {
      tabPreview.classList.add('border-blue-500', 'text-white');
      tabPreview.classList.remove('border-transparent', 'text-slate-400');
      tabEditor.classList.add('border-transparent', 'text-slate-400');
      tabEditor.classList.remove('border-blue-500', 'text-white');
      
      previewPanel.classList.remove('hidden');
      previewPanel.classList.add('flex');
      editorPanel.classList.add('hidden');
      editorPanel.classList.remove('block');
    });

    // Document Selector Dropdown Toggle
    const docBtn = document.getElementById('doc-selector-btn');
    const docMenu = document.getElementById('doc-selector-menu');
    if (docBtn && docMenu) {
      docBtn.onclick = (e) => {
        e.stopPropagation();
        docMenu.classList.toggle('hidden');
      };
      document.addEventListener('click', () => {
        docMenu.classList.add('hidden');
      });
    }

    const btnSaveDb = document.getElementById('btn-save-db') as HTMLButtonElement;

    btnSaveDb.addEventListener('click', async () => {
      btnSaveDb.disabled = true;
      btnSaveDb.innerText = 'MENYIMPAN...';

      const docNum = (document.getElementById('rab-number') as HTMLInputElement).value.trim();
      const clientName = (document.getElementById('client-name') as HTMLInputElement).value.trim();
      const clientCompany = (document.getElementById('client-company') as HTMLInputElement).value.trim();
      
      const rawText = document.getElementById('p-total')!.innerText;
      const amount = parseFloat(rawText.replace(/[^\d]/g, '')) || 0;
      
      const docDate = (document.getElementById('rab-date') as HTMLInputElement).value;

      try {
        const { error } = await supabase
          .from('documents')
          .upsert({
            doc_type: 'rab',
            doc_number: docNum,
            client_name: clientName,
            client_company: clientCompany,
            amount: amount,
            status: 'draft',
            doc_date: docDate,
            deadline: null,
            doc_data: {
              project_name: (document.getElementById('spk-project') as HTMLInputElement).value,
              items: currentItems,
              discount: parseFloat((document.getElementById('discount-percent') as HTMLInputElement).value) || 0,
              tax: parseFloat((document.getElementById('tax-percent') as HTMLInputElement).value) || 0,
              deposit: parseFloat((document.getElementById('rab-deposit') as HTMLInputElement).value) || 0
            }
          }, { onConflict: 'doc_number' });

        if (error) throw error;
        showToast('RAB berhasil disimpan ke database!', 'success');
      } catch (err: any) {
        showToast(err.message || 'Gagal menyimpan RAB.', 'error');
      } finally {
        btnSaveDb.disabled = false;
        btnSaveDb.innerText = '💾 Simpan Ke Database';
      }
    });

    // Init
    loadPreset('landing');
  </script>
</Layout>
