---
import Layout from '../../layouts/Layout.astro';
import Logo from '../../components/Logo.astro';
---

<Layout title="Laporan Keuangan | LUMOVELO" description="Kelola dan ekspor data laporan keuangan Lumovelo." noindex={true}>
  <div id="admin-layout" class="hidden min-h-screen dashboard-root grain flex">
    
    <!-- Sidebar Navigation -->
    <aside class="hidden lg:flex w-[248px] shrink-0 flex-col border-r border-[#1A1A1E] bg-[#0C0C0E]">
      <!-- Logo -->
      <div class="px-5 pt-6 pb-7 flex items-center gap-2.5">
        <div class="w-8 h-8 rounded-lg flex items-center justify-center bg-[#C5F82A]">
          <Logo class="w-4 h-4 text-[#0A0A0B]" />
        </div>
        <div class="flex items-baseline gap-1.5">
          <span class="font-semibold tracking-tight text-[15px] text-white">LUMOVELO</span>
          <span class="mono text-[10px] text-[#5C5C63]">v2.4</span>
        </div>
      </div>

      <!-- Workspace switcher -->
      <div class="px-3 mb-5">
        <div class="w-full flex items-center gap-2.5 px-2.5 py-2 rounded-lg border border-[#232328] bg-[#131316]">
          <div class="w-6 h-6 rounded-md flex items-center justify-center text-[10px] font-bold bg-[#2A2A30] text-[#C5F82A]">LV</div>
          <div class="flex-1 min-w-0">
            <div class="text-[12px] font-medium leading-tight text-white">Lumovelo Agency</div>
            <div class="text-[10px] mono text-[#5C5C63]">workspace · admin</div>
          </div>
        </div>
      </div>

      <!-- Nav -->
      <nav class="px-3 flex-1 overflow-y-auto scroll-thin" id="nav">
        <div class="px-2.5 mb-1.5 mono text-[10px] uppercase tracking-wider text-[#5C5C63]">Analytics</div>
        <a href="/admin/dashboard/" class="nav-item flex items-center gap-3 px-2.5 py-2 rounded-md text-[13px] text-[#8A8A90]">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="7" height="9" rx="1"/><rect x="14" y="3" width="7" height="5" rx="1"/><rect x="14" y="12" width="7" height="9" rx="1"/><rect x="3" y="16" width="7" height="5" rx="1"/></svg>
          Overview
        </a>
        <a href="/admin/finance/" class="nav-item active flex items-center gap-3 px-2.5 py-2 rounded-md text-[13px] text-[#F4F4F2]">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 3v18h18"/><path d="M7 14l4-4 3 3 5-6"/></svg>
          Revenue
        </a>
        <a href="/admin/profit-sharing/" class="nav-item flex items-center gap-3 px-2.5 py-2 rounded-md text-[13px] text-[#8A8A90]">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="9" cy="8" r="4"/><path d="M3 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2"/><circle cx="17" cy="6" r="2.5"/><path d="M14 21v-1a3 3 0 0 1 3-3h0a3 3 0 0 1 3 3v1"/></svg>
          Bagi Hasil Tim
        </a>
        <a href="/admin/blog/" class="nav-item flex items-center gap-3 px-2.5 py-2 rounded-md text-[13px] text-[#8A8A90]">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 2v20M2 12h20"/><circle cx="12" cy="12" r="9"/></svg>
          Kelola Blog
        </a>
        <a href="/admin/leads/" class="nav-item flex items-center gap-3 px-2.5 py-2 rounded-md text-[13px] text-[#8A8A90]">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="shrink-0"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          Leads AI
        </a>
        <a href="/admin/ai-settings/" class="nav-item flex items-center gap-3 px-2.5 py-2 rounded-md text-[13px] text-[#8A8A90]">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
          Pengaturan AI
        </a>

        <div class="px-2.5 mb-1.5 mt-5 mono text-[10px] uppercase tracking-wider text-[#5C5C63]">Workspace</div>
        <a href="/workspace/invoice/" class="nav-item flex items-center gap-3 px-2.5 py-2 rounded-md text-[13px] text-[#8A8A90]">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 9h6v6H9z"/></svg>
          Buat Invoice
        </a>
      </nav>

      <!-- User logout footer -->
      <div class="px-3 pb-4 pt-1 border-t border-[#1A1A1E]">
        <button id="btn-logout" class="w-full flex items-center gap-2.5 px-2 py-2 rounded-md hover:bg-[#16161A] transition text-left group">
          <div class="w-8 h-8 rounded-full flex items-center justify-center text-[11px] font-semibold bg-[#2A2A30] text-[#F4F4F2]">AD</div>
          <div class="flex-1 min-w-0">
            <div class="text-[12px] font-medium leading-tight text-white group-hover:text-[#F87171] transition-colors">Sign Out</div>
            <div class="text-[10px] mono text-[#5C5C63]">administrator</div>
          </div>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-[#8A8A90] group-hover:text-[#F87171] transition-colors"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        </button>
      </div>
    </aside>

    <!-- Main Content Area -->
    <main class="flex-1 min-w-0 flex flex-col">
      <!-- Top bar -->
      <header class="sticky top-0 z-20 flex items-center gap-3 px-4 lg:px-8 h-16 border-b border-[#1A1A1E] backdrop-blur-md bg-[rgba(10,10,11,0.78)]">
        <button class="lg:hidden p-2 rounded-md hover:bg-[#16161A] text-white">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
        </button>
        <div class="hidden md:flex items-center gap-2 text-[13px] text-[#8A8A90]">
          <span>Lumovelo</span>
          <span class="text-[#5C5C63]">/</span>
          <span class="text-[#F4F4F2] font-medium">Laporan Keuangan</span>
        </div>

        <div class="ml-auto flex items-center gap-3">
          <button id="btn-add-trx" class="flex items-center gap-1.5 h-9 px-3 rounded-lg text-[12px] font-semibold bg-[#C5F82A] text-[#0A0A0B] hover:opacity-90 transition-opacity cursor-pointer">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg>
            Tambah Transaksi
          </button>
          <button id="btn-export" class="flex items-center gap-1.5 h-9 px-3 rounded-lg text-[12px] font-semibold bg-[#131316] border border-[#232328] text-white hover:bg-[#18181C] transition-colors cursor-pointer">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>
            Ekspor (CSV)
          </button>
        </div>
      </header>

      <!-- Content -->
      <div class="flex-1 overflow-y-auto scroll-thin px-4 lg:px-8 py-7">
        <!-- Page header -->
        <section class="mb-6">
          <div class="flex items-center gap-2 mb-2">
            <span class="live-dot w-1.5 h-1.5 rounded-full bg-[#C5F82A]"></span>
            <span class="mono text-[11px] uppercase tracking-wider text-[#8A8A90]">MODUL ADMINISTRASI KEUANGAN</span>
          </div>
          <h1 class="serif text-[44px] leading-[0.95] text-white">Laporan Keuangan</h1>
          <p class="mt-2 text-[14px] text-[#8A8A90]">Kelola, catat, saring, dan ekspor seluruh log transaksi proyek client agensi.</p>
        </section>

        <!-- Filters Row -->
        <section class="grid grid-cols-1 sm:grid-cols-3 gap-4 bg-[#131316] p-4 border border-[#232328] rounded-2xl mb-6">
          <div class="space-y-1">
            <label for="filter-status" class="text-[10px] font-mono font-bold text-[#8A8A90] uppercase tracking-wider">Saring Status</label>
            <select id="filter-status" class="w-full bg-[#0A0A0B] border border-[#232328] focus:border-[#C5F82A] rounded-xl px-3 py-2 text-xs text-white focus:outline-none transition-colors">
              <option value="ALL">SEMUA STATUS</option>
              <option value="PAID">LUNAS (PAID)</option>
              <option value="UNPAID">BELUM DIBAYAR (UNPAID)</option>
              <option value="OVERDUE">JATUH TEMPO (OVERDUE)</option>
            </select>
          </div>
          <div class="space-y-1">
            <label for="filter-type" class="text-[10px] font-mono font-bold text-[#8A8A90] uppercase tracking-wider">Saring Dokumen</label>
            <select id="filter-type" class="w-full bg-[#0A0A0B] border border-[#232328] focus:border-[#C5F82A] rounded-xl px-3 py-2 text-xs text-white focus:outline-none transition-colors">
              <option value="ALL">SEMUA JENIS DOKUMEN</option>
              <option value="invoice">INVOICE PENAGIHAN</option>
              <option value="mou">MOU PERJANJIAN</option>
              <option value="spk">SPK KONTRAK KERJA</option>
              <option value="kuitansi">KUITANSI PEMBAYARAN</option>
            </select>
          </div>
          <div class="space-y-1">
            <label for="search-client" class="text-[10px] font-mono font-bold text-[#8A8A90] uppercase tracking-wider">Cari Klien / Perusahaan</label>
            <input type="text" id="search-client" class="w-full bg-[#0A0A0B] border border-[#232328] focus:border-[#C5F82A] rounded-xl px-3 py-2 text-xs text-white focus:outline-none transition-colors" placeholder="Ketik nama klien..." />
          </div>
        </section>

        <!-- Transactions Table -->
        <section class="card overflow-hidden border border-[#232328]">
          <div class="overflow-x-auto scroll-thin">
            <table class="w-full text-[13px]">
              <thead>
                <tr class="text-[10px] mono uppercase tracking-wider text-[#5C5C63] bg-[#0E0E11]">
                  <th class="px-5 py-3 text-left font-medium">Klien</th>
                  <th class="px-3 py-3 text-left font-medium">Kontak</th>
                  <th class="px-3 py-3 text-left font-medium">Tgl Pesan</th>
                  <th class="px-3 py-3 text-left font-medium">Deadline</th>
                  <th class="px-3 py-3 text-left font-medium">Keterangan Tugas</th>
                  <th class="px-3 py-3 text-left font-medium">Eksekutor</th>
                  <th class="px-3 py-3 text-left font-medium">Status</th>
                  <th class="px-3 py-3 text-left font-medium">Total Nilai</th>
                  <th class="px-5 py-3 text-right font-medium">Aksi</th>
                </tr>
              </thead>
              <tbody id="finance-table-body" class="divide-y divide-[#1A1A1E] text-[#8A8A90]">
                <tr>
                  <td colspan="9" class="p-8 text-center text-[#5C5C63] font-medium">Memuat data transaksi...</td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>

        <!-- Footer -->
        <footer class="mt-6 pt-5 border-t border-[#1A1A1E] flex flex-col sm:flex-row items-center justify-between gap-3 text-[11px] text-[#5C5C63]">
          <div class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-[#C5F82A] live-dot"></span>
            <span class="mono">All systems operational · 99.98% uptime</span>
          </div>
          <div class="flex items-center gap-4 mono text-[#5C5C63]">
            <span>© 2026 Lumovelo Control Panel</span>
          </div>
        </footer>
      </div>
    </main>
  </div>

  <!-- Add/Edit Transaction Modal -->
  <div id="transaction-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-slate-950/80 backdrop-blur-sm p-4">
    <div class="bg-[#131316] border border-[#232328] rounded-2xl w-full max-w-md p-6 space-y-4 shadow-2xl">
      <h3 id="modal-title" class="serif text-xl text-white">Tambah Transaksi Baru</h3>
      
      <form id="modal-form" class="space-y-3.5 text-xs text-slate-300">
        <input type="hidden" id="modal-doc-id" />
        
        <div class="grid grid-cols-2 gap-3">
          <div class="space-y-1">
            <label for="modal-doc-number" class="text-[#8A8A90] font-bold uppercase tracking-wider text-[9px] mono">Nomor Dokumen</label>
            <input type="text" id="modal-doc-number" required class="w-full bg-[#0A0A0B] border border-[#232328] focus:border-[#C5F82A] rounded-lg p-2.5 text-white outline-none" placeholder="INV/2026/001" />
          </div>
          <div class="space-y-1">
            <label for="modal-doc-type" class="text-[#8A8A90] font-bold uppercase tracking-wider text-[9px] mono">Jenis Dokumen</label>
            <select id="modal-doc-type" class="w-full bg-[#0A0A0B] border border-[#232328] focus:border-[#C5F82A] rounded-lg p-2.5 text-white outline-none">
              <option value="invoice">Invoice</option>
              <option value="spk">SPK</option>
              <option value="mou">MoU</option>
              <option value="kuitansi">Kuitansi</option>
              <option value="rab">RAB</option>
              <option value="bast">BAST</option>
              <option value="srs">SRS</option>
            </select>
          </div>
        </div>

        <div class="space-y-1">
          <label for="modal-client-name" class="text-[#8A8A90] font-bold uppercase tracking-wider text-[9px] mono">Nama Klien</label>
          <input type="text" id="modal-client-name" required class="w-full bg-[#0A0A0B] border border-[#232328] focus:border-[#C5F82A] rounded-lg p-2.5 text-white outline-none" placeholder="Budi Santoso" />
        </div>

        <div class="space-y-1">
          <label for="modal-client-company" class="text-[#8A8A90] font-bold uppercase tracking-wider text-[9px] mono">Nama Perusahaan</label>
          <input type="text" id="modal-client-company" class="w-full bg-[#0A0A0B] border border-[#232328] focus:border-[#C5F82A] rounded-lg p-2.5 text-white outline-none" placeholder="PT. HijabStyle Mode" />
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div class="space-y-1">
            <label for="modal-amount" class="text-[#8A8A90] font-bold uppercase tracking-wider text-[9px] mono">Nilai Proyek (Rp)</label>
            <input type="number" id="modal-amount" required class="w-full bg-[#0A0A0B] border border-[#232328] focus:border-[#C5F82A] rounded-lg p-2.5 text-white outline-none" placeholder="5000000" />
          </div>
          <div class="space-y-1">
            <label for="modal-status" class="text-[#8A8A90] font-bold uppercase tracking-wider text-[9px] mono">Status</label>
            <select id="modal-status" class="w-full bg-[#0A0A0B] border border-[#232328] focus:border-[#C5F82A] rounded-lg p-2.5 text-white outline-none">
              <option value="UNPAID">UNPAID</option>
              <option value="PAID">PAID</option>
              <option value="OVERDUE">OVERDUE</option>
              <option value="draft">draft</option>
              <option value="signed">signed</option>
            </select>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div class="space-y-1">
            <label for="modal-doc-date" class="text-[#8A8A90] font-bold uppercase tracking-wider text-[9px] mono">Tanggal</label>
            <input type="date" id="modal-doc-date" required class="w-full bg-[#0A0A0B] border border-[#232328] focus:border-[#C5F82A] rounded-lg p-2.5 text-white outline-none" />
          </div>
          <div class="space-y-1">
            <label for="modal-deadline" class="text-[#8A8A90] font-bold uppercase tracking-wider text-[9px] mono">Deadline</label>
            <input type="text" id="modal-deadline" class="w-full bg-[#0A0A0B] border border-[#232328] focus:border-[#C5F82A] rounded-lg p-2.5 text-white outline-none" placeholder="30 Hari Kerja" />
          </div>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div class="space-y-1">
            <label for="modal-client-phone" class="text-[#8A8A90] font-bold uppercase tracking-wider text-[9px] mono">Nomor WA Klien</label>
            <input type="text" id="modal-client-phone" class="w-full bg-[#0A0A0B] border border-[#232328] focus:border-[#C5F82A] rounded-lg p-2.5 text-white outline-none" placeholder="6285..." />
          </div>
          <div class="space-y-1">
            <label for="modal-assignee" class="text-[#8A8A90] font-bold uppercase tracking-wider text-[9px] mono">Eksekutor</label>
            <input type="text" id="modal-assignee" class="w-full bg-[#0A0A0B] border border-[#232328] focus:border-[#C5F82A] rounded-lg p-2.5 text-white outline-none" placeholder="Nama rekan tim" />
          </div>
        </div>

        <div class="space-y-1">
          <label for="modal-task-desc" class="text-[#8A8A90] font-bold uppercase tracking-wider text-[9px] mono">Deskripsi Tugas</label>
          <input type="text" id="modal-task-desc" class="w-full bg-[#0A0A0B] border border-[#232328] focus:border-[#C5F82A] rounded-lg p-2.5 text-white outline-none" placeholder="Pekerjaan Landing Page & SEO" />
        </div>

        <div class="pt-4 flex justify-end gap-3 text-xs">
          <button type="button" id="modal-btn-cancel" class="px-4 py-2 bg-[#232328] hover:bg-[#2e2e34] text-white rounded-xl font-semibold transition-colors cursor-pointer">
            Batal
          </button>
          <button type="submit" id="modal-btn-save" class="px-5 py-2 bg-[#C5F82A] hover:opacity-90 text-[#0A0A0B] rounded-xl font-bold transition-all cursor-pointer">
            Simpan
          </button>
        </div>
      </form>
    </div>
  </div>

  <style>
    @import url('https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap');
    
    :root {
      --bg: #0A0A0B;
      --panel: #131316;
      --panel-2: #18181C;
      --border: #232328;
      --border-soft: #1A1A1E;
      --ink: #F4F4F2;
      --muted: #8A8A90;
      --muted-2: #5C5C63;
      --accent: #C5F82A;
      --accent-dim: #8FB520;
      --warn: #F5A524;
      --rose: #F87171;
    }
    
    .dashboard-root {
      background: var(--bg) !important;
      color: var(--ink) !important;
      font-family: 'Inter', system-ui, sans-serif !important;
      -webkit-font-smoothing: antialiased;
    }
    
    .serif {
      font-family: 'Instrument Serif', serif !important;
      font-weight: 400;
      letter-spacing: -0.01em;
    }
    
    .mono {
      font-family: 'JetBrains Mono', monospace !important;
    }
    
    .grain {
      background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.02) 1px, transparent 0);
      background-size: 3px 3px;
    }
    
    .card {
      background: var(--panel) !important;
      border: 1px solid var(--border) !important;
      border-radius: 14px;
    }
    
    .nav-item {
      transition: all .18s ease;
      position: relative;
    }
    
    .nav-item:hover {
      background: var(--panel-2) !important;
      color: var(--ink) !important;
    }
    
    .nav-item.active {
      background: var(--panel-2) !important;
      color: var(--ink) !important;
    }
    
    .nav-item.active::before {
      content: '';
      position: absolute;
      left: -1px;
      top: 50%;
      transform: translateY(-50%);
      width: 3px;
      height: 18px;
      background: var(--accent);
      border-radius: 2px;
    }
    
    .pill {
      border: 1px solid var(--border);
      border-radius: 999px;
      transition: all .15s ease;
    }
    
    .pill:hover {
      border-color: #3a3a42;
    }
    
    .pill.active {
      background: var(--accent) !important;
      color: #0A0A0B !important;
      border-color: var(--accent) !important;
      font-weight: 600;
    }
    
    .row-hover:hover {
      background: var(--panel-2) !important;
    }
    
    .scroll-thin::-webkit-scrollbar {
      width: 6px;
      height: 6px;
    }
    
    .scroll-thin::-webkit-scrollbar-thumb {
      background: #2a2a30;
      border-radius: 3px;
    }
    
    .scroll-thin::-webkit-scrollbar-track {
      background: transparent;
    }
    
    .kbd {
      font-family: 'JetBrains Mono', monospace !important;
      font-size: 10px;
      border: 1px solid var(--border);
      border-bottom-width: 2px;
      border-radius: 4px;
      padding: 1px 5px;
      color: var(--muted);
    }
    
    @keyframes pulse-soft {
      0%, 100% {
        opacity: 1;
      }
      50% {
        opacity: .45;
      }
    }
    
    .live-dot {
      animation: pulse-soft 1.8s ease-in-out infinite;
    }
  </style>

  <script>
    import { supabase } from '../../lib/supabase';

    const adminLayout = document.getElementById('admin-layout')!;
    const btnLogout = document.getElementById('btn-logout')!;
    const btnExport = document.getElementById('btn-export')!;
    
    const filterStatus = document.getElementById('filter-status') as HTMLSelectElement;
    const filterType = document.getElementById('filter-type') as HTMLSelectElement;
    const searchClient = document.getElementById('search-client') as HTMLInputElement;

    let allDocs: any[] = [];
    let filteredDocs: any[] = [];

    // Session validation
    async function validateAdminSession() {
      const { data: { session } } = await supabase.auth.getSession();
      if (!session) {
        window.location.href = '/admin/login/';
      } else {
        adminLayout.classList.remove('hidden');
        loadTransactions();
      }
    }
    validateAdminSession();

    async function loadTransactions() {
      try {
        const { data, error } = await supabase
          .from('documents')
          .select('*')
          .order('created_at', { ascending: false });

        if (error) throw error;

        allDocs = data || [];
        applyFilters();
      } catch (err) {
        console.error('Error loading transactions:', err);
      }
    }

    function applyFilters() {
      const statusVal = filterStatus.value;
      const typeVal = filterType.value;
      const searchVal = searchClient.value.toLowerCase().trim();

      filteredDocs = allDocs.filter((doc) => {
        const matchStatus = statusVal === 'ALL' || doc.status === statusVal;
        const matchType = typeVal === 'ALL' || doc.doc_type === typeVal;
        
        const clientName = (doc.client_name || '').toLowerCase();
        const clientComp = (doc.client_company || '').toLowerCase();
        const matchSearch = !searchVal || clientName.includes(searchVal) || clientComp.includes(searchVal);

        return matchStatus && matchType && matchSearch;
      });

      renderTable();
    }

    function renderTable() {
      const tableBody = document.getElementById('finance-table-body')!;
      if (filteredDocs.length === 0) {
        tableBody.innerHTML = `
          <tr>
            <td colspan="9" class="p-8 text-center text-[#5C5C63] font-medium">Tidak ada transaksi yang cocok dengan penyaringan.</td>
          </tr>
        `;
        return;
      }

      tableBody.innerHTML = filteredDocs.map((doc) => {
        const clientPhone = doc.doc_data?.client_phone || '-';
        const taskDesc = doc.doc_data?.task_description || doc.doc_type?.toUpperCase() || '-';
        const assigneeName = doc.doc_data?.assignee || doc.assignee || '-';
        const formattedDeadline = doc.deadline || '-';
        
        const formattedAmount = doc.amount ? `Rp ${Number(doc.amount).toLocaleString('id-ID')}` : '-';

        let statusText = 'Belum Selesai';
        let statusBadgeClass = 'border-[#232328] text-[#8A8A90] bg-[#131316]';
        if (doc.status === 'PAID' || doc.status === 'signed') {
          statusText = 'Selesai (Paid)';
          statusBadgeClass = 'border-emerald-500/20 text-emerald-400 bg-emerald-500/10';
        } else if (doc.status === 'UNPAID' || doc.status === 'draft') {
          statusText = 'Belum Selesai';
          statusBadgeClass = 'border-amber-500/20 text-amber-400 bg-amber-500/10';
        } else if (doc.status === 'OVERDUE') {
          statusText = 'Jatuh Tempo (Overdue)';
          statusBadgeClass = 'border-rose-500/20 text-rose-400 bg-rose-500/10';
        }

        return `
          <tr class="row-hover border-t border-[#1A1A1E] transition">
            <td class="px-5 py-3">
              <div class="font-bold text-white">${doc.client_name || '-'}</div>
              <div class="text-[10px] text-[#5C5C63] mt-0.5">${doc.client_company || '-'}</div>
            </td>
            <td class="px-3 py-3 font-mono text-slate-300 text-[12px]">${clientPhone}</td>
            <td class="px-3 py-3 text-slate-300">${doc.doc_date || '-'}</td>
            <td class="px-3 py-3 text-slate-300 font-mono">${formattedDeadline}</td>
            <td class="px-3 py-3 max-w-[200px] truncate text-slate-300" title="${taskDesc}">${taskDesc}</td>
            <td class="px-3 py-3 font-bold text-slate-200">${assigneeName}</td>
            <td class="px-3 py-3">
              <span class="inline-flex items-center px-2 py-0.5 rounded-md border text-[9px] font-black uppercase tracking-wider ${statusBadgeClass}">
                ${statusText}
              </span>
            </td>
            <td class="px-3 py-3 font-mono text-[#F4F4F2] font-bold text-right">${formattedAmount}</td>
            <td class="px-5 py-3 text-right space-x-1.5">
              <button class="btn-edit px-2 py-1 bg-[#2563eb]/10 border border-[#2563eb]/20 text-[#3b82f6] hover:bg-[#2563eb] hover:text-white rounded text-[10px] font-semibold uppercase transition-all cursor-pointer" data-id="${doc.id}">
                Edit
              </button>
              <button class="btn-delete px-2 py-1 bg-[#f87171]/10 border border-[#f87171]/20 text-[#f87171] hover:bg-[#f87171] hover:text-white rounded text-[10px] font-semibold uppercase transition-all cursor-pointer" data-id="${doc.id}">
                Hapus
              </button>
            </td>
          </tr>
        `;
      }).join('');
    }

    // Export Functionality
    btnExport.addEventListener('click', () => {
      if (filteredDocs.length === 0) return;

      const headers = ['Nama Klien', 'Perusahaan', 'Nomor Kontak', 'Tanggal Pemesanan', 'Deadline', 'Keterangan Tugas', 'Eksekutor', 'Status Eksekusi', 'Total Nilai'];
      
      const rows = filteredDocs.map((doc) => [
        doc.client_name || '',
        doc.client_company || '',
        doc.doc_data?.client_phone || '',
        doc.doc_date || '',
        doc.deadline || '',
        doc.doc_data?.task_description || doc.doc_type || '',
        doc.doc_data?.assignee || doc.assignee || '',
        doc.status === 'PAID' ? 'Selesai' : 'Belum Selesai',
        doc.amount || 0
      ]);

      const csvContent = [headers, ...rows]
        .map((row) => row.map((cell) => `"${String(cell).replace(/"/g, '""')}"`).join(','))
        .join('\n');

      const blob = new Blob(['\ufeff' + csvContent], { type: 'text/csv;charset=utf-8;' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `Laporan-Keuangan-Lumovelo-${new Date().toISOString().slice(0, 10)}.csv`;
      a.click();
      URL.revokeObjectURL(url);
    });

    // Modal logic
    const modal = document.getElementById('transaction-modal')!;
    const modalForm = document.getElementById('modal-form') as HTMLFormElement;
    const btnAddTrx = document.getElementById('btn-add-trx')!;
    const btnCancel = document.getElementById('modal-btn-cancel')!;
    const modalTitle = document.getElementById('modal-title')!;

    // Modal Inputs
    const mId = document.getElementById('modal-doc-id') as HTMLInputElement;
    const mNumber = document.getElementById('modal-doc-number') as HTMLInputElement;
    const mType = document.getElementById('modal-doc-type') as HTMLSelectElement;
    const mName = document.getElementById('modal-client-name') as HTMLInputElement;
    const mCompany = document.getElementById('modal-client-company') as HTMLInputElement;
    const mAmount = document.getElementById('modal-amount') as HTMLInputElement;
    const mStatus = document.getElementById('modal-status') as HTMLSelectElement;
    const mDate = document.getElementById('modal-doc-date') as HTMLInputElement;
    const mDeadline = document.getElementById('modal-deadline') as HTMLInputElement;
    const mPhone = document.getElementById('modal-client-phone') as HTMLInputElement;
    const mTask = document.getElementById('modal-task-desc') as HTMLInputElement;
    const mAssignee = document.getElementById('modal-assignee') as HTMLInputElement;

    // Show modal for adding
    btnAddTrx.addEventListener('click', () => {
      modalTitle.innerText = 'Tambah Transaksi Baru';
      modalForm.reset();
      mId.value = '';
      mNumber.disabled = false;
      modal.classList.remove('hidden');
    });

    // Hide modal
    btnCancel.addEventListener('click', () => {
      modal.classList.add('hidden');
    });

    // Event delegation on table body for Edit & Delete
    const tableBody = document.getElementById('finance-table-body')!;
    tableBody.addEventListener('click', async (e) => {
      const target = e.target as HTMLElement;
      if (target.classList.contains('btn-edit')) {
        const id = target.getAttribute('data-id');
        openEditModal(id);
      } else if (target.classList.contains('btn-delete')) {
        const id = target.getAttribute('data-id');
        if (confirm('Apakah Anda yakin ingin menghapus transaksi ini?')) {
          await deleteTransaction(id);
        }
      }
    });

    // Open Edit Modal
    function openEditModal(id: string | null) {
      const doc = allDocs.find((d) => d.id === id);
      if (!doc) return;

      modalTitle.innerText = 'Edit Transaksi';
      mId.value = doc.id;
      mNumber.value = doc.doc_number || '';
      mNumber.disabled = true; // Can't edit doc_number once created
      mType.value = doc.doc_type || 'invoice';
      mName.value = doc.client_name || '';
      mCompany.value = doc.client_company || '';
      mAmount.value = doc.amount || '0';
      mStatus.value = doc.status || 'UNPAID';
      mDate.value = doc.doc_date || '';
      mDeadline.value = doc.deadline || '';
      mPhone.value = doc.doc_data?.client_phone || '';
      mTask.value = doc.doc_data?.task_description || '';
      mAssignee.value = doc.doc_data?.assignee || doc.assignee || '';

      modal.classList.remove('hidden');
    }

    // Delete Transaction
    async function deleteTransaction(id: string | null) {
      if (!id) return;
      try {
        const { error } = await supabase
          .from('documents')
          .delete()
          .eq('id', id);

        if (error) throw error;
        // @ts-ignore
        showToast('Transaksi berhasil dihapus!', 'success');
        loadTransactions();
      } catch (err: any) {
        // @ts-ignore
        showToast(err.message || 'Gagal menghapus transaksi.', 'error');
      }
    }

    // Submit modal (insert / update)
    modalForm.addEventListener('submit', async (e) => {
      e.preventDefault();

      const id = mId.value;
      const docData = {
        doc_type: mType.value,
        doc_number: mNumber.value.trim(),
        client_name: mName.value.trim(),
        client_company: mCompany.value.trim(),
        amount: parseFloat(mAmount.value) || 0,
        status: mStatus.value,
        doc_date: mDate.value,
        deadline: mDeadline.value.trim(),
        doc_data: {
          client_phone: mPhone.value.trim(),
          task_description: mTask.value.trim(),
          assignee: mAssignee.value.trim()
        }
      };

      try {
        if (id) {
          // Update
          const { error } = await supabase
            .from('documents')
            .update(docData)
            .eq('id', id);

          if (error) throw error;
          // @ts-ignore
          showToast('Transaksi berhasil diperbarui!', 'success');
        } else {
          // Insert
          const { error } = await supabase
            .from('documents')
            .insert(docData);

          if (error) throw error;
          // @ts-ignore
          showToast('Transaksi berhasil ditambahkan!', 'success');
        }

        modal.classList.add('hidden');
        loadTransactions();
      } catch (err: any) {
        // @ts-ignore
        showToast(err.message || 'Gagal menyimpan transaksi.', 'error');
      }
    });

    filterStatus.addEventListener('change', applyFilters);
    filterType.addEventListener('change', applyFilters);
    searchClient.addEventListener('input', applyFilters);

    btnLogout.addEventListener('click', async () => {
      await supabase.auth.signOut();
      window.location.href = '/admin/login/';
    });
  </script>
</Layout>
