---
import Layout from '../../layouts/Layout.astro';
import Logo from '../../components/Logo.astro';
---

<Layout title="AI Leads Manager | LUMOVELO" description="Manajer prospek berbasis AI Lumovelo." noindex={true}>
  <div id="admin-layout" class="hidden min-h-screen dashboard-root grain flex">
    
    <!-- Sidebar Navigation -->
    <aside class="hidden lg:flex w-[248px] shrink-0 flex-col border-r border-[#1A1A1E] bg-[#0C0C0E]">
      <!-- Logo -->
      <div class="px-5 pt-6 pb-7 flex items-center gap-2.5">
        <div class="w-8 h-8 rounded-lg flex items-center justify-center bg-[#C5F82A]">
          <Logo class="w-4 h-4 text-[#0A0A0B]" />
        </div>
        <div class="flex items-baseline gap-1.5">
          <span class="font-semibold tracking-tight text-[15px] text-white">LUMOVELO</span>
          <span class="mono text-[10px] text-[#5C5C63]">v2.4</span>
        </div>
      </div>

      <!-- Workspace switcher -->
      <div class="px-3 mb-5">
        <div class="w-full flex items-center gap-2.5 px-2.5 py-2 rounded-lg border border-[#232328] bg-[#131316]">
          <div class="w-6 h-6 rounded-md flex items-center justify-center text-[10px] font-bold bg-[#2A2A30] text-[#C5F82A]">LV</div>
          <div class="flex-1 min-w-0">
            <div class="text-[12px] font-medium leading-tight text-white">Lumovelo Agency</div>
            <div class="text-[10px] mono text-[#5C5C63]">workspace · admin</div>
          </div>
        </div>
      </div>

      <!-- Nav -->
      <nav class="px-3 flex-1 overflow-y-auto scroll-thin" id="nav">
        <div class="px-2.5 mb-1.5 mono text-[10px] uppercase tracking-wider text-[#5C5C63]">Analytics</div>
        <a href="/admin/dashboard/" class="nav-item flex items-center gap-3 px-2.5 py-2 rounded-md text-[13px] text-[#8A8A90]">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="7" height="9" rx="1"/><rect x="14" y="3" width="7" height="5" rx="1"/><rect x="14" y="12" width="7" height="9" rx="1"/><rect x="3" y="16" width="7" height="5" rx="1"/></svg>
          Overview
        </a>
        <a href="/admin/finance/" class="nav-item flex items-center gap-3 px-2.5 py-2 rounded-md text-[13px] text-[#8A8A90]">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 3v18h18"/><path d="M7 14l4-4 3 3 5-6"/></svg>
          Revenue
        </a>
        <a href="/admin/profit-sharing/" class="nav-item flex items-center gap-3 px-2.5 py-2 rounded-md text-[13px] text-[#8A8A90]">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="9" cy="8" r="4"/><path d="M3 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2"/><circle cx="17" cy="6" r="2.5"/><path d="M14 21v-1a3 3 0 0 1 3-3h0a3 3 0 0 1 3 3v1"/></svg>
          Bagi Hasil Tim
        </a>
        <a href="/admin/blog/" class="nav-item flex items-center gap-3 px-2.5 py-2 rounded-md text-[13px] text-[#8A8A90]">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 2v20M2 12h20"/><circle cx="12" cy="12" r="9"/></svg>
          Kelola Blog
        </a>
        <a href="/admin/leads/" class="nav-item active flex items-center gap-3 px-2.5 py-2 rounded-md text-[13px] text-[#F4F4F2]">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="shrink-0"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          Leads AI
        </a>
        <a href="/admin/ai-settings/" class="nav-item flex items-center gap-3 px-2.5 py-2 rounded-md text-[13px] text-[#8A8A90]">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
          Pengaturan AI
        </a>

        <div class="px-2.5 mb-1.5 mt-5 mono text-[10px] uppercase tracking-wider text-[#5C5C63]">Workspace</div>
        <a href="/workspace/invoice/" class="nav-item flex items-center gap-3 px-2.5 py-2 rounded-md text-[13px] text-[#8A8A90]">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 9h6v6H9z"/></svg>
          Buat Invoice
        </a>
      </nav>

      <!-- Usage card -->
      <div class="m-3 p-3.5 rounded-xl border border-[#232328]" style="background: linear-gradient(180deg, #16161A 0%, #0E0E11 100%);">
        <div class="flex items-center justify-between mb-2">
          <span class="text-[11px] font-medium text-white">Target Sales</span>
          <span class="mono text-[10px] text-[#8A8A90]" id="sales-target-percentage">0%</span>
        </div>
        <div class="h-1.5 rounded-full overflow-hidden bg-[#232328]">
          <div id="sales-target-bar" class="h-full rounded-full" style="width: 0%; background: linear-gradient(90deg, #C5F82A, #8FB520);"></div>
        </div>
        <div class="flex items-center justify-between mt-3">
          <span class="mono text-[10px] text-[#5C5C63]" id="sales-target-ratio">Rp 0 / Rp 100M</span>
          <a href="/admin/finance/" class="text-[11px] font-medium text-[#C5F82A] hover:underline">Detail →</a>
        </div>
      </div>

      <!-- User logout footer -->
      <div class="px-3 pb-4 pt-1 border-t border-[#1A1A1E]">
        <button id="btn-logout" class="w-full flex items-center gap-2.5 px-2 py-2 rounded-md hover:bg-[#16161A] transition text-left group">
          <div class="w-8 h-8 rounded-full flex items-center justify-center text-[11px] font-semibold bg-[#2A2A30] text-[#F4F4F2]">AD</div>
          <div class="flex-1 min-w-0">
            <div class="text-[12px] font-medium leading-tight text-white group-hover:text-[#F87171] transition-colors">Sign Out</div>
            <div class="text-[10px] mono text-[#5C5C63]">administrator</div>
          </div>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-[#8A8A90] group-hover:text-[#F87171] transition-colors"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        </button>
      </div>
    </aside>

    <!-- Main Content Area -->
    <main class="flex-1 min-w-0 flex flex-col h-screen overflow-hidden">
      <!-- Top bar -->
      <header class="z-20 flex items-center gap-3 px-4 lg:px-8 h-16 border-b border-[#1A1A1E] backdrop-blur-md bg-[rgba(10,10,11,0.78)] shrink-0">
        <button class="lg:hidden p-2 rounded-md hover:bg-[#16161A] text-white">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
        </button>
        <div class="hidden md:flex items-center gap-2 text-[13px] text-[#8A8A90]">
          <span>Lumovelo</span>
          <span class="text-[#5C5C63]">/</span>
          <span class="text-[#F4F4F2] font-medium">Leads AI</span>
        </div>

        <!-- Search Bar and Status filter -->
        <div class="ml-auto flex items-center gap-3">
          <div class="flex items-center gap-2 px-3 h-9 rounded-lg border border-[#232328] bg-[#131316] w-52 sm:w-64">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-[#8A8A90]"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>
            <input type="text" id="search-leads" placeholder="Cari nama, perusahaan..." class="bg-transparent text-[12px] flex-1 outline-none placeholder:text-[#5C5C63] text-[#F4F4F2]">
          </div>
          
          <select id="filter-status" class="bg-[#131316] border border-[#232328] text-[#8A8A90] hover:text-white rounded-lg h-9 px-3 text-[12px] font-medium focus:outline-none cursor-pointer transition">
            <option value="all">Semua Status</option>
            <option value="pending">Pending</option>
            <option value="contacted">Contacted</option>
            <option value="deal">Deal</option>
            <option value="no_response">No Reply</option>
          </select>

          <select id="filter-temperature" class="bg-[#131316] border border-[#232328] text-[#8A8A90] hover:text-white rounded-lg h-9 px-3 text-[12px] font-medium focus:outline-none cursor-pointer transition">
            <option value="all">Semua Suhu</option>
            <option value="hot">🔥 Hot Leads</option>
            <option value="warm">☀️ Warm Leads</option>
            <option value="cold">❄️ Cold Leads</option>
          </select>
        </div>
      </header>

      <!-- Main Layout: Master on the left, Detail on the right -->
      <div class="flex-1 flex overflow-hidden p-6 gap-6">
        
        <!-- Left Pane: Leads List (Master) -->
        <section class="w-full lg:w-[380px] xl:w-[420px] flex flex-col shrink-0 overflow-y-auto space-y-3 scroll-thin pr-1" id="leads-list-container">
          <div class="text-center py-12 text-[#5C5C63] font-medium text-[13px]">Memuat data prospek AI...</div>
        </section>

        <!-- Right Pane: Detail View -->
        <section class="hidden lg:flex flex-1 flex-col border border-[#232328] bg-[#131316] rounded-xl overflow-hidden" id="lead-detail-container">
          <!-- Empty State -->
          <div class="flex-1 flex flex-col items-center justify-center p-8 text-[#5C5C63] text-center">
            <span class="text-4xl mb-3">🤖</span>
            <h3 class="text-white font-semibold text-[15px]">Pilih Prospek</h3>
            <p class="text-[12px] mt-1 max-w-sm leading-relaxed">Pilih salah satu prospek di sebelah kiri untuk melihat analisis kebutuhan, tech stack, dan log percakapan klien secara lengkap.</p>
          </div>
        </section>

      </div>
    </main>
  </div>

  <!-- Custom Confirm Modal -->
  <div id="delete-modal" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-[#000000]/80 backdrop-blur-sm hidden opacity-0 transition-opacity duration-200">
    <div class="w-full max-w-sm p-6 bg-[#131316] border border-[#232328] rounded-xl flex flex-col space-y-4 shadow-2xl transform scale-95 transition-transform duration-200">
      <div class="w-10 h-10 rounded-full bg-rose-500/10 border border-rose-500/20 flex items-center justify-center text-rose-400">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
      </div>
      <div>
        <h4 class="text-[15px] font-bold text-white">Hapus Prospek & Sesi Chat?</h4>
        <p class="text-[12px] text-[#8A8A90] mt-1.5 leading-relaxed">Tindakan ini akan menghapus data prospek beserta seluruh riwayat obrolan AI secara menyeluruh dan permanen dari database.</p>
      </div>
      <div class="flex items-center gap-2.5 pt-2">
        <button id="btn-delete-cancel" class="flex-1 py-2 px-3 rounded-lg border border-[#232328] hover:bg-[#1C1C24] text-[12px] font-semibold text-white transition">
          Batal
        </button>
        <button id="btn-delete-confirm" class="flex-1 py-2 px-3 rounded-lg bg-rose-600 hover:bg-rose-700 text-[12px] font-semibold text-white transition flex items-center justify-center gap-1.5">
          Ya, Hapus
        </button>
      </div>
    </div>
  </div>

  <!-- Custom Toast Container -->
  <div id="toast-container" class="fixed top-6 right-6 z-50 flex flex-col gap-2.5 pointer-events-none"></div>

  <style>
    @import url('https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap');
    
    :root {
      --bg: #0A0A0B;
      --panel: #131316;
      --panel-2: #18181C;
      --border: #232328;
      --border-soft: #1A1A1E;
      --ink: #F4F4F2;
      --muted: #8A8A90;
      --muted-2: #5C5C63;
      --accent: #C5F82A;
      --accent-dim: #8FB520;
      --warn: #F5A524;
      --rose: #F87171;
    }
    
    .dashboard-root {
      background: var(--bg) !important;
      color: var(--ink) !important;
      font-family: 'Inter', system-ui, sans-serif !important;
      -webkit-font-smoothing: antialiased;
    }
    
    .serif {
      font-family: 'Instrument Serif', serif !important;
      font-weight: 400;
      letter-spacing: -0.01em;
    }
    
    .mono {
      font-family: 'JetBrains Mono', monospace !important;
    }
    
    .grain {
      background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.02) 1px, transparent 0);
      background-size: 3px 3px;
    }
    
    .card {
      background: var(--panel) !important;
      border: 1px solid var(--border) !important;
      border-radius: 14px;
    }
    
    .nav-item {
      transition: all .18s ease;
      position: relative;
    }
    
    .nav-item:hover {
      background: var(--panel-2) !important;
      color: var(--ink) !important;
    }
    
    .nav-item.active {
      background: var(--panel-2) !important;
      color: var(--ink) !important;
    }
    
    .nav-item.active::before {
      content: '';
      position: absolute;
      left: -1px;
      top: 50%;
      transform: translateY(-50%);
      width: 3px;
      height: 18px;
      background: var(--accent);
      border-radius: 2px;
    }
    
    .scroll-thin::-webkit-scrollbar {
      width: 6px;
      height: 6px;
    }
    
    .scroll-thin::-webkit-scrollbar-thumb {
      background: #2a2a30;
      border-radius: 3px;
    }
    
    .scroll-thin::-webkit-scrollbar-track {
      background: transparent;
    }
  </style>

  <script>
    import { supabase } from '../../lib/supabase';

    const adminLayout = document.getElementById('admin-layout')!;
    const btnLogout = document.getElementById('btn-logout')!;
    const leadsListContainer = document.getElementById('leads-list-container')!;
    const leadDetailContainer = document.getElementById('lead-detail-container')!;
    const searchInput = document.getElementById('search-leads') as HTMLInputElement;
    const statusFilter = document.getElementById('filter-status') as HTMLSelectElement;
    const tempFilter = document.getElementById('filter-temperature') as HTMLSelectElement;
    
    let rawLeads: any[] = [];
    let rawSessions: any[] = [];
    let activeLeadId: string | null = null;
    let searchQuery = '';
    let statusQuery = 'all';
    let tempQuery = 'all';

    // Auth Validation check
    async function validateAdminSession() {
      const { data: { session } } = await supabase.auth.getSession();
      if (!session) {
        window.location.href = '/admin/login/';
        return;
      }

      // Check if user email is authorized admin
      const userEmail = session.user.email?.toLowerCase();
      const allowedEmails = (import.meta.env.PUBLIC_ADMIN_EMAILS || 'admin@lumovelo.com')
        .split(',')
        .map(e => e.trim().toLowerCase());
      const isAdmin = userEmail && (allowedEmails.includes(userEmail) || userEmail.endsWith('@lumovelo.com'));

      if (!isAdmin) {
        await supabase.auth.signOut();
        alert('Akses Ditolak: Anda bukan administrator resmi.');
        window.location.href = '/admin/login/';
        return;
      }

      adminLayout.classList.remove('hidden');
      loadLeadsData();
      loadSalesTargetStats();
    }
    validateAdminSession();

    // Load sales targets in sidebar
    async function loadSalesTargetStats() {
      try {
        const { data: docs } = await supabase.from('documents').select('amount, status, doc_type');
        let revenue = 0;
        docs?.forEach(doc => {
          if (doc.doc_type === 'invoice' && doc.status === 'PAID') {
            revenue += Number(doc.amount) || 0;
          }
        });
        const targetValue = 100000000;
        const currentPercentage = Math.min((revenue / targetValue) * 100, 100);
        document.getElementById('sales-target-percentage')!.innerText = `${currentPercentage.toFixed(1)}%`;
        document.getElementById('sales-target-bar')!.style.width = `${currentPercentage}%`;
        document.getElementById('sales-target-ratio')!.innerText = `Rp ${(revenue / 1000000).toFixed(1)}M / Rp ${(targetValue / 1000000).toFixed(0)}M`;
      } catch (e) {
        console.error(e);
      }
    }

    // Fetch leads and sessions
    async function loadLeadsData() {
      try {
        const { data: leads, error: leadsError } = await supabase
          .from('leads')
          .select('*')
          .order('created_at', { ascending: false });

        if (leadsError) throw leadsError;

        const { data: sessions, error: sessionsError } = await supabase
          .from('ai_chat_sessions')
          .select('*');

        if (sessionsError) throw sessionsError;

        rawLeads = leads || [];
        rawSessions = sessions || [];

        renderLeadsList();
        
        // If there is an active lead selected, re-render the details
        if (activeLeadId) {
          renderLeadDetail(activeLeadId);
        }
      } catch (err) {
        console.error('Error fetching leads:', err);
        leadsListContainer.innerHTML = `<div class="text-rose-400 py-6 text-center font-medium">Gagal memuat data.</div>`;
      }
    }

    // Filter and Render Leads List
    function renderLeadsList() {
      const filteredLeads = rawLeads.filter(lead => {
        const name = (lead.client_name || '').toLowerCase();
        const company = (lead.company_name || '').toLowerCase();
        const needs = (lead.project_needs || '').toLowerCase();
        
        const matchesSearch = name.includes(searchQuery) || company.includes(searchQuery) || needs.includes(searchQuery);
        const matchesStatus = statusQuery === 'all' || lead.status === statusQuery;
        const matchesTemp = tempQuery === 'all' || (lead.lead_temperature || 'cold') === tempQuery;
        
        return matchesSearch && matchesStatus && matchesTemp;
      });

      if (filteredLeads.length === 0) {
        leadsListContainer.innerHTML = `
          <div class="text-center py-12 text-[#5C5C63] font-medium text-[13px]">Prospek tidak ditemukan.</div>
        `;
        return;
      }

      leadsListContainer.innerHTML = filteredLeads.map(lead => {
        const isActive = lead.id === activeLeadId;
        const activeClass = isActive ? 'border-[#C5F82A] bg-[#1A1A1E]' : 'border-[#232328] bg-[#131316] hover:border-[#3a3a42]';
        
        let statusColorClass = 'bg-[#0E0E11] text-[#8A8A90] border border-[#232328]';
        if (lead.status === 'deal') {
          statusColorClass = 'bg-emerald-500/10 text-emerald-400 border border-emerald-500/20';
        } else if (lead.status === 'contacted') {
          statusColorClass = 'bg-blue-500/10 text-blue-400 border border-blue-500/20';
        } else if (lead.status === 'no_response') {
          statusColorClass = 'bg-rose-500/10 text-rose-400 border border-rose-500/20';
        }

        const date = new Date(lead.created_at).toLocaleDateString('id-ID', {
          day: '2-digit',
          month: 'short',
          hour: '2-digit',
          minute: '2-digit'
        });

        let tempBadgeHtml = '';
        const temp = lead.lead_temperature || 'cold';
        if (temp === 'hot') {
          tempBadgeHtml = `<span class="px-1.5 py-0.5 rounded text-[8px] mono font-bold bg-rose-500/10 text-rose-400 border border-rose-500/20">🔥 HOT</span>`;
        } else if (temp === 'warm') {
          tempBadgeHtml = `<span class="px-1.5 py-0.5 rounded text-[8px] mono font-bold bg-amber-500/10 text-amber-400 border border-amber-500/20">☀️ WARM</span>`;
        } else {
          tempBadgeHtml = `<span class="px-1.5 py-0.5 rounded text-[8px] mono font-bold bg-blue-500/10 text-blue-400 border border-blue-500/20">❄️ COLD</span>`;
        }

        return `
          <div class="p-4 rounded-xl border cursor-pointer transition flex flex-col space-y-2.5 ${activeClass}" data-lead-id="${lead.id}">
            <div class="flex items-start justify-between gap-2">
              <div>
                <h4 class="text-[13px] font-semibold text-white">${lead.client_name || 'Klien Anonim'}</h4>
                <p class="text-[10px] mono text-[#5C5C63] mt-0.5">${lead.company_name || 'Tanpa Perusahaan'}</p>
              </div>
              <div class="flex flex-col items-end gap-1 shrink-0">
                <span class="px-2 py-0.5 rounded text-[9px] mono font-bold uppercase tracking-wider ${statusColorClass}">
                  ${lead.status || 'pending'}
                </span>
                ${tempBadgeHtml}
              </div>
            </div>
            
            <div class="text-[11px] text-[#8A8A90] line-clamp-1">
              ${lead.project_needs || 'Kebutuhan belum teridentifikasi'}
            </div>
            
            <div class="flex items-center justify-between text-[9px] mono text-[#5C5C63] pt-1.5 border-t border-[#1A1A1E]">
              <span>${lead.whatsapp_number || 'No. WA tidak ada'}</span>
              <span>${date}</span>
            </div>
          </div>
        `;
      }).join('');

      // Bind click event to each card
      leadsListContainer.querySelectorAll('[data-lead-id]').forEach(card => {
        card.addEventListener('click', () => {
          const leadId = card.getAttribute('data-lead-id')!;
          activeLeadId = leadId;
          
          // Re-render list to update active highlight border
          renderLeadsList();
          renderLeadDetail(leadId);
        });
      });
    }

    // Generate WA Template Message
    function getWaMessage(lead: any) {
      const name = lead.client_name || 'Kak';
      const company = lead.company_name ? ` untuk ${lead.company_name}` : '';
      const needs = lead.project_needs ? ` mengenai ${lead.project_needs}` : '';
      return `Halo Kak ${name}, saya Admin dari Lumovelo. Kami melihat Kakak sempat berkonsultasi dengan asisten AI kami${company}${needs}. Apakah ada detail proyek yang ingin didiskusikan lebih lanjut agar kami dapat menyiapkan penawarannya?`;
    }

    // Render Lead Detail view (Right Pane)
    async function renderLeadDetail(leadId: string) {
      const lead = rawLeads.find(l => l.id === leadId);
      if (!lead) return;

      const session = rawSessions.find(s => s.id === lead.session_id);
      const isSessionAiEnabled = session ? session.is_ai_enabled : true;

      // Render tech stack badges
      let techStackBadges = '<span class="text-[#5C5C63] italic text-[11px]">Belum teridentifikasi</span>';
      if (lead.tech_stack) {
        const techs = lead.tech_stack.split(',').map((t: string) => t.trim()).filter(Boolean);
        if (techs.length > 0) {
          techStackBadges = techs.map((t: string) => `<span class="px-2 py-0.5 rounded bg-blue-600/10 text-blue-400 text-[11px] font-mono border border-blue-500/20">${t}</span>`).join(' ');
        }
      }

      const sessionAiClass = isSessionAiEnabled 
        ? 'border-blue-500/20 text-blue-400 bg-blue-500/5 hover:bg-blue-500/15'
        : 'border-amber-500/20 text-amber-400 bg-amber-500/5 hover:bg-amber-500/15';

      leadDetailContainer.innerHTML = `
        <!-- Detail Header -->
        <div class="p-5 border-b border-[#232328] bg-[#0C0C0E] flex flex-wrap items-center justify-between gap-4 shrink-0">
          <div>
            <h2 class="text-[16px] font-semibold text-white">${lead.client_name || 'Klien Anonim'}</h2>
            <p class="text-[11px] text-[#8A8A90] mt-0.5">${lead.company_name || 'Perusahaan/PT tidak disebutkan'}</p>
          </div>
          <div class="flex items-center gap-2">
            <!-- WA Link -->
            ${lead.whatsapp_number ? `
              <a href="https://wa.me/${lead.whatsapp_number.replace(/[^0-9]/g, '')}?text=${encodeURIComponent(getWaMessage(lead))}" target="_blank" rel="noopener noreferrer" class="flex items-center gap-1.5 py-1.5 px-3 rounded-lg bg-emerald-600 hover:bg-emerald-700 text-white font-semibold transition text-[12px]">
                Hubungi via WhatsApp
              </a>
            ` : `
              <span class="py-1.5 px-3 rounded-lg bg-[#2A2A30] text-[#5C5C63] font-medium text-[12px] cursor-not-allowed">WA tidak ada</span>
            `}

            <!-- Dropdown Status -->
            <select id="detail-status-select" class="bg-[#1C1C24] border border-[#232328] text-white rounded-lg px-2.5 h-[34px] font-semibold text-[12px] focus:outline-none cursor-pointer">
              <option value="pending" ${lead.status === 'pending' ? 'selected' : ''}>Pending</option>
              <option value="contacted" ${lead.status === 'contacted' ? 'selected' : ''}>Contacted</option>
              <option value="deal" ${lead.status === 'deal' ? 'selected' : ''}>Deal</option>
              <option value="no_response" ${lead.status === 'no_response' ? 'selected' : ''}>No Reply</option>
            </select>

            <!-- Toggle AI -->
            ${lead.session_id ? `
              <button id="detail-toggle-ai" class="h-[34px] px-3.5 rounded-lg border text-[12px] font-semibold transition ${sessionAiClass}" data-session-id="${lead.session_id}" data-ai-enabled="${isSessionAiEnabled}">
                ${isSessionAiEnabled ? 'Mute AI Assistant' : 'Unmute AI Assistant'}
              </button>
            ` : ''}

            <!-- Delete Button -->
            <button id="detail-delete-lead" class="h-[34px] w-[34px] rounded-lg border border-red-500/20 text-red-400 bg-red-500/5 hover:bg-red-500/15 flex items-center justify-center transition" title="Hapus Prospek & Sesi Chat" data-lead-id="${lead.id}" data-session-id="${lead.session_id || ''}">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="shrink-0"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
            </button>
          </div>
        </div>

        <!-- Detail Body -->
        <div class="flex-1 flex flex-col min-h-0 overflow-hidden divide-y divide-[#1A1A1E]">
          <!-- Summary Area -->
          <div class="p-5 bg-[#0E0E11]/30 grid grid-cols-1 md:grid-cols-4 gap-4 shrink-0">
            <div class="md:col-span-2">
              <span class="text-[10px] uppercase tracking-wider text-[#5C5C63] font-mono">Detail Analisis Kebutuhan</span>
              <p class="text-[12px] text-slate-300 mt-1.5 leading-relaxed">${lead.project_needs || '-'}</p>
            </div>
            <div>
              <span class="text-[10px] uppercase tracking-wider text-[#5C5C63] font-mono">Rekomendasi Tech Stack</span>
              <div class="flex flex-wrap gap-1.5 mt-2">
                ${techStackBadges}
              </div>
            </div>
            <div>
              <span class="text-[10px] uppercase tracking-wider text-[#5C5C63] font-mono block">Estimasi Budget</span>
              <span class="text-[13px] font-bold text-[#C5F82A] mt-1 block">${lead.estimated_budget || 'Belum dihitung'}</span>
              <div class="mt-2.5">
                <span class="text-[10px] uppercase tracking-wider text-[#5C5C63] font-mono block">Suhu Prospek</span>
                <div class="mt-1 flex items-center">
                  ${lead.lead_temperature === 'hot' 
                    ? '<span class="px-1.5 py-0.5 rounded text-[8px] font-bold bg-rose-500/10 text-rose-400 border border-rose-500/20">🔥 HOT LEAD</span>' 
                    : (lead.lead_temperature === 'warm' 
                      ? '<span class="px-1.5 py-0.5 rounded text-[8px] font-bold bg-amber-500/10 text-amber-400 border border-amber-500/20">☀️ WARM LEAD</span>' 
                      : '<span class="px-1.5 py-0.5 rounded text-[8px] font-bold bg-blue-500/10 text-blue-400 border border-blue-500/20">❄️ COLD LEAD</span>')}
                </div>
              </div>
            </div>
          </div>

          <!-- Chat Logs Area -->
          <div class="flex-1 flex flex-col min-h-0 overflow-hidden">
            <div class="px-5 py-3.5 bg-[#0C0C0E]/50 border-b border-[#1A1A1E] flex justify-between items-center shrink-0">
              <span class="text-[12px] font-semibold text-white">Log Percakapan Klien & AI</span>
              <span class="mono text-[10px] text-[#5C5C63]">${lead.session_id ? `Sesi ID: ${lead.session_id.substring(0,8)}...` : 'Sesi tidak ada'}</span>
            </div>
            
            <div id="detail-chat-log" class="flex-1 overflow-y-auto p-5 space-y-3.5 scroll-thin">
              <div class="text-[#5C5C63] text-center py-8">Memuat riwayat chat...</div>
            </div>

            <!-- Admin Manual Chat Input Form -->
            ${lead.session_id ? `
              <form id="admin-chat-form" class="p-3 border-t border-[#1A1A1E] bg-[#0C0C0E]/50 flex gap-2 shrink-0">
                <input
                  type="text"
                  id="admin-chat-input"
                  placeholder="Ketik pesan manual ke klien..."
                  autocomplete="off"
                  class="bg-[#131316] border border-[#232328] focus:border-[#C5F82A] focus:outline-none rounded-lg px-3 py-2 text-[12px] text-white placeholder-slate-600 flex-1 transition"
                />
                <button
                  type="submit"
                  class="bg-[#C5F82A] hover:bg-[#b2e025] text-black font-semibold px-4 rounded-lg text-[12px] transition flex items-center gap-1 cursor-pointer shrink-0"
                >
                  Kirim
                </button>
              </form>
            ` : ''}
          </div>
        </div>
      `;

      // Load and Render chat messages
      if (lead.session_id) {
        loadChatLogs(lead.session_id);
      } else {
        document.getElementById('detail-chat-log')!.innerHTML = `
          <div class="text-center py-12 text-[#5C5C63] italic text-[12px]">Belum ada riwayat pesan untuk sesi ini.</div>
        `;
      }

      // Bind events for details controls
      bindDetailEvents(lead.id, lead.session_id);
    }

    // Load Chat messages for selected lead session
    async function loadChatLogs(sessionId: string) {
      const chatLogContainer = document.getElementById('detail-chat-log')!;
      try {
        const { data: messages, error } = await supabase
          .from('ai_chat_messages')
          .select('*')
          .eq('session_id', sessionId)
          .order('created_at', { ascending: true });

        if (error) throw error;

        const cleanMessages = messages?.filter(m => !m.message_content.startsWith('[System Info:'));

        if (!cleanMessages || cleanMessages.length === 0) {
          chatLogContainer.innerHTML = `
            <div class="text-center py-12 text-[#5C5C63] italic text-[12px]">Tidak ada pesan obrolan terkirim.</div>
          `;
          return;
        }

        chatLogContainer.innerHTML = cleanMessages.map(msg => {
          const isUser = msg.sender === 'user';
          const senderName = isUser ? 'Klien' : 'Asisten AI';
          const bgClass = isUser ? 'bg-[#1C1C24] text-white border border-[#2A2A35]' : 'bg-[#0E0E11] text-slate-300 border border-[#1A1A1E]';
          const alignClass = isUser ? 'items-end' : 'items-start';
          const headerColor = isUser ? 'text-blue-400' : 'text-[#C5F82A]';

          const formattedTime = new Date(msg.created_at).toLocaleTimeString('id-ID', {
            hour: '2-digit',
            minute: '2-digit'
          });

          return `
            <div class="flex flex-col ${alignClass} max-w-[85%] ${isUser ? 'ml-auto' : 'mr-auto'}">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-[10px] font-mono font-bold uppercase ${headerColor}">${senderName}</span>
                <span class="text-[9px] mono text-[#5C5C63]">${formattedTime}</span>
              </div>
              <div class="p-3 rounded-2xl ${isUser ? 'rounded-tr-none' : 'rounded-tl-none'} ${bgClass} text-[12px] leading-relaxed whitespace-pre-wrap">
                ${msg.message_content}
              </div>
            </div>
          `;
        }).join('');

        chatLogContainer.scrollTop = chatLogContainer.scrollHeight;

      } catch (err) {
        console.error('Error fetching chat log:', err);
        chatLogContainer.innerHTML = `<div class="text-rose-400 py-6 text-center font-medium">Gagal memuat percakapan.</div>`;
      }
    }

    // Bind event listeners inside Detail pane
    function bindDetailEvents(leadId: string, sessionId: string | null) {
      const select = document.getElementById('detail-status-select') as HTMLSelectElement;
      if (select) {
        select.addEventListener('change', async () => {
          const newStatus = select.value;
          try {
            const { error } = await supabase
              .from('leads')
              .update({ status: newStatus })
              .eq('id', leadId);

            if (error) throw error;
            loadLeadsData();
          } catch (err) {
            console.error(err);
            alert('Gagal mengubah status.');
          }
        });
      }

      const toggleBtn = document.getElementById('detail-toggle-ai') as HTMLButtonElement;
      if (toggleBtn && sessionId) {
        toggleBtn.addEventListener('click', async () => {
          const currentAiEnabled = toggleBtn.getAttribute('data-ai-enabled') === 'true';
          const newAiEnabled = !currentAiEnabled;
          
          try {
            const { error } = await supabase
              .from('ai_chat_sessions')
              .update({ is_ai_enabled: newAiEnabled, status: newAiEnabled ? 'active' : 'need_admin' })
              .eq('id', sessionId);

            if (error) throw error;
            loadLeadsData();
          } catch (err) {
            console.error(err);
            alert('Gagal mengubah status AI.');
          }
        });
      }

      // 3. Delete Lead & Session
      const deleteBtn = document.getElementById('detail-delete-lead') as HTMLButtonElement;
      if (deleteBtn) {
        deleteBtn.addEventListener('click', () => {
          showDeleteModal(leadId, sessionId);
        });
      }

      // 4. Admin Manual Chat Form
      const adminChatForm = document.getElementById('admin-chat-form') as HTMLFormElement;
      const adminChatInput = document.getElementById('admin-chat-input') as HTMLInputElement;
      if (adminChatForm && adminChatInput && sessionId) {
        adminChatForm.addEventListener('submit', async (e) => {
          e.preventDefault();
          const messageText = adminChatInput.value.trim();
          if (!messageText) return;

          try {
            const { data: { session } } = await supabase.auth.getSession();
            const token = session?.access_token;
            if (!token) {
              showToast('Sesi admin kedaluwarsa. Silakan login kembali.', 'error');
              return;
            }

            const response = await fetch('/api/send-admin-message', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ sessionId, message: messageText, token })
            });

            if (response.ok) {
              adminChatInput.value = '';
              loadChatLogs(sessionId);
            } else {
              const errData = await response.json();
              showToast(errData.error || 'Gagal mengirim pesan.', 'error');
            }
          } catch (err) {
            console.error('Error sending admin message:', err);
            showToast('Gagal mengirim pesan admin.', 'error');
          }
        });
      }
    }

    // --- LOGIKA MODAL & TOAST KUSTOM ---

    // Toast Notification Helper
    function showToast(message: string, type: 'success' | 'error' = 'success') {
      const container = document.getElementById('toast-container')!;
      const toast = document.createElement('div');
      toast.className = `flex items-center gap-2.5 p-3.5 pr-5 rounded-xl border shadow-xl transition-all duration-300 transform translate-y-2 opacity-0 pointer-events-auto bg-[#131316]`;
      
      let iconHtml = '';
      if (type === 'success') {
        toast.classList.add('border-emerald-500/20');
        iconHtml = `
          <div class="w-5 h-5 rounded-full bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center text-emerald-400">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
        `;
      } else {
        toast.classList.add('border-rose-500/20');
        iconHtml = `
          <div class="w-5 h-5 rounded-full bg-rose-500/10 border border-rose-500/20 flex items-center justify-center text-rose-400">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </div>
        `;
      }
      
      toast.innerHTML = `
        ${iconHtml}
        <span class="text-[12px] font-medium text-white">${message}</span>
      `;
      
      container.appendChild(toast);
      
      toast.offsetHeight; // trigger reflow
      toast.classList.remove('translate-y-2', 'opacity-0');
      
      setTimeout(() => {
        toast.classList.add('translate-y-[-8px]', 'opacity-0');
        setTimeout(() => {
          toast.remove();
        }, 300);
      }, 3000);
    }

    const deleteModal = document.getElementById('delete-modal')!;
    const modalContent = deleteModal.querySelector('.w-full')!;
    const btnDeleteCancel = document.getElementById('btn-delete-cancel')!;
    const btnDeleteConfirm = document.getElementById('btn-delete-confirm')!;
    
    let pendingDeleteLeadId: string | null = null;
    let pendingDeleteSessionId: string | null = null;

    function showDeleteModal(leadId: string, sessionId: string | null) {
      pendingDeleteLeadId = leadId;
      pendingDeleteSessionId = sessionId;
      deleteModal.classList.remove('hidden');
      deleteModal.offsetHeight;
      deleteModal.classList.remove('opacity-0');
      modalContent.classList.remove('scale-95');
      modalContent.classList.add('scale-100');
    }

    function hideDeleteModal() {
      deleteModal.classList.add('opacity-0');
      modalContent.classList.add('scale-95');
      modalContent.classList.remove('scale-100');
      setTimeout(() => {
        deleteModal.classList.add('hidden');
        pendingDeleteLeadId = null;
        pendingDeleteSessionId = null;
      }, 200);
    }

    btnDeleteCancel.addEventListener('click', hideDeleteModal);
    deleteModal.addEventListener('click', (e) => {
      if (e.target === deleteModal) hideDeleteModal();
    });

    btnDeleteConfirm.addEventListener('click', async () => {
      if (!pendingDeleteLeadId) return;

      btnDeleteConfirm.setAttribute('disabled', 'true');
      btnDeleteConfirm.innerHTML = `
        <svg class="animate-spin -ml-1 mr-2 h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" style="border-radius: 50%;">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
        </svg>
        Menghapus...
      `;

      try {
        const { data: { session } } = await supabase.auth.getSession();
        const token = session?.access_token;

        const response = await fetch('/api/delete-lead', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({
            leadId: pendingDeleteLeadId,
            sessionId: pendingDeleteSessionId,
            token
          })
        });

        const result = await response.json();

        if (!response.ok) {
          throw new Error(result.error || 'Gagal menghapus prospek.');
        }

        showToast('Prospek dan riwayat chat berhasil dihapus.');
        activeLeadId = null;
        
        // Reset detail pane
        leadDetailContainer.innerHTML = `
          <!-- Empty State -->
          <div class="flex-1 flex flex-col items-center justify-center p-8 text-[#5C5C63] text-center">
            <span class="text-4xl mb-3">🤖</span>
            <h3 class="text-white font-semibold text-[15px]">Pilih Prospek</h3>
            <p class="text-[12px] mt-1 max-w-sm leading-relaxed">Pilih salah satu prospek di sebelah kiri untuk melihat analisis kebutuhan, tech stack, dan log percakapan klien secara lengkap.</p>
          </div>
        `;

        hideDeleteModal();
        loadLeadsData();
      } catch (err: any) {
        console.error('Error deleting lead:', err);
        showToast(err.message || 'Gagal menghapus prospek.', 'error');
      } finally {
        btnDeleteConfirm.removeAttribute('disabled');
        btnDeleteConfirm.innerText = 'Ya, Hapus';
      }
    });

    // Search and filter inputs
    searchInput.addEventListener('input', () => {
      searchQuery = searchInput.value.toLowerCase().trim();
      renderLeadsList();
    });

    statusFilter.addEventListener('change', () => {
      statusQuery = statusFilter.value;
      renderLeadsList();
    });

    tempFilter.addEventListener('change', () => {
      tempQuery = tempFilter.value;
      renderLeadsList();
    });

    // Auto-polling log obrolan admin secara berkala (5 detik sekali)
    setInterval(() => {
      if (activeLeadId) {
        const lead = rawLeads.find(l => l.id === activeLeadId);
        if (lead && lead.session_id) {
          loadChatLogs(lead.session_id);
        }
      }
    }, 5000);

    btnLogout.addEventListener('click', async () => {
      await supabase.auth.signOut();
      window.location.href = '/admin/login/';
    });
  </script>
</Layout>
