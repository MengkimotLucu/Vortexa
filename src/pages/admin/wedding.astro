---
import Layout from '../../layouts/Layout.astro';
import Logo from '../../components/Logo.astro';
---

<Layout title="Manajemen Undangan Pernikahan | LUMOVELO" description="Kelola status aktif dan data undangan pernikahan klien." noindex={true}>
  <div id="admin-layout" class="hidden min-h-screen bg-slate-950 text-slate-100 flex font-sans select-none">
    
    <!-- Sidebar Navigation -->
    <aside class="w-64 border-r border-slate-800 bg-slate-900 flex flex-col justify-between shrink-0">
      <div>
        <div class="p-6 border-b border-slate-800 flex items-center gap-3">
          <div class="w-8 h-8 rounded-lg border border-slate-700 bg-blue-600 flex items-center justify-center">
            <Logo class="w-4 h-4 text-white" />
          </div>
          <span class="font-display font-black text-base tracking-widest text-white">LUMOVELO</span>
        </div>

        <nav class="p-4 space-y-1.5">
          <a href="/admin/dashboard/" class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-400 hover:text-white hover:bg-slate-800/50 border border-transparent hover:border-slate-800 text-xs font-black uppercase tracking-wider transition-all">
            📊 Ringkasan Panel
          </a>
          <a href="/admin/finance/" class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-400 hover:text-white hover:bg-slate-800/50 border border-transparent hover:border-slate-800 text-xs font-black uppercase tracking-wider transition-all">
            💰 Laporan Keuangan
          </a>
          <a href="/admin/profit-sharing/" class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-400 hover:text-white hover:bg-slate-800/50 border border-transparent hover:border-slate-800 text-xs font-black uppercase tracking-wider transition-all">
            🤝 Bagi Hasil Tim
          </a>
          <a href="/admin/wedding/" class="flex items-center gap-3 px-4 py-3 rounded-xl bg-blue-600/10 text-blue-400 border border-blue-500/20 text-xs font-black uppercase tracking-wider">
            💍 Undangan Pernikahan
          </a>
          <a href="/workspace/invoice/" class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-400 hover:text-white hover:bg-slate-800/50 border border-transparent hover:border-slate-800 text-xs font-black uppercase tracking-wider transition-all">
            📄 Buat Dokumen
          </a>
        </nav>
      </div>

      <div class="p-4 border-t border-slate-800">
        <button id="btn-logout" class="w-full flex items-center justify-center gap-2 px-4 py-3 rounded-xl bg-rose-500/10 border border-rose-500/20 text-rose-400 hover:bg-rose-500 hover:text-white text-xs font-black uppercase tracking-widest transition-all cursor-pointer">
          🚪 Keluar Dashboard
        </button>
      </div>
    </aside>

    <!-- Main Content Area -->
    <main class="flex-1 flex flex-col min-w-0">
      <header class="h-20 border-b border-slate-800 bg-slate-900/40 px-8 flex items-center justify-between">
        <div>
          <h1 class="text-sm font-mono font-bold text-slate-400 uppercase tracking-widest">MANAJEMEN UNDANGAN DIGITAL</h1>
          <p class="text-xs text-slate-500 mt-0.5">Kelola status aktif, verifikasi data, dan hapus undangan pernikahan klien.</p>
        </div>
        <div class="flex items-center gap-3">
          <div class="w-2.5 h-2.5 rounded-full bg-emerald-500 animate-pulse"></div>
          <span class="text-xs font-mono text-slate-400">DATABASE: SUPABASE CONNECTED</span>
        </div>
      </header>

      <!-- Body -->
      <div class="p-8 overflow-y-auto flex-1 space-y-6">
        
        <!-- Daftar Undangan Pernikahan Klien -->
        <div class="bg-slate-900/50 border border-slate-800 rounded-2xl overflow-hidden">
          <div class="p-6 border-b border-slate-800 flex justify-between items-center">
            <h3 class="font-display font-black text-sm text-white uppercase tracking-wider">Daftar Undangan Pernikahan Klien</h3>
            <span class="text-[10px] font-mono text-emerald-500">WEDDING INVITATIONS</span>
          </div>

          <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse text-xs">
              <thead>
                <tr class="border-b border-slate-800/80 bg-slate-950/40 text-slate-400 font-bold">
                  <th class="p-4">KLIEN</th>
                  <th class="p-4">SLUG / LINK</th>
                  <th class="p-4">TEMA DESAIN</th>
                  <th class="p-4">MEMPELAI</th>
                  <th class="p-4">TANGGAL AKAD</th>
                  <th class="p-4">WA RSVP</th>
                  <th class="p-4">STATUS</th>
                  <th class="p-4 text-right">AKSI</th>
                </tr>
              </thead>
              <tbody id="wedding-table-body" class="divide-y divide-slate-800/50 text-slate-300">
                <tr>
                  <td colspan="8" class="p-8 text-center text-slate-500 font-medium">Memuat data undangan...</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>

      </div>
    </main>
  </div>

  <script>
    import { supabase } from '../../lib/supabase';

    const adminLayout = document.getElementById('admin-layout')!;
    const btnLogout = document.getElementById('btn-logout')!;
    
    let allWeddings: any[] = [];

    // Auth Validation check
    async function validateAdminSession() {
      const { data: { session } } = await supabase.auth.getSession();
      if (!session) {
        window.location.href = '/admin/login/';
      } else {
        adminLayout.classList.remove('hidden');
        loadWeddingsData();
      }
    }
    validateAdminSession();

    // Fetch and Render Weddings
    async function loadWeddingsData() {
      try {
        const { data: weddings, error: weddingsError } = await supabase
          .from('wedding_invitations')
          .select('*')
          .order('created_at', { ascending: false });

        if (weddingsError) throw weddingsError;

        const weddingTableBody = document.getElementById('wedding-table-body')!;
        if (!weddings || weddings.length === 0) {
          allWeddings = [];
          weddingTableBody.innerHTML = `
            <tr>
              <td colspan="8" class="p-8 text-center text-slate-500 font-medium">Belum ada data undangan pernikahan yang disubmit.</td>
            </tr>
          `;
        } else {
          allWeddings = weddings;
          weddingTableBody.innerHTML = weddings.map((w) => {
            const isActive = w.payment_info?.is_active !== false;
            const statusText = isActive ? 'AKTIF' : 'NONAKTIF';
            const statusClass = isActive 
              ? 'bg-emerald-500/10 border border-emerald-500/20 text-emerald-400' 
              : 'bg-amber-500/10 border border-amber-500/20 text-amber-400';

            const toggleText = isActive ? 'Matikan' : 'Aktifkan';
            const toggleBtnClass = isActive
              ? 'px-2.5 py-1 rounded-lg bg-amber-500/10 border border-amber-500/20 text-amber-400 hover:bg-amber-500 hover:text-white transition-all cursor-pointer text-[9px] font-black uppercase tracking-wider btn-toggle-wedding'
              : 'px-2.5 py-1 rounded-lg bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 hover:bg-emerald-500 hover:text-white transition-all cursor-pointer text-[9px] font-black uppercase tracking-wider btn-toggle-wedding';

            return `
              <tr class="hover:bg-slate-900/20 transition-colors">
                <td class="p-4 font-bold text-white">${w.client_name}</td>
                <td class="p-4">
                  <a href="/undangan/form" target="_blank" class="text-blue-400 hover:underline font-mono">
                    lumovelo.agency/${w.slug}
                  </a>
                </td>
                <td class="p-4 uppercase font-mono text-slate-400">${w.theme}</td>
                <td class="p-4 text-slate-300">${w.groom_name} & ${w.bride_name}</td>
                <td class="p-4 text-slate-400">${w.akad_date || '-'}</td>
                <td class="p-4 font-mono text-slate-400">${w.whatsapp_rsvp || '-'}</td>
                <td class="p-4">
                  <span class="px-2 py-0.5 rounded-lg text-[9px] font-black uppercase tracking-wider ${statusClass}">
                    ${statusText}
                  </span>
                </td>
                <td class="p-4 text-right space-x-1.5 whitespace-nowrap">
                  <button data-id="${w.id}" data-active="${isActive}" class="${toggleBtnClass}">${toggleText}</button>
                  <button data-id="${w.id}" class="px-2.5 py-1 rounded-lg bg-rose-500/10 border border-rose-500/20 text-rose-400 hover:bg-rose-500 hover:text-white transition-all cursor-pointer text-[9px] font-black uppercase tracking-wider btn-delete-wedding">Hapus</button>
                </td>
              </tr>
            `;
          }).join('');
        }
      } catch (err) {
        console.error('Error fetching weddings:', err);
      }
    }

    btnLogout.addEventListener('click', async () => {
      await supabase.auth.signOut();
      window.location.href = '/admin/login/';
    });

    // Event delegation for wedding actions
    const weddingTableBodyEl = document.getElementById('wedding-table-body')!;
    weddingTableBodyEl.addEventListener('click', async (e) => {
      const target = e.target as HTMLElement;
      if (target.classList.contains('btn-toggle-wedding')) {
        const id = target.getAttribute('data-id');
        const currentActive = target.getAttribute('data-active') === 'true';
        if (id) await toggleWeddingStatus(id, currentActive);
      } else if (target.classList.contains('btn-delete-wedding')) {
        const id = target.getAttribute('data-id');
        if (id && confirm('Apakah Anda yakin ingin menghapus data undangan ini?')) {
          await deleteWedding(id);
        }
      }
    });

    async function toggleWeddingStatus(id: string, currentActive: boolean) {
      try {
        const wedding = allWeddings.find((w) => w.id === id);
        if (!wedding) return;

        const updatedPaymentInfo = {
          ...(wedding.payment_info || {}),
          is_active: !currentActive
        };

        const { error } = await supabase
          .from('wedding_invitations')
          .update({ payment_info: updatedPaymentInfo })
          .eq('id', id);

        if (error) throw error;

        (window as any).showToast(`Undangan berhasil ${!currentActive ? 'diaktifkan' : 'dinonaktifkan'}!`, 'success');
        loadWeddingsData();
      } catch (err: any) {
        (window as any).showToast(err.message || 'Gagal mengubah status undangan.', 'error');
      }
    }

    async function deleteWedding(id: string) {
      try {
        const { error } = await supabase
          .from('wedding_invitations')
          .delete()
          .eq('id', id);

        if (error) throw error;

        (window as any).showToast('Undangan berhasil dihapus!', 'success');
        loadWeddingsData();
      } catch (err: any) {
        (window as any).showToast(err.message || 'Gagal menghapus undangan.', 'error');
      }
    }
  </script>
</Layout>
