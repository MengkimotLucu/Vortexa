---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import Logo from '../../components/Logo.astro';
---

<Layout title="Dashboard Admin | LUMOVELO" description="Panel pusat kontrol agensi Lumovelo." noindex={true}>
  <div id="admin-layout" class="min-h-screen dashboard-root grain flex relative">
    
    <!-- Sidebar Backdrop Overlay on Mobile -->
    <div id="admin-sidebar-overlay" class="fixed inset-0 bg-black/70 z-[90] lg:hidden hidden opacity-0 transition-opacity duration-300"></div>

    <!-- Sidebar Navigation -->
    <aside id="admin-sidebar" class="fixed inset-y-0 left-0 z-[100] flex w-[248px] -translate-x-full flex-col border-r border-[#1A1A1E] bg-[#0C0C0E] transition-transform duration-300 lg:static lg:flex lg:translate-x-0 lg:z-auto">
      <!-- Logo -->
      <div class="px-5 pt-6 pb-7 flex items-center justify-between gap-2.5">
        <div class="flex items-center gap-2.5">
          <div class="w-8 h-8 rounded-lg flex items-center justify-center bg-[#C5F82A]">
            <Logo class="w-4 h-4 text-[#0A0A0B]" />
          </div>
          <div class="flex items-baseline gap-1.5">
            <span class="font-semibold tracking-tight text-[15px] text-white">LUMOVELO</span>
            <span class="mono text-[10px] text-[#5C5C63]">v2.4</span>
          </div>
        </div>
        <!-- Close button on mobile -->
        <button id="btn-close-sidebar" class="lg:hidden p-1.5 rounded-md hover:bg-[#16161A] text-white cursor-pointer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
        </button>
      </div>

      <!-- Workspace switcher -->
      <div class="px-3 mb-5">
        <div class="w-full flex items-center gap-2.5 px-2.5 py-2 rounded-lg border border-[#232328] bg-[#131316]">
          <div class="w-6 h-6 rounded-md flex items-center justify-center text-[10px] font-bold bg-[#2A2A30] text-[#C5F82A]">LV</div>
          <div class="flex-1 min-w-0">
            <div class="text-[12px] font-medium leading-tight text-white">Lumovelo Agency</div>
            <div class="text-[10px] mono text-[#5C5C63]">workspace · admin</div>
          </div>
        </div>
      </div>

      <!-- Nav -->
      <nav class="px-3 flex-1 overflow-y-auto scroll-thin" id="nav">
        <div class="px-2.5 mb-1.5 mono text-[10px] uppercase tracking-wider text-[#5C5C63]">Analytics</div>
        <a href="/admin/dashboard/" class="nav-item active flex items-center gap-3 px-2.5 py-2 rounded-md text-[13px] text-[#F4F4F2]">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="7" height="9" rx="1"/><rect x="14" y="3" width="7" height="5" rx="1"/><rect x="14" y="12" width="7" height="9" rx="1"/><rect x="3" y="16" width="7" height="5" rx="1"/></svg>
          Overview
        </a>
        <a href="/admin/finance/" class="nav-item flex items-center gap-3 px-2.5 py-2 rounded-md text-[13px] text-[#8A8A90]">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 3v18h18"/><path d="M7 14l4-4 3 3 5-6"/></svg>
          Revenue
        </a>
        <a href="/admin/profit-sharing/" class="nav-item flex items-center gap-3 px-2.5 py-2 rounded-md text-[13px] text-[#8A8A90]">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="9" cy="8" r="4"/><path d="M3 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2"/><circle cx="17" cy="6" r="2.5"/><path d="M14 21v-1a3 3 0 0 1 3-3h0a3 3 0 0 1 3 3v1"/></svg>
          Bagi Hasil Tim
        </a>
        <a href="/admin/blog/" class="nav-item flex items-center gap-3 px-2.5 py-2 rounded-md text-[13px] text-[#8A8A90]">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 2v20M2 12h20"/><circle cx="12" cy="12" r="9"/></svg>
          Kelola Blog
        </a>
        <a href="/admin/leads/" class="nav-item flex items-center gap-3 px-2.5 py-2 rounded-md text-[13px] text-[#8A8A90]">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="shrink-0"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          Leads AI
        </a>
        <a href="/admin/telemetry/" class="nav-item flex items-center gap-3 px-2.5 py-2 rounded-md text-[13px] text-[#8A8A90]">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          Telemetri & IP
        </a>
        <a href="/admin/ai-settings/" class="nav-item flex items-center gap-3 px-2.5 py-2 rounded-md text-[13px] text-[#8A8A90]">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
          Pengaturan AI
        </a>

        <div class="px-2.5 mb-1.5 mt-5 mono text-[10px] uppercase tracking-wider text-[#5C5C63]">Workspace / Dokumen</div>
        <a href="/workspace/invoice/" class="nav-item flex items-center gap-3 px-2.5 py-1.5 rounded-md text-[12.5px] text-[#8A8A90]">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="shrink-0"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 9h6v6H9z"/></svg>
          Invoice & Kuitansi
        </a>
        <a href="/workspace/spk/" class="nav-item flex items-center gap-3 px-2.5 py-1.5 rounded-md text-[12.5px] text-[#8A8A90]">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="shrink-0"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
          SPK & MoU Kontrak
        </a>
        <a href="/workspace/rab/" class="nav-item flex items-center gap-3 px-2.5 py-1.5 rounded-md text-[12.5px] text-[#8A8A90]">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="shrink-0"><path d="M3 3v18h18"/><path d="M18 17V9"/><path d="M13 17V5"/><path d="M8 17v-3"/></svg>
          RAB & SRS Proposal
        </a>
        <a href="/workspace/bast/" class="nav-item flex items-center gap-3 px-2.5 py-1.5 rounded-md text-[12.5px] text-[#8A8A90]">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="shrink-0"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          BAST Serah Terima
        </a>
      </nav>

      <!-- Usage card -->
      <div class="m-3 p-3.5 rounded-xl border border-[#232328]" style="background: linear-gradient(180deg, #16161A 0%, #0E0E11 100%);">
        <div class="flex items-center justify-between mb-2">
          <span class="text-[11px] font-medium text-white">Target Sales</span>
          <span class="mono text-[10px] text-[#8A8A90]" id="sales-target-percentage">0%</span>
        </div>
        <div class="h-1.5 rounded-full overflow-hidden bg-[#232328]">
          <div id="sales-target-bar" class="h-full rounded-full" style="width: 0%; background: linear-gradient(90deg, #C5F82A, #8FB520);"></div>
        </div>
        <div class="flex items-center justify-between mt-3">
          <span class="mono text-[10px] text-[#5C5C63]" id="sales-target-ratio">Rp 0 / Rp 100M</span>
          <a href="/admin/finance/" class="text-[11px] font-medium text-[#C5F82A] hover:underline">Detail →</a>
        </div>
      </div>

      <!-- User logout footer -->
      <div class="px-3 pb-4 pt-1 border-t border-[#1A1A1E]">
        <button id="btn-logout" class="w-full flex items-center gap-2.5 px-2 py-2 rounded-md hover:bg-[#16161A] transition text-left group">
          <div class="w-8 h-8 rounded-full flex items-center justify-center text-[11px] font-semibold bg-[#2A2A30] text-[#F4F4F2]">AD</div>
          <div class="flex-1 min-w-0">
            <div class="text-[12px] font-medium leading-tight text-white group-hover:text-[#F87171] transition-colors">Sign Out</div>
            <div class="text-[10px] mono text-[#5C5C63]">administrator</div>
          </div>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-[#8A8A90] group-hover:text-[#F87171] transition-colors"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        </button>
      </div>
    </aside>

    <!-- Main Content Area -->
    <main class="flex-1 min-w-0 flex flex-col">
      <!-- Top bar -->
      <header class="sticky top-0 z-20 flex items-center gap-3 px-4 lg:px-8 h-16 border-b border-[#1A1A1E] backdrop-blur-md bg-[rgba(10,10,11,0.78)]">
        <button id="btn-open-sidebar" class="lg:hidden p-2 rounded-md hover:bg-[#16161A] text-white cursor-pointer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
        </button>
        <div class="hidden md:flex items-center gap-2 text-[13px] text-[#8A8A90]">
          <span>Lumovelo</span>
          <span class="text-[#5C5C63]">/</span>
          <span class="text-[#F4F4F2] font-medium">Overview</span>
        </div>

        <div class="ml-auto flex items-center gap-2">
          <div class="hidden sm:flex items-center gap-2 px-3 h-9 rounded-lg border border-[#232328] bg-[#131316] w-52 md:w-64">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-[#8A8A90]"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>
            <input type="text" placeholder="Cari dokumen, invoice..." class="bg-transparent text-[12px] flex-1 outline-none placeholder:text-[#5C5C63] text-[#F4F4F2]">
            <span class="kbd">⌘K</span>
          </div>

          <!-- Quick Document Creation Menu -->
          <div class="relative">
            <button id="btn-quick-doc-menu" class="flex items-center gap-1.5 h-9 px-3 rounded-lg text-[12px] font-semibold bg-[#C5F82A] text-[#0A0A0B] hover:opacity-90 transition-opacity cursor-pointer shadow-md">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg>
              <span>Buat Dokumen</span>
            </button>
            
            <div id="quick-doc-dropdown" class="hidden absolute right-0 mt-2 w-52 bg-[#131316] border border-[#232328] rounded-xl shadow-2xl z-50 py-1.5 font-sans overflow-hidden">
              <div class="px-3 py-1.5 text-[10px] mono uppercase text-[#5C5C63] border-b border-[#1A1A1E]">Pilih Jenis Dokumen</div>
              <a href="/workspace/invoice/" class="flex items-center gap-2.5 px-3 py-2 text-[12px] text-white hover:bg-[#1C1C24] transition">
                <span class="w-2 h-2 rounded-full bg-[#C5F82A]"></span> Invoice & Kuitansi
              </a>
              <a href="/workspace/spk/" class="flex items-center gap-2.5 px-3 py-2 text-[12px] text-white hover:bg-[#1C1C24] transition">
                <span class="w-2 h-2 rounded-full bg-blue-400"></span> SPK & MoU Kontrak
              </a>
              <a href="/workspace/rab/" class="flex items-center gap-2.5 px-3 py-2 text-[12px] text-white hover:bg-[#1C1C24] transition">
                <span class="w-2 h-2 rounded-full bg-purple-400"></span> RAB & SRS Proposal
              </a>
              <a href="/workspace/bast/" class="flex items-center gap-2.5 px-3 py-2 text-[12px] text-white hover:bg-[#1C1C24] transition">
                <span class="w-2 h-2 rounded-full bg-emerald-400"></span> BAST Serah Terima
              </a>
            </div>
          </div>
        </div>
      </header>

      <!-- Content -->
      <div class="flex-1 flex flex-col justify-start items-stretch overflow-y-auto scroll-thin px-4 lg:px-6 py-5">
        <!-- Page header -->
        <section class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-5">
          <div>
            <div class="flex items-center gap-2 mb-2">
              <span class="live-dot w-1.5 h-1.5 rounded-full bg-[#C5F82A]"></span>
              <span class="mono text-[11px] uppercase tracking-wider text-[#8A8A90]">DATABASE: SUPABASE CONNECTED</span>
            </div>
            <h1 id="greeting-title" class="serif text-[44px] md:text-[52px] leading-[0.95] text-white">Good morning, Admin.</h1>
            <p class="mt-2 text-[14px] text-[#8A8A90]">Berikut rangkuman aktivitas, dokumen keuangan, dan leads masuk hari ini.</p>
          </div>
          <div class="flex items-center gap-1.5 shrink-0" id="range">
            <button class="pill px-3 h-8 text-[12px] text-[#8A8A90] cursor-pointer" data-range="24h">24h</button>
            <button class="pill px-3 h-8 text-[12px] text-[#8A8A90] cursor-pointer" data-range="7d">7d</button>
            <button class="pill active px-3 h-8 text-[12px] text-[#0A0A0B] bg-[#C5F82A] border-[#C5F82A] cursor-pointer" data-range="30d">30d</button>
            <button class="pill px-3 h-8 text-[12px] text-[#8A8A90] cursor-pointer" data-range="90d">90d</button>
            <button class="pill px-3 h-8 text-[12px] text-[#8A8A90] cursor-pointer" data-range="ytd">YTD</button>
          </div>
        </section>

        <!-- KPI Cards Grid -->
        <section class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-4 mb-4">
          <!-- Omzet Proyek -->
          <div class="card p-5 relative overflow-hidden">
            <div class="flex items-center justify-between mb-3">
              <span class="text-[12px] text-[#8A8A90]">Omzet Proyek</span>
              <span class="mono text-[10px] px-1.5 py-0.5 rounded bg-[rgba(197,248,42,0.12)] text-[#C5F82A]">+18.4%</span>
            </div>
            <div class="flex items-baseline gap-1.5">
              <span id="stat-revenue" class="serif text-[32px] leading-none text-white font-bold">Rp 0</span>
            </div>
            <div class="mt-1 text-[11px] mono text-[#5C5C63]">akumulasi invoice dibayar</div>
            <svg viewBox="0 0 120 32" class="mt-3 w-full h-8">
              <path class="spark-path" stroke="#C5F82A" d="M0,28 L15,24 L30,26 L45,18 L60,20 L75,12 L90,14 L105,6 L120,8"/>
              <path d="M0,28 L15,24 L30,26 L45,18 L60,20 L75,12 L90,14 L105,6 L120,8 L120,32 L0,32 Z" fill="url(#sparkG1)"/>
              <defs>
                <linearGradient id="sparkG1" x1="0" x2="0" y1="0" y2="1">
                  <stop offset="0%" stop-color="#C5F82A" stop-opacity="0.25"/>
                  <stop offset="100%" stop-color="#C5F82A" stop-opacity="0"/>
                </linearGradient>
              </defs>
            </svg>
          </div>

          <!-- Dokumen Terbit -->
          <div class="card p-5 relative overflow-hidden">
            <div class="flex items-center justify-between mb-3">
              <span class="text-[12px] text-[#8A8A90]">Dokumen Terbit</span>
              <span class="mono text-[10px] px-1.5 py-0.5 rounded bg-[rgba(244,244,242,0.12)] text-[#F4F4F2]">+7.2%</span>
            </div>
            <div class="flex items-baseline gap-1.5">
              <span id="stat-docs" class="serif text-[32px] leading-none text-white font-bold">0 Dokumen</span>
            </div>
            <div class="mt-1 text-[11px] mono text-[#5C5C63]">invoices & quotations</div>
            <svg viewBox="0 0 120 32" class="mt-3 w-full h-8">
              <path class="spark-path" stroke="#F4F4F2" d="M0,22 L15,20 L30,18 L45,16 L60,18 L75,14 L90,12 L105,10 L120,8"/>
              <path d="M0,22 L15,20 L30,18 L45,16 L60,18 L75,14 L90,12 L105,10 L120,8 L120,32 L0,32 Z" fill="url(#sparkG2)"/>
              <defs>
                <linearGradient id="sparkG2" x1="0" x2="0" y1="0" y2="1">
                  <stop offset="0%" stop-color="#F4F4F2" stop-opacity="0.18"/>
                  <stop offset="100%" stop-color="#F4F4F2" stop-opacity="0"/>
                </linearGradient>
              </defs>
            </svg>
          </div>

          <!-- Tagihan Pending -->
          <div class="card p-5 relative overflow-hidden">
            <div class="flex items-center justify-between mb-3">
              <span class="text-[12px] text-[#8A8A90]">Tagihan Pending</span>
              <span class="mono text-[10px] px-1.5 py-0.5 rounded bg-[rgba(245,165,36,0.14)] text-[#F5A524]">-0.6%</span>
            </div>
            <div class="flex items-baseline gap-1.5">
              <span id="stat-unpaid" class="serif text-[32px] leading-none text-white font-bold">Rp 0</span>
            </div>
            <div class="mt-1 text-[11px] mono text-[#5C5C63]">menunggu pembayaran klien</div>
            <svg viewBox="0 0 120 32" class="mt-3 w-full h-8">
              <path class="spark-path" stroke="#F5A524" d="M0,14 L15,12 L30,16 L45,14 L60,18 L75,16 L90,20 L105,18 L120,22"/>
              <path d="M0,14 L15,12 L30,16 L45,14 L60,18 L75,16 L90,20 L105,18 L120,22 L120,32 L0,32 Z" fill="url(#sparkG3)"/>
              <defs>
                <linearGradient id="sparkG3" x1="0" x2="0" y1="0" y2="1">
                  <stop offset="0%" stop-color="#F5A524" stop-opacity="0.2"/>
                  <stop offset="100%" stop-color="#F5A524" stop-opacity="0"/>
                </linearGradient>
              </defs>
            </svg>
          </div>

          <!-- Prospek AI (Leads) -->
          <div id="kpi-leads-card" class="card p-5 relative overflow-hidden cursor-pointer hover:border-[#3a3a42] transition-colors">
            <div class="flex items-center justify-between mb-3">
              <span class="text-[12px] text-[#8A8A90]">Prospek AI (Leads)</span>
              <span class="mono text-[10px] px-1.5 py-0.5 rounded bg-[rgba(248,113,113,0.14)] text-[#F87171]">+1.1%</span>
            </div>
            <div class="flex items-baseline gap-1.5">
              <span id="stat-leads" class="serif text-[32px] leading-none text-white font-bold">0 Sesi</span>
            </div>
            <div class="mt-1 text-[11px] mono text-[#5C5C63]">chat widget & data kontak</div>
            <svg viewBox="0 0 120 32" class="mt-3 w-full h-8">
              <path class="spark-path" stroke="#F87171" d="M0,24 L15,22 L30,24 L45,20 L60,22 L75,18 L90,20 L105,16 L120,14"/>
              <path d="M0,24 L15,22 L30,24 L45,20 L60,22 L75,18 L90,20 L105,16 L120,14 L120,32 L0,32 Z" fill="url(#sparkG4)"/>
              <defs>
                <linearGradient id="sparkG4" x1="0" x2="0" y1="0" y2="1">
                  <stop offset="0%" stop-color="#F87171" stop-opacity="0.18"/>
                  <stop offset="100%" stop-color="#F87171" stop-opacity="0"/>
                </linearGradient>
              </defs>
            </svg>
          </div>
        </section>

        <!-- Main grid: chart + side -->
        <section class="grid grid-cols-1 xl:grid-cols-3 gap-4 mb-4">
          <!-- Revenue chart -->
          <div class="card p-5 xl:col-span-2">
            <div class="flex flex-wrap items-start justify-between gap-3 mb-5">
              <div>
                <h2 class="text-[15px] font-semibold text-white">Grafik Kinerja Omzet</h2>
                <p class="text-[12px] mt-0.5 text-[#8A8A90]">Representasi visual 30 hari terakhir</p>
              </div>
              <div class="flex items-center gap-4 text-[12px]">
                <label class="flex items-center gap-2">
                  <span class="w-2.5 h-2.5 rounded-sm bg-[#C5F82A]"></span>
                  <span class="text-[#8A8A90]">Invoice Terbayar</span>
                </label>
                <label class="flex items-center gap-2">
                  <span class="w-2.5 h-2.5 rounded-sm bg-[#F87171]"></span>
                  <span class="text-[#8A8A90]">Tagihan Pending</span>
                </label>
              </div>
            </div>

            <!-- Chart SVG -->
            <div class="relative">
              <svg id="range-chart-svg" viewBox="0 0 720 240" class="w-full h-[240px]" preserveAspectRatio="none">
                <defs>
