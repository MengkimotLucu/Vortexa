  <style>
    @import url('https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap');
    
    :root {
      --bg: #0A0A0B;
      --panel: #131316;
      --panel-2: #18181C;
      --border: #232328;
      --border-soft: #1A1A1E;
      --ink: #F4F4F2;
      --muted: #8A8A90;
      --muted-2: #5C5C63;
      --accent: #C5F82A;
      --accent-dim: #8FB520;
      --warn: #F5A524;
      --rose: #F87171;
    }
    
    .dashboard-root {
      background: var(--bg) !important;
      color: var(--ink) !important;
      font-family: 'Inter', system-ui, sans-serif !important;
      -webkit-font-smoothing: antialiased;
    }
    
    .serif {
      font-family: 'Instrument Serif', serif !important;
      font-weight: 400;
      letter-spacing: -0.01em;
    }
    
    .mono {
      font-family: 'JetBrains Mono', monospace !important;
    }
    
    .grain {
      background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.02) 1px, transparent 0);
      background-size: 3px 3px;
    }
    
    .card {
      background: var(--panel) !important;
      border: 1px solid var(--border) !important;
      border-radius: 14px;
    }
    
    .nav-item {
      transition: all .18s ease;
      position: relative;
    }
    
    .nav-item:hover {
      background: var(--panel-2) !important;
      color: var(--ink) !important;
    }
    
    .nav-item.active {
      background: var(--panel-2) !important;
      color: var(--ink) !important;
    }
    
    .nav-item.active::before {
      content: '';
      position: absolute;
      left: -1px;
      top: 50%;
      transform: translateY(-50%);
      width: 3px;
      height: 18px;
      background: var(--accent);
      border-radius: 2px;
    }
    
    .pill {
      border: 1px solid var(--border);
      border-radius: 999px;
      transition: all .15s ease;
    }
    
    .pill:hover {
      border-color: #3a3a42;
    }
    
    .pill.active {
      background: var(--accent) !important;
      color: #0A0A0B !important;
      border-color: var(--accent) !important;
      font-weight: 600;
    }
    
    .row-hover:hover {
      background: var(--panel-2) !important;
    }
    
    .scroll-thin::-webkit-scrollbar {
      width: 6px;
      height: 6px;
    }
    
    .scroll-thin::-webkit-scrollbar-thumb {
      background: #2a2a30;
      border-radius: 3px;
    }
    
    .scroll-thin::-webkit-scrollbar-track {
      background: transparent;
    }
    
    .spark-path {
      fill: none;
      stroke-width: 1.5;
    }
    
    .ring-dot {
      box-shadow: 0 0 0 3px var(--panel);
    }
    
    @keyframes pulse-soft {
      0%, 100% {
        opacity: 1;
      }
      50% {
        opacity: .45;
      }
    }
    
    .live-dot {
      animation: pulse-soft 1.8s ease-in-out infinite;
    }
    
    .kbd {
      font-family: 'JetBrains Mono', monospace !important;
      font-size: 10px;
      border: 1px solid var(--border);
      border-bottom-width: 2px;
      border-radius: 4px;
      padding: 1px 5px;
      color: var(--muted);
    }
  </style>

  <script>
    import { supabase } from '../../lib/supabase';

    const adminLayout = document.getElementById('admin-layout')!;
    const btnLogout = document.getElementById('btn-logout')!;
    
    let rawDocs: any[] = [];
    let rawSharingLogs: any[] = [];
    let rawLeads: any[] = [];
    let rawSessions: any[] = [];
    let currentRange = '30d';

    // Auth Validation check
    async function validateAdminSession() {
      const { data: { session } } = await supabase.auth.getSession();
      if (!session) {
        window.location.href = '/admin/login/';
        return;
      }

      // Check if user email is authorized admin
      const userEmail = session.user.email?.toLowerCase();
      const allowedEmails = (import.meta.env.PUBLIC_ADMIN_EMAILS || 'admin@lumovelo.com')
        .split(',')
        .map(e => e.trim().toLowerCase());
      const isAdmin = userEmail && allowedEmails.includes(userEmail);

      if (!isAdmin) {
        await supabase.auth.signOut();
        await (window as any).showAlert('Akses Ditolak: Anda bukan administrator resmi.');
        window.location.href = '/admin/login/';
        return;
      }

      adminLayout.classList.remove('hidden');
      setGreetingMessage();
      loadDashboardStats();
    }
    validateAdminSession();

    // Set greeting depending on hour
    function setGreetingMessage() {
      const hour = new Date().getHours();
      let greeting = 'Good evening, Admin.';
      if (hour < 12) {
        greeting = 'Good morning, Admin.';
      } else if (hour < 18) {
        greeting = 'Good afternoon, Admin.';
      }
      document.getElementById('greeting-title')!.innerText = greeting;
    }

    // Stats and Tables fetch
    async function loadDashboardStats() {
      try {
        // Fetch all documents
        const { data: docs, error: docsError } = await supabase
          .from('documents')
          .select('*')
          .order('created_at', { ascending: false });

        if (docsError) throw docsError;

        // Fetch Profit Sharing logs
        const { data: sharingLogs, error: sharingError } = await supabase
          .from('profit_sharing')
          .select('*');

        if (sharingError) throw sharingError;

        // Fetch Leads
        const { data: leads, error: leadsError } = await supabase
          .from('leads')
          .select('*')
          .order('created_at', { ascending: false });

        if (leadsError) throw leadsError;

        // Fetch Chat Sessions
        const { data: sessions, error: sessionsError } = await supabase
          .from('ai_chat_sessions')
          .select('*');

        if (sessionsError) throw sessionsError;

        rawDocs = docs || [];
        rawSharingLogs = sharingLogs || [];
        rawLeads = leads || [];
        rawSessions = sessions || [];

        renderDashboardForRange(currentRange);
      } catch (err) {
        console.error('Error fetching dashboard stats:', err);
      }
    }

    // Render dashboard views based on range
    function renderDashboardForRange(range: string) {
      const now = new Date();
      let limitDate = new Date(now.getTime() - 30 * 24 * 60 * 60 * 1000); // default 30d

      if (range === '24h') {
        limitDate = new Date(now.getTime() - 24 * 60 * 60 * 1000);
      } else if (range === '7d') {
        limitDate = new Date(now.getTime() - 7 * 24 * 60 * 60 * 1000);
      } else if (range === '30d') {
        limitDate = new Date(now.getTime() - 30 * 24 * 60 * 60 * 1000);
      } else if (range === '90d') {
        limitDate = new Date(now.getTime() - 90 * 24 * 60 * 60 * 1000);
      } else if (range === 'ytd') {
        limitDate = new Date(now.getFullYear(), 0, 1);
      }

      // Filter documents & sharing logs
      const filteredDocs = rawDocs.filter(d => new Date(d.created_at || d.doc_date) >= limitDate);
      const filteredSharing = rawSharingLogs.filter(s => new Date(s.created_at) >= limitDate);

      // 1. Calculate KPI stats
      const docCount = filteredDocs.length;
      let revenue = 0;
      let unpaid = 0;

      filteredDocs.forEach((doc) => {
        if (doc.doc_type === 'invoice') {
          const docAmount = Number(doc.amount) || 0;
          if (doc.status === 'PAID') {
            revenue += docAmount;
          } else if (doc.status === 'UNPAID' || doc.status === 'OVERDUE') {
            unpaid += docAmount;
          }
        }
      });

      document.getElementById('stat-revenue')!.innerText = `Rp ${revenue.toLocaleString('id-ID')}`;
      document.getElementById('stat-docs')!.innerText = `${docCount} Dokumen`;
      document.getElementById('stat-unpaid')!.innerText = `Rp ${unpaid.toLocaleString('id-ID')}`;

      // Update Leads KPI count dynamically
      const activeLeadsCount = rawLeads.length;
      document.getElementById('stat-leads')!.innerText = `${activeLeadsCount} Sesi`;

      // 2. Sales Target bar calculations (Sales Target: 100M IDR)
      const targetValue = 100000000;
      const currentPercentage = Math.min((revenue / targetValue) * 100, 100);
      document.getElementById('sales-target-percentage')!.innerText = `${currentPercentage.toFixed(1)}%`;
      document.getElementById('sales-target-bar')!.style.width = `${currentPercentage}%`;
      document.getElementById('sales-target-ratio')!.innerText = `Rp ${(revenue / 1000000).toFixed(1)}M / Rp ${(targetValue / 1000000).toFixed(0)}M`;

      // 3. Top Sources (Layanan Populer) based on PAID invoices revenue in range
      const serviceRevenue = {
        'Landing Page': 0,
        'Company Profile': 0,
        'Toko Online': 0,
        'AI Chatbot': 0,
        'SEO & Video Ads': 0,
        'Software QA': 0,
        'Lainnya': 0
      };

      let rangePaidRevenue = 0;
      filteredDocs.forEach((doc) => {
        if (doc.doc_type === 'invoice' && doc.status === 'PAID') {
          const amt = Number(doc.amount) || 0;
          rangePaidRevenue += amt;
          
          const desc = (doc.doc_data?.task_description || doc.doc_type || '').toLowerCase();
          if (desc.includes('landing')) {
            serviceRevenue['Landing Page'] += amt;
          } else if (desc.includes('company') || desc.includes('profile') || desc.includes('profil')) {
            serviceRevenue['Company Profile'] += amt;
          } else if (desc.includes('toko') || desc.includes('online') || desc.includes('shop') || desc.includes('commerce')) {
            serviceRevenue['Toko Online'] += amt;
          } else if (desc.includes('bot') || desc.includes('chatbot') || desc.includes('ai')) {
            serviceRevenue['AI Chatbot'] += amt;
          } else if (desc.includes('seo') || desc.includes('video') || desc.includes('creative') || desc.includes('ads')) {
            serviceRevenue['SEO & Video Ads'] += amt;
          } else if (desc.includes('qa') || desc.includes('test') || desc.includes('testing') || desc.includes('quality')) {
            serviceRevenue['Software QA'] += amt;
          } else {
            serviceRevenue['Lainnya'] += amt;
          }
        }
      });

      const displayStats = Object.entries(serviceRevenue).map(([service, amount]) => {
        const percentage = rangePaidRevenue > 0 ? (amount / rangePaidRevenue) * 100 : 0;
        return { service, amount, percentage };
      }).sort((a, b) => b.amount - a.amount);

      const sourcesListContainer = document.getElementById('sources-list-container')!;
      if (rangePaidRevenue === 0) {
        const defaultOptions = ['Landing Page', 'Company Profile', 'Toko Online', 'AI Chatbot', 'SEO & Video Ads', 'Software QA', 'Lainnya'];
        sourcesListContainer.innerHTML = defaultOptions.map((service, index) => {
          const initial = service.charAt(0);
          return `
            <div>
              <div class="flex items-center justify-between mb-1.5">
                <div class="flex items-center gap-2.5">
                  <div class="w-6 h-6 rounded-md flex items-center justify-center text-[10px] font-bold bg-[#2A2A30] text-[#F4F4F2]">${initial}</div>
                  <span class="text-[13px] font-medium text-white">${service}</span>
                </div>
                <span class="mono text-[12px] text-white">0%</span>
              </div>
              <div class="h-1 rounded-full overflow-hidden bg-[#1A1A1E]">
                <div class="h-full rounded-full bg-[#5C5C63]" style="width: 0%;"></div>
              </div>
            </div>
          `;
        }).join('');
      } else {
        const progressColors = ['#C5F82A', '#8FB520', '#5C5C63', '#5C5C63', '#5C5C63', '#5C5C63'];
        sourcesListContainer.innerHTML = displayStats.map((item, index) => {
          const initial = item.service.charAt(0);
          const color = progressColors[index] || '#5C5C63';
          return `
            <div>
              <div class="flex items-center justify-between mb-1.5">
                <div class="flex items-center gap-2.5">
                  <div class="w-6 h-6 rounded-md flex items-center justify-center text-[10px] font-bold bg-[#2A2A30] text-[#F4F4F2]">${initial}</div>
                  <span class="text-[13px] font-medium text-white">${item.service}</span>
                </div>
                <div class="text-right">
                  <span class="mono text-[12px] text-white">${item.percentage.toFixed(1)}%</span>
                  <span class="mono text-[9px] text-[#8A8A90] ml-1">Rp ${(item.amount/1000000).toFixed(1)}M</span>
                </div>
              </div>
              <div class="h-1 rounded-full overflow-hidden bg-[#1A1A1E]">
                <div class="h-full rounded-full" style="width: ${item.percentage}%; background-color: ${color};"></div>
              </div>
            </div>
          `;
        }).join('');
      }

      // 4. Render table rows for Documents in range
      const tableBody = document.getElementById('docs-table-body')!;
      if (filteredDocs.length === 0) {
        tableBody.innerHTML = `
          <tr>
            <td colspan="5" class="p-8 text-center text-[#5C5C63] font-medium">Belum ada riwayat dokumen tersimpan untuk periode ini.</td>
          </tr>
        `;
      } else {
        tableBody.innerHTML = filteredDocs.slice(0, 10).map((doc) => {
          const formattedAmount = doc.amount ? `Rp ${Number(doc.amount).toLocaleString('id-ID')}` : '-';
          
          let statusBadgeClass = 'border-[#232328] text-[#8A8A90] bg-[#131316]';
          if (doc.status === 'PAID' || doc.status === 'signed') {
            statusBadgeClass = 'border-emerald-500/20 text-emerald-400 bg-emerald-500/10';
          } else if (doc.status === 'UNPAID' || doc.status === 'draft') {
            statusBadgeClass = 'border-amber-500/20 text-amber-400 bg-amber-500/10';
          } else if (doc.status === 'OVERDUE') {
            statusBadgeClass = 'border-rose-500/20 text-rose-400 bg-rose-500/10';
          }

          return `
            <tr class="row-hover border-t border-[#1A1A1E] transition hidden sm:table-row">
              <td class="px-5 py-3">
                <div class="flex items-center gap-2.5">
                  <div class="w-7 h-7 rounded-full flex items-center justify-center text-[10px] font-semibold bg-[#2A2A30] text-white">
                    ${(doc.client_name || 'K').slice(0, 2).toUpperCase()}
                  </div>
                  <div>
                    <div class="font-medium leading-tight text-white">${doc.doc_number || '-'}</div>
                    <div class="mono text-[10px] text-[#5C5C63] mt-0.5">${doc.client_name || '-'} (${doc.client_company || '-'})</div>
                  </div>
                </div>
              </td>
              <td class="px-3 py-3"><span class="text-[11px] font-bold text-blue-400 uppercase font-mono">${doc.doc_type}</span></td>
              <td class="px-3 py-3">
                <span class="inline-flex items-center px-2 py-0.5 rounded-md border text-[10px] font-semibold uppercase tracking-wider ${statusBadgeClass}">
                  ${doc.status}
                </span>
              </td>
              <td class="px-3 py-3 mono text-[11px] text-[#8A8A90]">${doc.doc_date || '-'}</td>
              <td class="px-5 py-3 text-right mono font-medium text-slate-200">${formattedAmount}</td>
            </tr>

            <!-- Mobile Card Layout -->
            <tr class="sm:hidden border-t border-[#1A1A1E]">
              <td colspan="5" class="p-3.5">
                <div class="flex flex-col space-y-2">
                  <div class="flex items-start justify-between gap-2">
                    <div>
                      <div class="font-semibold text-[13px] text-white">${doc.doc_number || '-'}</div>
                      <div class="text-[11px] text-[#8A8A90] mt-0.5">${doc.client_name || '-'}</div>
                    </div>
                    <span class="inline-flex items-center px-2 py-0.5 rounded-md border text-[9px] font-bold uppercase tracking-wider ${statusBadgeClass}">
                      ${doc.status}
                    </span>
                  </div>
                  <div class="flex items-center justify-between text-[11px] pt-1.5 border-t border-[#1A1A1E]">
                    <span class="mono text-[10px] text-[#5C5C63]">${doc.doc_date || '-'} · <strong class="text-blue-400 font-mono uppercase">${doc.doc_type}</strong></span>
                    <span class="mono font-bold text-white">${formattedAmount}</span>
                  </div>
                </div>
              </td>
            </tr>
          `;
        }).join('');
      }

      // 5. Render Distribusi Komisi Tim in range
      const memberStats: Record<string, { name: string; totalAmount: number; projectCount: number }> = {};
      filteredSharing.forEach((item) => {
        const name = (item.member_name || 'Kas Agensi (Lumovelo)').trim();
        if (name) {
          if (!memberStats[name]) {
            memberStats[name] = {
              name,
              totalAmount: 0,
              projectCount: 0
            };
          }
          memberStats[name].totalAmount += Number(item.amount) || 0;
          memberStats[name].projectCount += 1;
        }
      });

      const sortedSharing = Object.values(memberStats).sort((a, b) => b.totalAmount - a.totalAmount);
      const maxSharingAmount = sortedSharing.length > 0 ? sortedSharing[0].totalAmount : 1;

      const sharingDistBody = document.getElementById('sharing-dist-body')!;
      if (sortedSharing.length === 0) {
        sharingDistBody.innerHTML = `
          <div class="text-center py-8 text-[#5C5C63] font-medium">Belum ada pembagian bagi hasil terdaftar.</div>
        `;
      } else {
        const progressColors = ['#C5F82A', '#8FB520', '#5C5C63', '#5C5C63', '#5C5C63'];
        sharingDistBody.innerHTML = sortedSharing.slice(0, 6).map((member, index) => {
          const barWidth = Math.min((member.totalAmount / maxSharingAmount) * 100, 100);
          const color = progressColors[index] || '#5C5C63';
          const initial = member.name.slice(0, 1).toUpperCase();
          
          return `
            <div>
              <div class="flex items-center justify-between mb-1.5">
                <div class="flex items-center gap-2.5">
                  <div class="w-6 h-6 rounded-md flex items-center justify-center text-[10px] font-bold bg-[#2A2A30] text-[#F4F4F2]">${initial}</div>
                  <div>
                    <span class="text-[13px] font-semibold text-white leading-tight">${member.name}</span>
                    <span class="mono text-[9px] text-[#8A8A90] ml-1.5">${member.projectCount} Proyek</span>
                  </div>
                </div>
                <span class="mono text-[11px] text-white">Rp ${member.totalAmount.toLocaleString('id-ID')}</span>
              </div>
              <div class="h-1.5 rounded-full overflow-hidden bg-[#1A1A1E]">
                <div class="h-full rounded-full" style="width: ${barWidth}%; background-color: ${color};"></div>
              </div>
            </div>
          `;
        }).join('');
      }

      // 6. Update Line Chart dynamically
      updateLineChart(filteredDocs, range);
    }

    // Update Line Chart SVG dynamically
    function updateLineChart(filteredDocs: any[], rangeName: string) {
      const now = new Date();
      let dateKeys: Date[] = [];

      if (rangeName === '24h') {
        for (let i = 23; i >= 0; i--) {
          dateKeys.push(new Date(now.getTime() - i * 60 * 60 * 1000));
        }
      } else if (rangeName === '7d') {
        for (let i = 6; i >= 0; i--) {
          dateKeys.push(new Date(now.getTime() - i * 24 * 60 * 60 * 1000));
        }
      } else if (rangeName === '30d') {
        for (let i = 29; i >= 0; i--) {
          dateKeys.push(new Date(now.getTime() - i * 24 * 60 * 60 * 1000));
        }
      } else if (rangeName === '90d') {
        for (let i = 11; i >= 0; i--) {
          dateKeys.push(new Date(now.getTime() - i * 7 * 24 * 60 * 60 * 1000));
        }
      } else { // ytd
        const currentMonth = now.getMonth();
        for (let i = 0; i <= currentMonth; i++) {
          dateKeys.push(new Date(now.getFullYear(), i, 1));
        }
      }

      const revenueValues = new Array(dateKeys.length).fill(0);
      const pendingValues = new Array(dateKeys.length).fill(0);

      filteredDocs.forEach(doc => {
        if (doc.doc_type === 'invoice') {
          const amt = Number(doc.amount) || 0;
          const docDate = new Date(doc.created_at || doc.doc_date);
          
          let closestIndex = -1;
          let minDiff = Infinity;
          dateKeys.forEach((k, idx) => {
            const diff = Math.abs(docDate.getTime() - k.getTime());
            if (diff < minDiff) {
              minDiff = diff;
              closestIndex = idx;
            }
          });

          if (closestIndex !== -1) {
            if (doc.status === 'PAID') {
              revenueValues[closestIndex] += amt;
            } else if (doc.status === 'UNPAID' || doc.status === 'OVERDUE') {
              pendingValues[closestIndex] += amt;
            }
          }
        }
      });

      let cumRev = 0;
      let cumPend = 0;
      const revPoints = revenueValues.map(v => {
        cumRev += v;
        return cumRev;
      });
      const pendPoints = pendingValues.map(v => {
        cumPend += v;
        return cumPend;
      });

      const maxVal = Math.max(...revPoints, ...pendPoints, 100000);

      const getSVGCoords = (points: number[]) => {
        const segmentWidth = 720 / (points.length - 1 || 1);
        return points.map((val, idx) => {
          const x = idx * segmentWidth;
          const y = 210 - (val / maxVal) * 170;
          return { x, y };
        });
      };

      const revCoords = getSVGCoords(revPoints);
      const pendCoords = getSVGCoords(pendPoints);

      const buildPathD = (coords: { x: number; y: number }[]) => 
        coords.map((c, i) => `${i === 0 ? 'M' : 'L'}${c.x.toFixed(1)},${c.y.toFixed(1)}`).join(' ');
      
      const buildAreaD = (coords: { x: number; y: number }[]) => 
        coords.length > 0 ? `${buildPathD(coords)} L720,240 L0,240 Z` : 'M0,240 L720,240 Z';

      const revPathD = buildPathD(revCoords);
      const revAreaD = buildAreaD(revCoords);
      const pendPathD = buildPathD(pendCoords);
      const pendAreaD = buildAreaD(pendCoords);

      const revArea = document.getElementById('rev-area-path');
      const revLine = document.getElementById('rev-line-path');
      const pendArea = document.getElementById('pend-area-path');
      const pendLine = document.getElementById('pend-line-path');
      const highlightPoint = document.getElementById('chart-highlight-point');
      const highlightGlow = document.getElementById('chart-highlight-glow');
      const highlightLine = document.getElementById('chart-highlight-line');

      if (revArea) revArea.setAttribute('d', revAreaD);
      if (revLine) revLine.setAttribute('d', revPathD);
      if (pendArea) pendArea.setAttribute('d', pendAreaD);
      if (pendLine) pendLine.setAttribute('d', pendPathD);

      if (revCoords.length > 0) {
        const lastPt = revCoords[revCoords.length - 1];
        if (highlightPoint) {
          highlightPoint.setAttribute('cx', lastPt.x.toFixed(1));
          highlightPoint.setAttribute('cy', lastPt.y.toFixed(1));
        }
        if (highlightGlow) {
          highlightGlow.setAttribute('cx', lastPt.x.toFixed(1));
          highlightGlow.setAttribute('cy', lastPt.y.toFixed(1));
        }
        if (highlightLine) {
          highlightLine.setAttribute('x1', lastPt.x.toFixed(1));
          highlightLine.setAttribute('y1', lastPt.y.toFixed(1));
          highlightLine.setAttribute('x2', lastPt.x.toFixed(1));
        }
      }

      const xLabelsContainer = document.getElementById('chart-x-labels');
      if (xLabelsContainer) {
        if (rangeName === '24h') {
          xLabelsContainer.innerHTML = '<span>00:00</span><span>06:00</span><span>12:00</span><span>18:00</span><span>23:00</span>';
        } else if (rangeName === '7d') {
          xLabelsContainer.innerHTML = '<span>Hari 1</span><span>Hari 3</span><span>Hari 5</span><span>Hari 7</span>';
        } else if (rangeName === '30d') {
          xLabelsContainer.innerHTML = '<span>Hari 1</span><span>Hari 5</span><span>Hari 10</span><span>Hari 15</span><span>Hari 20</span><span>Hari 25</span><span>Hari 30</span>';
        } else if (rangeName === '90d') {
          xLabelsContainer.innerHTML = '<span>Minggu 1</span><span>Minggu 4</span><span>Minggu 8</span><span>Minggu 12</span>';
        } else {
          xLabelsContainer.innerHTML = '<span>Jan</span><span>Mar</span><span>May</span><span>Jul</span><span>Sep</span><span>Nov</span><span>Dec</span>';
        }
      }
    }

    // Range selector click handler
    const rangeContainer = document.getElementById('range')!;
    rangeContainer.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.pill');
      if (btn) {
        const range = btn.getAttribute('data-range');
        if (range) {
          currentRange = range;
          
          // Update active style on range buttons
          rangeContainer.querySelectorAll('.pill').forEach(b => {
            b.classList.remove('active', 'bg-[#C5F82A]', 'text-[#0A0A0B]', 'border-[#C5F82A]');
            b.classList.add('text-[#8A8A90]');
          });

          btn.classList.add('active', 'bg-[#C5F82A]', 'text-[#0A0A0B]', 'border-[#C5F82A]');
          btn.classList.remove('text-[#8A8A90]');

          renderDashboardForRange(range);
        }
      }
    });

    btnLogout.addEventListener('click', async () => {
      await supabase.auth.signOut();
      document.cookie = 'sb-access-token=; path=/; expires=Thu, 01 Jan 1970 00:00:00 GMT; SameSite=Lax; Secure';
      document.cookie = 'sb-refresh-token=; path=/; expires=Thu, 01 Jan 1970 00:00:00 GMT; SameSite=Lax; Secure';
      window.location.href = '/admin/login/';
    });

    // Mobile Sidebar Drawer Control
    const adminSidebar = document.getElementById('admin-sidebar');
    const btnOpenSidebar = document.getElementById('btn-open-sidebar');
    const btnCloseSidebar = document.getElementById('btn-close-sidebar');
    const sidebarOverlay = document.getElementById('admin-sidebar-overlay');

    function openSidebar() {
      if (adminSidebar && sidebarOverlay) {
        adminSidebar.classList.remove('-translate-x-full');
        sidebarOverlay.classList.remove('hidden');
        setTimeout(() => sidebarOverlay.classList.remove('opacity-0'), 10);
      }
    }

    function closeSidebar() {
      if (adminSidebar && sidebarOverlay) {
        adminSidebar.classList.add('-translate-x-full');
        sidebarOverlay.classList.add('opacity-0');
        setTimeout(() => sidebarOverlay.classList.add('hidden'), 300);
      }
    }

    btnOpenSidebar?.addEventListener('click', openSidebar);
    btnCloseSidebar?.addEventListener('click', closeSidebar);
    sidebarOverlay?.addEventListener('click', closeSidebar);

    // Quick Document Dropdown Control
    const btnQuickDocMenu = document.getElementById('btn-quick-doc-menu');
    const quickDocDropdown = document.getElementById('quick-doc-dropdown');

    if (btnQuickDocMenu && quickDocDropdown) {
      btnQuickDocMenu.addEventListener('click', (e) => {
        e.stopPropagation();
        quickDocDropdown.classList.toggle('hidden');
      });

      document.addEventListener('click', (e) => {
        if (!quickDocDropdown.contains(e.target as Node) && e.target !== btnQuickDocMenu) {
          quickDocDropdown.classList.add('hidden');
        }
      });
    }

    // --- REDIRECT KPI LEADS CARD ---
    const kpiLeadsCard = document.getElementById('kpi-leads-card');
    if (kpiLeadsCard) {
      kpiLeadsCard.addEventListener('click', () => {
        window.location.href = '/admin/leads/';
      });
    }
  </script>
</Layout>
