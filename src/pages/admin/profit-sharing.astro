---
import Layout from '../../layouts/Layout.astro';
import Logo from '../../components/Logo.astro';
---

<Layout title="Bagi Hasil Tim | LUMOVELO" description="Kalkulasi dan pencatatan bagi hasil tim internal agensi." noindex={true}>
  <div id="admin-layout" class="hidden min-h-screen dashboard-root grain flex">
    
    <!-- Sidebar Navigation -->
    <aside class="hidden lg:flex w-[248px] shrink-0 flex-col border-r border-[#1A1A1E] bg-[#0C0C0E]">
      <!-- Logo -->
      <div class="px-5 pt-6 pb-7 flex items-center gap-2.5">
        <div class="w-8 h-8 rounded-lg flex items-center justify-center bg-[#C5F82A]">
          <Logo class="w-4 h-4 text-[#0A0A0B]" />
        </div>
        <div class="flex items-baseline gap-1.5">
          <span class="font-semibold tracking-tight text-[15px] text-white">LUMOVELO</span>
          <span class="mono text-[10px] text-[#5C5C63]">v2.4</span>
        </div>
      </div>

      <!-- Workspace switcher -->
      <div class="px-3 mb-5">
        <div class="w-full flex items-center gap-2.5 px-2.5 py-2 rounded-lg border border-[#232328] bg-[#131316]">
          <div class="w-6 h-6 rounded-md flex items-center justify-center text-[10px] font-bold bg-[#2A2A30] text-[#C5F82A]">LV</div>
          <div class="flex-1 min-w-0">
            <div class="text-[12px] font-medium leading-tight text-white">Lumovelo Agency</div>
            <div class="text-[10px] mono text-[#5C5C63]">workspace · admin</div>
          </div>
        </div>
      </div>

      <!-- Nav -->
      <nav class="px-3 flex-1 overflow-y-auto scroll-thin" id="nav">
        <div class="px-2.5 mb-1.5 mono text-[10px] uppercase tracking-wider text-[#5C5C63]">Analytics</div>
        <a href="/admin/dashboard/" class="nav-item flex items-center gap-3 px-2.5 py-2 rounded-md text-[13px] text-[#8A8A90]">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="7" height="9" rx="1"/><rect x="14" y="3" width="7" height="5" rx="1"/><rect x="14" y="12" width="7" height="9" rx="1"/><rect x="3" y="16" width="7" height="5" rx="1"/></svg>
          Overview
        </a>
        <a href="/admin/finance/" class="nav-item flex items-center gap-3 px-2.5 py-2 rounded-md text-[13px] text-[#8A8A90]">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 3v18h18"/><path d="M7 14l4-4 3 3 5-6"/></svg>
          Revenue
        </a>
        <a href="/admin/profit-sharing/" class="nav-item active flex items-center gap-3 px-2.5 py-2 rounded-md text-[13px] text-[#F4F4F2]">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="9" cy="8" r="4"/><path d="M3 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2"/><circle cx="17" cy="6" r="2.5"/><path d="M14 21v-1a3 3 0 0 1 3-3h0a3 3 0 0 1 3 3v1"/></svg>
          Bagi Hasil Tim
        </a>
        <a href="/admin/blog/" class="nav-item flex items-center gap-3 px-2.5 py-2 rounded-md text-[13px] text-[#8A8A90]">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 2v20M2 12h20"/><circle cx="12" cy="12" r="9"/></svg>
          Kelola Blog
        </a>
        <a href="/admin/leads/" class="nav-item flex items-center gap-3 px-2.5 py-2 rounded-md text-[13px] text-[#8A8A90]">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="shrink-0"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          Leads AI
        </a>
        <a href="/admin/ai-settings/" class="nav-item flex items-center gap-3 px-2.5 py-2 rounded-md text-[13px] text-[#8A8A90]">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
          Pengaturan AI
        </a>

        <div class="px-2.5 mb-1.5 mt-5 mono text-[10px] uppercase tracking-wider text-[#5C5C63]">Workspace</div>
        <a href="/workspace/invoice/" class="nav-item flex items-center gap-3 px-2.5 py-2 rounded-md text-[13px] text-[#8A8A90]">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 9h6v6H9z"/></svg>
          Buat Invoice
        </a>
      </nav>

      <!-- User logout footer -->
      <div class="px-3 pb-4 pt-1 border-t border-[#1A1A1E]">
        <button id="btn-logout" class="w-full flex items-center gap-2.5 px-2 py-2 rounded-md hover:bg-[#16161A] transition text-left group">
          <div class="w-8 h-8 rounded-full flex items-center justify-center text-[11px] font-semibold bg-[#2A2A30] text-[#F4F4F2]">AD</div>
          <div class="flex-1 min-w-0">
            <div class="text-[12px] font-medium leading-tight text-white group-hover:text-[#F87171] transition-colors">Sign Out</div>
            <div class="text-[10px] mono text-[#5C5C63]">administrator</div>
          </div>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-[#8A8A90] group-hover:text-[#F87171] transition-colors"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        </button>
      </div>
    </aside>

    <!-- Main Content Area -->
    <main class="flex-1 min-w-0 flex flex-col">
      <!-- Top bar -->
      <header class="sticky top-0 z-20 flex items-center gap-3 px-4 lg:px-8 h-16 border-b border-[#1A1A1E] backdrop-blur-md bg-[rgba(10,10,11,0.78)]">
        <button class="lg:hidden p-2 rounded-md hover:bg-[#16161A] text-white">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
        </button>
        <div class="hidden md:flex items-center gap-2 text-[13px] text-[#8A8A90]">
          <span>Lumovelo</span>
          <span class="text-[#5C5C63]">/</span>
          <span class="text-[#F4F4F2] font-medium">Bagi Hasil Tim</span>
        </div>
      </header>

      <!-- Content -->
      <div class="flex-1 overflow-y-auto scroll-thin px-4 lg:px-8 py-7 grid grid-cols-1 lg:grid-cols-3 gap-6">
        
        <!-- Left Column: Form Calculator -->
        <div class="lg:col-span-1 space-y-6">
          <section>
            <div class="flex items-center gap-2 mb-2">
              <span class="live-dot w-1.5 h-1.5 rounded-full bg-[#C5F82A]"></span>
              <span class="mono text-[11px] uppercase tracking-wider text-[#8A8A90]">BAGI HASIL TIM REKAN</span>
            </div>
            <h1 class="serif text-[44px] leading-[0.95] text-white">Bagi Hasil</h1>
            <p class="mt-2 text-[14px] text-[#8A8A90]">Kalkulasikan komisi pembagian hasil untuk rekan tim secara transparan dan aman.</p>
          </section>

          <!-- Calculator panel -->
          <div class="card p-5 space-y-4 border border-[#232328]">
            <h3 class="serif text-xl text-white">Kalkulator Bagi Hasil</h3>
            
            <div class="space-y-4">
              <div class="space-y-1.5">
                <label for="calc-doc" class="text-[10px] font-mono font-bold text-[#8A8A90] uppercase tracking-wider">Pilih Proyek / Invoice</label>
                <select id="calc-doc" class="w-full bg-[#0A0A0B] border border-[#232328] focus:border-[#C5F82A] rounded-xl px-3 py-2 text-xs text-white focus:outline-none transition-colors">
                  <option value="">PILIH PROYEK (INVOICE)</option>
                </select>
              </div>
              <div class="space-y-1.5">
                <label for="calc-amount" class="text-[10px] font-mono font-bold text-[#8A8A90] uppercase tracking-wider">Nilai Proyek (IDR)</label>
                <input type="number" id="calc-amount" disabled class="w-full bg-[#0A0A0B]/40 border border-[#232328] rounded-xl px-3 py-2 text-xs text-slate-400 focus:outline-none" placeholder="Pilih proyek terlebih dahulu" />
              </div>
            </div>

            <!-- Dynamic Team Members splits -->
            <div class="space-y-3">
              <label class="text-[10px] font-mono font-bold text-[#8A8A90] uppercase tracking-wider block">Rincian Penerima Komisi</label>
              
              <div id="members-list-container" class="space-y-3">
                <!-- Row 1: Kas Agensi (Default) -->
                <div class="flex items-center gap-3 bg-[#0A0A0B]/40 p-3 rounded-xl border border-[#232328]">
                  <div class="flex-1 font-bold text-xs text-white">Kas Agensi (Lumovelo)</div>
                  <div class="w-20 shrink-0">
                    <input type="number" value="60" id="share-agensi" class="w-full bg-[#0A0A0B] border border-[#232328] focus:border-[#C5F82A] rounded-lg px-2 py-1 text-xs text-center text-white focus:outline-none transition-colors share-percent-input" />
                  </div>
                  <div class="text-xs font-mono font-bold text-[#8A8A90] shrink-0 w-24 text-right" id="share-val-agensi">Rp 0</div>
                </div>
              </div>

              <!-- Button Add Member -->
              <button type="button" id="btn-add-member" class="w-full py-2.5 border border-dashed border-[#232328] hover:border-[#8A8A90] rounded-xl text-[10px] font-bold uppercase tracking-wider text-[#8A8A90] hover:text-white transition-all cursor-pointer">
                + Tambah Anggota Pelaksana
              </button>
            </div>

            <!-- Total validation alert -->
            <div id="total-alert" class="hidden text-xs text-[#F87171] font-bold">Total persentase harus tepat 100%!</div>

            <button type="button" id="btn-save-sharing" class="w-full bg-[#C5F82A] hover:opacity-90 text-[#0A0A0B] py-3 rounded-xl text-xs font-bold uppercase tracking-widest cursor-pointer transition-all">
              Simpan Pembagian Hasil
            </button>
          </div>
        </div>

        <!-- Right Column: Database Log -->
        <div class="lg:col-span-2 space-y-6">
          <!-- Summary Card -->
          <div class="card overflow-hidden border border-[#232328]">
            <div class="p-5 border-b border-[#1A1A1E]">
              <h2 class="text-[15px] font-semibold text-white">Akumulasi Penerimaan Tim</h2>
              <p class="text-[12px] mt-0.5 text-[#8A8A90]">Total seluruh dana komisi bagi hasil terakumulasi per penerima</p>
            </div>
            <div class="overflow-x-auto scroll-thin">
              <table class="w-full text-[13px]">
                <thead>
                  <tr class="text-[10px] mono uppercase tracking-wider text-[#5C5C63] bg-[#0E0E11]">
                    <th class="px-5 py-3 text-left font-medium">Nama Anggota</th>
                    <th class="px-3 py-3 text-left font-medium">Peran Utama</th>
                    <th class="px-3 py-3 text-left font-medium">Proyek Diikuti</th>
                    <th class="px-3 py-3 text-right font-medium text-emerald-400">Lunas (Paid)</th>
                    <th class="px-3 py-3 text-right font-medium text-amber-400">Pending (Unpaid)</th>
                    <th class="px-5 py-3 text-right font-medium">Total Akumulasi</th>
                  </tr>
                </thead>
                <tbody id="summary-sharing-body" class="divide-y divide-[#1A1A1E] text-[#8A8A90]">
                  <tr>
                    <td colspan="6" class="p-8 text-center text-[#5C5C63] font-medium">Memuat ringkasan komisi...</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>

          <div class="card overflow-hidden border border-[#232328]">
            <div class="p-5 border-b border-[#1A1A1E]">
              <h2 class="text-[15px] font-semibold text-white">Riwayat Pembagian Terdaftar</h2>
              <p class="text-[12px] mt-0.5 text-[#8A8A90]">Daftar detail distribusi komisi dari database</p>
            </div>
            <div class="overflow-x-auto scroll-thin">
              <table class="w-full text-[13px]">
                <thead>
                  <tr class="text-[10px] mono uppercase tracking-wider text-[#5C5C63] bg-[#0E0E11]">
                    <th class="px-5 py-3 text-left font-medium">Nama</th>
                    <th class="px-3 py-3 text-left font-medium">Peran</th>
                    <th class="px-3 py-3 text-left font-medium">Persentase</th>
                    <th class="px-3 py-3 text-left font-medium">Jumlah Diterima</th>
                    <th class="px-3 py-3 text-left font-medium">Status</th>
                    <th class="px-5 py-3 text-right font-medium">Aksi</th>
                  </tr>
                </thead>
                <tbody id="sharing-log-body" class="divide-y divide-[#1A1A1E] text-[#8A8A90]">
                  <tr>
                    <td colspan="6" class="p-8 text-center text-[#5C5C63] font-medium">Memuat riwayat pembagian...</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>

      </div>
    </main>
  </div>

  <style>
    @import url('https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap');
    
    :root {
      --bg: #0A0A0B;
      --panel: #131316;
      --panel-2: #18181C;
      --border: #232328;
      --border-soft: #1A1A1E;
      --ink: #F4F4F2;
      --muted: #8A8A90;
      --muted-2: #5C5C63;
      --accent: #C5F82A;
      --accent-dim: #8FB520;
      --warn: #F5A524;
      --rose: #F87171;
    }
    
    .dashboard-root {
      background: var(--bg) !important;
      color: var(--ink) !important;
      font-family: 'Inter', system-ui, sans-serif !important;
      -webkit-font-smoothing: antialiased;
    }
    
    .serif {
      font-family: 'Instrument Serif', serif !important;
      font-weight: 400;
      letter-spacing: -0.01em;
    }
    
    .mono {
      font-family: 'JetBrains Mono', monospace !important;
    }
    
    .grain {
      background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.02) 1px, transparent 0);
      background-size: 3px 3px;
    }
    
    .card {
      background: var(--panel) !important;
      border: 1px solid var(--border) !important;
      border-radius: 14px;
    }
    
    .nav-item {
      transition: all .18s ease;
      position: relative;
    }
    
    .nav-item:hover {
      background: var(--panel-2) !important;
      color: var(--ink) !important;
    }
    
    .nav-item.active {
      background: var(--panel-2) !important;
      color: var(--ink) !important;
    }
    
    .nav-item.active::before {
      content: '';
      position: absolute;
      left: -1px;
      top: 50%;
      transform: translateY(-50%);
      width: 3px;
      height: 18px;
      background: var(--accent);
      border-radius: 2px;
    }
    
    .row-hover:hover {
      background: var(--panel-2) !important;
    }
    
    .scroll-thin::-webkit-scrollbar {
      width: 6px;
      height: 6px;
    }
    
    .scroll-thin::-webkit-scrollbar-thumb {
      background: #2a2a30;
      border-radius: 3px;
    }
    
    .scroll-thin::-webkit-scrollbar-track {
      background: transparent;
    }
    
    @keyframes pulse-soft {
      0%, 100% {
        opacity: 1;
      }
      50% {
        opacity: .45;
      }
    }
    
    .live-dot {
      animation: pulse-soft 1.8s ease-in-out infinite;
    }
  </style>

  <script>
    import { supabase } from '../../lib/supabase';

    const adminLayout = document.getElementById('admin-layout')!;
    const btnLogout = document.getElementById('btn-logout')!;
    const calcDoc = document.getElementById('calc-doc') as HTMLSelectElement;
    const calcAmount = document.getElementById('calc-amount') as HTMLInputElement;
    const btnAddMember = document.getElementById('btn-add-member')!;
    const container = document.getElementById('members-list-container')!;
    const totalAlert = document.getElementById('total-alert')!;
    const btnSaveSharing = document.getElementById('btn-save-sharing') as HTMLButtonElement;

    let availableProjects: any[] = [];
    let customMembers: any[] = [];

    // Session validation
    async function validateAdminSession() {
      const { data: { session } } = await supabase.auth.getSession();
      if (!session) {
        window.location.href = '/admin/login/';
        return;
      }

      // Check if user email is authorized admin
      const userEmail = session.user.email?.toLowerCase();
      const allowedEmails = (import.meta.env.PUBLIC_ADMIN_EMAILS || 'admin@lumovelo.com')
        .split(',')
        .map(e => e.trim().toLowerCase());
      const isAdmin = userEmail && (allowedEmails.includes(userEmail) || userEmail.endsWith('@lumovelo.com'));

      if (!isAdmin) {
        await supabase.auth.signOut();
        alert('Akses Ditolak: Anda bukan administrator resmi.');
        window.location.href = '/admin/login/';
        return;
      }

      adminLayout.classList.remove('hidden');
      loadProjects();
      loadSharingLog();
    }
    validateAdminSession();

    async function loadProjects() {
      try {
        const { data, error } = await supabase
          .from('documents')
          .select('id, doc_number, client_name, amount')
          .eq('doc_type', 'invoice')
          .order('created_at', { ascending: false });

        if (error) throw error;
        availableProjects = data || [];
        
        calcDoc.innerHTML = '<option value="">PILIH PROYEK (INVOICE)</option>' + availableProjects.map(p => 
          `<option value="${p.id}">${p.doc_number} - ${p.client_name}</option>`
        ).join('');
      } catch (err) {
        console.error('Error loading projects:', err);
      }
    }

    calcDoc.addEventListener('change', () => {
      const selectedId = calcDoc.value;
      const proj = availableProjects.find(p => p.id === selectedId);
      if (proj) {
        calcAmount.value = proj.amount;
      } else {
        calcAmount.value = '';
      }
      recalculateShares();
    });

    function recalculateShares() {
      const totalAmount = Number(calcAmount.value) || 0;
      
      // Kas Agensi calculation
      const agensiPercent = Number((document.getElementById('share-agensi') as HTMLInputElement).value) || 0;
      const agensiShare = (agensiPercent / 100) * totalAmount;
      document.getElementById('share-val-agensi')!.innerText = `Rp ${agensiShare.toLocaleString('id-ID')}`;

      // Custom members calculation
      let totalPercentSum = agensiPercent;
      customMembers.forEach(m => {
        const percentInput = document.getElementById(`share-pct-${m.id}`) as HTMLInputElement;
        const valLabel = document.getElementById(`share-val-${m.id}`) as HTMLDivElement;
        
        if (percentInput && valLabel) {
          const percent = Number(percentInput.value) || 0;
          totalPercentSum += percent;
          const share = (percent / 100) * totalAmount;
          valLabel.innerText = `Rp ${share.toLocaleString('id-ID')}`;
        }
      });

      if (totalPercentSum !== 100 && totalAmount > 0) {
        totalAlert.innerText = `Total persentase saat ini: ${totalPercentSum}%. Harus tepat 100%!`;
        totalAlert.classList.remove('hidden');
      } else {
        totalAlert.classList.add('hidden');
      }
    }

    // Add team member row
    let memberIdCounter = 0;
    btnAddMember.addEventListener('click', () => {
      memberIdCounter++;
      const id = memberIdCounter;

      const row = document.createElement('div');
      row.className = 'flex items-center gap-3 bg-[#0A0A0B]/20 p-3 rounded-xl border border-[#232328]';
      row.id = `member-row-${id}`;
      row.innerHTML = `
        <div class="flex-1 min-w-0 grid grid-cols-2 gap-2">
          <input type="text" id="member-name-${id}" placeholder="Nama Anggota" class="bg-[#0A0A0B] border border-[#232328] focus:border-[#C5F82A] rounded-lg px-2 py-1 text-xs text-white focus:outline-none w-full" />
          <input type="text" id="member-role-${id}" placeholder="Peran / Role" class="bg-[#0A0A0B] border border-[#232328] focus:border-[#C5F82A] rounded-lg px-2 py-1 text-xs text-white focus:outline-none w-full" />
        </div>
        <div class="w-20 shrink-0">
          <input type="number" value="10" id="share-pct-${id}" class="w-full bg-[#0A0A0B] border border-[#232328] focus:border-[#C5F82A] rounded-lg px-2 py-1 text-xs text-center text-white focus:outline-none share-percent-input" />
        </div>
        <div class="text-xs font-mono font-bold text-[#8A8A90] shrink-0 w-24 text-right" id="share-val-${id}">Rp 0</div>
        <button type="button" class="text-rose-500 hover:text-rose-400 text-xs px-1 cursor-pointer font-bold btn-remove-member-row" data-id="${id}">✕</button>
      `;

      container.appendChild(row);
      customMembers.push({ id });

      row.querySelector('.share-percent-input')!.addEventListener('input', recalculateShares);
      row.querySelector(`.btn-remove-member-row`)!.addEventListener('click', (e: any) => {
        const rowId = e.target.getAttribute('data-id');
        document.getElementById(`member-row-${rowId}`)!.remove();
        customMembers = customMembers.filter(m => m.id !== Number(rowId));
        recalculateShares();
      });

      recalculateShares();
    });

    document.getElementById('share-agensi')!.addEventListener('input', recalculateShares);

    // Save sharing records
    btnSaveSharing.addEventListener('click', async () => {
      const selectedId = calcDoc.value;
      if (!selectedId) {
        // @ts-ignore
        showToast('Pilih proyek terlebih dahulu.', 'warning');
        return;
      }

      const totalAmount = Number(calcAmount.value) || 0;
      if (totalAmount <= 0) {
        // @ts-ignore
        showToast('Nilai proyek tidak valid.', 'warning');
        return;
      }

      // Check sum percentage
      const agensiPercent = Number((document.getElementById('share-agensi') as HTMLInputElement).value) || 0;
      let totalPercentSum = agensiPercent;
      const payload: any[] = [];

      // Add Agensi row
      payload.push({
        doc_id: selectedId,
        member_name: 'Kas Agensi (Lumovelo)',
        role: 'Agensi',
        percentage: agensiPercent,
        amount: (agensiPercent / 100) * totalAmount,
        status: 'paid'
      });

      // Add custom members
      const selectedNames = new Set();
      for (const m of customMembers) {
        const nameInp = document.getElementById(`member-name-${m.id}`) as HTMLInputElement;
        const roleInp = document.getElementById(`member-role-${m.id}`) as HTMLInputElement;
        const pctInp = document.getElementById(`share-pct-${m.id}`) as HTMLInputElement;
        
        if (nameInp && roleInp && pctInp) {
          const name = nameInp.value.trim();
          if (!name) {
            // @ts-ignore
            showToast('Nama anggota tidak boleh kosong!', 'warning');
            return;
          }
          if (selectedNames.has(name)) {
            // @ts-ignore
            showToast(`Nama anggota tim "${name}" tidak boleh dimasukkan lebih dari sekali!`, 'warning');
            return;
          }
          selectedNames.add(name);

          const role = roleInp.value.trim() || 'Pelaksana';
          const pct = Number(pctInp.value) || 0;
          totalPercentSum += pct;

          payload.push({
            doc_id: selectedId,
            member_name: name,
            role,
            percentage: pct,
            amount: (pct / 100) * totalAmount,
            status: 'unpaid'
          });
        }
      }

      if (totalPercentSum !== 100) {
        // @ts-ignore
        showToast(`Persentase total adalah ${totalPercentSum}%. Harus tepat 100%!`, 'warning');
        return;
      }

      btnSaveSharing.disabled = true;
      btnSaveSharing.innerText = 'MENYIMPAN...';

      try {
        const { error } = await supabase
          .from('profit_sharing')
          .insert(payload);

        if (error) throw error;

        // @ts-ignore
        showToast('Berhasil menyimpan data pembagian bagi hasil!', 'success');
        
        // Reset dynamic rows
        customMembers.forEach(m => {
          document.getElementById(`member-row-${m.id}`)?.remove();
        });
        customMembers = [];
        (document.getElementById('share-agensi') as HTMLInputElement).value = '60';
        recalculateShares();

        loadSharingLog();
      } catch (err: any) {
        // @ts-ignore
        showToast(err.message || 'Gagal menyimpan.', 'error');
      } finally {
        btnSaveSharing.disabled = false;
        btnSaveSharing.innerText = 'Simpan Pembagian Hasil';
      }
    });

    // Load saved profit sharing logs
    async function loadSharingLog() {
      try {
        const { data, error } = await supabase
          .from('profit_sharing')
          .select('*')
          .order('created_at', { ascending: false });

        if (error) throw error;

        const tableBody = document.getElementById('sharing-log-body')!;
        const summaryBody = document.getElementById('summary-sharing-body')!;

        if (!data || data.length === 0) {
          tableBody.innerHTML = `
            <tr>
              <td colspan="6" class="p-8 text-center text-[#5C5C63] font-medium">Belum ada pembagian hasil terdaftar.</td>
            </tr>
          `;
          summaryBody.innerHTML = `
            <tr>
              <td colspan="6" class="p-8 text-center text-[#5C5C63] font-medium">Belum ada ringkasan komisi.</td>
            </tr>
          `;
          return;
        }

        // Aggregate totals per member
        const summaryStats: Record<string, { name: string; role: string; projectCount: number; paid: number; unpaid: number; total: number }> = {};
        data.forEach((item) => {
          const name = item.member_name || 'Kas Agensi (Lumovelo)';
          const role = item.role || 'Pelaksana';
          const amt = Number(item.amount) || 0;
          const isPaid = item.status === 'paid';

          if (!summaryStats[name]) {
            summaryStats[name] = {
              name,
              role,
              projectCount: 0,
              paid: 0,
              unpaid: 0,
              total: 0
            };
          }

          summaryStats[name].projectCount += 1;
          summaryStats[name].total += amt;
          if (isPaid) {
            summaryStats[name].paid += amt;
          } else {
            summaryStats[name].unpaid += amt;
          }
        });

        // Render summary table rows
        const sortedSummary = Object.values(summaryStats).sort((a, b) => b.total - a.total);
        summaryBody.innerHTML = sortedSummary.map((member) => {
          return `
            <tr class="row-hover border-t border-[#1A1A1E] transition">
              <td class="px-5 py-3 font-bold text-white">${member.name}</td>
              <td class="px-3 py-3 text-slate-300">${member.role}</td>
              <td class="px-3 py-3 text-slate-300 font-mono">${member.projectCount}</td>
              <td class="px-3 py-3 text-right text-emerald-400 font-mono">Rp ${member.paid.toLocaleString('id-ID')}</td>
              <td class="px-3 py-3 text-right text-amber-400 font-mono">Rp ${member.unpaid.toLocaleString('id-ID')}</td>
              <td class="px-5 py-3 text-right text-white font-mono font-bold">Rp ${member.total.toLocaleString('id-ID')}</td>
            </tr>
          `;
        }).join('');

        tableBody.innerHTML = data.map((item) => {
          const formattedAmount = `Rp ${Number(item.amount).toLocaleString('id-ID')}`;
          
          let statusBadgeClass = 'border-[#232328] text-[#8A8A90] bg-[#131316]';
          if (item.status === 'paid') {
            statusBadgeClass = 'border-emerald-500/20 text-emerald-400 bg-emerald-500/10';
          } else {
            statusBadgeClass = 'border-amber-500/20 text-amber-400 bg-amber-500/10';
          }

          const actionBtn = item.status === 'unpaid' 
            ? `<button class="px-2 py-1 bg-[#2563eb]/10 border border-[#2563eb]/20 text-[#3b82f6] hover:bg-[#2563eb] hover:text-white rounded text-[10px] font-semibold uppercase transition-all cursor-pointer btn-pay-share" data-id="${item.id}">Bayar</button>`
            : '-';

          return `
            <tr class="row-hover border-t border-[#1A1A1E] transition">
              <td class="px-5 py-3 font-bold text-white">${item.member_name}</td>
              <td class="px-3 py-3 text-slate-300">${item.role}</td>
              <td class="px-3 py-3 font-mono font-bold text-slate-300">${item.percentage}%</td>
              <td class="px-3 py-3 font-mono text-[#F4F4F2] font-bold text-right">${formattedAmount}</td>
              <td class="px-3 py-3">
                <span class="inline-flex items-center px-2 py-0.5 rounded-md border text-[9px] font-black uppercase tracking-wider ${statusBadgeClass}">
                  ${item.status.toUpperCase()}
                </span>
              </td>
              <td class="px-5 py-3 text-right">${actionBtn}</td>
            </tr>
          `;
        }).join('');

        // Bind update status trigger
        document.querySelectorAll('.btn-pay-share').forEach((btn) => {
          btn.addEventListener('click', async (e: any) => {
            const id = e.target.getAttribute('data-id');
            if (id && confirm('Konfirmasi bahwa bagi hasil ini sudah dibayar/ditransfer?')) {
              try {
                const { error } = await supabase
                  .from('profit_sharing')
                  .update({ status: 'paid' })
                  .eq('id', id);

                if (error) throw error;

                // @ts-ignore
                showToast('Bagi hasil berhasil dikonfirmasi lunas!', 'success');
                loadSharingLog();
              } catch (err: any) {
                // @ts-ignore
                showToast(err.message || 'Gagal memperbarui status bagi hasil.', 'error');
              }
            }
          });
        });

      } catch (err) {
        console.error('Error loading sharing log:', err);
      }
    }

    btnLogout.addEventListener('click', async () => {
      await supabase.auth.signOut();
      window.location.href = '/admin/login/';
    });
  </script>
</Layout>
