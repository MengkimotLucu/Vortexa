---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import Logo from '../../components/Logo.astro';
---

<Layout title="Pengaturan AI | LUMOVELO" description="Atur instruksi chatbot AI Lumovelo." noindex={true}>
  <div id="admin-layout" class="min-h-screen dashboard-root grain flex relative">
    
    <!-- Sidebar Backdrop Overlay on Mobile -->
    <div id="admin-sidebar-overlay" class="fixed inset-0 bg-black/70 z-[90] lg:hidden hidden opacity-0 transition-opacity duration-300"></div>

    <!-- Sidebar Navigation -->
    <aside id="admin-sidebar" class="fixed inset-y-0 left-0 z-[100] flex w-[248px] -translate-x-full flex-col border-r border-[#1A1A1E] bg-[#0C0C0E] transition-transform duration-300 lg:static lg:flex lg:translate-x-0 lg:z-auto">
      <!-- Logo -->
      <div class="px-5 pt-6 pb-7 flex items-center justify-between gap-2.5">
        <div class="flex items-center gap-2.5">
          <div class="w-8 h-8 rounded-lg flex items-center justify-center bg-[#C5F82A]">
            <Logo class="w-4 h-4 text-[#0A0A0B]" />
          </div>
          <div class="flex items-baseline gap-1.5">
            <span class="font-semibold tracking-tight text-[15px] text-white">LUMOVELO</span>
            <span class="mono text-[10px] text-[#5C5C63]">v2.4</span>
          </div>
        </div>
        <!-- Close button on mobile -->
        <button id="btn-close-sidebar" class="lg:hidden p-1.5 rounded-md hover:bg-[#16161A] text-white cursor-pointer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
        </button>
      </div>

      <!-- Workspace switcher -->
      <div class="px-3 mb-5">
        <div class="w-full flex items-center gap-2.5 px-2.5 py-2 rounded-lg border border-[#232328] bg-[#131316]">
          <div class="w-6 h-6 rounded-md flex items-center justify-center text-[10px] font-bold bg-[#2A2A30] text-[#C5F82A]">LV</div>
          <div class="flex-1 min-w-0">
            <div class="text-[12px] font-medium leading-tight text-white">Lumovelo Agency</div>
            <div class="text-[10px] mono text-[#5C5C63]">workspace · admin</div>
          </div>
        </div>
      </div>

      <!-- Nav -->
      <nav class="px-3 flex-1 overflow-y-auto scroll-thin" id="nav">
        <div class="px-2.5 mb-1.5 mono text-[10px] uppercase tracking-wider text-[#5C5C63]">Analytics</div>
        <a href="/admin/dashboard/" class="nav-item flex items-center gap-3 px-2.5 py-2 rounded-md text-[13px] text-[#8A8A90]">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="7" height="9" rx="1"/><rect x="14" y="3" width="7" height="5" rx="1"/><rect x="14" y="12" width="7" height="9" rx="1"/><rect x="3" y="16" width="7" height="5" rx="1"/></svg>
          Overview
        </a>
        <a href="/admin/finance/" class="nav-item flex items-center gap-3 px-2.5 py-2 rounded-md text-[13px] text-[#8A8A90]">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 3v18h18"/><path d="M7 14l4-4 3 3 5-6"/></svg>
          Revenue
        </a>
        <a href="/admin/profit-sharing/" class="nav-item flex items-center gap-3 px-2.5 py-2 rounded-md text-[13px] text-[#8A8A90]">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="9" cy="8" r="4"/><path d="M3 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2"/><circle cx="17" cy="6" r="2.5"/><path d="M14 21v-1a3 3 0 0 1 3-3h0a3 3 0 0 1 3 3v1"/></svg>
          Bagi Hasil Tim
        </a>
        <a href="/admin/blog/" class="nav-item flex items-center gap-3 px-2.5 py-2 rounded-md text-[13px] text-[#8A8A90]">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 2v20M2 12h20"/><circle cx="12" cy="12" r="9"/></svg>
          Kelola Blog
        </a>
        <a href="/admin/leads/" class="nav-item flex items-center gap-3 px-2.5 py-2 rounded-md text-[13px] text-[#8A8A90]">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="shrink-0"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          Leads AI
        </a>
        <a href="/admin/telemetry/" class="nav-item flex items-center gap-3 px-2.5 py-2 rounded-md text-[13px] text-[#8A8A90]">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          Telemetri & IP
        </a>
        <a href="/admin/ai-settings/" class="nav-item active flex items-center gap-3 px-2.5 py-2 rounded-md text-[13px] text-[#F4F4F2]">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
          Pengaturan AI
        </a>

        <div class="px-2.5 mb-1.5 mt-5 mono text-[10px] uppercase tracking-wider text-[#5C5C63]">Workspace / Dokumen</div>
        <a href="/workspace/invoice/" class="nav-item flex items-center gap-3 px-2.5 py-1.5 rounded-md text-[12.5px] text-[#8A8A90]">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="shrink-0"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 9h6v6H9z"/></svg>
          Invoice & Kuitansi
        </a>
        <a href="/workspace/spk/" class="nav-item flex items-center gap-3 px-2.5 py-1.5 rounded-md text-[12.5px] text-[#8A8A90]">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="shrink-0"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
          SPK & MoU Kontrak
        </a>
        <a href="/workspace/rab/" class="nav-item flex items-center gap-3 px-2.5 py-1.5 rounded-md text-[12.5px] text-[#8A8A90]">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="shrink-0"><path d="M3 3v18h18"/><path d="M18 17V9"/><path d="M13 17V5"/><path d="M8 17v-3"/></svg>
          RAB & SRS Proposal
        </a>
        <a href="/workspace/bast/" class="nav-item flex items-center gap-3 px-2.5 py-1.5 rounded-md text-[12.5px] text-[#8A8A90]">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="shrink-0"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          BAST Serah Terima
        </a>
      </nav>

      <!-- User logout footer -->
      <div class="px-3 pb-4 pt-1 border-t border-[#1A1A1E]">
        <button id="btn-logout" class="w-full flex items-center gap-2.5 px-2 py-2 rounded-md hover:bg-[#16161A] transition text-left group">
          <div class="w-8 h-8 rounded-full flex items-center justify-center text-[11px] font-semibold bg-[#2A2A30] text-[#F4F4F2]">AD</div>
          <div class="flex-1 min-w-0">
            <div class="text-[12px] font-medium leading-tight text-white group-hover:text-[#F87171] transition-colors">Sign Out</div>
            <div class="text-[10px] mono text-[#5C5C63]">administrator</div>
          </div>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-[#8A8A90] group-hover:text-[#F87171] transition-colors"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        </button>
      </div>
    </aside>

    <!-- Main Content Area -->
    <main class="flex-1 min-w-0 flex flex-col h-screen overflow-hidden">
      <!-- Top bar -->
      <header class="sticky top-0 z-20 flex items-center gap-3 px-4 lg:px-8 h-16 border-b border-[#1A1A1E] backdrop-blur-md bg-[rgba(10,10,11,0.78)] shrink-0">
        <button id="btn-open-sidebar" class="lg:hidden p-2 rounded-md hover:bg-[#16161A] text-white cursor-pointer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
        </button>
        <div class="hidden md:flex items-center gap-2 text-[13px] text-[#8A8A90]">
          <span>Lumovelo</span>
          <span class="text-[#5C5C63]">/</span>
          <span class="text-[#F4F4F2] font-medium">Pengaturan AI</span>
        </div>
      </header>

      <!-- Content Container -->
      <div class="flex-1 overflow-y-auto scroll-thin px-4 lg:px-8 py-6 bg-[#0A0A0B]">
        <!-- Page Header -->
        <section class="mb-6">
          <div class="flex items-center gap-2 mb-2">
            <span class="live-dot w-1.5 h-1.5 rounded-full bg-[#C5F82A]"></span>
            <span class="mono text-[11px] uppercase tracking-wider text-[#8A8A90]">MODUL DYNAMIC PROMPT</span>
          </div>
          <h1 class="serif text-[36px] lg:text-[44px] leading-none text-white font-bold">Konfigurasi Asisten AI</h1>
          <p class="mt-2 text-[13px] text-[#8A8A90]">Sesuaikan aturan perilaku, penawaran harga, dan data filter untuk Chatbot AI Lumovelo di sini.</p>
        </section>

        <!-- Migration Alert (Hidden by default) -->
        <div id="migration-alert" class="hidden p-4 mb-6 bg-amber-500/10 border border-amber-500/20 rounded-xl">
          <div class="flex items-start gap-3">
            <span class="text-lg">⚠️</span>
            <div class="flex-1">
              <h4 class="text-xs font-bold uppercase tracking-wider text-amber-400">Migrasi Supabase Dibutuhkan</h4>
              <p class="text-[11px] text-slate-300 mt-1 leading-relaxed">
                Tabel <code class="mono text-white bg-slate-950 px-1 py-0.5 rounded">ai_config</code> belum terdeteksi di database Anda. Silakan salin kueri SQL di bawah ini dan jalankan di SQL Editor Supabase Anda:
              </p>
              <pre class="bg-slate-950 border border-slate-900 rounded-lg p-3 mt-3 text-[10px] mono text-emerald-400 overflow-x-auto select-all" id="migration-sql-code"></pre>
            </div>
          </div>
        </div>

        <!-- Main Form Grid -->
        <div class="grid grid-cols-1 gap-6 max-w-5xl">
          <!-- Textareas for instructions -->
          <div class="card p-5 bg-[#0C0C0E]/50 border border-[#1A1A1E] rounded-xl flex flex-col gap-4">
            <div class="flex items-center justify-between border-b border-[#1A1A1E] pb-3">
              <h3 class="text-[14px] font-bold text-white uppercase tracking-wider">Instruksi AI (Bahasa Indonesia)</h3>
              <span class="text-[9px] font-mono text-[#5C5C63]">Default Locale: ID</span>
            </div>
            <textarea
              id="prompt-id"
              rows="12"
              class="w-full bg-[#131316]/50 border border-[#232328] focus:border-[#C5F82A] focus:outline-none rounded-lg p-4 text-[12px] leading-relaxed text-slate-200 placeholder-slate-600 font-mono scroll-thin"
              placeholder="Tulis instruksi perilaku dan daftar harga Lumovelo..."
            ></textarea>
          </div>

          <div class="card p-5 bg-[#0C0C0E]/50 border border-[#1A1A1E] rounded-xl flex flex-col gap-4">
            <div class="flex items-center justify-between border-b border-[#1A1A1E] pb-3">
              <h3 class="text-[14px] font-bold text-white uppercase tracking-wider">AI Instruction (English)</h3>
              <span class="text-[9px] font-mono text-[#5C5C63]">Default Locale: EN</span>
            </div>
            <textarea
              id="prompt-en"
              rows="12"
              class="w-full bg-[#131316]/50 border border-[#232328] focus:border-[#C5F82A] focus:outline-none rounded-lg p-4 text-[12px] leading-relaxed text-slate-200 placeholder-slate-600 font-mono scroll-thin"
              placeholder="Write the instruction behavior and service prices..."
            ></textarea>
          </div>

          <!-- API Keys Monitor Section -->
          <div class="card p-5 bg-[#0C0C0E]/50 border border-[#1A1A1E] rounded-xl flex flex-col gap-4">
            <div class="flex items-center justify-between border-b border-[#1A1A1E] pb-3">
              <div>
                <h3 class="text-[14px] font-bold text-white uppercase tracking-wider">Pemantauan Kuota & Status API Key</h3>
                <p class="text-[11px] text-[#8A8A90] mt-0.5">Pantau kuota sisa, rate-limit, dan beralih otomatis/manual antar kunci API.</p>
              </div>
              <span class="text-[9px] font-mono text-emerald-400 bg-emerald-500/10 px-2 py-0.5 rounded border border-emerald-500/20">Active Keys</span>
            </div>

            <!-- Warning Alert for limited/exhausted keys -->
            <div id="api-keys-warning-banner" class="hidden p-4 bg-rose-500/10 border border-rose-500/20 rounded-xl">
              <div class="flex items-start gap-2.5">
                <span class="text-sm">🛑</span>
                <div>
                  <h4 class="text-[11px] font-bold uppercase tracking-wider text-rose-400">Peringatan: API Utama Terkena Limit!</h4>
                  <p class="text-[10px] text-slate-300 mt-0.5 leading-relaxed">
                    Sistem mendeteksi API Key utama yang dipilih sedang terblokir (Rate limit). Sistem akan otomatis menggunakan API cadangan aktif lainnya, atau Anda dapat menukar kunci utama secara manual di bawah ini.
                  </p>
                </div>
              </div>
            </div>

            <!-- API Keys Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4" id="api-keys-list-container">
              <div class="col-span-full text-center py-6 text-[#5C5C63] text-xs">Memuat data API monitor...</div>
            </div>
          </div>

          <!-- Custom Blacklist Words Card -->
          <div class="card p-5 bg-[#0C0C0E]/50 border border-[#1A1A1E] rounded-xl flex flex-col gap-4">
            <div class="flex items-center justify-between border-b border-[#1A1A1E] pb-3">
              <div>
                <h3 class="text-[14px] font-bold text-white uppercase tracking-wider">Filter Auto-Block Kata Terlarang (Blacklist)</h3>
                <p class="text-[11px] text-[#8A8A90] mt-0.5">Cegah pesan spam/iseng sebelum memanggil AI untuk menghemat kuota API 100%.</p>
              </div>
              <span class="text-[9px] font-mono text-purple-400 bg-purple-500/10 px-2 py-0.5 rounded border border-purple-500/20">Anti-Spam Filter</span>
            </div>

            <div class="flex flex-col gap-2">
              <label for="blacklisted-words" class="text-[11px] font-medium text-slate-300">
                Daftar Kata/Frasa Terlarang (Dipisahkan koma):
              </label>
              <textarea
                id="blacklisted-words"
                rows="4"
                class="w-full bg-[#131316]/50 border border-[#232328] focus:border-[#C5F82A] focus:outline-none rounded-lg p-3 text-[12px] text-slate-200 placeholder-slate-600 font-mono scroll-thin"
                placeholder="jokowi, prabowo, trump, anjing, babi, monyet, asdfghjkl, testerrr"
              ></textarea>
              <p class="text-[10px] text-[#5C5C63]">
                💡 Catatan: Sistem otomatis menormalisasi huruf leetspeak (misal: <code class="mono text-white">4nj1ng</code> ➔ <code class="mono text-white">anjing</code>) dan membedakan kata dalam konteks kalimat bisnis.
              </p>
            </div>
          </div>

          <!-- Submit Button banner -->
          <div class="flex items-center justify-between gap-4 p-4 border border-[#1A1A1E] rounded-xl bg-[#0C0C0E]/30">
            <span class="text-[11px] text-[#8A8A90] font-medium" id="status-message">Perubahan prompt akan segera aktif saat disimpan.</span>
            <button
              id="btn-save-prompts"
              class="flex items-center justify-center h-10 px-5 rounded-lg text-[12px] font-bold bg-[#C5F82A] text-[#0A0A0B] hover:opacity-90 transition cursor-pointer"
            >
              Simpan Konfigurasi
            </button>
          </div>
        </div>
      </div>
    </main>

  </div>
</Layout>

<style>
  /* Custom scrollbar and UI styles */
  .scroll-thin::-webkit-scrollbar {
    width: 4px;
    height: 4px;
  }
  .scroll-thin::-webkit-scrollbar-track {
    background: transparent;
  }
  .scroll-thin::-webkit-scrollbar-thumb {
    background: #1e293b;
    border-radius: 99px;
  }
  .scroll-thin::-webkit-scrollbar-thumb:hover {
    background: #334155;
  }
  .live-dot {
    box-shadow: 0 0 8px #C5F82A;
    animation: pulse-glow 2s infinite;
  }
  @keyframes pulse-glow {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(0.9); }
  }
</style>

<script>
  import { supabase } from '../../lib/supabase';

  const adminLayout = document.getElementById('admin-layout')!;
  const btnLogout = document.getElementById('btn-logout')!;
  const btnSave = document.getElementById('btn-save-prompts') as HTMLButtonElement;
  const promptIdInput = document.getElementById('prompt-id') as HTMLTextAreaElement;
  const promptEnInput = document.getElementById('prompt-en') as HTMLTextAreaElement;
  const statusMsg = document.getElementById('status-message')!;
  const migrationAlert = document.getElementById('migration-alert')!;
  const migrationSqlCode = document.getElementById('migration-sql-code')!;

  let sessionToken = '';

  // Auth Validation Check
  async function validateAdminSession() {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) {
      window.location.href = '/admin/login/';
      return;
    }

    // Check if user email is authorized admin
    const userEmail = session.user.email?.toLowerCase();
    const allowedEmails = (import.meta.env.PUBLIC_ADMIN_EMAILS || 'admin@lumovelo.com')
      .split(',')
      .map(e => e.trim().toLowerCase());
    const isAdmin = userEmail && allowedEmails.includes(userEmail);

    if (!isAdmin) {
      await supabase.auth.signOut();
      await (window as any).showAlert('Akses Ditolak: Anda bukan administrator resmi.');
      window.location.href = '/admin/login/';
      return;
    }

    sessionToken = session.access_token;
    adminLayout.classList.remove('hidden');
    loadAIConfig();
  }
  validateAdminSession();

  // Load Config from Server API
  async function loadAIConfig() {
    try {
      statusMsg.textContent = 'Memuat konfigurasi...';
      const response = await fetch('/api/ai-config-handler');
      const data = await response.json();

      if (data.need_migration) {
        migrationAlert.classList.remove('hidden');
        migrationSqlCode.textContent = data.sql;
        statusMsg.textContent = 'Migrasi database diperlukan.';
        statusMsg.className = 'text-[11px] text-amber-400 font-semibold';
        return;
      }

      if (response.ok) {
        promptIdInput.value = data.system_instruction_id || '';
        promptEnInput.value = data.system_instruction_en || '';
        
        const blacklistedWordsInput = document.getElementById('blacklisted-words') as HTMLTextAreaElement;
        if (blacklistedWordsInput) {
          blacklistedWordsInput.value = data.blacklisted_words || '';
        }

        // Render API monitor keys
        renderApiKeys(data.api_keys || []);

        if (data.is_fallback) {
          statusMsg.textContent = 'Menampilkan template fallback default (belum ada di database).';
        } else {
          statusMsg.textContent = 'Konfigurasi berhasil dimuat dari database.';
        }
      } else {
        throw new Error('Gagal memuat.');
      }
    } catch (err) {
      console.error(err);
      statusMsg.textContent = 'Gagal memuat data dari database.';
    }
  }

  // Render API keys visual progress bars
  function renderApiKeys(keys: any[]) {
    const container = document.getElementById('api-keys-list-container')!;
    const warningBanner = document.getElementById('api-keys-warning-banner')!;
    
    if (keys.length === 0) {
      container.innerHTML = `<div class="col-span-full text-center py-6 text-[#5C5C63] text-xs">Belum ada API Key terdaftar.</div>`;
      warningBanner.classList.add('hidden');
      return;
    }

    // Check if any selected key is limited/exhausted or exceeded limit
    const selectedKey = keys.find(k => k.is_selected);
    if (selectedKey && (selectedKey.status === 'limited' || selectedKey.status === 'exhausted' || (selectedKey.used_quota >= selectedKey.max_quota))) {
      warningBanner.classList.remove('hidden');
    } else {
      warningBanner.classList.add('hidden');
    }

    container.innerHTML = keys.map(key => {
      const percent = Math.min((key.used_quota / key.max_quota) * 100, 100);
      let barColor = 'bg-[#C5F82A]'; // green
      if (percent >= 90 || key.status === 'limited') {
        barColor = 'bg-[#F87171]'; // red
      } else if (percent >= 70) {
        barColor = 'bg-[#F5A524]'; // orange/amber
      }

      let badgeClass = 'bg-emerald-500/10 border-emerald-500/20 text-emerald-400';
      let statusText = 'Normal';
      if (key.status === 'limited') {
        badgeClass = 'bg-rose-500/10 border-rose-500/20 text-rose-400 animate-pulse';
        statusText = 'Rate-Limited';
      } else if (key.status === 'exhausted' || percent >= 100) {
        badgeClass = 'bg-rose-500/10 border-rose-500/20 text-rose-400';
        statusText = 'Kuota Habis';
      }

      let isSelectedBadge = key.is_selected 
        ? '<span class="text-[9px] font-bold uppercase px-2 py-0.5 rounded bg-[#C5F82A] text-[#0A0A0B] border border-[#C5F82A]">UTAMA</span>' 
        : '';

      let timerHtml = '';
      if (key.status === 'limited' && key.last_limited_at) {
        timerHtml = `<div class="mono text-[10px] text-rose-400 mt-1.5 font-bold" data-countdown-id="${key.id}" data-limited-at="${key.last_limited_at}" data-duration="${key.reset_duration_seconds}">
          Reset dalam: --:--
        </div>`;
      }

      return `
        <div class="p-4 rounded-xl border ${key.is_selected ? 'border-[#C5F82A]/30 bg-[#0E0E11]/80' : 'border-[#1A1A1E] bg-[#0C0C0E]/50'} flex flex-col gap-3">
          <div class="flex items-center justify-between">
            <div class="flex flex-col gap-0.5">
              <span class="text-white text-[12px] font-bold">${key.key_name}</span>
              <span class="text-[10px] mono text-[#5C5C63] mt-0.5">${key.api_key_masked}</span>
            </div>
            <div class="flex items-center gap-1.5">
              ${isSelectedBadge}
              <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[9px] font-semibold border ${badgeClass}">
                ${statusText}
              </span>
            </div>
          </div>
          
          <div>
            <div class="flex items-center justify-between mb-1">
              <span class="text-[10px] text-[#8A8A90]">Digunakan: <b>${key.used_quota}</b> / ${key.max_quota} req</span>
              <span class="mono text-[10px] text-[#8A8A90]">${percent.toFixed(1)}%</span>
            </div>
            <div class="h-1.5 rounded-full overflow-hidden bg-[#1A1A1E]">
              <div class="h-full rounded-full ${barColor}" style="width: ${percent}%"></div>
            </div>
            ${timerHtml}
          </div>

          <div class="flex items-center justify-between mt-1 pt-2 border-t border-[#1A1A1E]">
            <div class="flex items-center gap-2">
              <button 
                data-switch-id="${key.id}" 
                class="px-2.5 py-1 rounded ${key.is_selected ? 'bg-[#232328] text-[#5C5C63] cursor-not-allowed' : 'bg-[#131316] hover:bg-[#232328] border border-[#232328] text-white hover:text-[#C5F82A] cursor-pointer'} text-[10px] font-bold uppercase tracking-wider transition"
                ${key.is_selected ? 'disabled' : ''}
              >
                Switch
              </button>
              <button 
                data-reset-id="${key.id}" 
                class="p-1 rounded hover:bg-[#16161A] text-[#8A8A90] hover:text-white transition cursor-pointer" 
                title="Reset Kuota ke 0"
              >
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
              </button>
            </div>
            <span class="text-[9px] mono text-[#5C5C63]">Reset: ${key.reset_duration_seconds}s</span>
          </div>
        </div>
      `;
    }).join('');

    // Bind switch actions
    container.querySelectorAll('[data-switch-id]').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        const id = (e.target as HTMLElement).getAttribute('data-switch-id');
        if (id) await switchApiKey(parseInt(id));
      });
    });

    // Bind reset actions
    container.querySelectorAll('[data-reset-id]').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        const target = (e.target as HTMLElement).closest('[data-reset-id]');
        const id = target ? target.getAttribute('data-reset-id') : null;
        if (id) await resetApiKeyQuota(parseInt(id));
      });
    });
  }

  // Switch API key action
  async function switchApiKey(keyId: number) {
    try {
      statusMsg.textContent = 'Mengganti API Key...';
      const response = await fetch('/api/ai-config-handler', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          token: sessionToken,
          action: 'switch_key',
          keyId: keyId
        })
      });

      const result = await response.json();
      if (response.ok) {
        window.showToast?.('API Key berhasil diganti!', 'success');
        loadAIConfig();
      } else {
        throw new Error(result.error || 'Gagal mengganti key.');
      }
    } catch (err: any) {
      console.error(err);
      window.showToast?.('Gagal: ' + err.message, 'error');
      loadAIConfig();
    }
  }

  // Reset API key quota action
  async function resetApiKeyQuota(keyId: number) {
    if (!await (window as any).showConfirm('Apakah Anda yakin ingin me-reset hitungan kuota kunci API ini kembali ke 0?')) {
      return;
    }
    try {
      statusMsg.textContent = 'Mereset kuota...';
      const response = await fetch('/api/ai-config-handler', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          token: sessionToken,
          action: 'reset_key',
          keyId: keyId
        })
      });

      const result = await response.json();
      if (response.ok) {
        window.showToast?.('Kuota API Key berhasil direset!', 'success');
        loadAIConfig();
      } else {
        throw new Error(result.error || 'Gagal reset kuota.');
      }
    } catch (err: any) {
      console.error(err);
      window.showToast?.('Gagal: ' + err.message, 'error');
      loadAIConfig();
    }
  }

  // Update countdown timers dynamically
  setInterval(() => {
    document.querySelectorAll('[data-countdown-id]').forEach((el) => {
      const limitedAtStr = el.getAttribute('data-limited-at');
      const durationSeconds = parseInt(el.getAttribute('data-duration') || '60', 10);
      if (!limitedAtStr) return;

      const limitedAt = new Date(limitedAtStr);
      const now = new Date();
      const diffMs = now.getTime() - limitedAt.getTime();
      const diffSeconds = Math.floor(diffMs / 1000);
      const remaining = durationSeconds - diffSeconds;

      if (remaining <= 0) {
        el.innerHTML = '<span class="text-emerald-400 font-bold">Siap Pulih (muat ulang)...</span>';
        setTimeout(() => {
          loadAIConfig();
        }, 3000);
      } else {
        const mins = Math.floor(remaining / 60);
        const secs = remaining % 60;
        const formatted = `${mins.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`;
        el.textContent = `Reset dalam: ${formatted}`;
      }
    });
  }, 1000);

  // Save Config to Server API
  btnSave.addEventListener('click', async () => {
    const system_instruction_id = promptIdInput.value.trim();
    const system_instruction_en = promptEnInput.value.trim();

    if (!system_instruction_id || !system_instruction_en) {
      await (window as any).showAlert('Instruksi prompt tidak boleh kosong!');
      return;
    }

    try {
      statusMsg.textContent = 'Menyimpan konfigurasi...';
      btnSave.disabled = true;

      const blacklistedWordsInput = document.getElementById('blacklisted-words') as HTMLTextAreaElement;

      const response = await fetch('/api/ai-config-handler', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          token: sessionToken,
          system_instruction_id: promptIdInput.value,
          system_instruction_en: promptEnInput.value,
          blacklisted_words: blacklistedWordsInput?.value || ''
        })
      });

      const result = await response.json();
      btnSave.disabled = false;

      if (response.ok) {
        if (result.need_migration) {
          migrationAlert.classList.remove('hidden');
          migrationSqlCode.textContent = result.sql;
          statusMsg.textContent = '✓ Instruksi prompt disimpan! Jalankan SQL di atas di Supabase agar blacklist tersimpan permanen.';
          statusMsg.className = 'text-[11px] text-amber-400 font-semibold';
        } else {
          statusMsg.textContent = '✓ Pengaturan AI berhasil disimpan!';
          statusMsg.className = 'text-[11px] text-emerald-400 font-semibold';
          migrationAlert.classList.add('hidden');
          setTimeout(() => {
            statusMsg.textContent = 'Perubahan prompt akan segera aktif saat disimpan.';
            statusMsg.className = 'text-[11px] text-[#8A8A90] font-medium';
          }, 5000);
        }
      } else {
        if (result.need_migration) {
          migrationAlert.classList.remove('hidden');
          migrationSqlCode.textContent = result.sql;
          statusMsg.textContent = 'Gagal menyimpan: Migrasi database diperlukan.';
          statusMsg.className = 'text-[11px] text-amber-400 font-semibold';
        } else {
          throw new Error(result.error || 'Gagal menyimpan.');
        }
      }
    } catch (err: any) {
      btnSave.disabled = false;
      statusMsg.textContent = 'Gagal menyimpan: ' + (err.message || 'Error internal.');
      statusMsg.className = 'text-[11px] text-rose-500 font-semibold';
    }
  });

  // Mobile Sidebar Drawer Control
  const adminSidebar = document.getElementById('admin-sidebar');
  const btnOpenSidebar = document.getElementById('btn-open-sidebar');
  const btnCloseSidebar = document.getElementById('btn-close-sidebar');
  const sidebarOverlay = document.getElementById('admin-sidebar-overlay');

  function openSidebar() {
    if (adminSidebar && sidebarOverlay) {
      adminSidebar.classList.remove('-translate-x-full');
      sidebarOverlay.classList.remove('hidden');
      setTimeout(() => sidebarOverlay.classList.remove('opacity-0'), 10);
    }
  }

  function closeSidebar() {
    if (adminSidebar && sidebarOverlay) {
      adminSidebar.classList.add('-translate-x-full');
      sidebarOverlay.classList.add('opacity-0');
      setTimeout(() => sidebarOverlay.classList.add('hidden'), 300);
    }
  }

  btnOpenSidebar?.addEventListener('click', openSidebar);
  btnCloseSidebar?.addEventListener('click', closeSidebar);
  sidebarOverlay?.addEventListener('click', closeSidebar);

  // Logout handler
  btnLogout.addEventListener('click', async () => {
    await supabase.auth.signOut();
    document.cookie = 'sb-access-token=; path=/; expires=Thu, 01 Jan 1970 00:00:00 GMT; SameSite=Lax; Secure';
    document.cookie = 'sb-refresh-token=; path=/; expires=Thu, 01 Jan 1970 00:00:00 GMT; SameSite=Lax; Secure';
    window.location.href = '/admin/login/';
  });
</script>
