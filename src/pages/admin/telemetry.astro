---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import Logo from '../../components/Logo.astro';
---

<Layout title="Telemetri & Cek IP | LUMOVELO" description="Pusat pelacakan telemetri IP, lokasi geografis, dan analisis provider seluler." noindex={true}>
  <!-- Leaflet CSS for Interactive OpenStreetMap -->
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />

  <div id="admin-layout" class="hidden min-h-screen dashboard-root grain flex relative">
    
    <!-- Sidebar Backdrop Overlay on Mobile -->
    <div id="admin-sidebar-overlay" class="fixed inset-0 bg-black/70 z-[90] lg:hidden hidden opacity-0 transition-opacity duration-300"></div>

    <!-- Sidebar Navigation -->
    <aside id="admin-sidebar" class="fixed inset-y-0 left-0 z-[100] flex w-[248px] -translate-x-full flex-col border-r border-[#1A1A1E] bg-[#0C0C0E] transition-transform duration-300 lg:static lg:flex lg:translate-x-0 lg:z-auto">
      <!-- Logo -->
      <div class="px-5 pt-6 pb-7 flex items-center justify-between gap-2.5">
        <div class="flex items-center gap-2.5">
          <div class="w-8 h-8 rounded-lg flex items-center justify-center bg-[#C5F82A]">
            <Logo class="w-4 h-4 text-[#0A0A0B]" />
          </div>
          <div class="flex items-baseline gap-1.5">
            <span class="font-semibold tracking-tight text-[15px] text-white">LUMOVELO</span>
            <span class="mono text-[10px] text-[#5C5C63]">v2.4</span>
          </div>
        </div>
        <!-- Close button on mobile -->
        <button id="btn-close-sidebar" class="lg:hidden p-1.5 rounded-md hover:bg-[#16161A] text-white cursor-pointer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
        </button>
      </div>

      <!-- Workspace switcher -->
      <div class="px-3 mb-5">
        <div class="w-full flex items-center gap-2.5 px-2.5 py-2 rounded-lg border border-[#232328] bg-[#131316]">
          <span class="w-2 h-2 rounded-full bg-[#C5F82A]"></span>
          <span class="text-[12px] font-medium text-white flex-1 truncate">Lumovelo Studio</span>
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-[#8A8A90]"><path d="M6 9l6 6 6-6"/></svg>
        </div>
      </div>

      <!-- Navigation links -->
      <nav class="px-3 space-y-1 flex-1 overflow-y-auto scroll-thin">
        <div class="px-2.5 mb-1.5 mono text-[10px] uppercase tracking-wider text-[#5C5C63]">Analytics & Security</div>
        <a href="/admin/dashboard/" class="nav-item flex items-center gap-3 px-2.5 py-2 rounded-md text-[13px] text-[#8A8A90]">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="7" height="9" rx="1"/><rect x="14" y="3" width="7" height="5" rx="1"/><rect x="14" y="12" width="7" height="9" rx="1"/><rect x="3" y="16" width="7" height="5" rx="1"/></svg>
          Overview
        </a>
        <a href="/admin/leads/" class="nav-item flex items-center gap-3 px-2.5 py-2 rounded-md text-[13px] text-[#8A8A90]">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          Leads AI Chatbot
        </a>
        <a href="/admin/telemetry/" class="nav-item active flex items-center gap-3 px-2.5 py-2 rounded-md text-[13px] text-[#F4F4F2]">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          Telemetri & IP
        </a>
        <a href="/admin/finance/" class="nav-item flex items-center gap-3 px-2.5 py-2 rounded-md text-[13px] text-[#8A8A90]">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          Keuangan Agensi
        </a>
        <a href="/admin/profit-sharing/" class="nav-item flex items-center gap-3 px-2.5 py-2 rounded-md text-[13px] text-[#8A8A90]">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
          Bagi Hasil Tim
        </a>
        <a href="/admin/blog/" class="nav-item flex items-center gap-3 px-2.5 py-2 rounded-md text-[13px] text-[#8A8A90]">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
          Kelola Blog
        </a>
        <a href="/admin/ai-settings/" class="nav-item flex items-center gap-3 px-2.5 py-2 rounded-md text-[13px] text-[#8A8A90]">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
          Pengaturan AI
        </a>

        <div class="px-2.5 mb-1.5 mt-5 mono text-[10px] uppercase tracking-wider text-[#5C5C63]">Workspace / Dokumen</div>
        <a href="/workspace/invoice/" class="nav-item flex items-center gap-3 px-2.5 py-1.5 rounded-md text-[12.5px] text-[#8A8A90]">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="shrink-0"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 9h6v6H9z"/></svg>
          Invoice & Kuitansi
        </a>
        <a href="/workspace/spk/" class="nav-item flex items-center gap-3 px-2.5 py-1.5 rounded-md text-[12.5px] text-[#8A8A90]">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="shrink-0"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
          SPK & MoU Kontrak
        </a>
        <a href="/workspace/rab/" class="nav-item flex items-center gap-3 px-2.5 py-1.5 rounded-md text-[12.5px] text-[#8A8A90]">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="shrink-0"><path d="M3 3v18h18"/><path d="M18 17V9"/><path d="M13 17V5"/><path d="M8 17v-3"/></svg>
          RAB & SRS Proposal
        </a>
        <a href="/workspace/bast/" class="nav-item flex items-center gap-3 px-2.5 py-1.5 rounded-md text-[12.5px] text-[#8A8A90]">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="shrink-0"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          BAST Serah Terima
        </a>
      </nav>

      <!-- User logout footer -->
      <div class="px-3 pb-4 pt-1 border-t border-[#1A1A1E]">
        <button id="btn-logout" class="w-full flex items-center gap-2.5 px-2 py-2 rounded-md hover:bg-[#16161A] transition text-left group">
          <div class="w-8 h-8 rounded-full flex items-center justify-center text-[11px] font-semibold bg-[#2A2A30] text-[#F4F4F2]">AD</div>
          <div class="flex-1 min-w-0">
            <div class="text-[12px] font-medium leading-tight text-white group-hover:text-[#F87171] transition-colors">Sign Out</div>
            <div class="text-[10px] mono text-[#5C5C63]">administrator</div>
          </div>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-[#8A8A90] group-hover:text-[#F87171] transition-colors"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        </button>
      </div>
    </aside>

    <!-- Main Content Area -->
    <main class="flex-1 min-w-0 flex flex-col overflow-y-auto scroll-thin">
      <!-- Top bar -->
      <header class="sticky top-0 z-20 flex items-center gap-3 px-4 lg:px-8 h-16 border-b border-[#1A1A1E] backdrop-blur-md bg-[rgba(10,10,11,0.78)] shrink-0">
        <button id="btn-open-sidebar" class="lg:hidden p-2 rounded-md hover:bg-[#16161A] text-white cursor-pointer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
        </button>
        <div class="hidden md:flex items-center gap-2 text-[13px] text-[#8A8A90]">
          <span>Lumovelo</span>
          <span class="text-[#5C5C63]">/</span>
          <span class="text-[#F4F4F2] font-medium">Pusat Telemetri & IP</span>
        </div>
      </header>

      <!-- Main Page Content -->
      <div class="p-4 sm:p-6 max-w-7xl w-full mx-auto space-y-6">
        
        <!-- Header banner -->
        <section class="flex flex-col md:flex-row md:items-center justify-between gap-4">
          <div>
            <div class="flex items-center gap-2 mb-1.5">
              <span class="w-2 h-2 rounded-full bg-purple-400 animate-ping"></span>
              <span class="mono text-[11px] uppercase tracking-wider text-purple-400 font-semibold">SECURITY & TELEMETRY TOOLKIT</span>
            </div>
            <h1 class="text-2xl sm:text-3xl font-bold text-white tracking-tight">Pusat Pelacakan IP & Provider</h1>
            <p class="text-[12px] sm:text-[13px] text-[#8A8A90] mt-1 max-w-2xl">
              Cek lokasi geografis IP, identifikasi provider ISP (XL, Telkomsel, Indihome), serta lacak histori lead & operator seluler secara real-time dengan Peta Interaktif (100% Gratis).
            </p>
          </div>

          <!-- Search form -->
          <form id="telemetry-search-form" class="flex flex-col sm:flex-row items-stretch sm:items-center gap-2 bg-[#0C0C0E] p-2 rounded-xl border border-[#232328] w-full md:w-auto shadow-xl">
            <div class="flex items-center gap-2 px-3 h-10 bg-[#131316] rounded-lg border border-[#232328] flex-1 sm:w-80">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-purple-400 shrink-0"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
              <input 
                type="text" 
                id="telemetry-search-input"
                placeholder="Masukkan IP (ex: 103.3.220.127) atau No. HP"
                class="bg-transparent text-[13px] text-white outline-none w-full placeholder:text-[#5C5C63] font-mono"
                value="103.3.220.127"
              >
            </div>
            <button 
              type="submit"
              id="btn-telemetry-search"
              class="h-10 px-5 rounded-lg bg-purple-600 hover:bg-purple-500 text-white font-bold text-[12px] transition flex items-center justify-center gap-2 cursor-pointer shadow-lg shrink-0"
            >
              <span>Lacak Telemetri</span>
            </button>
          </form>
        </section>

        <!-- Dynamic Results Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
          
          <!-- Left Column: Interactive Map Box -->
          <div class="lg:col-span-7 flex flex-col gap-4">
            <div class="p-4 bg-[#0C0C0E] border border-[#232328] rounded-xl flex flex-col h-[380px] sm:h-[440px] shadow-xl overflow-hidden relative">
              <div class="flex items-center justify-between mb-3 shrink-0">
                <h3 class="text-[14px] font-bold text-white flex items-center gap-2">
                  <span>🗺️</span> Peta Visualisasi Lokasi Real-Time
                </h3>
                <span id="map-status-badge" class="text-[10px] font-mono text-emerald-400 bg-emerald-500/10 px-2 py-0.5 rounded border border-emerald-500/20">OpenStreetMap Active</span>
              </div>
              
              <!-- Map Container -->
              <div id="interactive-map" class="w-full flex-1 rounded-lg border border-[#1A1A1E] z-10"></div>
            </div>
          </div>

          <!-- Right Column: Detail Information Cards -->
          <div class="lg:col-span-5 flex flex-col gap-4">
            <div id="telemetry-details-card" class="p-5 bg-[#0C0C0E] border border-[#232328] rounded-xl flex flex-col gap-4 shadow-xl min-h-[380px] sm:min-h-[440px]">
              <div class="text-center py-12 text-[#5C5C63] text-xs">Masukkan IP atau Nomor HP untuk memuat analisis telemetri...</div>
            </div>
          </div>

        </div>

      </div>
    </main>
  </div>
</Layout>

<!-- Leaflet JS CDN for Interactive OpenStreetMap -->
<script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

<script>
  import { supabase } from '../../lib/supabase';

  let map: any = null;
  let marker: any = null;

  async function initTelemetryPage() {
    const adminLayout = document.getElementById('admin-layout');
    if (!adminLayout) return;

    // Session validation
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) {
      window.location.href = '/admin/login/';
      return;
    }

    adminLayout.classList.remove('hidden');

    // Initialize Leaflet Map centered at Indonesia
    const mapElement = document.getElementById('interactive-map');
    if (mapElement && (window as any).L) {
      const L = (window as any).L;
      map = L.map('interactive-map').setView([-6.2088, 106.8456], 10); // Default Jakarta/Indonesia

      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        maxZoom: 19,
        attribution: '&copy; OpenStreetMap contributors'
      }).addTo(map);

      // Auto-search default IP on page load
      executeSearch('103.3.220.127');
    }

    // Bind Search Form
    const searchForm = document.getElementById('telemetry-search-form') as HTMLFormElement;
    const searchInput = document.getElementById('telemetry-search-input') as HTMLInputElement;

    searchForm?.addEventListener('submit', (e) => {
      e.preventDefault();
      const query = searchInput.value.trim();
      if (query) {
        executeSearch(query);
      }
    });

    // Mobile Sidebar Drawer Control
    const adminSidebar = document.getElementById('admin-sidebar');
    const btnOpenSidebar = document.getElementById('btn-open-sidebar');
    const btnCloseSidebar = document.getElementById('btn-close-sidebar');
    const sidebarOverlay = document.getElementById('admin-sidebar-overlay');

    function openSidebar() {
      if (adminSidebar && sidebarOverlay) {
        adminSidebar.classList.remove('-translate-x-full');
        sidebarOverlay.classList.remove('hidden');
        setTimeout(() => sidebarOverlay.classList.remove('opacity-0'), 10);
      }
    }

    function closeSidebar() {
      if (adminSidebar && sidebarOverlay) {
        adminSidebar.classList.add('-translate-x-full');
        sidebarOverlay.classList.add('opacity-0');
        setTimeout(() => sidebarOverlay.classList.add('hidden'), 300);
      }
    }

    btnOpenSidebar?.addEventListener('click', openSidebar);
    btnCloseSidebar?.addEventListener('click', closeSidebar);
    sidebarOverlay?.addEventListener('click', closeSidebar);

    const btnLogout = document.getElementById('btn-logout');
    btnLogout?.addEventListener('click', async () => {
      await supabase.auth.signOut();
      window.location.href = '/admin/login/';
    });
  }

  async function executeSearch(query: string) {
    const detailsCard = document.getElementById('telemetry-details-card');
    const btnSearch = document.getElementById('btn-telemetry-search') as HTMLButtonElement;

    if (!detailsCard) return;

    try {
      if (btnSearch) btnSearch.disabled = true;
      detailsCard.innerHTML = `<div class="text-xs text-purple-400 font-medium py-8 text-center animate-pulse">🔍 Mengambil data lokasi & telemetri...</div>`;

      const { data: { session } } = await supabase.auth.getSession();
      const token = session?.access_token;

      const res = await fetch('/api/lookup', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ query, token })
      });

      const data = await res.json();
      if (btnSearch) btnSearch.disabled = false;

      if (!res.ok) {
        detailsCard.innerHTML = `<div class="text-xs text-rose-400 font-medium py-6 text-center">❌ ${data.error || 'Gagal mengambil data.'}</div>`;
        return;
      }

      if (data.type === 'ip') {
        const geo = data.geo;
        const history = data.history || [];

        // Update Map Marker
        if (geo && geo.lat && geo.lon && map && (window as any).L) {
          const L = (window as any).L;
          map.setView([geo.lat, geo.lon], 12);

          if (marker) {
            map.removeLayer(marker);
          }

          marker = L.marker([geo.lat, geo.lon]).addTo(map);
          marker.bindPopup(`
            <div style="font-family: sans-serif; padding: 2px;">
              <strong style="color: #1e293b;">${data.query}</strong><br/>
              <span style="font-size: 11px; color: #475569;">📍 ${geo.city}, ${geo.region}</span><br/>
              <span style="font-size: 11px; color: #2563eb;">🌐 ${geo.isp}</span>
            </div>
          `).openPopup();
        }

        detailsCard.innerHTML = `
          <div class="flex flex-col gap-4">
            <div class="flex items-center justify-between border-b border-[#1A1A1E] pb-3">
              <span class="px-2.5 py-1 rounded bg-purple-500/10 text-purple-400 font-mono text-[11px] font-bold border border-purple-500/20">ALAMAT IP PUBLIC</span>
              ${data.isBanned ? '<span class="px-2.5 py-1 rounded bg-rose-500/10 text-rose-400 font-bold text-[10px]">🚫 TERBLOKIR</span>' : ''}
            </div>

            <div>
              <span class="text-[10px] uppercase tracking-wider text-[#5C5C63] font-mono">Query IP Target</span>
              <h2 class="text-xl font-bold text-white mono mt-0.5">${data.query}</h2>
            </div>

            ${geo ? `
              <div class="grid grid-cols-1 gap-3 text-[12px] bg-[#131316] p-3.5 rounded-xl border border-[#232328]">
                <div>
                  <span class="text-[#8A8A90] block text-[10px] uppercase font-mono">📍 Lokasi Geografis Real-Time</span>
                  <span class="text-white font-semibold">${geo.city}, ${geo.region} (${geo.country})</span>
                </div>
                <div>
                  <span class="text-[#8A8A90] block text-[10px] uppercase font-mono">🌐 Provider Internet (ISP)</span>
                  <span class="text-purple-400 font-semibold">${geo.isp}</span>
                </div>
                <div>
                  <span class="text-[#8A8A90] block text-[10px] uppercase font-mono">📱 Tipe Perangkat / Jaringan</span>
                  <span class="text-slate-200 font-medium">${geo.isMobile ? 'Koneksi Seluler (HP)' : 'Desktop / Wi-Fi'} ${geo.isProxy ? '⚠️ (Proxy/VPN)' : ''}</span>
                </div>
              </div>
            ` : `
              <div class="text-xs text-[#8A8A90] italic">Data lokasi publik IP ini terbatas.</div>
            `}

            <div>
              <span class="text-[10px] uppercase tracking-wider text-[#5C5C63] font-mono block mb-1.5">Riwayat Chatbot internal (${history.length} Sesi)</span>
              ${history.length > 0 ? `
                <div class="space-y-1.5 max-h-32 overflow-y-auto scroll-thin">
                  ${history.map((s: any) => `
                    <div class="p-2 rounded bg-[#131316] border border-[#1A1A1E] text-[11px] flex justify-between items-center">
                      <span class="text-slate-200">${s.client_name || 'Klien Anonim'}</span>
                      <span class="text-[#5C5C63] mono text-[9px]">${new Date(s.created_at).toLocaleDateString('id-ID')}</span>
                    </div>
                  `).join('')}
                </div>
              ` : `
                <span class="text-[11px] text-[#5C5C63] italic">Belum ada riwayat chat di database.</span>
              `}
            </div>

            <div class="pt-3 border-t border-[#1A1A1E] flex flex-wrap items-center gap-2">
              ${geo?.mapUrl ? `
                <a href="${geo.mapUrl}" target="_blank" rel="noopener noreferrer" class="flex-1 py-2 px-3 rounded-lg bg-blue-600/10 hover:bg-blue-600/20 text-blue-400 font-semibold text-[11px] border border-blue-500/20 text-center transition">
                  🗺️ Maps Google
                </a>
              ` : ''}
              ${!data.isBanned ? `
                <button id="btn-ban-page-ip" class="flex-1 py-2 px-3 rounded-lg bg-rose-500/10 hover:bg-rose-500/20 text-rose-400 font-semibold text-[11px] border border-rose-500/20 text-center transition cursor-pointer" data-ip="${data.query}">
                  🚫 Blokir IP Ini
                </button>
              ` : ''}
            </div>
          </div>
        `;

        const banBtn = document.getElementById('btn-ban-page-ip');
        if (banBtn) {
          banBtn.addEventListener('click', async () => {
            const confirmed = await (window as any).showConfirm(`Apakah Anda yakin ingin memblokir IP ${data.query}?`);
            if (!confirmed) return;

            const banRes = await fetch('/api/ai-config-handler', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ token, action: 'ban_ip', ipToBan: data.query })
            });

            if (banRes.ok) {
              (window as any).showToast(`IP ${data.query} berhasil diblokir!`, 'success');
              executeSearch(data.query);
            }
          });
        }

      } else if (data.type === 'phone') {
        const history = data.history || [];

        detailsCard.innerHTML = `
          <div class="flex flex-col gap-4">
            <div class="flex items-center justify-between border-b border-[#1A1A1E] pb-3">
              <span class="px-2.5 py-1 rounded bg-emerald-500/10 text-emerald-400 font-mono text-[11px] font-bold border border-emerald-500/20">NOMOR HP</span>
            </div>

            <div>
              <span class="text-[10px] uppercase tracking-wider text-[#5C5C63] font-mono">Query Nomor HP</span>
              <h2 class="text-xl font-bold text-white mono mt-0.5">${data.query}</h2>
            </div>

            <div class="grid grid-cols-1 gap-3 text-[12px] bg-[#131316] p-3.5 rounded-xl border border-[#232328]">
              <div>
                <span class="text-[#8A8A90] block text-[10px] uppercase font-mono">📱 Operator Seluler / Provider</span>
                <span class="text-emerald-400 font-bold">${data.provider}</span>
              </div>
              <div>
                <span class="text-[#8A8A90] block text-[10px] uppercase font-mono">🌐 Format Internasional</span>
                <code class="mono text-white font-semibold">${data.cleanedPhone}</code>
              </div>
            </div>

            <div>
              <span class="text-[10px] uppercase tracking-wider text-[#5C5C63] font-mono block mb-1.5">Riwayat Lead Internal (${history.length} Entri)</span>
              ${history.length > 0 ? `
                <div class="space-y-1.5 max-h-36 overflow-y-auto scroll-thin">
                  ${history.map((l: any) => `
                    <div class="p-2.5 rounded bg-[#131316] border border-[#1A1A1E] text-[11px] flex justify-between items-center">
                      <div>
                        <strong class="text-white block">${l.client_name || 'Klien Anonim'}</strong>
                        <span class="text-[10px] text-[#8A8A90]">${l.company_name || 'Agensi/Personal'}</span>
                      </div>
                      <span class="px-1.5 py-0.5 rounded text-[9px] font-mono uppercase bg-blue-500/10 text-blue-400 font-semibold border border-blue-500/20">${l.status}</span>
                    </div>
                  `).join('')}
                </div>
              ` : `
                <span class="text-[11px] text-[#5C5C63] italic">Belum ada riwayat lead dengan nomor HP ini.</span>
              `}
            </div>

            <div class="pt-3 border-t border-[#1A1A1E] flex flex-wrap items-center gap-2">
              <a href="${data.waUrl}" target="_blank" rel="noopener noreferrer" class="flex-1 py-2 px-3 rounded-lg bg-emerald-600 hover:bg-emerald-500 text-white font-semibold text-[11px] text-center transition">
                💬 Chat via WhatsApp
              </a>
              <a href="${data.truecallerUrl}" target="_blank" rel="noopener noreferrer" class="flex-1 py-2 px-3 rounded-lg bg-blue-600 hover:bg-blue-500 text-white font-semibold text-[11px] text-center transition">
                🔎 Cek di Truecaller
              </a>
            </div>
          </div>
        `;
      }

    } catch (err: any) {
      if (btnSearch) btnSearch.disabled = false;
      detailsCard.innerHTML = `<div class="text-xs text-rose-400 font-medium py-6 text-center">❌ ${err.message || 'Gagal mengambil data.'}</div>`;
    }
  }

  document.addEventListener('DOMContentLoaded', initTelemetryPage);
</script>
