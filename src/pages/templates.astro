---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';

const lang = Astro.currentLocale === 'en' ? 'en' : 'id';

const content = {
  id: {
    title: "Katalog Tema Undangan Digital | LUMOVELO",
    description: "Lihat pilihan tema desain undangan pernikahan digital kami untuk setiap paket layanan secara transparan.",
    subtitle: "PILIHAN TEMA TERBAIK",
    mainTitle: "KATALOG TEMA UNDANGAN DIGITAL",
    starterTitle: "Template Starter (Basic — Rp 149.000)",
    starterDesc: "Desain standar responsif, praktis, dengan masa aktif 3 bulan.",
    premiumTitle: "Premium Features (Pro — Rp 299.000)",
    premiumDesc: "Fitur interaktif musik, galeri foto, nama tamu otomatis, & masa aktif 1 tahun.",
    customTitle: "Custom Storytelling (Elite — Rp 599.000)",
    customDesc: "Desain kustom semi-Figma eksklusif, video teaser, dan buku tamu digital QR.",
    backBtn: "Kembali ke Beranda"
  },
  en: {
    title: "Digital Wedding Invitation Themes | LUMOVELO",
    description: "Browse our digital wedding invitation design templates for each package transparently.",
    subtitle: "BEST DESIGN THEMES",
    mainTitle: "DIGITAL WEDDING THEMES",
    starterTitle: "Starter Template (Basic — Rp 149.000)",
    starterDesc: "Responsive standard designs, practical, active for 3 months.",
    premiumTitle: "Premium Features (Pro — Rp 299.000)",
    premiumDesc: "Interactive music, photo gallery, customized guest names, & active for 1 year.",
    customTitle: "Custom Storytelling (Elite — Rp 599.000)",
    customDesc: "Exclusive custom layouts, video player teaser, and QR digital guestbook.",
    backBtn: "Back to Home"
  }
}[lang];

const templatesData = {
  starter: [
    { name: "Undangan A (Modern Basic)", url: "https://demo.lumovelo.agency/wedding/starter-a", tag: "MODERN" },
    { name: "Undangan B (Rustic Standard)", url: "https://demo.lumovelo.agency/wedding/starter-b", tag: "RUSTIC" },
    { name: "Undangan C (Elegant Clean)", url: "https://demo.lumovelo.agency/wedding/starter-c", tag: "ELEGANT" },
    { name: "Undangan D (Minimalist Line)", url: "https://demo.lumovelo.agency/wedding/starter-d", tag: "MINIMALIST" }
  ],
  premium: [
    { name: "Undangan E (Modern Premium)", url: "https://demo.lumovelo.agency/wedding/premium-a", tag: "PREMIUM" },
    { name: "Undangan F (Gold Luxury)", url: "https://demo.lumovelo.agency/wedding/premium-b", tag: "LUXURY" },
    { name: "Undangan G (Floral Elegant)", url: "https://demo.lumovelo.agency/wedding/premium-c", tag: "FLORAL" },
    { name: "Undangan H (Dark Aesthetic)", url: "https://demo.lumovelo.agency/wedding/premium-d", tag: "AESTHETIC" }
  ],
  custom: [
    { name: "Undangan I (Custom Storytelling A)", url: "https://demo.lumovelo.agency/wedding/custom-a", tag: "ELITE" },
    { name: "Undangan J (Custom Storytelling B)", url: "https://demo.lumovelo.agency/wedding/custom-b", tag: "ELITE" },
    { name: "Undangan K (Custom Storytelling C)", url: "https://demo.lumovelo.agency/wedding/custom-c", tag: "ELITE" },
    { name: "Undangan L (Custom Storytelling D)", url: "https://demo.lumovelo.agency/wedding/custom-d", tag: "ELITE" }
  ]
};
---

<Layout title={content.title} description={content.description}>
  <header class="w-full z-50 border-b border-slate-200 bg-white/70 backdrop-blur-md sticky top-0">
    <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
      <a href={lang === 'en' ? '/en/' : '/'} class="flex items-center gap-3 group">
        <div class="w-10 h-10 rounded-xl border-2 border-slate-900 bg-blue-600 flex items-center justify-center font-display font-black text-white text-xl tracking-wider shadow-lg shadow-blue-600/10 group-hover:rotate-6 transition-transform">
          L
        </div>
        <span class="font-display font-black text-xl tracking-widest text-slate-900 group-hover:text-blue-600 transition-colors">LUMOVELO</span>
      </a>

      <a href={lang === 'en' ? '/en/' : '/'} class="inline-flex items-center justify-center px-5 py-2.5 rounded-lg border-2 border-slate-200 hover:border-slate-400 bg-white text-slate-700 hover:text-slate-900 text-xs font-black uppercase tracking-wider transition-all">
        ➔ {content.backBtn}
      </a>
    </div>
  </header>

  <main class="py-16 md:py-24 bg-white min-h-screen">
    <div class="max-w-6xl mx-auto px-6">
      
      <!-- Page Header -->
      <div class="text-center max-w-3xl mx-auto mb-20">
        <span class="font-mono font-bold text-xs tracking-widest text-blue-600 uppercase">{content.subtitle}</span>
        <h1 class="font-display font-black text-4xl sm:text-5xl text-slate-900 uppercase tracking-tight mt-3 leading-tight">
          {content.mainTitle}
        </h1>
        <div class="h-1 w-20 bg-blue-600 mx-auto mt-6"></div>
      </div>

      <!-- Section: Starter -->
      <section id="starter" class="mb-20 scroll-mt-24">
        <div class="border-b border-slate-100 pb-4 mb-8">
          <h2 class="font-display font-black text-xl md:text-2xl text-slate-900 uppercase">{content.starterTitle}</h2>
          <p class="text-xs text-slate-500 font-semibold mt-1">{content.starterDesc}</p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6">
          {templatesData.starter.map((item) => (
            <div class="p-6 border-2 border-slate-900 rounded-2xl shadow-[4px_4px_0px_#0f172a] bg-white flex flex-col justify-between h-48">
              <div>
                <span class="text-[9px] font-mono font-black text-slate-400 bg-slate-50 border border-slate-200 px-2 py-0.5 rounded-md uppercase tracking-wider">{item.tag}</span>
                <h3 class="font-display font-black text-base text-slate-900 mt-4 leading-tight">{item.name}</h3>
              </div>
              <a href={item.url} target="_blank" rel="noopener noreferrer" class="text-xs font-black uppercase tracking-wider text-blue-600 hover:text-blue-700 hover:underline inline-flex items-center gap-1 mt-4">
                Lihat Demo Undangan ➔
              </a>
            </div>
          ))}
        </div>
      </section>

      <!-- Section: Premium -->
      <section id="premium" class="mb-20 scroll-mt-24">
        <div class="border-b border-slate-100 pb-4 mb-8">
          <h2 class="font-display font-black text-xl md:text-2xl text-slate-900 uppercase">{content.premiumTitle}</h2>
          <p class="text-xs text-slate-500 font-semibold mt-1">{content.premiumDesc}</p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6">
          {templatesData.premium.map((item) => (
            <div class="p-6 border-2 border-slate-900 rounded-2xl shadow-[4px_4px_0px_#2563eb] bg-white flex flex-col justify-between h-48">
              <div>
                <span class="text-[9px] font-mono font-black text-blue-600 bg-blue-50 border border-blue-150 px-2 py-0.5 rounded-md uppercase tracking-wider">{item.tag}</span>
                <h3 class="font-display font-black text-base text-slate-900 mt-4 leading-tight">{item.name}</h3>
              </div>
              <a href={item.url} target="_blank" rel="noopener noreferrer" class="text-xs font-black uppercase tracking-wider text-blue-600 hover:text-blue-700 hover:underline inline-flex items-center gap-1 mt-4">
                Lihat Demo Undangan ➔
              </a>
            </div>
          ))}
        </div>
      </section>

      <!-- Section: Custom -->
      <section id="custom" class="scroll-mt-24">
        <div class="border-b border-slate-100 pb-4 mb-8">
          <h2 class="font-display font-black text-xl md:text-2xl text-slate-900 uppercase">{content.customTitle}</h2>
          <p class="text-xs text-slate-500 font-semibold mt-1">{content.customDesc}</p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6">
          {templatesData.custom.map((item) => (
            <div class="p-6 border-2 border-slate-900 rounded-2xl shadow-[4px_4px_0px_#0f172a] bg-white flex flex-col justify-between h-48">
              <div>
                <span class="text-[9px] font-mono font-black text-slate-400 bg-slate-50 border border-slate-200 px-2 py-0.5 rounded-md uppercase tracking-wider">{item.tag}</span>
                <h3 class="font-display font-black text-base text-slate-900 mt-4 leading-tight">{item.name}</h3>
              </div>
              <a href={item.url} target="_blank" rel="noopener noreferrer" class="text-xs font-black uppercase tracking-wider text-blue-600 hover:text-blue-700 hover:underline inline-flex items-center gap-1 mt-4">
                Lihat Demo Undangan ➔
              </a>
            </div>
          ))}
        </div>
      </section>

    </div>
  </main>
  
  <Footer />
</Layout>
