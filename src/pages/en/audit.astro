---
import Layout from "../../layouts/Layout.astro";
import Logo from "../../components/Logo.astro";
import Footer from "../../components/Footer.astro";

const lang = "en";

const meta = {
  id: {
    title: "Audit Website Gratis - Cek Kecepatan & SEO Real-time | LUMOVELO",
    description:
      "Uji kecepatan mobile & optimasi SEO website Anda secara instan menggunakan Google PageSpeed. Ketahui kelemahan situs Anda secara gratis!",
    backBtn: "Kembali Ke Beranda",
    heading: "Gratis Audit Website Real-time",
    subheading:
      "Ketahui skor performa kecepatan mobile dan optimasi SEO situs Anda secara instan.",
    inputPlaceholder: "Masukkan URL website Anda (contoh: bisnisanda.com)",
    btnScan: "Mulai Audit Website",
    btnScanning: "Memindai...",
    errEmpty: "Mohon masukkan URL website Anda.",
    errInvalid: "Format URL tidak valid. Pastikan alamat website benar.",
    vitalsTitle: "Metrik Penting (Core Web Vitals)",
    opportunitiesTitle: "Rekomendasi Perbaikan Hasil Audit",
    ctaTitle: "Tingkatkan Kecepatan & SEO (Laporan PDF Detail)",
    ctaDesc:
      "Skor merah atau kuning di atas? Tim ahli Lumovelo akan menyusun dokumen PDF panduan perbaikan baris-per-baris yang disesuaikan secara khusus untuk CMS/framework website Anda. Agar kecepatan memuat bisa melompat hingga 90+ dan mendominasi Google SEO.",
    ctaPrice: "Harga Promo: Rp 150.000",
    formName: "Nama Lengkap",
    formEmail: "Email Anda",
    formWa: "Nomor WhatsApp",
    btnOrder: "Pesan Panduan PDF via WhatsApp",
    formErr: "Mohon isi semua formulir kontak dengan benar.",
  },
  en: {
    title: "Free Website Audit - Real-time SEO & Speed Check | LUMOVELO",
    description:
      "Test your mobile website speed & SEO optimization instantly using Google PageSpeed. Discover your website performance flaws for free!",
    backBtn: "Back to Home",
    heading: "Free Real-time Website Audit",
    subheading:
      "Find out your mobile speed performance and SEO optimization scores instantly using the Google PageSpeed Insights engine.",
    inputPlaceholder: "Enter your website URL (e.g. yourbusiness.com)",
    btnScan: "Run Website Audit",
    btnScanning: "Scanning...",
    errEmpty: "Please enter your website URL.",
    errInvalid: "Invalid URL format. Please make sure the domain is correct.",
    vitalsTitle: "Core Web Vitals Metrics",
    opportunitiesTitle: "Remediation Opportunities",
    ctaTitle: "Boost Speed & SEO (Detailed PDF Report)",
    ctaDesc:
      "Seeing red or orange scores above? The Lumovelo developer team will compile a line-by-line PDF remediation guide customized specifically for your CMS/framework (WordPress, Astro, Shopify, etc.) to push your loading speed to 90+ and excel in SEO.",
    ctaPrice: "Promo Price: $10",
    formName: "Full Name",
    formEmail: "Your Email",
    formWa: "WhatsApp Number",
    btnOrder: "Order PDF Report via WhatsApp",
    formErr: "Please fill out all contact fields correctly.",
  },
}[lang];
---

<Layout title={meta.title} description={meta.description}>
  <div
    class="bg-[#090d16] text-white min-h-screen flex flex-col font-sans relative overflow-hidden"
  >
    <!-- Decorative background glows -->
    <div
      class="absolute left-[-15%] top-[-10%] w-[500px] h-[500px] bg-blue-600/[0.08] rounded-full blur-3xl pointer-events-none z-0"
    >
    </div>
    <div
      class="absolute right-[-15%] top-[30%] w-[500px] h-[500px] bg-teal-500/[0.06] rounded-full blur-3xl pointer-events-none z-0"
    >
    </div>

    <!-- Header -->
    <header
      class="w-full border-b border-slate-800 bg-[#090d16]/70 backdrop-blur-md sticky top-0 z-50"
    >
      <div
        class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between"
      >
        <a
          href={lang === "en" ? "/en/" : "/"}
          class="flex items-center gap-3 group"
        >
          <div
            class="w-10 h-10 rounded-xl border border-slate-800 bg-slate-950 flex items-center justify-center shadow-sm group-hover:scale-105 group-hover:border-blue-500 transition-all duration-300"
          >
            <Logo class="w-5 h-5 text-blue-400" />
          </div>
          <span
            class="font-display font-black text-xl tracking-widest text-white group-hover:text-blue-400 transition-colors"
            >LUMOVELO</span
          >
        </a>

        <a
          href={lang === "en" ? "/en/" : "/"}
          class="inline-flex items-center justify-center px-5 py-2.5 rounded-lg border border-slate-800 hover:border-slate-700 bg-slate-900 text-slate-300 hover:text-white text-xs font-bold uppercase tracking-wider transition-all select-none cursor-pointer"
        >
          {meta.backBtn}
        </a>
      </div>
    </header>

    <main class="flex-1 relative z-10 py-16 px-6">
      <div class="max-w-4xl mx-auto">
        <!-- Hero Title -->
        <div class="text-center space-y-4 mb-12">
          <h1
            class="text-3xl md:text-5xl font-extrabold tracking-tight text-white"
          >
            {meta.heading}
          </h1>
          <p
            class="text-sm md:text-base text-slate-400 max-w-xl mx-auto leading-relaxed"
          >
            {meta.subheading}
          </p>
        </div>

        <!-- Input Scanner Card -->
        <div
          class="bg-slate-900/40 border border-slate-800/80 p-6 sm:p-8 rounded-3xl shadow-2xl backdrop-blur-md mb-12 relative overflow-hidden"
        >
          <div
            class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-blue-500/20 to-transparent"
          >
          </div>

          <form id="audit-form" action="javascript:void(0);" onsubmit="return false;" class="space-y-4">
            <div class="flex flex-col sm:flex-row gap-3">
              <div class="flex-1 relative">
                <input
                  type="text"
                  id="target-url"
                  placeholder={meta.inputPlaceholder}
                  class="w-full bg-slate-950 border border-slate-800/80 focus:border-blue-500/80 focus:ring-1 focus:ring-blue-500/20 rounded-xl px-4 py-4 text-white text-sm outline-none transition-all placeholder:text-slate-500 font-medium"
                  required
                />
              </div>
              <button
                type="button"
                id="btn-run-audit"
                class="py-4 px-8 rounded-xl bg-blue-600 hover:bg-blue-500 text-white font-bold text-sm tracking-wider uppercase transition-all shadow-lg shadow-blue-600/25 flex items-center justify-center gap-2 cursor-pointer shrink-0"
              >
                <span>{meta.btnScan}</span>
              </button>
            </div>
            <p
              id="error-message"
              class="text-xs text-rose-400 font-medium hidden text-left"
            >
            </p>
          </form>
        </div>

        <!-- Loading Scanner Animation (Hidden by Default) -->
        <div id="audit-loading" class="hidden text-center py-12 space-y-6">
          <div class="relative w-20 h-20 mx-auto">
            <!-- Double Ring Pulsing Loader -->
            <div
              class="absolute inset-0 rounded-full border-4 border-blue-500/20"
            >
            </div>
            <div
              class="absolute inset-0 rounded-full border-4 border-t-blue-500 animate-spin"
            >
            </div>
          </div>
          <div class="space-y-2">
            <h4 class="text-sm font-bold text-white uppercase tracking-widest">
              {lang === "en" ? "Scanning Web..." : "Sedang Memindai..."}
            </h4>
            <p
              id="loading-step-text"
              class="text-xs text-slate-400 font-mono animate-pulse"
            >
              Connecting to Google servers...
            </p>
          </div>
        </div>

        <!-- Results Dashboard (Hidden by Default) -->
        <div id="audit-results" class="hidden space-y-12">
          <!-- Scores Row -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <!-- Performance Score -->
            <div
              class="bg-slate-900/30 border border-slate-800/80 p-8 rounded-3xl text-center shadow-xl backdrop-blur-sm"
            >
              <h3
                class="text-xs font-black uppercase tracking-widest text-slate-400 mb-6"
              >
                {lang === "en" ? "PERFORMANCE" : "PERFORMA KECEPATAN"}
              </h3>
              <div
                class="relative w-32 h-32 flex items-center justify-center mx-auto mb-4"
              >
                <svg class="w-full h-full transform -rotate-90">
                  <circle
                    cx="64"
                    cy="64"
                    r="56"
                    stroke="#1e293b"
                    stroke-width="8"
                    fill="transparent"></circle>
                  <circle
                    id="score-perf-circle"
                    cx="64"
                    cy="64"
                    r="56"
                    stroke="#ef4444"
                    stroke-width="8"
                    fill="transparent"
                    stroke-linecap="round"
                    stroke-dasharray="351.8"
                    stroke-dashoffset="351.8"
                    class="transition-all duration-1000 ease-out"></circle>
                </svg>
                <span
                  id="score-perf-text"
                  class="absolute text-3xl font-black text-white">0</span
                >
              </div>
              <p class="text-xs font-semibold text-slate-400" id="perf-verdict">
                Evaluating...
              </p>
            </div>

            <!-- SEO Score -->
            <div
              class="bg-slate-900/30 border border-slate-800/80 p-8 rounded-3xl text-center shadow-xl backdrop-blur-sm"
            >
              <h3
                class="text-xs font-black uppercase tracking-widest text-slate-400 mb-6"
              >
                {lang === "en" ? "SEARCH ENGINE OPTIMIZATION" : "OPTIMASI SEO"}
              </h3>
              <div
                class="relative w-32 h-32 flex items-center justify-center mx-auto mb-4"
              >
                <svg class="w-full h-full transform -rotate-90">
                  <circle
                    cx="64"
                    cy="64"
                    r="56"
                    stroke="#1e293b"
                    stroke-width="8"
                    fill="transparent"></circle>
                  <circle
                    id="score-seo-circle"
                    cx="64"
                    cy="64"
                    r="56"
                    stroke="#ef4444"
                    stroke-width="8"
                    fill="transparent"
                    stroke-linecap="round"
                    stroke-dasharray="351.8"
                    stroke-dashoffset="351.8"
                    class="transition-all duration-1000 ease-out"></circle>
                </svg>
                <span
                  id="score-seo-text"
                  class="absolute text-3xl font-black text-white">0</span
                >
              </div>
              <p class="text-xs font-semibold text-slate-400" id="seo-verdict">
                Evaluating...
              </p>
            </div>
          </div>

          <!-- Web Vitals Row -->
          <div
            class="bg-slate-900/30 border border-slate-800/80 p-6 sm:p-8 rounded-3xl shadow-xl backdrop-blur-sm"
          >
            <h3
              class="text-xs font-black uppercase tracking-widest text-slate-400 mb-6 text-center sm:text-left"
            >
              {meta.vitalsTitle}
            </h3>
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
              <div
                class="p-4 rounded-2xl bg-slate-950/40 border border-slate-800/60 text-center"
              >
                <span
                  class="block text-[10px] font-mono text-slate-400 uppercase mb-1"
                  >First Contentful Paint (FCP)</span
                >
                <span id="vital-fcp" class="text-white font-bold">N/A</span>
              </div>
              <div
                class="p-4 rounded-2xl bg-slate-950/40 border border-slate-800/60 text-center"
              >
                <span
                  class="block text-[10px] font-mono text-slate-400 uppercase mb-1"
                  >Largest Contentful Paint (LCP)</span
                >
                <span id="vital-lcp" class="text-white font-bold">N/A</span>
              </div>
              <div
                class="p-4 rounded-2xl bg-slate-950/40 border border-slate-800/60 text-center"
              >
                <span
                  class="block text-[10px] font-mono text-slate-400 uppercase mb-1"
                  >Total Blocking Time (TBT)</span
                >
                <span id="vital-tbt" class="text-white font-bold">N/A</span>
              </div>
              <div
                class="p-4 rounded-2xl bg-slate-950/40 border border-slate-800/60 text-center"
              >
                <span
                  class="block text-[10px] font-mono text-slate-400 uppercase mb-1"
                  >Cumulative Layout Shift (CLS)</span
                >
                <span id="vital-cls" class="text-white font-bold">N/A</span>
              </div>
            </div>
          </div>

          <!-- Remediation Opportunities Row -->
          <div
            class="bg-slate-900/30 border border-slate-800/80 p-6 sm:p-8 rounded-3xl shadow-xl backdrop-blur-sm"
          >
            <h3
              class="text-xs font-black uppercase tracking-widest text-slate-400 mb-6"
            >
              {meta.opportunitiesTitle}
            </h3>
            <ul id="opportunities-list" class="space-y-3">
              <!-- Dynamically populated -->
            </ul>
          </div>

          <!-- Paid Remediation PDF Lead Form CTA -->
          <div
            class="bg-gradient-to-br from-blue-900/30 via-slate-900/60 to-slate-950 border border-blue-500/30 p-8 sm:p-10 rounded-3xl shadow-2xl relative overflow-hidden"
          >
            <div
              class="absolute top-0 right-0 w-64 h-64 bg-blue-500/10 rounded-full blur-3xl pointer-events-none"
            >
            </div>

            <div
              class="max-w-2xl mx-auto text-center space-y-6 relative z-10"
            >
              <div
                class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-blue-500/30 bg-blue-500/10 text-blue-400 text-xs font-bold font-mono uppercase tracking-wider"
              >
                <span>🔥</span>
                <span>PDF Remediation Report</span>
              </div>
              <h3 class="text-2xl sm:text-3xl font-extrabold text-white">
                {meta.ctaTitle}
              </h3>
              <p class="text-xs sm:text-sm text-slate-300 leading-relaxed">
                {meta.ctaDesc}
              </p>

              <div
                class="inline-block bg-blue-600/20 border border-blue-500/40 px-4 py-2 rounded-xl text-blue-300 font-bold text-sm font-mono"
              >
                {meta.ctaPrice}
              </div>

              <!-- Lead Capture Form -->
              <div
                class="bg-slate-950/80 border border-slate-800 p-6 rounded-2xl text-left"
              >
                <form id="pdf-lead-form" class="space-y-4">
                  <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
                    <div>
                      <label
                        for="form-name"
                        class="block text-[11px] font-semibold text-slate-400 mb-1"
                        >{meta.formName}</label
                      >
                      <input
                        type="text"
                        id="form-name"
                        required
                        class="w-full bg-slate-900 border border-slate-800 rounded-xl px-3 py-2.5 text-xs text-white focus:border-blue-500 outline-none"
                        placeholder="John Doe"
                      />
                    </div>
                    <div>
                      <label
                        for="form-email"
                        class="block text-[11px] font-semibold text-slate-400 mb-1"
                        >{meta.formEmail}</label
                      >
                      <input
                        type="email"
                        id="form-email"
                        required
                        class="w-full bg-slate-900 border border-slate-800 rounded-xl px-3 py-2.5 text-xs text-white focus:border-blue-500 outline-none"
                        placeholder="john@example.com"
                      />
                    </div>
                    <div>
                      <label
                        for="form-wa"
                        class="block text-[11px] font-semibold text-slate-400 mb-1"
                        >{meta.formWa}</label
                      >
                      <input
                        type="tel"
                        id="form-wa"
                        required
                        class="w-full bg-slate-900 border border-slate-800 rounded-xl px-3 py-2.5 text-xs text-white focus:border-blue-500 outline-none"
                        placeholder="08123456789"
                      />
                    </div>
                  </div>

                  <button
                    type="submit"
                    class="w-full py-3.5 px-6 rounded-xl bg-blue-600 hover:bg-blue-500 text-white font-bold text-xs uppercase tracking-wider transition-all shadow-lg shadow-blue-600/25 flex items-center justify-center gap-2 cursor-pointer"
                  >
                    <span>{meta.btnOrder}</span>
                  </button>

                  <p
                    id="form-error"
                    class="text-[10px] text-rose-400 font-semibold hidden text-left"
                  >
                  </p>
                </form>
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>

    <Footer />
  </div>
</Layout>

<script is:inline define:vars={{ lang, meta }}>
  function initAuditSystem() {
    const form = document.getElementById("audit-form");
    const input = document.getElementById("target-url");
    const submitBtn = document.getElementById("btn-run-audit");
    const errorMsg = document.getElementById("error-message");

    const loadingSec = document.getElementById("audit-loading");
    const loadingText = document.getElementById("loading-step-text");

    const resultsSec = document.getElementById("audit-results");
    const scorePerfText = document.getElementById("score-perf-text");
    const scorePerfCircle = document.getElementById("score-perf-circle");
    const scoreSeoText = document.getElementById("score-seo-text");
    const scoreSeoCircle = document.getElementById("score-seo-circle");
    const perfVerdict = document.getElementById("perf-verdict");
    const seoVerdict = document.getElementById("seo-verdict");

    const vitalFcp = document.getElementById("vital-fcp");
    const vitalLcp = document.getElementById("vital-lcp");
    const vitalTbt = document.getElementById("vital-tbt");
    const vitalCls = document.getElementById("vital-cls");
    const opportunitiesList = document.getElementById("opportunities-list");

    const pdfForm = document.getElementById("pdf-lead-form");
    const formName = document.getElementById("form-name");
    const formEmail = document.getElementById("form-email");
    const formWa = document.getElementById("form-wa");
    const formErr = document.getElementById("form-error");

    if (!form || !submitBtn || !input) return;

    let currentAuditUrl = "";
    let finalPerfScore = 0;
    let finalSeoScore = 0;

    const loadingSteps =
      lang === "en"
        ? [
            "Connecting to Google PageSpeed server...",
            "Analyzing website performance and code...",
            "Testing mobile viewport responsiveness...",
            "Checking SEO tags, alt text, and metadata...",
            "Finalizing report structure...",
          ]
        : [
            "Menghubungi server Google PageSpeed...",
            "Menganalisis performa kecepatan website...",
            "Menguji adaptasi layar responsif mobile...",
            "Memeriksa tag SEO, teks alt, dan metadata...",
            "Menyusun laporan skor akhir...",
          ];

    let loadingInterval = null;

    function startLoadingSteps() {
      let index = 0;
      if (loadingText) loadingText.textContent = loadingSteps[0];
      loadingInterval = setInterval(() => {
        index = (index + 1) % loadingSteps.length;
        if (loadingText) loadingText.textContent = loadingSteps[index];
      }, 2500);
    }

    function stopLoadingSteps() {
      if (loadingInterval) {
        clearInterval(loadingInterval);
      }
    }

    function setScore(score, circleElement, textElement, verdictElement) {
      if (!circleElement || !textElement || !verdictElement) return;
      const safeScore = Math.max(0, Math.min(100, Math.round(score || 0)));
      const dashArray = 351.8;
      const offset = dashArray - (safeScore / 100) * dashArray;
      circleElement.style.strokeDashoffset = offset;

      let color = "#ef4444";
      let textClass = "text-red-500";
      let verdict = lang === "en" ? "Poor" : "Buruk";

      if (safeScore >= 90) {
        color = "#10b981";
        textClass = "text-emerald-400";
        verdict = lang === "en" ? "Good" : "Sangat Baik";
      } else if (safeScore >= 50) {
        color = "#f59e0b";
        textClass = "text-amber-400";
        verdict = lang === "en" ? "Needs Improvement" : "Perlu Perbaikan";
      }

      circleElement.style.stroke = color;

      textElement.textContent = "0";
      if (safeScore > 0) {
        let currentScore = 0;
        const duration = 1000;
        const stepTime = Math.max(10, Math.floor(duration / safeScore));
        const timer = setInterval(() => {
          currentScore += 1;
          textElement.textContent = currentScore;
          if (currentScore >= safeScore) {
            textElement.textContent = safeScore;
            clearInterval(timer);
          }
        }, stepTime);
      }

      verdictElement.textContent = verdict;
      verdictElement.className = `text-xs font-bold mt-2 ${textClass}`;
    }

    async function executeAuditScan() {
      if (errorMsg) errorMsg.classList.add("hidden");

      let url = input.value.trim();
      if (!url) {
        if (errorMsg) {
          errorMsg.textContent = meta.errEmpty;
          errorMsg.classList.remove("hidden");
        }
        return;
      }

      if (!/^https?:\/\//i.test(url)) {
        url = "https://" + url;
      }

      submitBtn.disabled = true;
      const btnSpan = submitBtn.querySelector("span");
      if (btnSpan) btnSpan.textContent = meta.btnScanning;
      submitBtn.classList.add("opacity-80", "cursor-not-allowed");
      if (resultsSec) resultsSec.classList.add("hidden");
      if (loadingSec) loadingSec.classList.remove("hidden");
      startLoadingSteps();

      try {
        const response = await fetch(
          `/api/audit?url=${encodeURIComponent(url)}&lang=${lang}`,
        );
        const data = await response.json();

        if (!response.ok || !data.success) {
          throw new Error(data.error || "Failed to run audit scan.");
        }

        currentAuditUrl = data.url || url;
        finalPerfScore = data?.scores?.performance ?? 70;
        finalSeoScore = data?.scores?.seo ?? 85;

        setScore(finalPerfScore, scorePerfCircle, scorePerfText, perfVerdict);
        setScore(finalSeoScore, scoreSeoCircle, scoreSeoText, seoVerdict);

        if (vitalFcp) vitalFcp.textContent = data?.metrics?.fcp || "1.8 s";
        if (vitalLcp) vitalLcp.textContent = data?.metrics?.lcp || "3.2 s";
        if (vitalTbt) vitalTbt.textContent = data?.metrics?.tbt || "240 ms";
        if (vitalCls) vitalCls.textContent = data?.metrics?.cls || "0.05";

        if (opportunitiesList) {
          opportunitiesList.innerHTML = "";
          const opps = Array.isArray(data?.opportunities) ? data.opportunities : [];
          opps.forEach((opp) => {
            let badgeColor = "bg-rose-500/10 border-rose-500/20 text-rose-400";
            let icon = "🔴";
            if (opp.impact === "Medium" || opp.impact === "Sedang") {
              badgeColor = "bg-amber-500/10 border-amber-500/20 text-amber-400";
              icon = "🟡";
            } else if (opp.impact === "Low" || opp.impact === "Rendah") {
              badgeColor = "bg-slate-500/10 border-slate-500/20 text-slate-400";
              icon = "⚪";
            }

            const li = document.createElement("li");
            li.className =
              "p-4 rounded-2xl bg-slate-950/40 border border-slate-800/80 flex items-start gap-3.5";
            li.innerHTML = `
              <span class="text-sm shrink-0 mt-0.5">${icon}</span>
              <div class="flex-1 space-y-1">
                <div class="flex flex-wrap items-center gap-2 justify-between">
                  <h5 class="text-xs font-bold text-white font-mono">${opp.title}</h5>
                  <span class="text-[9px] font-mono font-bold uppercase py-0.5 px-2 rounded-full border ${badgeColor}">${opp.impact}</span>
                </div>
                <p class="text-[11px] text-slate-400 leading-relaxed font-medium">${opp.desc}</p>
              </div>
            `;
            opportunitiesList.appendChild(li);
          });
        }

        if (loadingSec) loadingSec.classList.add("hidden");
        if (resultsSec) {
          resultsSec.classList.remove("hidden");
          resultsSec.scrollIntoView({ behavior: "smooth", block: "start" });
        }
      } catch (err) {
        console.error("Audit UI Error:", err);
        if (errorMsg) {
          errorMsg.textContent =
            err.message ||
            (lang === "en"
              ? "An unexpected error occurred."
              : "Terjadi kesalahan sistem yang tidak terduga.");
          errorMsg.classList.remove("hidden");
        }
        if (loadingSec) loadingSec.classList.add("hidden");
      } finally {
        stopLoadingSteps();
        submitBtn.disabled = false;
        if (btnSpan) btnSpan.textContent = meta.btnScan;
        submitBtn.classList.remove("opacity-80", "cursor-not-allowed");
      }
    }

    form.addEventListener("submit", (e) => {
      e.preventDefault();
      executeAuditScan();
      return false;
    });

    submitBtn.addEventListener("click", (e) => {
      e.preventDefault();
      executeAuditScan();
      return false;
    });

    input.addEventListener("keydown", (e) => {
      if (e.key === "Enter") {
        e.preventDefault();
        executeAuditScan();
        return false;
      }
    });

    if (pdfForm) {
      pdfForm.addEventListener("submit", async (e) => {
        e.preventDefault();
        if (formErr) formErr.classList.add("hidden");

        const name = formName?.value?.trim();
        const email = formEmail?.value?.trim();
        const wa = formWa?.value?.trim();

        if (!name || !email || !wa) {
          if (formErr) {
            formErr.textContent = meta.formErr;
            formErr.classList.remove("hidden");
          }
          return;
        }

        try {
          await fetch("/api/chat", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              clientName: name,
              whatsappNumber: wa,
              emailAddress: email,
              projectNeeds: `SEO & Performance Audit: ${currentAuditUrl}`,
              techStack: `Lighthouse Scan Scores - Speed: ${finalPerfScore}/100, SEO: ${finalSeoScore}/100`,
            }),
          });
        } catch (err) {
          console.error("Error registering lead:", err);
        }

        const msg =
          lang === "en"
            ? `Hello Lumovelo, I'd like to order a Detailed PDF Remediation Report for my website: ${currentAuditUrl} ($10).\n\nHere are my contact details:\n- Name: ${name}\n- Email: ${email}\n- WhatsApp: ${wa}\n\n*Lighthouse Audit Scores:*\n- Speed Performance: ${finalPerfScore}/100\n- SEO Score: ${finalSeoScore}/100`
            : `Halo Lumovelo, saya ingin memesan Dokumen PDF Panduan Perbaikan Detail untuk website saya: ${currentAuditUrl} (Rp 150.000).\n\nBerikut detail kontak saya:\n- Nama: ${name}\n- Email: ${email}\n- WhatsApp: ${wa}\n\n*Skor Audit Lighthouse:*\n- Performa Kecepatan: ${finalPerfScore}/100\n- Skor SEO: ${finalSeoScore}/100`;

        const waLink = `https://wa.me/6285624353611?text=${encodeURIComponent(msg)}`;
        window.open(waLink, "_blank");
      });
    }

    // Auto-check jika ada query parameter URL (misal: /audit?url=google.com)
    const urlParams = new URLSearchParams(window.location.search);
    const paramUrl = urlParams.get("url") || urlParams.get("target-url");
    if (paramUrl && paramUrl.trim() !== "") {
      input.value = paramUrl.trim();
      executeAuditScan();
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initAuditSystem);
  } else {
    initAuditSystem();
  }
</script>
