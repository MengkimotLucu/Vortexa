---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import Logo from '../../components/Logo.astro';

const lang = Astro.currentLocale === 'en' ? 'en' : 'id';
const waNumber = import.meta.env.PUBLIC_WHATSAPP_NUMBER || '6285624353611';


const content = {
  id: {
    title: "Jasa SEO Bulanan & Optimasi SEO Google | LUMOVELO",
    header: "ADVANCED SEO & MARKETING FUNNEL",
    headline: "Jasa SEO Bulanan & Optimasi SEO Google",
    desc: "Kami menawarkan jasa seo bulanan & optimasi seo google untuk menaikkan peringkat website Anda ke halaman 1 google. Dengan menerapkan strategi optimasi yang tepat dan membuat konten berkualitas secara konsisten, kami membantu Anda menjangkau calon pelanggan potensial dalam jangka panjang.",
    cta: "Konsultasikan Strategi SEO Anda",
    back: "Kembali ke Beranda",
    pricingHeader: "/ PAKET INVESTASI SEO",
    pricingTitle: "Pilih Paket Optimasi SEO Sesuai Target Bisnis Anda",
    workflowHeader: "/ ALUR KERJA OPTIMASI",
    workflowTitle: "Proses Transparan Meningkatkan Peringkat Google",
    whyUsHeader: "/ KEUNGGULAN KAMI",
    whyUsTitle: "Mengapa Memilih Jasa SEO Lumovelo?",
    periodOnce: "Proyek Sekali Jalan",
    periodMonthly: "Investasi Bulanan"
  },
  en: {
    title: "Advanced SEO & Digital Marketing Funnel Agency | LUMOVELO",
    header: "ADVANCED SEO & DIGITAL FUNNEL",
    headline: "Dominate Google Search Results & Drive High-Intent Buyers Organically",
    desc: "Drive targeted organic traffic every day. We optimize your website search rankings to reach ready-to-buy customers.",
    cta: "Consult Your SEO Strategy",
    back: "Back to Home",
    pricingHeader: "/ SEO INVESTMENT PACKAGES",
    pricingTitle: "Choose the Perfect SEO Package for Your Business Goals",
    workflowHeader: "/ OUR OPTIMIZATION WORKFLOW",
    workflowTitle: "Transparent Process to Boost Google Rankings",
    whyUsHeader: "/ WHY CHOOSE US",
    whyUsTitle: "Why Scale Organic Traffic With Lumovelo?",
    periodOnce: "One-time Project",
    periodMonthly: "Monthly Investment"
  }
}[lang];

const packages = [
  {
    name: lang === 'en' ? "Basic (Technical SEO Audit)" : "Basic (Technical SEO Audit)",
    price: "Rp750.000",
    period: content.periodOnce,
    features: lang === 'en' ? [
      "Comprehensive semantic HTML structure audit",
      "Core Web Vitals tuning (loading speed optimization)",
      "Sitemap XML creation & Google Search Console indexing setup",
      "Broken link fixes (404) & mobile friendliness optimization"
    ] : [
      "Audit menyeluruh struktur HTML semantik website",
      "Optimasi kecepatan muat halaman (Core Web Vitals tuning)",
      "Pembuatan dan pendaftaran peta situs (Sitemap XML) ke Google Search Console",
      "Perbaikan error link rusak (404) & optimasi keramahan perangkat mobile"
    ]
  },
  {
    name: lang === 'en' ? "Pro (Local SEO Optimization)" : "Pro (Local SEO Optimization)",
    price: "Rp1.450.000",
    period: content.periodOnce,
    popular: true,
    features: lang === 'en' ? [
      "Google Business Profile (Maps) setup, verification, & optimization",
      "High-intent local buyer keyword research",
      "Product review management framework setup",
      "On-page content optimization targeting local geographical area"
    ] : [
      "Setup, verifikasi, dan optimasi profil Google Bisnisku (Google Maps)",
      "Riset kata kunci lokal potensial dengan intensitas beli tinggi",
      "Strategi penataan ulasan (review management framework) produk",
      "Optimasi konten halaman utama untuk penargetan wilayah geografis lokal"
    ]
  },
  {
    name: lang === 'en' ? "Elite (Retainer Content & Keyword)" : "Elite (Retainer Content & Keyword)",
    price: "Rp2.450.000 / bln",
    period: content.periodMonthly,
    features: lang === 'en' ? [
      "Monthly competitor keyword research & analysis",
      "4 SEO-optimized blog articles creation (On-page optimization)",
      "Keyword rank monitoring & weekly traffic performance evaluation",
      "Continuous technical SEO fixes matching Google algorithm updates",
      "Benefit: Drives stable daily organic buyer traffic from Google without ad spend dependencies."
    ] : [
      "Riset berkala kata kunci kompetitor bulanan",
      "Pembuatan 4 artikel blog teroptimasi SEO (On-page optimization)",
      "Monitoring peringkat kata kunci & evaluasi performa trafik mingguan",
      "Perbaikan teknis SEO web berkelanjutan mengikuti update algoritma Google",
      "Benefit: Mendatangkan traffic pembeli organik yang stabil setiap hari dari Google tanpa ketergantungan pada iklan berbayar."
    ]
  },
  {
    name: lang === 'en' ? "Custom SEO Campaign" : "Custom SEO Campaign",
    price: "Mulai Rp4.500.000 / bln",
    period: content.periodMonthly,
    features: lang === 'en' ? [
      "E-commerce / multi-category content portal architectural optimization",
      "Safe and premium external Link Building acquisition strategies",
      "Massive content production with the latest industry trend research",
      "In-depth business ROI performance tracking reports from search channel"
    ] : [
      "Optimasi arsitektur website e-commerce skala besar / portal konten multi-kategori",
      "Strategi akuisisi tautan premium luar secara aman (Off-page Link Building)",
      "Produksi konten berskala masif dengan riset tren industri terkini",
      "Laporan analitik mendalam performa bisnis (ROI tracking dari kanal pencarian)"
    ]
  }
];

const homeLink = lang === 'en' ? '/en/' : '/';
const contactLink = lang === 'en' ? '/en/kontak/' : '/kontak/';

const faqs = {
  id: [
    {
      q: "Mengapa bisnis saya membutuhkan jasa SEO bulanan?",
      a: "Jasa SEO bulanan membantu website Anda berada di halaman 1 Google secara organik tanpa harus terus-menerus membayar iklan berbayar (seperti Google Ads). Ini mendatangkan calon pelanggan potensial yang memang sedang mencari kata kunci terkait layanan Anda secara aktif dan berkelanjutan."
    },
    {
      q: "Berapa lama waktu yang dibutuhkan untuk melihat hasil optimasi SEO?",
      a: "SEO adalah strategi jangka panjang. Biasanya, perbaikan performa teknis kecepatan website dan indeksasi Google dapat terlihat dalam 2–4 minggu. Namun, peningkatan peringkat kata kunci kompetitif dan kenaikan trafik organik secara signifikan umumnya membutuhkan waktu antara 3 hingga 6 bulan."
    },
    {
      q: "Apakah Anda memberikan jaminan website saya pasti peringkat 1 di Google?",
      a: "Sesuai dengan pedoman resmi mesin pencari Google, tidak ada agensi yang bisa menjamin peringkat 1 mutlak secara instan karena algoritma Google selalu diperbarui secara dinamis. Namun, kami menerapkan strategi SEO putih (white-hat SEO) berbasis analisis data Semrush untuk menaikkan otoritas domain dan memenangkan kompetisi kata kunci di industri Anda."
    },
    {
      q: "Apa saja cakupan pekerjaan SEO bulanan di Lumovelo?",
      a: "Pekerjaan kami mencakup audit On-Page SEO (pembenahan meta tag, heading semantik, struktur link), audit Technical SEO (optimasi kecepatan load, sitemap, skema JSON-LD), riset kata kunci kompetitif bulanan, pembuatan konten berkualitas tinggi, serta pelaporan berkala performa kata kunci dan lalu lintas trafik Anda."
    },
    {
      q: "Bagaimana format laporan bulanan yang saya terima?",
      a: "Anda akan menerima laporan performa bulanan yang interaktif dan mudah dibaca, berisi peringkat kata kunci utama, perbandingan volume trafik organik dari bulan ke bulan, analisis audit kesalahan teknis situs, serta rencana tindakan (action plan) optimasi untuk bulan berikutnya."
    }
  ],
  en: [
    {
      q: "Why does my business need monthly SEO services?",
      a: "Monthly SEO services help position your website on page 1 of Google organically, saving you from continuously paying for advertisements (like Google Ads). It drives high-intent prospective customers who are actively searching for terms related to your offerings."
    },
    {
      q: "How long does it take to see results from SEO optimization?",
      a: "SEO is a long-term investment. Improvements in technical loading speed and indexing on Google can often be seen in 2 to 4 weeks. However, significant ranking growth for competitive keywords and steady organic traffic increase usually take 3 to 6 months."
    },
    {
      q: "Do you guarantee page 1 ranking on Google?",
      a: "In line with Google's official search engine guidelines, no agency can guarantee absolute first page rankings because Google's algorithm updates dynamically. However, we utilize white-hat SEO strategies powered by Semrush insights to increase domain authority and secure keyword wins."
    },
    {
      q: "What tasks are included in the monthly SEO service at Lumovelo?",
      a: "Our work covers On-Page SEO audits (improving meta tags, semantic headings, internal links), Technical SEO audits (page speed optimization, sitemaps, JSON-LD structured data), monthly keyword research, content drafting, and periodic organic traffic reports."
    },
    {
      q: "What format of monthly reports do I receive?",
      a: "You will receive a clear, interactive monthly report outlining your primary keyword rankings, organic traffic volume comparison, website technical health audits, and proposed optimization actions for the next cycle."
    }
  ]
}[lang];

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": content.title,
  "description": content.desc,
  "provider": {
    "@type": "Organization",
    "name": "LUMOVELO",
    "url": "https://www.lumovelo.com"
  },
  "serviceType": "Search Engine Optimization (SEO)",
  "areaServed": "Worldwide",
  "offers": {
    "@type": "AggregateOffer",
    "priceCurrency": "IDR",
    "lowPrice": "750000",
    "highPrice": "4500000",
    "offerCount": "4",
    "offers": packages.map((pkg, idx) => ({
      "@type": "Offer",
      "name": pkg.name,
      "price": pkg.price.replace(/[^0-9]/g, ""),
      "priceCurrency": "IDR",
      "url": lang === 'en' ? "https://www.lumovelo.com/en/layanan/seo/" : "https://www.lumovelo.com/layanan/seo/"
    }))
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a
    }
  }))
};
---

<Layout title={content.title} description={content.desc} schema={[serviceSchema, faqSchema]}>
  <!-- Simple Subpage Header -->
  <header class="py-6 border-b border-slate-100 bg-white/80 backdrop-blur sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-6 flex items-center justify-between">
      <a href={homeLink} class="flex items-center gap-3 group">
        <div class="w-9 h-9 rounded-xl border border-blue-100 bg-white flex items-center justify-center shadow-sm">
          <Logo class="w-4.5 h-4.5 text-blue-600" />
        </div>
        <span class="font-display font-black text-lg tracking-widest text-slate-900">LUMOVELO</span>
      </a>
      <a href={homeLink} class="text-xs font-bold uppercase tracking-wider text-slate-500 hover:text-blue-600 transition-colors">
        {content.back}
      </a>
    </div>
  </header>

  <main class="bg-white min-h-screen relative overflow-hidden font-sans">
    <!-- Background Glimmer -->
    <div class="absolute right-[-10%] top-[10%] w-[400px] h-[400px] bg-blue-500/[0.02] rounded-full blur-3xl pointer-events-none"></div>
    
    <div class="max-w-6xl mx-auto px-6 py-16 relative z-10">
      
      <!-- Headline Block -->
      <div class="max-w-3xl mx-auto mb-16 text-center">
        <span class="text-xs font-mono font-bold tracking-widest text-blue-600 uppercase mb-3 block">
          {content.header}
        </span>
        <h1 class="font-display font-black text-4xl sm:text-5xl text-slate-900 leading-[1.15] uppercase tracking-tight font-sans">
          {content.headline}
        </h1>
        <p class="text-slate-500 mt-6 text-base sm:text-lg leading-relaxed font-semibold">
          {content.desc}
        </p>
      </div>

      <!-- Key Solutions Bento Grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-20">
        
        <!-- Solution 1 -->
        <div class="premium-glass p-8 bg-white border border-slate-100 shadow-sm rounded-3xl flex flex-col justify-between">
          <div class="space-y-4">
            <div class="w-12 h-12 rounded-2xl bg-blue-50 flex items-center justify-center text-blue-600">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <h3 class="text-lg font-black text-slate-900 uppercase">Technical SEO Audit</h3>
            <p class="text-xs text-slate-500 leading-relaxed font-medium">
              Optimasi kecepatan loading website (Core Web Vitals), struktur HTML semantik, peta situs (sitemap), dan keramahan mobile agar Google menyukai struktur web Anda.
            </p>
          </div>
          <span class="text-[10px] font-mono font-bold text-blue-600 uppercase tracking-widest mt-6 block">Uptime & speed optimization →</span>
        </div>

        <!-- Solution 2 -->
        <div class="premium-glass p-8 bg-white border border-slate-100 shadow-sm rounded-3xl flex flex-col justify-between">
          <div class="space-y-4">
            <div class="w-12 h-12 rounded-2xl bg-blue-50 flex items-center justify-center text-blue-600">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
            </div>
            <h3 class="text-lg font-black text-slate-900 uppercase">Keyword Research</h3>
            <p class="text-xs text-slate-500 leading-relaxed font-medium">
              Riset kata kunci dengan niat beli tinggi (*high-intent keywords*) dan pemetaan kompetitor untuk memastikan halaman Anda bersaing di peringkat teratas pencarian Google.
            </p>
          </div>
          <span class="text-[10px] font-mono font-bold text-blue-600 uppercase tracking-widest mt-6 block">Targeted buyer traffic →</span>
        </div>

        <!-- Solution 3 -->
        <div class="premium-glass p-8 bg-white border border-slate-100 shadow-sm rounded-3xl flex flex-col justify-between">
          <div class="space-y-4">
            <div class="w-12 h-12 rounded-2xl bg-blue-50 flex items-center justify-center text-blue-600">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
              </svg>
            </div>
            <h3 class="text-lg font-black text-slate-900 uppercase">Funnel & Conversion</h3>
            <p class="text-xs text-slate-500 leading-relaxed font-medium">
              Merancang alur kunjungan (landing page copywriting) yang memandu pengunjung dari pencarian organik langsung mengklik tombol konsultasi WhatsApp Anda.
            </p>
          </div>
          <span class="text-[10px] font-mono font-bold text-blue-600 uppercase tracking-widest mt-6 block">High conversion funnel →</span>
        </div>

      </div>

      <!-- Workflow Process Section -->
      <div class="mb-20">
        <div class="text-center mb-12">
          <span class="text-xs font-mono font-bold tracking-widest text-blue-600 uppercase mb-2 block">
            {content.workflowHeader}
          </span>
          <h2 class="font-display font-black text-2xl sm:text-3xl text-slate-900 uppercase tracking-tight">
            {content.workflowTitle}
          </h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          <div class="p-6 bg-slate-50 border border-slate-200/80 rounded-2xl relative">
            <span class="text-3xl font-display font-black text-blue-600/20 absolute top-4 right-4">01</span>
            <div class="w-10 h-10 rounded-xl bg-blue-600 text-white font-bold flex items-center justify-center mb-4 text-sm">01</div>
            <h3 class="font-display font-black text-base text-slate-900 uppercase mb-2">Audit & Riset Kata Kunci</h3>
            <p class="text-xs text-slate-500 font-semibold leading-relaxed">
              Menganalisis pencarian calon pembeli dan strategi kompetitor untuk menemukan kata kunci paling berpotensi.
            </p>
          </div>

          <div class="p-6 bg-slate-50 border border-slate-200/80 rounded-2xl relative">
            <span class="text-3xl font-display font-black text-blue-600/20 absolute top-4 right-4">02</span>
            <div class="w-10 h-10 rounded-xl bg-blue-600 text-white font-bold flex items-center justify-center mb-4 text-sm">02</div>
            <h3 class="font-display font-black text-base text-slate-900 uppercase mb-2">Optimasi Konten & Struktur</h3>
            <p class="text-xs text-slate-500 font-semibold leading-relaxed">
              Merapi konten dan struktur halaman agar mudah dibaca calon pembeli dan ramah mesin pencari Google.
            </p>
          </div>

          <div class="p-6 bg-slate-50 border border-slate-200/80 rounded-2xl relative">
            <span class="text-3xl font-display font-black text-blue-600/20 absolute top-4 right-4">03</span>
            <div class="w-10 h-10 rounded-xl bg-blue-600 text-white font-bold flex items-center justify-center mb-4 text-sm">03</div>
            <h3 class="font-display font-black text-base text-slate-900 uppercase mb-2">Penguatan Otoritas Website</h3>
            <p class="text-xs text-slate-500 font-semibold leading-relaxed">
              Membangun reputasi dan aksesibilitas website agar memenangkan persaingan di posisi teratas Google.
            </p>
          </div>

          <div class="p-6 bg-slate-50 border border-slate-200/80 rounded-2xl relative">
            <span class="text-3xl font-display font-black text-blue-600/20 absolute top-4 right-4">04</span>
            <div class="w-10 h-10 rounded-xl bg-blue-600 text-white font-bold flex items-center justify-center mb-4 text-sm">04</div>
            <h3 class="font-display font-black text-base text-slate-900 uppercase mb-2">Evaluasi & Laporan Bulanan</h3>
            <p class="text-xs text-slate-500 font-semibold leading-relaxed">
              Memantau pertumbuhan trafik dan posisi kata kunci secara berkala dengan laporan yang transparan.
            </p>
          </div>
        </div>
      </div>

      <!-- Why Choose Us Section -->
      <div class="mb-20 p-8 sm:p-12 bg-slate-900 text-white rounded-3xl relative overflow-hidden shadow-xl">
        <div class="absolute right-0 top-0 w-96 h-96 bg-blue-600/10 rounded-full blur-3xl pointer-events-none"></div>
        
        <div class="text-center max-w-2xl mx-auto mb-12 relative z-10">
          <span class="text-xs font-mono font-bold tracking-widest text-blue-400 uppercase mb-2 block">
            {content.whyUsHeader}
          </span>
          <h2 class="font-display font-black text-2xl sm:text-3xl text-white uppercase tracking-tight">
            {content.whyUsTitle}
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 relative z-10">
          <div class="p-6 bg-slate-800/60 border border-slate-700/60 rounded-2xl border-t-2 border-t-blue-500">
            <h3 class="font-display font-black text-base text-white uppercase mb-2">Trafik Organik Siap Beli</h3>
            <p class="text-xs text-slate-300 leading-relaxed font-medium">
              Menargetkan pencarian dengan niat beli tinggi sehingga pengunjung yang datang adalah calon pembeli potensial.
            </p>
          </div>

          <div class="p-6 bg-slate-800/60 border border-slate-700/60 rounded-2xl border-t-2 border-t-blue-500">
            <h3 class="font-display font-black text-base text-white uppercase mb-2">Tanpa Ketergantungan Iklan</h3>
            <p class="text-xs text-slate-300 leading-relaxed font-medium">
              Mendapatkan calon pembeli secara stabil dan berkelanjutan tanpa perlu terus menerus membakar anggaran iklan berbayar.
            </p>
          </div>

          <div class="p-6 bg-slate-800/60 border border-slate-700/60 rounded-2xl border-t-2 border-t-blue-500">
            <h3 class="font-display font-black text-base text-white uppercase mb-2">Laporan Transparan & Terukur</h3>
            <p class="text-xs text-slate-300 leading-relaxed font-medium">
              Laporan perkembangan peringkat dan trafik secara berkala yang mudah dipahami tanpa istilah teknis yang membingungkan.
            </p>
          </div>
        </div>
      </div>

      <!-- Long-form Informational Section for SEO -->
      <section class="mb-24 py-12 px-8 bg-slate-50 border border-slate-100 rounded-3xl">
        <div class="max-w-4xl mx-auto space-y-8 text-slate-700">
          {lang === 'en' ? (
            <>
              <div>
                <h2 class="font-display font-black text-2xl text-slate-900 uppercase tracking-tight mb-4">Professional SEO & Digital Marketing Funnel Agency</h2>
                <p class="text-xs leading-relaxed font-semibold mb-3">
                  To build authority and gain long-term traction, your brand needs a dedicated SEO strategy. We help you rank on the first page of Google organically, driving high-intent search traffic directly to your business. Our services focus on keyword optimization, semantic structure audits, and deep on-page optimizations.
                </p>
                <p class="text-xs leading-relaxed font-semibold mb-6">
                  We combine technical search engine optimization with conversion-focused design, ensuring that the traffic you receive converts into loyal customers. Partner with our team to achieve sustainable growth and decrease your dependency on paid advertising budgets.
                </p>
              </div>

              <div class="border-t border-slate-200 pt-6">
                <h3 class="font-display font-black text-lg text-slate-900 uppercase tracking-tight mb-4">Lumovelo's Monthly SEO Execution Framework</h3>
                <p class="text-xs leading-relaxed font-semibold mb-4">
                  We do not believe in superficial vanity metrics. Our monthly search engine optimization roadmap focuses on concrete technical improvements and semantic relevancy to ensure sustainable organic traffic.
                </p>
                
                <h4 class="font-display font-black text-xs text-slate-800 uppercase tracking-tight mb-2">1. In-Depth Keyword Research & Intent Mapping</h4>
                <ul class="list-disc pl-5 text-xs font-semibold space-y-2 mb-4 leading-relaxed">
                  <li><strong>Search Intent Identification:</strong> We categorize target terms into informational, commercial, transactional, and navigational intents. This ensures your content answers exactly what the user is looking for.</li>
                  <li><strong>Keyword Difficulty & Volume Filtering:</strong> We target high-value, high-intent keywords that present a realistic opportunity for your domain authority to rank on page 1 of Google.</li>
                  <li><strong>Competitor Content Gap Analysis:</strong> We analyze what keywords your direct competitors are ranking for and identify high-opportunity topics where your website can outperform them.</li>
                </ul>

                <h4 class="font-display font-black text-xs text-slate-800 uppercase tracking-tight mb-2">2. Technical SEO & On-Page Tuning</h4>
                <ul class="list-disc pl-5 text-xs font-semibold space-y-2 mb-4 leading-relaxed">
                  <li><strong>Core Web Vitals Optimization:</strong> We audit and improve page loading speed, cumulative layout shift, and first input delay to comply with Google's page experience signals.</li>
                  <li><strong>Semantic HTML Architecture:</strong> We format your content structure using correct heading tags (H1, H2, H3) and optimize internal linking patterns to distribute link equity efficiently.</li>
                  <li><strong>Structured Data JSON-LD Schema:</strong> We inject custom schemas like Product, Service, FAQPage, and Organization directly into the head tag to help search engine crawlers understand your pages easily.</li>
                </ul>

                <h4 class="font-display font-black text-xs text-slate-800 uppercase tracking-tight mb-2">3. Strategic Off-Page Link Building</h4>
                <ul class="list-disc pl-5 text-xs font-semibold space-y-2 mb-4 leading-relaxed">
                  <li><strong>White-Hat Outreach:</strong> We acquire safe, natural, and highly relevant contextual backlinks from reputable industry blogs, directories, and news platforms.</li>
                  <li><strong>Brand Mentions & Digital PR:</strong> We establish authority signals by positioning your brand as a reference source within your industry niche.</li>
                </ul>
