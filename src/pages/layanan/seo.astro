                        <span class="text-[11px]">{feature}</span>
                      </li>
                    ))}
                  </ul>
                </div>
                <a 
                  href={waUrl} 
                  target="_blank" 
                  rel="noopener noreferrer" 
                  class={`w-full inline-flex items-center justify-center py-2.5 rounded-xl border-2 font-black text-xs uppercase tracking-wider transition-all duration-200 cursor-pointer ${
                    pkg.popular
                      ? 'border-emerald-500 bg-emerald-500 hover:bg-emerald-600 text-white shadow-md hover:shadow-lg hover:-translate-y-0.5'
                      : 'border-slate-200 bg-white hover:bg-slate-50 text-slate-700 shadow-sm'
                  }`}
                >
                  {lang === 'en' ? 'Consult Now' : 'Konsultasi'}
                </a>
              </div>
            );
          })}
        </div>
      </div>

      <!-- FAQ Accordion Section -->
      <section class="mb-24 py-12 px-8 bg-slate-50 border border-slate-100 rounded-3xl">
        <div class="max-w-4xl mx-auto">
          <div class="text-center mb-10">
            <h2 class="font-mono font-bold text-[10px] tracking-widest text-blue-600 uppercase mb-2">/ F.A.Q.</h2>
            <h3 class="font-display font-black text-2xl text-slate-900 uppercase tracking-tight leading-snug">
              {lang === 'en' ? 'Frequently Asked Questions' : 'Pertanyaan Umum'}
            </h3>
          </div>
          <div class="space-y-4">
            {faqs.map((faq) => (
              <details class="group border border-slate-200 rounded-2xl bg-white p-6 [&_summary::-webkit-details-marker]:hidden cursor-pointer shadow-sm hover:shadow transition-shadow">
                <summary class="flex items-center justify-between font-display font-black text-sm sm:text-base uppercase text-slate-900 tracking-tight select-none">
                  <span>{faq.q}</span>
                  <svg class="w-4 h-4 text-blue-600 group-open:rotate-180 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <polyline points="6 9 12 15 18 9"/>
                  </svg>
                </summary>
                <p class="text-xs sm:text-sm text-slate-600 leading-relaxed font-semibold pt-4 border-t border-slate-200/50 mt-4">
                  {faq.a}
                </p>
              </details>
            ))}
          </div>
        </div>
      </section>

      <!-- Lead Funnel CTA -->
      <div class="premium-glass p-10 bg-slate-50 border border-slate-200/60 rounded-[2.5rem] flex flex-col md:flex-row items-center justify-between gap-8 animate-glow">
        <div class="space-y-2 max-w-xl text-center md:text-left">
          <h3 class="text-xl sm:text-2xl font-black text-slate-900 uppercase leading-snug">Ingin mendominasi hasil pencarian Google?</h3>
          <p class="text-xs text-slate-500 font-semibold leading-relaxed">
            Mulai riset dan audit SEO website Anda sekarang dengan berdiskusi langsung bersama spesialis marketing kami.
          </p>
        </div>
        <a 
          href={contactLink}
          class="inline-flex items-center justify-center px-6 py-4 rounded-2xl bg-emerald-500 hover:bg-emerald-600 text-white font-black text-xs uppercase tracking-wider transition-all duration-300 shadow-lg shadow-emerald-500/20 hover:shadow-emerald-500/35 hover:-translate-y-0.5 cursor-pointer shrink-0"
        >
          {content.cta}
        </a>
      </div>

    </div>
  </main>
  
  <Footer />
</Layout>

<script>
  function initHoverEffects() {
    if (window.innerWidth < 768) return;
    const cards = document.querySelectorAll('.service-card');
    cards.forEach((card: any) => {
      card.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = card.getBoundingClientRect();
        const width = rect.width;
        const height = rect.height;
        const rotateX = -((e.clientY - rect.top - height / 2) / height) * 3;
        const rotateY = ((e.clientX - rect.left - width / 2) / width) * 3;
        card.style.transform = `rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale(1.005)`;
      });

      card.addEventListener('mouseleave', () => {
        card.style.transform = 'rotateX(0deg) rotateY(0deg) scale(1)';
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHoverEffects);
  } else {
    initHoverEffects();
  }
</script>
