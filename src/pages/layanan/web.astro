---
import Layout from "../../layouts/Layout.astro";
import Footer from "../../components/Footer.astro";
import Logo from "../../components/Logo.astro";

const lang = Astro.currentLocale === "en" ? "en" : "id";
const waNumber = import.meta.env.PUBLIC_WHATSAPP_NUMBER || "6285624353611";

const content = {
  id: {
    title: "Jasa Pembuatan Website & Landing Page Premium | LUMOVELO",
    header: "WEBSITE DEVELOPMENT & LANDING PAGE",
    headline: "Website Premium Kustom, Cepat, Aman & Fokus Konversi Penjualan",
    desc: "Jasa pembuatan website dan landing page kustom Lumovelo. Kami membangun website company profile premium, toko online headless, dan landing page konversi tinggi dengan performa kecepatan serverless super cepat.",
    cta: "Konsultasikan Proyek Website Anda",
    back: "Kembali ke Beranda",
    pricingHeader: "/ PAKET PILIHAN WEB DEVELOPMENT",
    pricingTitle: "Investasi Solusi Website Sesuai Kebutuhan Bisnis Anda",
    workflowHeader: "/ ALUR KERJA PENGERJAAN",
    workflowTitle: "Proses Transparan dari Ide Hingga Peluncuran",
    whyUsHeader: "/ KEUNGGULAN KAMI",
    whyUsTitle: "Mengapa Memilih Jasa Pembuatan Website Lumovelo?",
    periodOnce: "Proyek Sekali Jalan",
    periodMonthly: "Investasi Bulanan",
  },
  en: {
    title: "Premium Web Development & Custom Landing Page Agency | LUMOVELO",
    header: "WEBSITE DEVELOPMENT & LANDING PAGE",
    headline:
      "High-Performance Custom Websites Engineered for Sales Conversion",
    desc: "Premium web development and custom landing page agency. We build high-performance corporate websites, headless e-commerce stores, and high-converting landing pages using fast serverless technology.",
    cta: "Consult Your Web Project",
    back: "Back to Home",
    pricingHeader: "/ WEB DEVELOPMENT CHOSEN PACKAGES",
    pricingTitle: "Invest in the Perfect Web Solution for Your Business",
    workflowHeader: "/ OUR DEVELOPMENT WORKFLOW",
    workflowTitle: "Transparent Process From Concept to Launch",
    whyUsHeader: "/ WHY CHOOSE US",
    whyUsTitle: "Why Build Your Website With Lumovelo?",
    periodOnce: "One-time Project",
    periodMonthly: "Monthly Investment",
  },
}[lang];

const packages = [
  {
    name: lang === "en" ? "Landing Page Pro" : "Landing Page Pro",
    price: "Rp1.450.000",
    period: content.periodOnce,
    features:
      lang === "en"
        ? [
            "Domain .com + Hosting",
            "1 Page, up to 7 converting sections",
            "Persuasive structured copywriting",
            "Direct WhatsApp Form & Button Integration",
            "Mobile & Desktop Responsive Design",
            "1 Ad platform tracking (Meta / TikTok / Google)",
            "Revision: 2x minor",
          ]
        : [
            "Domain .com + Hosting",
            "1 Halaman, hingga 7 section konversi",
            "Copywriting persuasif pendorong penjualan",
            "Integrasi Form & Tombol WhatsApp",
            "Desain responsif HP & desktop",
            "Tracking iklan 1 platform (Meta / TikTok / Google)",
            "Revisi: 2x minor",
          ],
  },
  {
    name: lang === "en" ? "Company Profile Pro" : "Company Profile Pro",
    price: "Rp2.650.000",
    period: content.periodOnce,
    popular: true,
    features:
      lang === "en"
        ? [
            "Domain .com + Hosting",
            "Up to 8 Pages clean navigation menu",
            "100% exclusive custom design",
            "Contact form & Google Maps integration",
            "Technical Speed Optimization (PageSpeed >85)",
            "Headless CMS for easy self-updating",
            "Revision: 3x minor",
          ]
        : [
            "Domain .com + Hosting",
            "Maksimal 8 Halaman menu navigasi bersih",
            "Desain kustom eksklusif 100%",
            "Integrasi formulir kontak & Google Map",
            "Optimasi Kecepatan Teknis (PageSpeed >85)",
            "Headless CMS untuk kemudahan update mandiri",
            "Revisi: 3x minor",
          ],
  },
  {
    name:
      lang === "en"
        ? "E-commerce Pro (Toko Online)"
        : "Toko Online E-commerce Pro",
    price: "Rp3.450.000",
    period: content.periodOnce,
    features:
      lang === "en"
        ? [
            "Domain .com + Hosting",
            "Input maximum 100 products catalog database",
            "Product search & dynamic category filter features",
            "Midtrans / Xendit Payment Gateway Integration",
            "Auto shipping cost calculator (RajaOngkir)",
            "Secure transaction database & SSL certificate",
            "3x Design & Coding Revisions During Development",
          ]
        : [
            "Domain .com + Hosting",
            "Input maksimal 100 produk ke database katalog",
            "Fitur pencarian produk & filter kategori dinamis",
            "Integrasi Payment Gateway Midtrans / Xendit",
            "Kalkulator ongkir otomatis (RajaOngkir)",
            "Database transaksi aman & sertifikat SSL",
            "Dukungan Revisi Desain & Koding 3x Selama Pengerjaan",
          ],
  },
  {
    name: lang === "en" ? "Custom Enterprise Web" : "Custom Enterprise Web",
    price: "Mulai Rp6.000.000",
    period: content.periodOnce,
    features:
      lang === "en"
        ? [
            "Corporate Hosting Setup",
            "Dynamic Multi-Language system implementation",
            "Figma premium component blueprint design system",
            "Complex interactive visual animations & databases",
            "Advanced custom analytics setup (A/B testing)",
            "Full technical support for 1 month",
            "Revision: Free progressively during development",
          ]
        : [
            "Setup Hosting khusus korporat",
            "Implementasi sistem Multi-Bahasa dinamis",
            "Desain sistem blueprint figma premium",
            "Database & animasi visual interaktif kompleks",
            "Tracking analitik kustom tingkat lanjut (A/B testing)",
            "Bantuan teknis penuh selama 1 bulan",
            "Revisi: Bebas bertahap selama pengerjaan",
          ],
  },
];

const homeLink = lang === "en" ? "/en/" : "/";
const contactLink = lang === "en" ? "/en/kontak/" : "/kontak/";

// Structured Schema Markup
const faqs = {
  id: [
    {
      q: "Berapa biaya pembuatan website di Lumovelo?",
      a: "Biaya pembuatan website bervariasi bergantung pada skala dan fitur yang Anda butuhkan, mulai dari Rp 950.000 untuk landing page konversi tinggi hingga Rp 7.500.000+ untuk custom web application dengan integrasi API dinamis dan visualisasi dasbor. Kami menyajikan harga transparan satu kali bayar tanpa ada biaya langganan bulanan tersembunyi."
    },
    {
      q: "Apakah saya mendapatkan akses mandiri untuk memperbarui konten website?",
      a: "Tentu saja. Kami mengintegrasikan sistem Headless CMS (Content Management System) yang praktis dan ramah pengguna. Anda dapat mengubah teks deskripsi, memperbarui harga produk, mengunggah portofolio gambar baru, serta mempublikasikan postingan blog secara mandiri melalui HP atau laptop tanpa menyentuh kode pemrograman."
    },
    {
      q: "Bagaimana performa kecepatan loading dan optimasi SEO website buatan Lumovelo?",
      a: "Kecepatan dan SEO adalah prioritas utama kami. Kami merancang arsitektur website menggunakan teknologi serverless super cepat (SSG/SSR) yang memiliki waktu respons instan. Kami juga menerapkan On-Page SEO lengkap (meta tags, semantic headings, sitemap, robots.txt, dan schema markup data terstruktur) agar website Anda langsung disukai oleh mesin pencari Google."
    },
    {
      q: "Apakah saya akan memiliki source code lengkap dan nama domain secara mandiri?",
      a: "Ya, sepenuhnya. Setelah proyek selesai dan pelunasan diselesaikan, seluruh kepemilikan source code dan aset digital akan diserahkan langsung kepada Anda. Kami juga mendaftarkan domain (.com atau .co.id) atas nama perusahaan Anda secara resmi, sehingga Anda memegang kendali penuh di masa depan."
    },
    {
      q: "Apakah website aman dari serangan hacker atau malware?",
      a: "Sangat aman. Karena kami menggunakan teknologi static-site generation (SSG) berbasis serverless modern, website Anda tidak memiliki server database konvensional yang terekspos langsung di internet. Hal ini meminimalkan celah kerentanan keamanan siber secara signifikan, menjadikannya sangat sulit diretas dibandingkan dengan website CMS tradisional seperti WordPress."
    }
  ],
  en: [
    {
      q: "How much does it cost to build a website at Lumovelo?",
      a: "Website creation costs vary depending on scale and features, starting from IDR 950,000 for high-converting landing pages to IDR 7,500,000+ for custom web applications with dynamic API integrations and dashboard visualizations. We offer transparent one-time pricing with no hidden monthly fees."
    },
    {
      q: "Do I get dashboard access to update my website content independently?",
      a: "Absolutely. We integrate user-friendly Headless CMS (Content Management System) dashboards. You can easily modify descriptions, adjust product prices, upload portfolio images, and publish blog articles independently via laptop or mobile without touching any source code."
    },
    {
      q: "How are the loading speed and SEO optimization of websites built by Lumovelo?",
      a: "Speed and SEO are our top design parameters. We engineer websites using ultra-fast serverless architectures (SSG/SSR) that render pages instantly. We also integrate comprehensive On-Page SEO properties (meta tags, semantic headings, sitemaps, robots.txt, and structured data schemas) so search engines can index your site quickly."
    },
    {
      q: "Will I have full ownership of the source code and domain name?",
      a: "Yes, 100%. Upon completion and final payment, complete ownership of the codebase and all digital assets is handed over to you. We also register domain names (.com or other extensions) officially under your brand name, ensuring you maintain absolute control."
    },
    {
      q: "Is the website secure against hacker attacks and malware?",
      a: "Extremely secure. Since we build websites utilizing modern serverless static-site generation (SSG), there is no live SQL database engine exposed directly on the web. This design eliminates common web vulnerabilities (like SQL injections), making it highly secure compared to traditional CMS platforms like WordPress."
    }
  ]
}[lang];

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name:
    lang === "en"
      ? "Website & Landing Page Development - LUMOVELO"
      : "Jasa Pembuatan Website & Landing Page - LUMOVELO",
  image: "https://www.lumovelo.com/og-image.png",
  description:
    lang === "en"
      ? "Premium custom corporate website creation, high-converting landing pages, and headless e-commerce stores integrated with payment gateways using fast serverless technology."
      : "Jasa pembuatan website company profile kustom, landing page konversi tinggi, dan toko online modern menggunakan teknologi headless serverless super cepat.",
  provider: {
    "@type": "Organization",
    name: "LUMOVELO",
    url: "https://www.lumovelo.com",
  },
  offers: {
    "@type": "AggregateOffer",
    priceCurrency: "IDR",
    lowPrice: "950000",
    highPrice: "7500000",
    offerCount: "4",
    offers: packages.map((pkg, idx) => ({
      "@type": "Offer",
      name: pkg.name,
      price: pkg.price.replace(/[^0-9]/g, ""),
      priceCurrency: "IDR",
      url: "https://www.lumovelo.com/layanan/web/",
    })),
  },
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a
    }
  }))
};
---

<Layout title={content.title} description={content.desc} schema={[schema, faqSchema]}>

  <!-- Simple Subpage Header -->
  <header
    class="py-6 border-b border-slate-100 bg-white/80 backdrop-blur sticky top-0 z-50"
  >
    <div class="max-w-7xl mx-auto px-6 flex items-center justify-between">
      <a href={homeLink} class="flex items-center gap-3 group">
        <div
          class="w-9 h-9 rounded-xl border border-blue-100 bg-white flex items-center justify-center shadow-sm"
        >
          <Logo class="w-4.5 h-4.5 text-blue-600" />
        </div>
        <span
          class="font-display font-black text-lg tracking-widest text-slate-900"
          >LUMOVELO</span
        >
      </a>
      <a
        href={homeLink}
        class="text-xs font-bold uppercase tracking-wider text-slate-500 hover:text-blue-600 transition-colors"
      >
        {content.back}
      </a>
    </div>
  </header>

  <main class="bg-white min-h-screen relative overflow-hidden font-sans">
    <!-- Background Glimmer -->
    <div
      class="absolute right-[-10%] top-[10%] w-[400px] h-[400px] bg-blue-500/[0.02] rounded-full blur-3xl pointer-events-none"
    >
    </div>

    <div class="max-w-6xl mx-auto px-6 py-16 relative z-10">
      <!-- Headline Block -->
      <div class="max-w-3xl mx-auto mb-16 text-center">
        <span
          class="text-xs font-mono font-bold tracking-widest text-blue-600 uppercase mb-3 block"
        >
          {content.header}
        </span>
        <h1
          class="font-display font-black text-4xl sm:text-5xl text-slate-900 leading-[1.15] uppercase tracking-tight font-sans"
        >
          {content.headline}
        </h1>
        <p
          class="text-slate-500 mt-6 text-base sm:text-lg leading-relaxed font-semibold"
        >
          {content.desc}
        </p>
      </div>

      <!-- Key Solutions Bento Grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-20">
        <!-- Solution 1 -->
        <div
          class="premium-glass p-8 bg-white border border-slate-100 shadow-sm rounded-3xl flex flex-col justify-between"
        >
          <div class="space-y-4">
            <div
              class="w-12 h-12 rounded-2xl bg-blue-50 flex items-center justify-center text-blue-600"
            >
              <svg
                class="w-6 h-6"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
            </div>
            <h3 class="text-lg font-black text-slate-900 uppercase">
              Landing Page Konversi
            </h3>
            <p class="text-xs text-slate-500 leading-relaxed font-medium">
              Didesain khusus untuk kampanye marketing Anda. Layout fokus
              konversi penjualan, integrasi form lead otomatis, dan optimasi
              load speed super kilat.
            </p>
          </div>
          <span
            class="text-[10px] font-mono font-bold text-blue-600 uppercase tracking-widest mt-6 block"
            >Ready for Google Ads/Meta Ads →</span
          >
        </div>

        <!-- Solution 2 -->
        <div
          class="premium-glass p-8 bg-white border border-slate-100 shadow-sm rounded-3xl flex flex-col justify-between"
        >
          <div class="space-y-4">
            <div
              class="w-12 h-12 rounded-2xl bg-blue-50 flex items-center justify-center text-blue-600"
            >
              <svg
                class="w-6 h-6"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"
                ></path>
              </svg>
            </div>
            <h3 class="text-lg font-black text-slate-900 uppercase">
              Company Profile
            </h3>
            <p class="text-xs text-slate-550 leading-relaxed font-medium">
              Tingkatkan kredibilitas korporat dengan layout modern berbasis
              bento grid eksklusif. Terintegrasi headless CMS untuk kemudahan
              mengubah konten secara mandiri.
            </p>
          </div>
          <span
            class="text-[10px] font-mono font-bold text-blue-600 uppercase tracking-widest mt-6 block"
            >Premium brand presence →</span
          >
        </div>

        <!-- Solution 3 -->
        <div
          class="premium-glass p-8 bg-white border border-slate-100 shadow-sm rounded-3xl flex flex-col justify-between"
        >
          <div class="space-y-4">
            <div
              class="w-12 h-12 rounded-2xl bg-blue-50 flex items-center justify-center text-blue-600"
            >
              <svg
                class="w-6 h-6"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
              </svg>
            </div>
            <h3 class="text-lg font-black text-slate-900 uppercase">
              Toko Online E-Commerce
            </h3>
            <p class="text-xs text-slate-500 leading-relaxed font-medium">
              Jual produk dengan mudah melalui integrasi logistik ongkir
              otomatis (RajaOngkir) dan gerbang pembayaran digital
              Midtrans/Xendit secara aman.
            </p>
          </div>
          <span
            class="text-[10px] font-mono font-bold text-blue-600 uppercase tracking-widest mt-6 block"
            >Headless checkout system →</span
          >
        </div>
      </div>

      <!-- Workflow Process Section -->
      <div class="mb-20">
        <div class="text-center mb-12">
          <span
            class="text-xs font-mono font-bold tracking-widest text-blue-600 uppercase mb-2 block"
          >
            {content.workflowHeader}
          </span>
          <h2
            class="font-display font-black text-2xl sm:text-3xl text-slate-900 uppercase tracking-tight"
          >
            {content.workflowTitle}
          </h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          <div
            class="p-6 bg-slate-50 border border-slate-200/80 rounded-2xl relative"
          >
            <span
              class="text-3xl font-display font-black text-blue-600/20 absolute top-4 right-4"
              >01</span
            >
            <div
              class="w-10 h-10 rounded-xl bg-blue-600 text-white font-bold flex items-center justify-center mb-4 text-sm"
            >
              01
            </div>
            <h3
              class="font-display font-black text-base text-slate-900 uppercase mb-2"
            >
              Konsultasi & Strategi Bisnis
            </h3>
            <p class="text-xs text-slate-500 font-semibold leading-relaxed">
              Memahami tujuan bisnis, target pembeli, serta merancang struktur
              website yang siap mendorong angka penjualan.
            </p>
          </div>

          <div
            class="p-6 bg-slate-50 border border-slate-200/80 rounded-2xl relative"
          >
            <span
              class="text-3xl font-display font-black text-blue-600/20 absolute top-4 right-4"
              >02</span
            >
            <div
              class="w-10 h-10 rounded-xl bg-blue-600 text-white font-bold flex items-center justify-center mb-4 text-sm"
            >
              02
            </div>
            <h3
              class="font-display font-black text-base text-slate-900 uppercase mb-2"
            >
              Perancangan Visual Eksklusif
            </h3>
            <p class="text-xs text-slate-500 font-semibold leading-relaxed">
              Merancang tampilan visual modern, profesional, dan persuasif yang
              meningkatkan kredibilitas brand Anda.
            </p>
          </div>

          <div
            class="p-6 bg-slate-50 border border-slate-200/80 rounded-2xl relative"
          >
            <span
              class="text-3xl font-display font-black text-blue-600/20 absolute top-4 right-4"
              >03</span
            >
            <div
              class="w-10 h-10 rounded-xl bg-blue-600 text-white font-bold flex items-center justify-center mb-4 text-sm"
            >
              03
            </div>
            <h3
              class="font-display font-black text-base text-slate-900 uppercase mb-2"
            >
              Pembangunan & Pengujian
            </h3>
            <p class="text-xs text-slate-500 font-semibold leading-relaxed">
              Membangun sistem website cepat, aman, serta siap pakai yang
              beroperasi lancar di semua tipe smartphone dan komputer.
            </p>
          </div>

          <div
            class="p-6 bg-slate-50 border border-slate-200/80 rounded-2xl relative"
          >
            <span
              class="text-3xl font-display font-black text-blue-600/20 absolute top-4 right-4"
              >04</span
            >
            <div
              class="w-10 h-10 rounded-xl bg-blue-600 text-white font-bold flex items-center justify-center mb-4 text-sm"
            >
              04
            </div>
            <h3
              class="font-display font-black text-base text-slate-900 uppercase mb-2"
            >
              Peluncuran & Garansi
            </h3>
            <p class="text-xs text-slate-500 font-semibold leading-relaxed">
              Website resmi dipublikasikan untuk mulai mendatangkan pelanggan,
              didukung garansi pemeliharaan teknis penuh.
            </p>
          </div>
        </div>
      </div>

      <!-- Why Choose Us Section -->
      <div
        class="mb-20 p-8 sm:p-12 bg-slate-900 text-white rounded-3xl relative overflow-hidden shadow-xl"
      >
        <div
          class="absolute right-0 top-0 w-96 h-96 bg-blue-600/10 rounded-full blur-3xl pointer-events-none"
        >
        </div>

        <div class="text-center max-w-2xl mx-auto mb-12 relative z-10">
          <span
            class="text-xs font-mono font-bold tracking-widest text-blue-400 uppercase mb-2 block"
          >
            {content.whyUsHeader}
          </span>
          <h2
            class="font-display font-black text-2xl sm:text-3xl text-white uppercase tracking-tight"
          >
            {content.whyUsTitle}
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 relative z-10">
          <div
            class="p-6 bg-slate-800/60 border border-slate-700/60 rounded-2xl border-t-2 border-t-blue-500"
          >
            <h3
              class="font-display font-black text-base text-white uppercase mb-2"
            >
              Fokus Penjualan & Konversi Prospek
            </h3>
            <p class="text-xs text-slate-300 leading-relaxed font-medium">
              Didesain khusus dengan alur visual persuasif yang mendorong
              pengunjung langsung melakukan transaksi atau menghubungi Anda via
              WhatsApp.
            </p>
          </div>

          <div
            class="p-6 bg-slate-800/60 border border-slate-700/60 rounded-2xl border-t-2 border-t-blue-500"
          >
            <h3
              class="font-display font-black text-base text-white uppercase mb-2"
            >
              Performa Cepat & Tanpa Lemot
            </h3>
            <p class="text-xs text-slate-300 leading-relaxed font-medium">
              Website dapat diakses instan dalam hitungan milidetik, mencegah
              calon pelanggan kabur akibat waktu muat halaman yang lambat.
            </p>
          </div>

          <div
            class="p-6 bg-slate-800/60 border border-slate-700/60 rounded-2xl border-t-2 border-t-blue-500"
          >
            <h3
              class="font-display font-black text-base text-white uppercase mb-2"
            >
              Hak Milik Penuh & Tanpa Biaya Tersembunyi
            </h3>
            <p class="text-xs text-slate-300 leading-relaxed font-medium">
              Seluruh aset website sepenuhnya menjadi hak milik bisnis Anda.
              Transparansi biaya terjamin tanpa biaya langganan yang mengikat.
            </p>
          </div>
        </div>
      </div>

      <!-- Pricing Packages Section -->
      <div class="mb-20">
        <div class="text-center mb-10">
          <h2
            class="font-mono font-bold text-[10px] tracking-widest text-blue-600 uppercase mb-2"
          >
            {content.pricingHeader}
          </h2>
          <h3
            class="font-display font-black text-2xl text-slate-900 uppercase tracking-tight leading-snug"
          >
            {content.pricingTitle}
          </h3>
        </div>

        <div
          class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 max-w-5xl mx-auto"
        >
          {
