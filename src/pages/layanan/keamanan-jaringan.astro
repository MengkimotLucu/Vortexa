      <!-- Call to Action Banner -->
      <div class="premium-glass p-10 bg-slate-50 border border-slate-200/60 rounded-[2.5rem] flex flex-col md:flex-row items-center justify-between gap-8 mb-12">
        <div class="space-y-2 max-w-xl text-center md:text-left">
          <span class="text-[9px] font-mono font-black text-blue-600 uppercase tracking-widest block mb-1">🔒 {lang === 'en' ? 'ZERO VULNERABILITY POLICY' : 'KEBIJAKAN TANPA CELAH KEAMANAN'}</span>
