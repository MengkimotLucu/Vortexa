---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import Logo from '../../components/Logo.astro';

const lang = Astro.currentLocale === 'en' ? 'en' : 'id';
const waNumber = import.meta.env.PUBLIC_WHATSAPP_NUMBER || '6285624353611';

const content = {
  id: {
    title: "QA Center | Jasa QA Testing & Pengujian Aplikasi Mobile | LUMOVELO",
    header: "SOFTWARE QUALITY ASSURANCE & TESTING",
    headline: "Jasa QA Testing & Pengujian Aplikasi Mobile Android, iOS, & Web",
    desc: "Kami mendeteksi bug, menguji ketahanan beban server, dan membangun otomatisasi pengujian (QA Automation) untuk menjamin website dan aplikasi mobile Anda 100% stabil, cepat, dan aman.",
    cta: "Konsultasikan Kebutuhan QA Anda",
    back: "Kembali ke Beranda",
    pricingHeader: "/ PAKET PILIHAN SOFTWARE QA TESTING",
    pricingTitle: "Investasi Kualitas Sistem untuk Mencegah Kehilangan Pelanggan",
    workflowHeader: "/ ALUR KERJA PENGUJIAN",
    workflowTitle: "Proses Transparan Memastikan Aplikasi Bebas Kendala",
    whyUsHeader: "/ KEUNGGULAN KAMI",
    whyUsTitle: "Mengapa Memilih Layanan Pengujian Lumovelo?",
    periodOnce: "Proyek Sekali Jalan",
    periodMonthly: "Investasi Bulanan"
  },
  en: {
    title: "Software QA Testing Agency & Mobile App Testing Services | LUMOVELO",
    header: "SOFTWARE QUALITY ASSURANCE & TESTING",
    headline: "Software QA Testing Agency & Mobile App Testing Services",
    desc: "As a premier software qa testing agency & mobile app testing services provider, we run rigorous test automations and manual audits to optimize your digital systems. We ensure a flawless user experience across diverse operating systems and real devices, refining your overall testing process before launch on the app store.",
    cta: "Consult Your QA Requirements",
    back: "Back to Home",
    pricingHeader: "/ SOFTWARE QA TESTING CHOSEN PACKAGES",
    pricingTitle: "Invest in Quality Engineering to Protect Your Customer Retention",
    workflowHeader: "/ OUR TESTING WORKFLOW",
    workflowTitle: "Transparent Process for Flawless Application Delivery",
    whyUsHeader: "/ WHY CHOOSE US",
    whyUsTitle: "Why Test Your Applications With Lumovelo?",
    periodOnce: "One-time Project",
    periodMonthly: "Monthly Investment"
  }
}[lang];

const packages = [
  {
    name: "Basic (Smoke Audit)",
    price: lang === 'en' ? "$69" : "Rp950.000",
    period: content.periodOnce,
    features: lang === 'en' ? [
      "Critical path testing (smoke/sanity checks)",
      "Responsiveness audit on 2 major mobile/desktop browsers",
      "Broken links verification & input validation",
      "Basic bug report (Excel/PDF format)",
      "Best for quick landing page & small website sanity checks"
    ] : [
      "Pengujian alur kritis utama (smoke & sanity checks)",
      "Audit responsivitas di 2 browser HP/Desktop terpopuler",
      "Verifikasi link rusak & validasi form input",
      "Laporan buglist dasar (format Excel/PDF)",
      "Cocok untuk landing page & web portofolio sederhana"
    ]
  },
  {
    name: "Pro (Multi-Device QA)",
    price: lang === 'en' ? "$169" : "Rp2.450.000",
    period: content.periodOnce,
    popular: true,
    features: lang === 'en' ? [
      "End-to-end functional testing (up to 8 pages/modules)",
      "Compatibility testing on 5+ real physical devices (Android & iOS)",
      "E-commerce checkout & payment gateway flow verification",
      "Detailed bug reports with screen recordings & screenshots",
      "1x free re-testing after developer bug fixes",
      "Ideal for mobile app MVPs & corporate web systems"
    ] : [
      "Pengujian fungsional penuh end-to-end (maks 8 halaman/modul)",
      "Pengujian kompatibilitas di 5+ perangkat fisik asli (Android & iOS)",
      "Verifikasi alur checkout e-commerce & payment gateway",
      "Laporan bug terperinci dengan video rekaman & screenshot",
      "1x verifikasi ulang gratis setelah developer melakukan bug fix",
      "Ideal untuk MVP aplikasi mobile & sistem web korporasi"
    ]
  },
  {
    name: "Elite (Performance & API)",
    price: lang === 'en' ? "$289" : "Rp4.250.000",
    period: content.periodOnce,
    features: lang === 'en' ? [
      "Server load testing (up to 1,000 concurrent virtual users)",
      "API response speed, reliability & validation",
      "App memory leaks & battery usage analytics",
      "Basic security headers check & vulnerability scan",
      "Optimization recommendation report for hosting/servers",
      "Best for SaaS apps, large portals, or high-traffic sites"
    ] : [
      "Load testing server hingga 1.000 concurrent virtual users",
      "Uji responsivitas, latency, & validasi endpoint API",
      "Analisis konsumsi baterai & kebocoran memori aplikasi",
      "Pengecekan basic security headers & vulnerability scan",
      "Laporan rekomendasi optimasi server & hosting",
      "Cocok untuk aplikasi SaaS, portal besar, atau web traffic tinggi"
    ]
  },
  {
    name: "Custom (Automation & Security)",
    price: lang === 'en' ? "From $649" : "Mulai Rp9.500.000",
    period: content.periodOnce,
    features: lang === 'en' ? [
      "Automated test scripts creation (Cypress / Playwright / Appium)",
      "CI/CD pipeline integration (GitHub Actions / GitLab CI)",
      "Basic penetration testing (OWASP Web/Mobile Top 10)",
      "Handoff training session for your internal tech team",
      "1-month test script maintenance & support",
      "Perfect for fintech apps, e-commerce, or enterprise systems"
    ] : [
      "Pembuatan skrip testing otomatis (Cypress / Playwright / Appium)",
      "Integrasi pengujian otomatis ke pipeline CI/CD (GitHub Actions)",
      "Audit keamanan penetrasi dasar (OWASP Web/Mobile Top 10)",
      "Sesi pelatihan serah terima kode untuk tim developer internal",
      "Dukungan pemeliharaan skrip otomatisasi selama 1 bulan pertama",
      "Sangat cocok untuk aplikasi fintech, e-commerce, atau korporat"
    ]
  }
];

const homeLink = lang === 'en' ? '/en/' : '/';
const contactLink = lang === 'en' ? '/en/contact/' : '/kontak/';

// Structured Schema Markup
const faqs = {
  id: [
    {
      q: "Apa itu QA testing dan mengapa penting untuk pengembangan software?",
      a: "Quality Assurance (QA) testing adalah proses pengujian perangkat lunak untuk memastikan bahwa aplikasi berjalan bebas dari bug, crash, dan error logika. Hal ini penting untuk menjaga retensi pelanggan, memberikan pengalaman pengguna yang mulus, dan menghindari biaya perbaikan yang mahal setelah produk dirilis ke pasar."
    },
    {
      q: "Perangkat apa saja yang Anda gunakan untuk pengujian aplikasi mobile?",
      a: "Kami melakukan pengujian pada perangkat fisik asli (real devices) Android dan iOS dengan spesifikasi dan versi sistem operasi (operating systems) yang beragam, bukan emulator. Ini memastikan aplikasi Anda kompatibel di berbagai tipe HP yang digunakan pelanggan riil Anda."
    },
    {
      q: "Kapan waktu terbaik untuk memulai QA testing pada proyek pengembangan?",
      a: "Kami menyarankan untuk melibatkan tim QA sejak awal siklus pengembangan (shift-left testing). Pengujian yang dilakukan sejak tahap desain API atau koding awal sangat membantu mendeteksi celah logika lebih dini, sehingga menghemat waktu dan biaya perbaikan secara signifikan."
    },
    {
      q: "Apa perbedaan antara manual testing dan otomatisasi pengujian (QA Automation)?",
      a: "Manual testing melibatkan pengujian fungsionalitas secara manual oleh tim tester kami untuk menilai pengalaman pengguna (user experience) secara intuitif. Sedangkan otomatisasi pengujian menggunakan skrip kode (seperti Playwright atau Cypress) untuk menjalankan pengujian regresi berulang secara cepat dan otomatis pada pipeline integrasi (CI/CD)."
    },
    {
      q: "Apakah Anda juga menyediakan pengujian beban (load testing) server?",
      a: "Ya. Kami melakukan pengujian beban server untuk mensimulasikan peak traffic (hingga ribuan virtual users secara bersamaan). Kami membantu mendeteksi kebocoran memori (memory leaks), batas maksimal beban server, serta menguji kecepatan respons API agar aplikasi Anda tetap stabil saat terjadi lonjakan traffic."
    }
  ],
  en: [
    {
      q: "What is QA testing and why is it important for software development?",
      a: "Quality Assurance (QA) testing is the process of testing software to ensure that the application runs free of bugs, crashes, and logic errors. It is essential for protecting customer retention, providing a seamless user experience, and avoiding expensive hotfixes after product release."
    },
    {
      q: "What devices do you use for mobile application testing?",
      a: "We perform testing on real physical Android and iOS devices with various specifications and operating system versions, not emulators. This ensures your application is compatible across the diverse range of smartphones used by your real customers."
    },
    {
      q: "When is the best time to start QA testing in a development project?",
      a: "We recommend involving the QA team early in the development lifecycle (shift-left testing). Testing conducted during early coding or API design phases helps identify logic flaws sooner, saving significant time and cost."
    },
    {
      q: "What is the difference between manual testing and QA automation?",
      a: "Manual testing involves our testers manually interacting with the app to evaluate usability, look-and-feel, and user experience. QA automation uses test scripts (such as Playwright or Cypress) to run regression testing suites quickly and automatically in CI/CD pipelines."
    },
    {
      q: "Do you also offer server load testing?",
      a: "Yes. We perform server load testing to simulate peak traffic conditions (up to thousands of concurrent virtual users). We help detect memory leaks, identify server bottlenecks, and analyze API response times to ensure your app stays stable under stress."
    }
  ]
}[lang];

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": lang === 'en' ? "Software QA Testing & Mobile App Testing Services - LUMOVELO" : "Jasa QA Testing & Pengujian Aplikasi Mobile - LUMOVELO",
  "image": "https://www.lumovelo.com/og-image.png",
  "description": lang === 'en' 
    ? "Professional software quality assurance, QA automation testing (Cypress/Playwright), API load testing, and Android & iOS mobile app compatibility testing on real devices."
    : "Jasa software quality assurance profesional, QA automation (Cypress/Playwright), load testing API, serta pengujian kompatibilitas aplikasi Android & iOS pada perangkat fisik asli.",
  "provider": {
    "@type": "Organization",
    "name": "LUMOVELO",
    "url": "https://www.lumovelo.com"
  },
  "serviceType": "Software QA Testing & Mobile App Testing",
  "areaServed": "Worldwide",
  "offers": {
    "@type": "AggregateOffer",
    "priceCurrency": lang === 'en' ? "USD" : "IDR",
    "lowPrice": lang === 'en' ? "69" : "950000",
    "highPrice": lang === 'en' ? "649" : "9500000",
    "offerCount": "4",
    "offers": packages.map((pkg, idx) => ({
      "@type": "Offer",
      "name": pkg.name,
      "price": pkg.price.replace(/[^0-9]/g, ""),
      "priceCurrency": lang === 'en' ? "USD" : "IDR",
      "url": lang === 'en' ? "https://www.lumovelo.com/en/layanan/qa/" : "https://www.lumovelo.com/layanan/qa/"
    }))
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a
    }
  }))
};
---

<Layout title={content.title} description={content.desc} schema={[serviceSchema, faqSchema]}>

  <!-- Simple Subpage Header -->
  <header class="py-6 border-b border-slate-100 bg-white/80 backdrop-blur sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-6 flex items-center justify-between">
      <a href={homeLink} class="flex items-center gap-3 group">
        <div class="w-9 h-9 rounded-xl border border-blue-100 bg-white flex items-center justify-center shadow-sm">
          <Logo class="w-4.5 h-4.5 text-blue-600" />
        </div>
        <span class="font-display font-black text-lg tracking-widest text-slate-900">LUMOVELO</span>
      </a>
      <a href={homeLink} class="text-xs font-bold uppercase tracking-wider text-slate-500 hover:text-blue-600 transition-colors">
        {content.back}
      </a>
    </div>
  </header>

  <main class="bg-white min-h-screen relative overflow-hidden font-sans">
    <!-- Background Glimmer -->
    <div class="absolute right-[-10%] top-[10%] w-[400px] h-[400px] bg-blue-500/[0.02] rounded-full blur-3xl pointer-events-none"></div>
    
    <div class="max-w-6xl mx-auto px-6 py-16 relative z-10">
      
      <!-- Headline Block -->
      <div class="max-w-3xl mx-auto mb-16 text-center">
        <span class="text-xs font-mono font-bold tracking-widest text-blue-600 uppercase mb-3 block">
          {content.header}
        </span>
        <h1 class="font-display font-black text-4xl sm:text-5xl text-slate-900 leading-[1.15] uppercase tracking-tight font-sans">
          {content.headline}
        </h1>
        <p class="text-slate-500 mt-6 text-base sm:text-lg leading-relaxed font-semibold">
          {content.desc}
        </p>
      </div>

      <!-- Key Solutions Bento Grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-20">
        
        <!-- Solution 1 -->
        <div class="premium-glass p-8 bg-white border border-slate-100 shadow-sm rounded-3xl flex flex-col justify-between">
          <div class="space-y-4">
            <div class="w-12 h-12 rounded-2xl bg-blue-50 flex items-center justify-center text-blue-600">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />
              </svg>
            </div>
            <h3 class="text-lg font-black text-slate-900 uppercase">{lang === 'en' ? 'Mobile App Testing' : 'Pengujian Aplikasi Mobile'}</h3>
            <p class="text-xs text-slate-500 leading-relaxed font-medium">
              {lang === 'en' 
                ? 'Comprehensive testing across real physical Android & iOS devices to verify visual responsiveness, layouts, transactional forms, and checkout flow stability.' 
                : 'Uji fungsionalitas & visual di berbagai perangkat fisik asli Android & iOS untuk menjamin kestabilan alur transaksi, responsivitas menu, dan validitas form.'}
            </p>
          </div>
          <span class="text-[10px] font-mono font-bold text-blue-600 uppercase tracking-widest mt-6 block">{lang === 'en' ? 'Real iOS & Android Devices →' : 'Perangkat Fisik Asli Android & iOS →'}</span>
        </div>

        <!-- Solution 2 -->
        <div class="premium-glass p-8 bg-white border border-slate-100 shadow-sm rounded-3xl flex flex-col justify-between">
          <div class="space-y-4">
            <div class="w-12 h-12 rounded-2xl bg-blue-50 flex items-center justify-center text-blue-600">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
              </svg>
            </div>
            <h3 class="text-lg font-black text-slate-900 uppercase">{lang === 'en' ? 'Performance & Load Tests' : 'Pengujian Performa & Beban'}</h3>
            <p class="text-xs text-slate-555 leading-relaxed font-medium">
              {lang === 'en' 
                ? 'Identify bottlenecks and verify API reliability by simulating up to 1,000 concurrent virtual users utilizing advanced scripting tools like k6 and JMeter.' 
                : 'Deteksi kemacetan server dan uji kestabilan API dengan simulasi traffic tinggi hingga 1.000 pengguna virtual sekaligus menggunakan tool k6 & JMeter.'}
            </p>
          </div>
          <span class="text-[10px] font-mono font-bold text-blue-600 uppercase tracking-widest mt-6 block">{lang === 'en' ? 'Up to 1,000 concurrent users →' : 'Hingga 1.000 concurrent users →'}</span>
        </div>

        <!-- Solution 3 -->
        <div class="premium-glass p-8 bg-white border border-slate-100 shadow-sm rounded-3xl flex flex-col justify-between">
          <div class="space-y-4">
            <div class="w-12 h-12 rounded-2xl bg-blue-50 flex items-center justify-center text-blue-600">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
              </svg>
            </div>
            <h3 class="text-lg font-black text-slate-900 uppercase">{lang === 'en' ? 'QA Automation & Pentest' : 'Otomatisasi & Pentest Dasar'}</h3>
            <p class="text-xs text-slate-500 leading-relaxed font-medium">
              {lang === 'en' 
                ? 'Save long-term regression costs with automatic test suites (Playwright/Cypress) integrated into CI/CD, plus basic penetration checks covering OWASP Top 10 vulnerabilities.' 
                : 'Hemat biaya regresi dengan skrip tes otomatis (Playwright/Cypress) terintegrasi CI/CD, dilengkapi pentest dasar guna mendeteksi kerentanan OWASP Top 10.'}
            </p>
          </div>
          <span class="text-[10px] font-mono font-bold text-blue-600 uppercase tracking-widest mt-6 block">{lang === 'en' ? 'CI/CD Regression & OWASP Security →' : 'Regresi CI/CD & Keamanan OWASP →'}</span>
        </div>

      </div>

      <!-- Pricing Packages Section -->
      <div class="mb-20">
        <div class="text-center mb-10">
          <h2 class="font-mono font-bold text-[10px] tracking-widest text-blue-600 uppercase mb-2">{content.pricingHeader}</h2>
          <h3 class="font-display font-black text-2xl text-slate-900 uppercase tracking-tight leading-snug">{content.pricingTitle}</h3>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 max-w-5xl mx-auto">
          {packages.map((pkg, idx) => {
            const waText = encodeURIComponent(
              `Halo Tim Lumovelo, saya tertarik untuk berkonsultasi mengenai paket "QA - ${pkg.name}" (${pkg.price}) yang tertera di website.`
            );
            const waUrl = `https://api.whatsapp.com/send?phone=${waNumber}&text=${waText}`;

            return (
              <div 
                class={`service-card border-2 p-5 rounded-2xl relative transition-all duration-300 flex flex-col justify-between min-h-[440px] ${
                  pkg.popular
                    ? 'border-slate-900 bg-white shadow-[4px_4px_0px_#2563eb] hover:shadow-[6px_6px_0px_#1d4ed8] hover:-translate-y-1.5'
                    : 'border-blue-600/10 hover:border-blue-600 bg-slate-50/50 hover:bg-slate-50/80 shadow-[3px_3px_0px_rgba(37,99,235,0.05)] hover:shadow-[4px_4px_0px_#2563eb] hover:-translate-y-1'
                }`}
              >
                {pkg.popular && (
                  <div class="absolute top-0 right-6 -translate-y-1/2 px-2.5 py-0.5 rounded-full border-2 border-slate-900 bg-amber-400 text-[8px] font-mono font-black text-slate-900 uppercase tracking-widest shadow-[1px_1px_0px_#0f172a]">
                    {lang === 'en' ? 'POPULAR' : 'POPULER'}
                  </div>
                )}
                <div>
                  <div class="flex justify-between items-start mb-4">
                    <span class="text-[8px] font-mono text-slate-450 bg-white border border-slate-200 px-2 py-0.5 rounded font-bold uppercase tracking-wider">
                      {idx === 3 ? 'CUSTOM' : `TIER_0${idx + 1}`}
                    </span>
                  </div>
                  <h4 class="font-display font-black text-base text-slate-900 uppercase leading-snug">{pkg.name}</h4>
                  <div class="my-3">
                    <div class="text-[8px] font-mono text-slate-450 font-bold uppercase tracking-widest">{pkg.period}</div>
                    <div class="text-xl font-display font-black text-blue-600 mt-0.5">{pkg.price}</div>
                  </div>
                  <ul class="space-y-2 text-xs text-slate-600 font-semibold mb-6 border-t border-slate-200/40 pt-3">
                    {pkg.features.map((feature) => (
                      <li class="flex items-start gap-1.5 leading-relaxed">
                        <svg class="w-3.5 h-3.5 text-blue-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                          <polyline points="20 6 9 17 4 12"/>
                        </svg>
                        <span class="text-[11px]">{feature}</span>
                      </li>
                    ))}
                  </ul>
                </div>
                <a 
                  href={waUrl} 
                  target="_blank" 
                  rel="noopener noreferrer" 
                  class={`w-full inline-flex items-center justify-center py-2.5 rounded-xl border-2 font-black text-xs uppercase tracking-wider transition-all duration-200 cursor-pointer ${
                    pkg.popular
                      ? 'border-emerald-500 bg-emerald-500 hover:bg-emerald-600 text-white shadow-md hover:shadow-lg hover:-translate-y-0.5'
                      : 'border-slate-200 bg-white hover:bg-slate-50 text-slate-700 shadow-sm'
                  }`}
                >
                  {lang === 'en' ? 'Consult Now' : 'Konsultasi'}
                </a>
              </div>
            );
          })}
        </div>
      </div>
      <!-- Long-form Informational Section for SEO -->
      <section class="mb-24 py-12 px-8 bg-slate-50 border border-slate-100 rounded-3xl">
        <div class="max-w-4xl mx-auto space-y-6 text-slate-700">
          {lang === 'en' ? (
            <>
              <h2 class="font-display font-black text-xl text-slate-900 uppercase tracking-tight">Enterprise Software QA Testing Agency & Mobile App Testing Services</h2>
              <p class="text-xs leading-relaxed font-semibold">
                As an experienced software qa testing agency & mobile app testing services provider, we understand the critical nature of a flawless release. Our QA engineers execute thorough manual testing and robust test automations across real devices and diverse operating systems. This ensures that every functional flow is validated, safeguarding user experience and retention rates.
              </p>
              <p class="text-xs leading-relaxed font-semibold">
                Our testing process covers functional tests, API verification, and peak load stress testing to ensure your application performs under heavy traffic. Partnering with our QA experts helps you launch confidently on the app store, knowing your systems are stable, secure, and ready for your target audience.
              </p>
            </>
          ) : (
            <>
              <h2 class="font-display font-black text-xl text-slate-900 uppercase tracking-tight">Layanan Jasa QA Testing & Pengujian Aplikasi Profesional</h2>
              <p class="text-xs leading-relaxed font-semibold">
                Kami menawarkan jasa QA testing yang menyeluruh untuk mendeteksi bug dan menguji keandalan sistem Anda sebelum meluncur ke publik. Pengujian kami meliputi verifikasi fungsionalitas, uji beban API, dan otomatisasi pengujian untuk memastikan website maupun aplikasi mobile Anda berjalan tanpa hambatan pada berbagai jenis perangkat.
              </p>
              <p class="text-xs leading-relaxed font-semibold">
                Dengan tim ahli QA kami, proses rilis aplikasi Anda ke toko aplikasi (app store) menjadi lebih terjamin. Kami mendokumentasikan setiap temuan error secara detail dan berkolaborasi erat dengan developer Anda untuk menjaga kualitas produk digital, menghadirkan pengalaman pengguna (user experience) yang luar biasa, serta mempertahankan kepercayaan pelanggan Anda secara berkelanjutan.
              </p>
            </>
          )}
        </div>
      </section>

      <!-- Workflow Process Section -->
      <div class="mb-20">
        <div class="text-center mb-12">
          <span class="text-xs font-mono font-bold tracking-widest text-blue-600 uppercase mb-2 block">
            {content.workflowHeader}
          </span>
          <h2 class="font-display font-black text-2xl sm:text-3xl text-slate-900 uppercase tracking-tight">
            {content.workflowTitle}
          </h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          <div class="p-6 bg-slate-50 border border-slate-200/80 rounded-2xl relative">
            <span class="text-3xl font-display font-black text-blue-600/20 absolute top-4 right-4">01</span>
