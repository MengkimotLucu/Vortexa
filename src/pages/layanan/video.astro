const graphicPackages = [
  {
    name: lang === 'en' ? "Basic (Social Media Starter)" : "Basic (Social Media Starter)",
    price: "Rp450.000 / bln",
    period: content.periodMonthly,
    features: lang === 'en' ? [
      "6 Custom feed graphic designs per month",
      "Standard content format (1:1 or 4:5 resolution)",
      "Agency-grade premium template layout",
      "Color palette & text matched to brand logo",
      "Revision: 1x per design",
      "Benefit: Secure consistent visual brand presence on social media with minimal budget."
    ] : [
      "6 Desain grafis feed tunggal per bulan",
      "Format konten standard (Resolusi 1:1 atau 4:5)",
      "Layout visual berbasis template premium agensi",
      "Color palette & teks disesuaikan dengan logo brand",
      "Revisi: 1x per desain",
    ]
  },
  {
    name: lang === 'en' ? "Pro (Brand Growth & Engagement)" : "Pro (Brand Growth & Engagement)",
    price: "Rp950.000 / bln",
    period: content.periodMonthly,
    popular: true,
    features: lang === 'en' ? [
      "12 Custom feed graphic designs per month",
      "2 Educational/promotional Carousel posts (max 5 slides per carousel)",
      "Custom visual design matching brand identity",
