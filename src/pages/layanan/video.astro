      "Sound effect & musik pendukung bebas klaim hak cipta",
      "Revisi: 1x per video"
    ]
  },
  {
    name: lang === 'en' ? "Pro (Social Media Growth)" : "Pro (Social Media Growth)",
    price: "Rp2.250.000 / bln",
    period: content.periodMonthly,
    popular: true,
    features: lang === 'en' ? [
      "8 Short Videos per month (TikTok / Reels / Shorts)",
      "4 Instagram feed/carousel graphic designs",
      "Fast-paced editing with 3-second attention hook tactics",
      "Custom animated subtitles matching brand aesthetic",
      "Transition sound FX syncing & trending audio tracking",
      "Revision: 2x per content"
    ] : [
      "8 Video Pendek per bulan (TikTok / Reels / Shorts)",
      "4 Desain grafis feed/carousel Instagram informatif",
      "Editing ritme cepat dilengkapi taktik penarik perhatian 3 detik pertama (Hook)",
      "Subtitle animasi berwarna kustom mengikuti estetika brand",
      "Penyelarasan efek suara transisi & pelacakan musik tren terkini",
