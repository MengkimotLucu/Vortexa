    ]
  },
  {
    name: lang === 'en' ? "Elite (Corporate & Motion Graphics)" : "Elite (Corporate & Motion Graphics)",
    price: "Rp4.450.000 / bln",
    period: content.periodMonthly,
    features: lang === 'en' ? [
      "12 Short Videos per month (TikTok / Reels / Shorts)",
      "1 Long-form corporate / product promo video (max 3 minutes)",
      "Custom motion graphics elements & animated logo bumper",
      "Kinetic typography for educational product highlights",
      "Advanced color grading & cinematic transitions",
      "Revision: 3x per video",
    ] : [
      "12 Video Pendek per bulan (TikTok / Reels / Shorts)",
      "1 Video promosi produk / Profil Perusahaan durasi panjang (Maksimal 3 menit)",
      "Elemen grafis bergerak buatan kustom (Motion Graphics) & Bumper Logo animasi",
      "Penerapan teks bergerak (Kinetic Typography) untuk poin edukasi produk",
      "Koreksi warna visual tingkat lanjut (Color Grading) & transisi efek sinematik",
      "Revisi: 3x per video",
    ]
  },
  {
    name: lang === 'en' ? "Custom Content Plan" : "Custom Content Plan",
    price: "Hubungi Kami",
    period: content.periodCustom,
    features: lang === 'en' ? [
