      "Riset visual aset pendukung (Elemen grafis & stock foto premium berlisensi)",
      "Optimasi tata letak mikro untuk keterbacaan tinggi di HP",
      "Revisi: 2x per konten",
    ]
  },
  {
    name: lang === 'en' ? "Elite (Full Campaign & Marketing Assets)" : "Elite (Full Campaign & Marketing Assets)",
    price: "Rp1.950.000 / bln",
    period: content.periodMonthly,
    features: lang === 'en' ? [
      "20 Custom feed graphic designs per month",
      "4 Carousel posts (max 7 slides per carousel)",
      "5 Instagram Stories interaction templates (Q&A, Polls, Quizzes)",
      "1 Digital Banner / Website Main Promo Banner design",
      "Advanced image manipulation (photo retouching & color matching)",
      "Revision: 3x per design",
    ] : [
      "20 Desain grafis feed tunggal per bulan",
      "4 Konten format Carousel (Maksimal 7 slide per carousel)",
      "5 Desain template Instagram Stories khusus interaksi (Q&A, Polling, Quiz)",
      "1 Desain Spanduk Digital / Banner Promosi Website utama",
      "Manipulasi gambar tingkat lanjut (Advanced photo retouching & color matching)",
      "Revisi: 3x per desain",
    ]
  },
  {
    name: lang === 'en' ? "Custom Design Plan" : "Custom Design Plan",
    price: "Hubungi Kami",
    period: content.periodCustom,
    features: lang === 'en' ? [
      "Fully tailored quantity of graphics, infographics, or carousels",
      "Complete brand identity design assets (Brand Guidelines, Logo Refresh, Stationery)",
      "High-converting creative ad banners (Meta & TikTok Ads)",
      "Print/packaging design materials (Packaging & Merchandise design)",
      "Revision: Free progressively during active work period",
      "Benefit: Complete visual creative division solution to support all your corporate daily design needs."
    ] : [
      "Volume kuantitas gambar, infografis, atau carousel disesuaikan penuh",
      "Desain aset identitas brand menyeluruh (Brand Guidelines, Logo Refresh, Stationery)",
      "Aset gambar kreatif khusus konversi tinggi untuk performa iklan (Meta & TikTok Ads Banner)",
      "Desain materi cetak / kemasan (Packaging & Merchandise design)",
      "Revisi: Bebas bertahap selama alur masa kerja aktif",
    ]
  }
];

const homeLink = lang === 'en' ? '/en/' : '/';
const contactLink = lang === 'en' ? '/en/kontak/' : '/kontak/';
const waNumber = import.meta.env.PUBLIC_WHATSAPP_NUMBER || '6285624353611';
---

<Layout title={content.title} description={content.desc}>
  <!-- Simple Subpage Header -->
  <header class="py-6 border-b border-slate-100 bg-white/80 backdrop-blur sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-6 flex items-center justify-between">
      <a href={homeLink} class="flex items-center gap-3 group">
        <div class="w-9 h-9 rounded-xl border border-blue-100 bg-white flex items-center justify-center shadow-sm">
          <Logo class="w-4.5 h-4.5 text-blue-600" />
        </div>
        <span class="font-display font-black text-lg tracking-widest text-slate-900">LUMOVELO</span>
      </a>
      <a href={homeLink} class="text-xs font-bold uppercase tracking-wider text-slate-500 hover:text-blue-600 transition-colors">
        {content.back}
      </a>
    </div>
  </header>

  <main class="bg-white min-h-screen relative overflow-hidden font-sans">
    <!-- Background Glimmer -->
    <div class="absolute right-[-10%] top-[10%] w-[400px] h-[400px] bg-blue-500/[0.02] rounded-full blur-3xl pointer-events-none"></div>
    
    <div class="max-w-6xl mx-auto px-6 py-16 relative z-10">
      
      <!-- Headline Block -->
      <div class="max-w-3xl mx-auto mb-16 text-center">
        <span class="text-xs font-mono font-bold tracking-widest text-blue-600 uppercase mb-3 block">
          {content.header}
        </span>
        <h1 class="font-display font-black text-4xl sm:text-5xl text-slate-900 leading-[1.15] uppercase tracking-tight font-sans">
          {content.headline}
        </h1>
        <p class="text-slate-500 mt-6 text-base sm:text-lg leading-relaxed font-semibold">
          {content.desc}
        </p>
      </div>

      <!-- Showreel Video Section -->
      <div class="max-w-4xl mx-auto mb-20">
        <div class="text-center mb-8">
          <h2 class="font-mono font-bold text-[10px] tracking-widest text-blue-600 uppercase mb-2">
            {lang === 'en' ? '/ CREATIVE SHOWREEL' : '/ SHOWREEL KREATIF'}
          </h2>
          <h3 class="font-display font-black text-2xl text-slate-900 uppercase tracking-tight leading-snug">
            {lang === 'en' ? 'Our Creative Edits & Motion Graphics Portfolio' : 'Portfolio Suntingan Video & Animasi Kreatif Kami'}
          </h3>
        </div>
        <div class="relative w-full aspect-video rounded-3xl overflow-hidden shadow-2xl border-4 border-slate-900/5 bg-slate-950">
          <iframe 
            class="w-full h-full absolute inset-0"
            src="https://www.youtube.com/embed/dQw4w9WgXcQ" 
            title="Lumovelo Creative Showreel" 
            frameborder="0" 
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
            allowfullscreen
          ></iframe>
        </div>
      </div>

      <!-- Key Solutions Bento Grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-20">
        
        <!-- Solution 1 -->
        <div class="premium-glass p-8 bg-white border border-slate-100 shadow-sm rounded-3xl flex flex-col justify-between">
          <div class="space-y-4">
            <div class="w-12 h-12 rounded-2xl bg-blue-50 flex items-center justify-center text-blue-600">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
              </svg>
            </div>
            <h3 class="text-lg font-black text-slate-900 uppercase">Short-Form Content</h3>
            <p class="text-xs text-slate-500 leading-relaxed font-medium">
              Penyuntingan video ritme cepat (TikTok, Instagram Reels, YouTube Shorts) dengan sound effect, caption dinamis, dan hook visual untuk meningkatkan engagement penonton.
            </p>
          </div>
          <span class="text-[10px] font-mono font-bold text-blue-600 uppercase tracking-widest mt-6 block">Maximize retention rates →</span>
        </div>

        <!-- Solution 2 -->
        <div class="premium-glass p-8 bg-white border border-slate-100 shadow-sm rounded-3xl flex flex-col justify-between">
          <div class="space-y-4">
            <div class="w-12 h-12 rounded-2xl bg-blue-50 flex items-center justify-center text-blue-600">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7 4v16M17 4v16M3 8h4m10 0h4M3 12h18M3 16h4m10 0h4M4 20h16a1 1 0 001-1V5a1 1 0 00-1-1H4a1 1 0 00-1 1v14a1 1 0 001 1z" />
              </svg>
            </div>
            <h3 class="text-lg font-black text-slate-900 uppercase">Corporate Promo Video</h3>
            <p class="text-xs text-slate-500 leading-relaxed font-medium">
              Pembuatan video presentasi produk, profil perusahaan Company Profile, iklan layanan, dengan warna, transisi cinematic, dan voice over profesional.
            </p>
          </div>
          <span class="text-[10px] font-mono font-bold text-blue-600 uppercase tracking-widest mt-6 block">Clean corporate edits →</span>
        </div>

        <!-- Solution 3 -->
        <div class="premium-glass p-8 bg-white border border-slate-100 shadow-sm rounded-3xl flex flex-col justify-between">
          <div class="space-y-4">
            <div class="w-12 h-12 rounded-2xl bg-blue-50 flex items-center justify-center text-blue-600">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-lg font-black text-slate-900 uppercase">Motion Graphics</h3>
            <p class="text-xs text-slate-500 leading-relaxed font-medium">
              Animasi grafis kustom, infografis bergerak, bumper logo, dan teks kinetik Kinetic Typography untuk memperjelas pesan teknis yang ingin disampaikan oleh brand Anda.
            </p>
          </div>
          <span class="text-[10px] font-mono font-bold text-blue-600 uppercase tracking-widest mt-6 block">Custom visual designs →</span>
        </div>

      </div>

      <!-- Workflow Process Section -->
      <div class="mb-20">
        <div class="text-center mb-12">
          <span class="text-xs font-mono font-bold tracking-widest text-blue-600 uppercase mb-2 block">
            {content.workflowHeader}
          </span>
          <h2 class="font-display font-black text-2xl sm:text-3xl text-slate-900 uppercase tracking-tight">
            {content.workflowTitle}
          </h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          <div class="p-6 bg-slate-50 border border-slate-200/80 rounded-2xl relative">
            <span class="text-3xl font-display font-black text-blue-600/20 absolute top-4 right-4">01</span>
            <div class="w-10 h-10 rounded-xl bg-blue-600 text-white font-bold flex items-center justify-center mb-4 text-sm">01</div>
            <h3 class="font-display font-black text-base text-slate-900 uppercase mb-2">Diskusi Konsep & Briefing</h3>
            <p class="text-xs text-slate-500 font-semibold leading-relaxed">
              Memahami arahan pesan brand, target audiens, serta format konten visual yang ingin diproduksi.
            </p>
          </div>

          <div class="p-6 bg-slate-50 border border-slate-200/80 rounded-2xl relative">
            <span class="text-3xl font-display font-black text-blue-600/20 absolute top-4 right-4">02</span>
            <div class="w-10 h-10 rounded-xl bg-blue-600 text-white font-bold flex items-center justify-center mb-4 text-sm">02</div>
            <h3 class="font-display font-black text-base text-slate-900 uppercase mb-2">Penyusunan Naskah & Alur</h3>
            <p class="text-xs text-slate-500 font-semibold leading-relaxed">
              Merancang naskah copywriting dan struktur alur visual penarik perhatian sejak detik pertama.
            </p>
          </div>

          <div class="p-6 bg-slate-50 border border-slate-200/80 rounded-2xl relative">
            <span class="text-3xl font-display font-black text-blue-600/20 absolute top-4 right-4">03</span>
            <div class="w-10 h-10 rounded-xl bg-blue-600 text-white font-bold flex items-center justify-center mb-4 text-sm">03</div>
            <h3 class="font-display font-black text-base text-slate-900 uppercase mb-2">Penyuntingan & Desain Grafis</h3>
            <p class="text-xs text-slate-500 font-semibold leading-relaxed">
              Melakukan pemotongan ritme cepat, penyesuaian warna, efek suara, serta grafis animasi berkualitas tinggi.
            </p>
          </div>

          <div class="p-6 bg-slate-50 border border-slate-200/80 rounded-2xl relative">
            <span class="text-3xl font-display font-black text-blue-600/20 absolute top-4 right-4">04</span>
            <div class="w-10 h-10 rounded-xl bg-blue-600 text-white font-bold flex items-center justify-center mb-4 text-sm">04</div>
            <h3 class="font-display font-black text-base text-slate-900 uppercase mb-2">Review & Penyerahan File</h3>
            <p class="text-xs text-slate-500 font-semibold leading-relaxed">
              Pengecekan hasil bersama, penyesuaian revisi, dan penyerahan aset video resolusi tinggi siap tayang.
            </p>
          </div>
        </div>
      </div>

      <!-- Why Choose Us Section -->
      <div class="mb-20 p-8 sm:p-12 bg-slate-900 text-white rounded-3xl relative overflow-hidden shadow-xl">
        <div class="absolute right-0 top-0 w-96 h-96 bg-blue-600/10 rounded-full blur-3xl pointer-events-none"></div>
        
        <div class="text-center max-w-2xl mx-auto mb-12 relative z-10">
          <span class="text-xs font-mono font-bold tracking-widest text-blue-400 uppercase mb-2 block">
            {content.whyUsHeader}
          </span>
          <h2 class="font-display font-black text-2xl sm:text-3xl text-white uppercase tracking-tight">
            {content.whyUsTitle}
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 relative z-10">
          <div class="p-6 bg-slate-800/60 border border-slate-700/60 rounded-2xl border-t-2 border-t-blue-500">
            <h3 class="font-display font-black text-base text-white uppercase mb-2">Penarik Perhatian Detik Pertama</h3>
            <p class="text-xs text-slate-300 leading-relaxed font-medium">
              Didesain dengan taktik ritme cepat untuk menghentikan guliran penonton dan memicu minat pembeli secara instan.
            </p>
          </div>

          <div class="p-6 bg-slate-800/60 border border-slate-700/60 rounded-2xl border-t-2 border-t-blue-500">
            <h3 class="font-display font-black text-base text-white uppercase mb-2">Menampilkan Citra Brand Premium</h3>
            <p class="text-xs text-slate-300 leading-relaxed font-medium">
              Hasil ekspor visual berkualitas tinggi yang memperkuat posisi dan kredibilitas bisnis Anda di media sosial.
            </p>
          </div>

          <div class="p-6 bg-slate-800/60 border border-slate-700/60 rounded-2xl border-t-2 border-t-blue-500">
            <h3 class="font-display font-black text-base text-white uppercase mb-2">Penyelesaian Tepat Waktu & Bebas Pusing</h3>
            <p class="text-xs text-slate-300 leading-relaxed font-medium">
              Seluruh proses dari naskah, editing, hingga efek suara ditangani penuh oleh tim berpengalaman sesuai jadwal.
            </p>
          </div>
        </div>
      </div>

      <!-- Pricing Packages Section -->
      <div class="mb-20">
        <div class="text-center mb-8">
          <h2 class="font-mono font-bold text-[10px] tracking-widest text-blue-600 uppercase mb-2">{content.pricingHeader}</h2>
          <h3 class="font-display font-black text-2xl text-slate-900 uppercase tracking-tight leading-snug">{content.pricingTitle}</h3>
        </div>

        <!-- TOGGLE SUB-TABS (Video vs Graphic) -->
        <div class="flex justify-center gap-2 mb-8 border-b border-slate-100 pb-1">
          <button 
            id="sub-tab-video" 
            class="media-tab-btn px-5 py-2.5 text-xs font-extrabold tracking-wider uppercase whitespace-nowrap rounded-t-xl transition-all duration-200 cursor-pointer border-b-2 border-blue-600 text-blue-600 bg-blue-50/5"
            data-target="video"
          >
            {content.tabVideo}
          </button>
          <button 
            id="sub-tab-graphic" 
            class="media-tab-btn px-5 py-2.5 text-xs font-extrabold tracking-wider uppercase whitespace-nowrap rounded-t-xl transition-all duration-200 cursor-pointer border-b-2 border-transparent text-slate-400 hover:text-slate-700"
            data-target="graphic"
          >
            {content.tabGraphic}
          </button>
        </div>

        <!-- Video Editing Packages Panel -->
        <div id="panel-video" class="media-panel">
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 max-w-5xl mx-auto">
            {videoPackages.map((pkg, idx) => {
              const waText = encodeURIComponent(
                `Halo Tim Lumovelo, saya tertarik untuk berkonsultasi mengenai paket "Video Editing - ${pkg.name}" (${pkg.price}) yang tertera di website.`
              );
              const waUrl = `https://api.whatsapp.com/send?phone=${waNumber}&text=${waText}`;

              return (
                <div 
                  class={`service-card border-2 p-5 rounded-2xl relative transition-all duration-300 flex flex-col justify-between min-h-[440px] ${
                    pkg.popular
                      ? 'border-slate-900 bg-white shadow-[4px_4px_0px_#2563eb] hover:shadow-[6px_6px_0px_#1d4ed8] hover:-translate-y-1.5'
                      : 'border-blue-600/10 hover:border-blue-600 bg-slate-50/50 hover:bg-slate-50/80 shadow-[3px_3px_0px_rgba(37,99,235,0.05)] hover:shadow-[4px_4px_0px_#2563eb] hover:-translate-y-1'
                  }`}
