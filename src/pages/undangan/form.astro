---
import Layout from '../../layouts/Layout.astro';
import Logo from '../../components/Logo.astro';
---

<Layout title="Formulir Data Undangan Pernikahan | LUMOVELO" description="Formulir pengisian data pernikahan digital bagi klien Lumovelo.">
  <div class="min-h-screen bg-slate-50 py-12 px-4 sm:px-6 lg:px-8 font-sans relative overflow-hidden">
    
    <!-- Background subtle shapes -->
    <div class="absolute w-[400px] h-[400px] rounded-full bg-blue-100/40 blur-[100px] top-[-10%] left-[-10%] pointer-events-none"></div>
    <div class="absolute w-[400px] h-[400px] rounded-full bg-indigo-100/30 blur-[100px] bottom-[-10%] right-[-10%] pointer-events-none"></div>

    <div class="max-w-3xl mx-auto z-10 relative space-y-8">
      
      <!-- Header -->
      <div class="text-center">
        <a href="/" class="inline-flex items-center gap-3 mb-4 group">
          <div class="w-10 h-10 rounded-xl border-2 border-slate-900 bg-blue-600 flex items-center justify-center font-display font-black text-white text-xl tracking-wider shadow-md shadow-blue-500/10 group-hover:rotate-6 transition-transform">
            L
          </div>
          <span class="font-display font-black text-xl tracking-widest text-slate-900 group-hover:text-blue-600 transition-colors">LUMOVELO</span>
        </a>
        <h1 class="font-display font-black text-2xl sm:text-3xl text-slate-900 uppercase tracking-tight">Formulir Undangan Digital</h1>
        <p class="text-xs sm:text-sm text-slate-500 font-semibold mt-2">Lengkapi informasi di bawah ini untuk mengaktifkan tema undangan pernikahan Anda.</p>
      </div>

      <!-- Main Form Container -->
      <form id="wedding-form" class="bg-white border-2 border-slate-200/80 rounded-3xl p-6 sm:p-10 shadow-sm space-y-8">
        
        <!-- Status alerts -->
        <div id="status-alert" class="hidden p-4 rounded-xl text-xs font-semibold leading-relaxed"></div>

        <!-- Section 1: Akun & Paket -->
        <div class="space-y-4">
          <h3 class="text-xs font-mono font-bold text-blue-600 border-b border-slate-100 pb-2 uppercase tracking-widest">1. Konfigurasi Link & Tema</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="space-y-1.5">
              <label for="client-name" class="text-xs font-bold text-slate-700 uppercase">Nama Klien / Pemesan</label>
              <input type="text" id="client-name" required class="w-full bg-slate-50 border border-slate-200 focus:border-blue-500 focus:bg-white rounded-xl px-4 py-3 text-sm text-slate-800 focus:outline-none transition-all" placeholder="Contoh: Budi Santoso" />
            </div>
            <div class="space-y-1.5">
              <label for="invite-slug" class="text-xs font-bold text-slate-700 uppercase">Custom Link Akhir (Slug)</label>
              <div class="flex">
                <span class="inline-flex items-center px-3 rounded-l-xl border border-r-0 border-slate-200 bg-slate-100 text-slate-500 text-xs font-semibold font-mono">
                  lumovelo.agency/
                </span>
                <input type="text" id="invite-slug" required class="flex-1 min-w-0 bg-slate-50 border border-slate-200 focus:border-blue-500 focus:bg-white rounded-r-xl px-4 py-3 text-sm text-slate-800 focus:outline-none transition-all" placeholder="budi-ani" />
              </div>
              <p class="text-[10px] text-slate-400 mt-1 font-medium">Link ini akan diakses oleh tamu undangan Anda (Gunakan huruf kecil dan tanda hubung).</p>
            </div>
          </div>
          <div class="space-y-1.5">
            <label for="invite-theme" class="text-xs font-bold text-slate-700 uppercase">Pilih Desain Tema Undangan</label>
            <select id="invite-theme" required class="w-full bg-slate-50 border border-slate-200 focus:border-blue-500 focus:bg-white rounded-xl px-4 py-3 text-sm text-slate-800 focus:outline-none transition-all">
              <option value="modern">Tema Modern (Starter / Premium)</option>
              <option value="rustic">Tema Rustic (Starter / Premium)</option>
              <option value="elegant">Tema Elegant (Premium)</option>
              <option value="floral">Tema Floral (Premium)</option>
              <option value="dark-aesthetic">Tema Dark Aesthetic (Premium)</option>
              <option value="custom">Tema Semi-Figma Kustom (Elite)</option>
            </select>
          </div>
        </div>

        <!-- Section 2: Data Pengantin Pria -->
        <div class="space-y-4">
          <h3 class="text-xs font-mono font-bold text-blue-600 border-b border-slate-100 pb-2 uppercase tracking-widest">2. Informasi Mempelai Pria</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="space-y-1.5">
              <label for="groom-name" class="text-xs font-bold text-slate-700 uppercase">Nama Lengkap Mempelai Pria</label>
              <input type="text" id="groom-name" required class="w-full bg-slate-50 border border-slate-200 focus:border-blue-500 focus:bg-white rounded-xl px-4 py-3 text-sm text-slate-800 focus:outline-none transition-all" placeholder="Budi Santoso" />
            </div>
            <div class="space-y-1.5">
              <label for="groom-ig" class="text-xs font-bold text-slate-700 uppercase">Username Instagram</label>
              <input type="text" id="groom-ig" class="w-full bg-slate-50 border border-slate-200 focus:border-blue-500 focus:bg-white rounded-xl px-4 py-3 text-sm text-slate-800 focus:outline-none transition-all" placeholder="@budisantoso" />
            </div>
          </div>
          <div class="space-y-1.5">
            <label for="groom-parents" class="text-xs font-bold text-slate-700 uppercase">Nama Orang Tua (Contoh: Putra dari Bapak X & Ibu Y)</label>
            <input type="text" id="groom-parents" required class="w-full bg-slate-50 border border-slate-200 focus:border-blue-500 focus:bg-white rounded-xl px-4 py-3 text-sm text-slate-800 focus:outline-none transition-all" placeholder="Putra dari Bapak Suherman & Ibu Herawati" />
          </div>
        </div>

        <!-- Section 3: Data Pengantin Wanita -->
        <div class="space-y-4">
          <h3 class="text-xs font-mono font-bold text-blue-600 border-b border-slate-100 pb-2 uppercase tracking-widest">3. Informasi Mempelai Wanita</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="space-y-1.5">
              <label for="bride-name" class="text-xs font-bold text-slate-700 uppercase">Nama Lengkap Mempelai Wanita</label>
              <input type="text" id="bride-name" required class="w-full bg-slate-50 border border-slate-200 focus:border-blue-500 focus:bg-white rounded-xl px-4 py-3 text-sm text-slate-800 focus:outline-none transition-all" placeholder="Siti Aminah" />
            </div>
            <div class="space-y-1.5">
              <label for="bride-ig" class="text-xs font-bold text-slate-700 uppercase">Username Instagram</label>
              <input type="text" id="bride-ig" class="w-full bg-slate-50 border border-slate-200 focus:border-blue-500 focus:bg-white rounded-xl px-4 py-3 text-sm text-slate-800 focus:outline-none transition-all" placeholder="@sitiaminah" />
            </div>
          </div>
          <div class="space-y-1.5">
            <label for="bride-parents" class="text-xs font-bold text-slate-700 uppercase">Nama Orang Tua (Contoh: Putri dari Bapak X & Ibu Y)</label>
            <input type="text" id="bride-parents" required class="w-full bg-slate-50 border border-slate-200 focus:border-blue-500 focus:bg-white rounded-xl px-4 py-3 text-sm text-slate-800 focus:outline-none transition-all" placeholder="Putri dari Bapak Gunawan & Ibu Rahmawati" />
          </div>
        </div>

        <!-- Section 4: Detail Akad & Resepsi -->
        <div class="space-y-6">
          <h3 class="text-xs font-mono font-bold text-blue-600 border-b border-slate-100 pb-2 uppercase tracking-widest">4. Jadwal & Lokasi Acara</h3>
          
          <div class="bg-slate-50 border border-slate-200/60 rounded-2xl p-6 space-y-4">
            <h4 class="text-xs font-black uppercase text-slate-800">A. Akad Nikah</h4>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div class="space-y-1.5">
                <label for="akad-date" class="text-xs font-semibold text-slate-600">Tanggal Akad</label>
                <input type="date" id="akad-date" required class="w-full bg-white border border-slate-200 focus:border-blue-500 rounded-xl px-3 py-2.5 text-sm text-slate-800 focus:outline-none transition-colors" />
              </div>
              <div class="space-y-1.5">
                <label for="akad-time" class="text-xs font-semibold text-slate-600">Waktu / Jam (Contoh: 09:00 - Selesai)</label>
                <input type="text" id="akad-time" required class="w-full bg-white border border-slate-200 focus:border-blue-500 rounded-xl px-3 py-2.5 text-sm text-slate-800 focus:outline-none transition-colors" placeholder="09:00 WIB - Selesai" />
              </div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div class="space-y-1.5">
                <label for="akad-location" class="text-xs font-semibold text-slate-600">Alamat Tempat / Masjid</label>
                <input type="text" id="akad-location" required class="w-full bg-white border border-slate-200 focus:border-blue-500 rounded-xl px-3 py-2.5 text-sm text-slate-800 focus:outline-none transition-colors" placeholder="Masjid Raya Al-Jabbar, Bandung" />
              </div>
              <div class="space-y-1.5">
                <label for="akad-maps" class="text-xs font-semibold text-slate-600">Tautan Share Lokasi Google Maps</label>
                <input type="url" id="akad-maps" required class="w-full bg-white border border-slate-200 focus:border-blue-500 rounded-xl px-3 py-2.5 text-sm text-slate-800 focus:outline-none transition-colors" placeholder="https://maps.google.com/..." />
              </div>
            </div>
          </div>

          <div class="bg-slate-50 border border-slate-200/60 rounded-2xl p-6 space-y-4">
            <h4 class="text-xs font-black uppercase text-slate-800">B. Resepsi Pernikahan</h4>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div class="space-y-1.5">
                <label for="resepsi-date" class="text-xs font-semibold text-slate-600">Tanggal Resepsi</label>
                <input type="date" id="resepsi-date" required class="w-full bg-white border border-slate-200 focus:border-blue-500 rounded-xl px-3 py-2.5 text-sm text-slate-800 focus:outline-none transition-colors" />
              </div>
              <div class="space-y-1.5">
                <label for="resepsi-time" class="text-xs font-semibold text-slate-600">Waktu / Jam Resepsi</label>
                <input type="text" id="resepsi-time" required class="w-full bg-white border border-slate-200 focus:border-blue-500 rounded-xl px-3 py-2.5 text-sm text-slate-800 focus:outline-none transition-colors" placeholder="11:00 WIB - 15:00 WIB" />
              </div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div class="space-y-1.5">
                <label for="resepsi-location" class="text-xs font-semibold text-slate-600">Alamat Tempat / Gedung</label>
                <input type="text" id="resepsi-location" required class="w-full bg-white border border-slate-200 focus:border-blue-500 rounded-xl px-3 py-2.5 text-sm text-slate-800 focus:outline-none transition-colors" placeholder="Gedung Balai Sartika, Bandung" />
              </div>
              <div class="space-y-1.5">
                <label for="resepsi-maps" class="text-xs font-semibold text-slate-600">Tautan Share Lokasi Google Maps</label>
                <input type="url" id="resepsi-maps" required class="w-full bg-white border border-slate-200 focus:border-blue-500 rounded-xl px-3 py-2.5 text-sm text-slate-800 focus:outline-none transition-colors" placeholder="https://maps.google.com/..." />
              </div>
            </div>
          </div>
        </div>

        <!-- Section 5: Media & Integrasi -->
        <div class="space-y-4">
          <h3 class="text-xs font-mono font-bold text-blue-600 border-b border-slate-100 pb-2 uppercase tracking-widest">5. Tambahan Musik, Foto, & Hadiah Kado</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="space-y-1.5">
              <label for="music-url" class="text-xs font-bold text-slate-700 uppercase">Tautan Background Music (Youtube / MP3 Link)</label>
              <input type="url" id="music-url" class="w-full bg-slate-50 border border-slate-200 focus:border-blue-500 focus:bg-white rounded-xl px-4 py-3 text-sm text-slate-800 focus:outline-none transition-all" placeholder="https://www.youtube.com/watch?v=..." />
            </div>
            <div class="space-y-1.5">
              <label for="whatsapp-rsvp" class="text-xs font-bold text-slate-700 uppercase">Nomor WA Penerima RSVP Tamu</label>
              <input type="text" id="whatsapp-rsvp" required class="w-full bg-slate-50 border border-slate-200 focus:border-blue-500 focus:bg-white rounded-xl px-4 py-3 text-sm text-slate-800 focus:outline-none transition-all" placeholder="Contoh: 6285624353611" />
            </div>
          </div>

          <div class="space-y-1.5 pt-2">
            <label class="text-xs font-bold text-slate-700 uppercase">Galeri Foto Prewedding (Maksimal 10 File)</label>
            <input type="file" id="prewedding-photos" multiple accept="image/*" class="w-full bg-slate-50 border border-slate-200 focus:border-blue-500 focus:bg-white rounded-xl px-4 py-3 text-sm text-slate-800 focus:outline-none transition-all" />
            <p class="text-[10px] text-slate-400 font-medium">Foto ini akan ditampilkan di galeri foto undangan pernikahan Anda.</p>
            <div id="photos-preview-container" class="grid grid-cols-5 gap-2 pt-2"></div>
          </div>
          
          <div class="bg-slate-50 border border-slate-200/60 rounded-2xl p-6 space-y-4">
            <h4 class="text-xs font-black uppercase text-slate-800">Integrasi Angpao Digital (Opsional)</h4>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
              <div class="space-y-1.5">
                <label for="bank-name" class="text-xs font-semibold text-slate-600">Nama Bank / E-Wallet</label>
                <input type="text" id="bank-name" class="w-full bg-white border border-slate-200 focus:border-blue-500 rounded-xl px-3 py-2.5 text-sm text-slate-800 focus:outline-none transition-colors" placeholder="Contoh: BCA / Mandiri / Gopay" />
              </div>
              <div class="space-y-1.5">
                <label for="bank-number" class="text-xs font-semibold text-slate-600">Nomor Rekening</label>
                <input type="text" id="bank-number" class="w-full bg-white border border-slate-200 focus:border-blue-500 rounded-xl px-3 py-2.5 text-sm text-slate-800 focus:outline-none transition-colors" placeholder="Contoh: 7770984321" />
              </div>
              <div class="space-y-1.5">
                <label for="bank-owner" class="text-xs font-semibold text-slate-600">Atas Nama Pemilik</label>
                <input type="text" id="bank-owner" class="w-full bg-white border border-slate-200 focus:border-blue-500 rounded-xl px-3 py-2.5 text-sm text-slate-800 focus:outline-none transition-colors" placeholder="Contoh: Budi Santoso" />
              </div>
            </div>
          </div>
        </div>

        <button 
          type="submit" 
          id="btn-submit"
          class="w-full bg-blue-600 hover:bg-blue-700 active:scale-[0.98] text-white py-4 rounded-2xl text-xs font-black uppercase tracking-widest cursor-pointer shadow-lg shadow-blue-500/20 transition-all flex items-center justify-center gap-2"
        >
          Kirim Data Undangan Pernikahan ➔
        </button>

      </form>
      
      <div class="text-center">
        <a href="/" class="text-xs font-semibold text-slate-500 hover:text-slate-650 transition-colors uppercase tracking-wider">
          ← Kembali ke Beranda Lumovelo
        </a>
      </div>

    </div>
  </div>

  <script>
    import { supabase } from '../../lib/supabase';

    const weddingForm = document.getElementById('wedding-form') as HTMLFormElement;
    const btnSubmit = document.getElementById('btn-submit') as HTMLButtonElement;
    const statusAlert = document.getElementById('status-alert') as HTMLDivElement;
    const photosInput = document.getElementById('prewedding-photos') as HTMLInputElement;
    const previewContainer = document.getElementById('photos-preview-container') as HTMLDivElement;

    // Show thumbnail previews of selected images
    photosInput.addEventListener('change', () => {
      previewContainer.innerHTML = '';
      if (photosInput.files) {
        Array.from(photosInput.files).slice(0, 10).forEach(file => {
          const reader = new FileReader();
          reader.onload = (e) => {
            const img = document.createElement('img');
            img.src = e.target?.result as string;
            img.className = 'w-full h-16 object-cover rounded-lg border border-slate-200';
            previewContainer.appendChild(img);
          };
          reader.readAsDataURL(file);
        });
      }
    });

    weddingForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      btnSubmit.disabled = true;
      btnSubmit.innerText = 'MEMPROSES DATA...';
      statusAlert.className = 'hidden';

      const clientName = (document.getElementById('client-name') as HTMLInputElement).value.trim();
      const inviteSlug = (document.getElementById('invite-slug') as HTMLInputElement).value.trim().toLowerCase();
      const inviteTheme = (document.getElementById('invite-theme') as HTMLSelectElement).value;

      const groomName = (document.getElementById('groom-name') as HTMLInputElement).value.trim();
      const groomIg = (document.getElementById('groom-ig') as HTMLInputElement).value.trim();
      const groomParents = (document.getElementById('groom-parents') as HTMLInputElement).value.trim();

      const brideName = (document.getElementById('bride-name') as HTMLInputElement).value.trim();
      const brideIg = (document.getElementById('bride-ig') as HTMLInputElement).value.trim();
      const brideParents = (document.getElementById('bride-parents') as HTMLInputElement).value.trim();

      const akadDate = (document.getElementById('akad-date') as HTMLInputElement).value;
      const akadTime = (document.getElementById('akad-time') as HTMLInputElement).value.trim();
      const akadLocation = (document.getElementById('akad-location') as HTMLInputElement).value.trim();
      const akadMaps = (document.getElementById('akad-maps') as HTMLInputElement).value.trim();

      const resepsiDate = (document.getElementById('resepsi-date') as HTMLInputElement).value;
      const resepsiTime = (document.getElementById('resepsi-time') as HTMLInputElement).value.trim();
      const resepsiLocation = (document.getElementById('resepsi-location') as HTMLInputElement).value.trim();
      const resepsiMaps = (document.getElementById('resepsi-maps') as HTMLInputElement).value.trim();

      const musicUrl = (document.getElementById('music-url') as HTMLInputElement).value.trim();
      const whatsappRsvp = (document.getElementById('whatsapp-rsvp') as HTMLInputElement).value.trim();

      const bankName = (document.getElementById('bank-name') as HTMLInputElement).value.trim();
      const bankNumber = (document.getElementById('bank-number') as HTMLInputElement).value.trim();
      const bankOwner = (document.getElementById('bank-owner') as HTMLInputElement).value.trim();

      try {
        const photoUrls: string[] = [];

        // Upload photos to Supabase Storage if files are provided
        if (photosInput.files && photosInput.files.length > 0) {
          btnSubmit.innerText = 'MENGUNGGAH FOTO...';
          const filesArray = Array.from(photosInput.files).slice(0, 10);
          
          for (let i = 0; i < filesArray.length; i++) {
            const file = filesArray[i];
            const fileExt = file.name.split('.').pop();
            const fileName = `${Date.now()}-${Math.random().toString(36).substring(2, 9)}.${fileExt}`;
            const filePath = `${inviteSlug}/${fileName}`;

            const { data: uploadData, error: uploadError } = await supabase.storage
              .from('wedding-galleries')
              .upload(filePath, file);

            if (!uploadError) {
              const { data: { publicUrl } } = supabase.storage
                .from('wedding-galleries')
                .getPublicUrl(filePath);
              photoUrls.push(publicUrl);
            } else {
              console.warn("Gagal mengunggah foto:", uploadError.message);
              // Fallback: We proceed with the registration even if some uploads fail
            }
          }
        }

        btnSubmit.innerText = 'MENYIMPAN DATA...';
        const { error } = await supabase
          .from('wedding_invitations')
          .insert({
            client_name: clientName,
            slug: inviteSlug,
            theme: inviteTheme,
            groom_name: groomName,
            groom_ig: groomIg,
            groom_parents: groomParents,
            bride_name: brideName,
            bride_ig: brideIg,
            bride_parents: brideParents,
            akad_date: akadDate,
            akad_time: akadTime,
            akad_location: akadLocation,
            akad_maps: akadMaps,
            resepsi_date: resepsiDate,
            resepsi_time: resepsiTime,
            resepsi_location: resepsiLocation,
            resepsi_maps: resepsiMaps,
            music_url: musicUrl,
            whatsapp_rsvp: whatsappRsvp,
            photos: photoUrls,
            payment_info: {
              bank_name: bankName,
              bank_number: bankNumber,
              bank_owner: bankOwner
            }
          });

        if (error) {
          throw error;
        }

        statusAlert.innerText = 'Sukses! Data undangan berhasil dikirim. Kami akan memproses verifikasi dan mengaktifkan link Anda segera.';
        statusAlert.className = 'p-4 rounded-xl text-xs font-semibold leading-relaxed bg-emerald-500/10 border border-emerald-500/20 text-emerald-600';
        
        // Reset form & preview
        weddingForm.reset();
        previewContainer.innerHTML = '';
      } catch (err: any) {
        statusAlert.innerText = err.message || 'Terjadi kesalahan saat menyimpan data. Periksa kembali inputan Anda.';
        statusAlert.className = 'p-4 rounded-xl text-xs font-semibold leading-relaxed bg-rose-500/10 border border-rose-500/20 text-rose-600';
      } finally {
        btnSubmit.disabled = false;
        btnSubmit.innerText = 'Kirim Data Undangan Pernikahan ➔';
      }
    });
  </script>
</Layout>
