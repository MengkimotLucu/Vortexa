<script>
  function initPricingDashboard() {
    const mainTabBtns = document.querySelectorAll('.main-tab-btn');
    const subTabBtns = document.querySelectorAll('.sub-tab-btn');
    const subNavContainers = document.querySelectorAll('.sub-nav-container');
    const servicePanels = document.querySelectorAll('.service-panel');

    // 1. Main category tab switcher
    mainTabBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const targetGroup = btn.getAttribute('data-target');

        // Update active class on main category buttons
        mainTabBtns.forEach(b => {
          b.classList.remove('border-slate-900', 'bg-slate-900', 'text-white', 'shadow-[3px_3px_0px_#2563eb]', 'hover:shadow-[5px_5px_0px_#2563eb]', '-translate-x-0.5', '-translate-y-0.5');
          b.classList.add('border-slate-200', 'bg-white', 'text-slate-700');
        });

        btn.classList.add('border-slate-900', 'bg-slate-900', 'text-white', 'shadow-[3px_3px_0px_#2563eb]', '-translate-x-0.5', '-translate-y-0.5');
        btn.classList.remove('border-slate-200', 'bg-white', 'text-slate-700');

        // Toggle sub-navigation containers
        subNavContainers.forEach(container => {
          if (container.id === `sub-nav-${targetGroup}`) {
            container.classList.remove('hidden');
          } else {
            container.classList.add('hidden');
          }
        });

        // Auto-select the first sub-category in the chosen group
        const targetSubNav = document.getElementById(`sub-nav-${targetGroup}`);
        if (targetSubNav) {
          const firstSubBtn = targetSubNav.querySelector('.sub-tab-btn') as HTMLElement;
          if (firstSubBtn) {
            firstSubBtn.click();
          }
        }
      });
    });

    // 2. Sub-category tab switcher
    subTabBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const subId = btn.getAttribute('data-sub-id');
        const group = btn.getAttribute('data-group');

        // Get sub-tabs in the current container only
        const siblingBtns = document.querySelectorAll(`.sub-tab-btn[data-group="${group}"]`);

        // Reset all sub-tabs in this group
        siblingBtns.forEach(b => {
          b.classList.remove('border-blue-600', 'text-blue-600', 'bg-blue-50/5');
          b.classList.add('border-transparent', 'text-slate-400', 'hover:text-slate-700');
        });

        // Set active sub-tab styling
        btn.classList.add('border-blue-600', 'text-blue-600', 'bg-blue-50/5');
        btn.classList.remove('border-transparent', 'text-slate-400', 'hover:text-slate-700');

        // Toggle visibility of panels
        servicePanels.forEach(panel => {
          if (panel.id === `panel-${subId}`) {
            panel.classList.remove('hidden');
          } else {
            panel.classList.add('hidden');
          }
        });
      });
    });

    // 3. Card mousemove effects for desktop viewports
    if (window.innerWidth >= 768) {
      const cards = document.querySelectorAll('.service-card');
      cards.forEach((card: any) => {
        card.addEventListener('mousemove', (e: MouseEvent) => {
          const rect = card.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          card.style.setProperty('--x', `${x}px`);
          card.style.setProperty('--y', `${y}px`);

          const width = rect.width;
          const height = rect.height;
          const rotateX = -((e.clientY - rect.top - height / 2) / height) * 3;
          const rotateY = ((e.clientX - rect.left - width / 2) / width) * 3;

          card.style.transform = `rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale(1.005)`;
        });

        card.addEventListener('mouseleave', () => {
          card.style.transform = 'rotateX(0deg) rotateY(0deg) scale(1)';
        });
      });
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPricingDashboard);
  } else {
    initPricingDashboard();
  }
</script>
