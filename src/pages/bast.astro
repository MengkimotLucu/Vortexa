---
import Logo from '../components/Logo.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout title="Premium BAST Builder | LUMOVELO" description="Workspace pembuatan Berita Acara Serah Terima (BAST) proyek resmi interaktif dengan ceklist hasil testing.">
  <div class="min-h-screen bg-slate-950 text-slate-100 flex flex-col font-sans select-none">
    <!-- Header -->
    <header class="border-b border-slate-800 bg-slate-900/80 backdrop-blur-md sticky top-0 z-40 px-6 py-4 flex items-center justify-between font-sans no-print">
      <div class="flex items-center gap-3">
        <a href="/" class="flex items-center gap-2 group">
          <div class="w-8 h-8 rounded-lg border border-slate-700 bg-blue-600 flex items-center justify-center shadow-[2px_2px_0px_rgba(37,99,235,0.4)]">
            <Logo class="w-4 h-4 text-white" />
          </div>
          <span class="font-display font-black text-lg tracking-wider text-white">LUMOVELO</span>
        </a>
        <span class="text-xs font-mono px-2 py-1 rounded bg-slate-800 text-slate-400 uppercase tracking-widest">Workspace v1.0</span>
      </div>
      
      <!-- Document Selector Dropdown -->
      <div class="relative inline-block text-left" id="doc-selector-dropdown-container">
        <button type="button" id="doc-selector-btn" class="inline-flex justify-between items-center gap-2 px-4 py-2 border border-slate-700 rounded-xl bg-slate-955 text-xs font-bold text-slate-300 hover:text-white hover:border-slate-650 transition-all cursor-pointer select-none">
          <span>📂 WORKSPACE: BAST SERAH TERIMA</span>
          <svg class="w-3.5 h-3.5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div id="doc-selector-menu" class="absolute right-0 mt-2 w-56 rounded-xl border border-slate-800 bg-slate-900 shadow-2xl py-1.5 z-50 hidden transition-all">
          <a href="/mou/" class="block px-4 py-2 text-xs text-slate-300 hover:text-white hover:bg-slate-800/60 border-b border-slate-800/30">📝 MoU Perjanjian</a>
          <a href="/spk/" class="block px-4 py-2 text-xs text-slate-300 hover:text-white hover:bg-slate-800/60 border-b border-slate-800/30">🤝 SPK / Kontrak Kerja</a>
          <a href="/rab/" class="block px-4 py-2 text-xs text-slate-300 hover:text-white hover:bg-slate-800/60 border-b border-slate-800/30">📊 RAB Anggaran Biaya</a>
          <a href="/srs/" class="block px-4 py-2 text-xs text-slate-300 hover:text-white hover:bg-slate-800/60 border-b border-slate-800/30">📋 SRS / Lampiran Scope</a>
          <a href="/invoice/" class="block px-4 py-2 text-xs text-slate-300 hover:text-white hover:bg-slate-800/60 border-b border-slate-800/30">💳 Invoice Penagihan</a>
          <a href="/kuitansi/" class="block px-4 py-2 text-xs text-slate-300 hover:text-white hover:bg-slate-800/60 border-b border-slate-800/30">🧾 Kuitansi Pembayaran</a>
          <a href="/bast/" class="block px-4 py-2 text-xs text-blue-400 bg-slate-800/40 font-bold border-b border-slate-800/30">📦 BAST Serah Terima</a>
        </div>
      </div>
    </header>

    <!-- Main Workspace -->
    <div class="flex-1 flex flex-col lg:flex-row overflow-hidden">
      <!-- Tabs for Mobile View -->
      <div class="lg:hidden flex border-b border-slate-800 bg-slate-900 no-print">
        <button id="tab-editor" class="flex-1 py-3 text-center text-sm font-bold border-b-2 border-blue-500 text-white bg-slate-900">
          Form Editor
        </button>
        <button id="tab-preview" class="flex-1 py-3 text-center text-sm font-bold border-b-2 border-transparent text-slate-400 bg-slate-900">
          Pratinjau A4
        </button>
      </div>

      <!-- Left Panel: Editor Form -->
      <aside id="editor-panel" class="w-full lg:w-[45%] border-r border-slate-800 bg-slate-900/30 overflow-y-auto p-6 space-y-6 block no-print">
        <!-- Preset Selector -->
        <div class="bg-slate-900/80 border border-slate-800 rounded-xl p-4 space-y-3">
          <label class="block text-xs font-mono font-bold tracking-widest text-blue-400 uppercase">PILIH TEMPLATE BAST</label>
          <div class="grid grid-cols-1 gap-2">
            <button type="button" id="preset-bast-full" class="px-2 py-2 rounded-lg bg-blue-600/10 hover:bg-blue-600/20 border border-blue-500/30 text-xs font-bold text-blue-400 transition-all hover:scale-[1.01] cursor-pointer">
              Serah Terima Proyek Website
            </button>
          </div>
        </div>

        <!-- Document Metadata -->
        <div class="space-y-4">
          <h3 class="text-sm font-mono font-bold text-slate-400 border-b border-slate-800 pb-2 uppercase tracking-wider">Metadata Dokumen</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="space-y-1.5">
              <label for="bast-number" class="text-xs font-semibold text-slate-400">Nomor BAST</label>
              <input type="text" id="bast-number" class="w-full bg-slate-900 border border-slate-800 focus:border-blue-500 rounded-lg px-3.5 py-2 text-sm text-white focus:outline-none transition-colors" placeholder="Contoh: 004/BAST-LV/VI/2026" />
            </div>
            <div class="space-y-1.5">
              <label for="bast-date" class="text-xs font-semibold text-slate-400">Tanggal Serah Terima</label>
              <input type="text" id="bast-date" class="w-full bg-slate-900 border border-slate-800 focus:border-blue-500 rounded-lg px-3.5 py-2 text-sm text-white focus:outline-none transition-colors" placeholder="Contoh: 01 Juli 2026" />
            </div>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="space-y-1.5">
              <label for="bast-city" class="text-xs font-semibold text-slate-400">Kota Lokasi</label>
              <input type="text" id="bast-city" class="w-full bg-slate-900 border border-slate-800 focus:border-blue-500 rounded-lg px-3.5 py-2 text-sm text-white focus:outline-none transition-colors" placeholder="Contoh: Bandung" />
            </div>
            <div class="space-y-1.5">
              <label for="bast-project" class="text-xs font-semibold text-slate-400">Nama Proyek</label>
              <input type="text" id="bast-project" class="w-full bg-slate-900 border border-slate-800 focus:border-blue-500 rounded-lg px-3.5 py-2 text-sm text-white focus:outline-none transition-colors" placeholder="Contoh: Pembuatan Landing Page HijabStyle" />
            </div>
          </div>
        </div>

        <!-- Party 1 (Client) Details -->
        <div class="space-y-4">
          <h3 class="text-sm font-mono font-bold text-slate-400 border-b border-slate-800 pb-2 uppercase tracking-wider">Klien Tujuan</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="space-y-1.5">
              <label for="client-name" class="text-xs font-semibold text-slate-400">Nama Lengkap</label>
              <input type="text" id="client-name" class="w-full bg-slate-900 border border-slate-800 focus:border-blue-500 rounded-lg px-3.5 py-2 text-sm text-white focus:outline-none transition-colors" placeholder="Nama representatif klien" />
            </div>
            <div class="space-y-1.5">
              <label for="client-company" class="text-xs font-semibold text-slate-400">Perusahaan Klien</label>
              <input type="text" id="client-company" class="w-full bg-slate-900 border border-slate-800 focus:border-blue-500 rounded-lg px-3.5 py-2 text-sm text-white focus:outline-none transition-colors" placeholder="Nama instansi klien" />
            </div>
          </div>
          <div class="space-y-1.5">
            <label for="client-address" class="text-xs font-semibold text-slate-400">Alamat Lengkap</label>
            <input type="text" id="client-address" class="w-full bg-slate-900 border border-slate-800 focus:border-blue-500 rounded-lg px-3.5 py-2 text-sm text-white focus:outline-none transition-colors" placeholder="Alamat lengkap klien" />
          </div>
        </div>

        <!-- Party 1 (Provider) Details -->
        <div class="space-y-4">
          <h3 class="text-sm font-mono font-bold text-slate-400 border-b border-slate-800 pb-2 uppercase tracking-wider">Pihak Pertama (Pihak I - Pelaksana/Penyedia Jasa)</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="space-y-1.5">
              <label for="p1-name" class="text-xs font-semibold text-slate-400">Nama Lengkap</label>
              <input type="text" id="p1-name" class="w-full bg-slate-950 border border-slate-800 focus:border-blue-500 rounded-lg px-3.5 py-2 text-sm text-white focus:outline-none transition-colors" value="Ahmad Rivaldi" />
            </div>
            <div class="space-y-1.5">
              <label for="p1-company" class="text-xs font-semibold text-slate-400">Nama Instansi / Perusahaan</label>
              <input type="text" id="p1-company" class="w-full bg-slate-950 border border-slate-800 focus:border-blue-500 rounded-lg px-3.5 py-2 text-sm text-white focus:outline-none transition-colors" value="LUMOVELO Agency" />
            </div>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="space-y-1.5">
              <label for="p1-position" class="text-xs font-semibold text-slate-400">Jabatan</label>
              <input type="text" id="p1-position" class="w-full bg-slate-955 border border-slate-800 focus:border-blue-500 rounded-lg px-3.5 py-2 text-sm text-white focus:outline-none transition-colors" value="CEO / Co-founder" />
            </div>
            <div class="space-y-1.5">
              <label for="comp-address" class="text-xs font-semibold text-slate-400">Alamat Perusahaan</label>
              <input type="text" id="comp-address" class="w-full bg-slate-955 border border-slate-800 focus:border-blue-500 rounded-lg px-3.5 py-2 text-sm text-white focus:outline-none transition-colors" value="Jl. Dipati Ukur No. 102, Coblong, Kota Bandung" />
            </div>
          </div>
        </div>

        <!-- Deliverables List -->
        <div class="space-y-4">
          <div class="flex items-center justify-between border-b border-slate-800 pb-2">
            <h3 class="text-sm font-mono font-bold text-slate-400 uppercase tracking-wider">Daftar Serah Terima Deliverable</h3>
            <button type="button" id="btn-add-item" class="px-2.5 py-1 rounded bg-blue-600 hover:bg-blue-700 text-white font-bold text-[10px] uppercase tracking-wider flex items-center gap-1 transition-colors cursor-pointer select-none">
              Tambah Item
            </button>
          </div>
          <div id="items-editor-container" class="space-y-3">
            <!-- Injected by JS -->
          </div>
        </div>

        <!-- Warranty / Support period -->
        <div class="space-y-1.5 bg-slate-900/50 border border-slate-800 rounded-2xl p-4">
          <label for="warranty-text" class="text-xs font-mono font-bold text-slate-400 block pb-1 border-b border-slate-800 uppercase tracking-wider">Ketentuan Masa Garansi</label>
          <input type="text" id="warranty-text" class="w-full bg-slate-950 border border-slate-800 focus:border-blue-500 rounded-lg px-3.5 py-2 text-sm text-white focus:outline-none transition-colors mt-2" value="30 (tiga puluh) hari kalender, terhitung sejak penandatanganan dokumen BAST ini." />
        </div>

        <!-- Actions -->
        <div class="pt-4 grid grid-cols-1 sm:grid-cols-2 gap-4">
          <button type="button" id="btn-download-pdf" class="w-full flex items-center justify-center gap-2.5 py-4 rounded-xl border-2 border-blue-600 bg-blue-600 hover:bg-blue-700 text-white font-black text-sm uppercase tracking-wider shadow-[4px_4px_0px_#020617] transition-all duration-200 hover:-translate-y-0.5 active:translate-y-0 active:shadow-none cursor-pointer select-none">
            Cetak / Simpan PDF
          </button>
          <button type="button" id="btn-download-word" class="w-full flex items-center justify-center gap-2.5 py-4 rounded-xl border-2 border-slate-700 bg-slate-800 hover:bg-slate-700 text-white font-black text-sm uppercase tracking-wider shadow-[4px_4px_0px_#020617] transition-all duration-200 hover:-translate-y-0.5 active:translate-y-0 active:shadow-none cursor-pointer select-none">
            Unduh Word (.doc)
          </button>
        </div>
      </aside>

      <!-- Right Panel: Live Document Preview (A4 representation) -->
      <section id="preview-panel" class="flex-1 bg-slate-900/20 overflow-y-auto p-4 md:p-8 flex justify-center items-start hidden lg:flex">
        <!-- Paper Container representing A4 -->
        <div id="paper-preview" class="w-full max-w-[210mm] min-h-[297mm] bg-white text-black p-[25mm] shadow-2xl rounded border border-slate-200/50 flex flex-col font-serif relative">
          <!-- Document Header -->
          <div class="text-center space-y-2 mb-8 font-sans">
            <h1 class="text-base font-bold uppercase tracking-wide leading-relaxed border-b-2 border-black pb-3">
              BERITA ACARA SERAH TERIMA (BAST) PEKERJAAN<br>
              <span id="p-project-name" class="text-sm font-normal">--</span>
            </h1>
            <p class="text-xs font-bold font-sans">
              Nomor: <span id="p-bast-number" class="underline">--</span>
            </p>
          </div>

          <!-- Document Body -->
          <div class="text-xs space-y-6 leading-relaxed text-justify flex-1">
            <p>
              Pada hari ini, <strong id="p-bast-day">--</strong> tanggal <strong id="p-bast-date">--</strong>, bertempat di <strong id="p-bast-city">--</strong>, kami yang bertandatangan di bawah ini:
            </p>

            <!-- Party 1 - LUMOVELO -->
            <div class="pl-4">
              <table class="w-full no-border font-serif text-xs">
                <tr>
                  <td class="w-[20%] font-bold">Nama</td>
                  <td class="w-[3%]">:</td>
                  <td><span class="font-bold" id="p-p1-name">Ahmad Rivaldi</span></td>
                </tr>
                <tr>
                  <td class="font-bold">Jabatan</td>
                  <td>:</td>
                  <td><span id="p-p1-position">CEO / Co-founder</span></td>
                </tr>
                <tr>
                  <td class="font-bold">Perusahaan</td>
                  <td>:</td>
                  <td><span class="font-bold" id="p-p1-company">LUMOVELO Agency</span></td>
                </tr>
                <tr>
                  <td class="font-bold">Alamat</td>
                  <td>:</td>
                  <td><span id="p-p1-address">Jl. Dipati Ukur No. 102, Coblong, Kota Bandung</span></td>
                </tr>
              </table>
              <p class="pt-1.5 text-slate-700">
                Dalam hal ini bertindak untuk dan atas nama <strong id="p-p1-company-ref">LUMOVELO Agency</strong>, yang selanjutnya disebut sebagai <strong>Pihak Pertama (Pihak I / Pelaksana Pekerjaan)</strong>.
              </p>
            </div>

            <!-- Party 1 - Client -->
            <div class="pl-4 border-t border-slate-100 pt-4">
              <table class="w-full no-border font-serif text-xs">
                <tr>
                  <td class="w-[20%] font-bold">Nama</td>
                  <td class="w-[3%]">:</td>
                  <td><span id="p-client-name" class="font-bold">--</span></td>
                </tr>
                <tr>
                  <td class="font-bold">Perusahaan</td>
                  <td>:</td>
                  <td><span id="p-client-company" class="font-bold">--</span></td>
                </tr>
                <tr>
                  <td class="font-bold">Alamat</td>
                  <td>:</td>
                  <td><span id="p-client-address">--</span></td>
                </tr>
              </table>
              <p class="pt-1.5 text-slate-700">
                Dalam hal ini bertindak untuk dan atas nama <strong id="p-client-company-ref">--</strong>, yang selanjutnya disebut sebagai <strong>Pihak Kedua (Pihak II / Pemberi Kerja)</strong>.
              </p>
            </div>

            <p>
              Dengan ini menyatakan bahwa Pihak Pertama telah menyelesaikan dan menyerahkan hasil pengerjaan proyek kepada Pihak Kedua, dan Pihak Kedua menyatakan telah menerima penyerahan tersebut dengan rincian deliverable sebagai berikut:
            </p>

            <!-- Table of Deliverables -->
            <div>
              <table class="w-full border-collapse border border-slate-300 text-[11px] font-sans">
                <thead>
                  <tr class="bg-slate-50 border-b border-slate-300">
                    <th class="p-2 border-r border-slate-300 w-8 text-center font-bold">NO</th>
                    <th class="p-2 border-r border-slate-300 w-44 font-bold">DELIVERABLE / ASET SERAH TERIMA</th>
                    <th class="p-2 font-bold">DESKRIPSI & STATUS PENERIMAAN</th>
                  </tr>
                </thead>
                <tbody id="preview-items-body">
                  <!-- Injected via Javascript -->
                </tbody>
              </table>
            </div>

            <!-- Warranty clause -->
            <p>
              Dengan ditandatanganinya Berita Acara Serah Terima ini, maka tanggung jawab operasional sepenuhnya beralih dari Pihak Pertama kepada Pihak Kedua. Pihak Pertama berkewajiban memberikan dukungan garansi perbaikan bug/error selama <strong><span id="p-warranty-text">--</span></strong>.
            </p>

            <!-- Signatures Section -->
            <div class="pt-12">
              <div class="flex justify-between items-start mt-8" id="p-signature-block">
                <div class="w-[45%] text-center space-y-14">
                  <div>
                    <p class="text-slate-500 font-sans text-[10px] uppercase font-bold">Pihak Kedua (Yang Menerima),</p>
                    <p class="font-bold font-sans text-xs uppercase mt-0.5"><span id="p-sign-client-company">--</span></p>
                  </div>
                  <div>
                    <div class="w-32 h-0.5 bg-black mx-auto"></div>
                    <p class="font-bold text-xs uppercase font-sans mt-1"><span id="p-sign-client-name">--</span></p>
                    <p class="text-[9px] text-slate-500 font-sans">Representatif Klien</p>
                  </div>
                </div>

                <div class="w-[45%] text-center space-y-14">
                  <div>
                    <p class="text-slate-500 font-sans text-[10px] uppercase font-bold">Pihak Pertama (Yang Menyerahkan),</p>
                    <p class="font-bold font-sans text-xs uppercase mt-0.5 text-blue-600" id="p-sign-p1-company">LUMOVELO Agency</p>
                  </div>
                  <div>
                    <div class="w-32 h-0.5 bg-black mx-auto"></div>
                    <p class="font-bold text-xs uppercase font-sans mt-1" id="p-sign-p1-name">Ahmad Rivaldi</p>
                    <p class="text-[9px] text-slate-500 font-sans" id="p-sign-p1-title">CEO / Co-founder</p>
                  </div>
                </div>
              </div>
            </div>

          </div>
        </div>
      </section>
    </div>
  </div>

  <style is:global>
    @media print {
      body * {
        visibility: hidden;
      }
      .no-print {
        display: none !important;
      }
      #preview-panel, #preview-panel * {
        visibility: visible;
      }
      #preview-panel {
        position: absolute;
        left: 0;
        top: 0;
        width: 100% !important;
        height: auto !important;
        padding: 0 !important;
        margin: 0 !important;
        background: white !important;
      }
      #paper-preview {
        box-shadow: none !important;
        border: none !important;
        padding: 0 !important;
        margin: 0 !important;
      }
    }
  </style>

  <script>
    const presets = {
      full: {
        number: '004/BAST-LV/VI/2026',
        city: 'Bandung',
        project: 'Pembuatan Landing Page Penjualan HijabStyle',
        clientName: 'Budi Santoso',
        clientCompany: 'PT. HijabStyle Mode',
        clientAddress: 'Jl. Kemang Raya No. 44, Jakarta Selatan',
        p1Name: 'Ahmad Rivaldi',
        p1Company: 'LUMOVELO Agency',
        p1Position: 'CEO / Co-founder',
        compAddress: 'Jl. Dipati Ukur No. 102, Coblong, Kota Bandung',
        warranty: '30 (tiga puluh) hari kalender, terhitung sejak penandatanganan dokumen BAST ini.',
        items: [
          { title: 'Kode Sumber Website (Astro Framework)', desc: 'Berkas koding lengkap yang diunggah ke repositori GitHub privat milik klien.' },
          { title: 'Setup Domain & Hosting (Vercel)', desc: 'Konfigurasi domain utama hijabstyle.id terhubung SSL dan serverless Edge Network.' },
          { title: 'Akses Kunci Akun Administrasi', desc: 'Serah terima kredensial login dashboard email, CMS, dan API WhatsApp form.' },
          { title: 'Hasil Uji Performa (Lighthouse Score)', desc: 'Laporan skor performa optimal di atas 95/100 pada uji kecepatan mobile.' }
        ]
      }
    };

    let currentItems: { title: string; desc: string }[] = [];

    // Inputs
    const bastNumInput = document.getElementById('bast-number') as HTMLInputElement;
    const bastDateInput = document.getElementById('bast-date') as HTMLInputElement;
    const bastCityInput = document.getElementById('bast-city') as HTMLInputElement;
    const bastProjInput = document.getElementById('bast-project') as HTMLInputElement;
    const clientNameInput = document.getElementById('client-name') as HTMLInputElement;
    const clientCompanyInput = document.getElementById('client-company') as HTMLInputElement;
    const clientAddressInput = document.getElementById('client-address') as HTMLInputElement;
    const warrantyInput = document.getElementById('warranty-text') as HTMLInputElement;
    const itemsContainer = document.getElementById('items-editor-container') as HTMLDivElement;
    const btnAddItem = document.getElementById('btn-add-item') as HTMLButtonElement;

    // Preview
    const pBastNum = document.getElementById('p-bast-number') as HTMLSpanElement;
    const pBastDate = document.getElementById('p-bast-date') as HTMLSpanElement;
    const pBastCity = document.getElementById('p-bast-city') as HTMLSpanElement;
    const pProjName = document.getElementById('p-project-name') as HTMLSpanElement;
    const pClientName = document.getElementById('p-client-name') as HTMLSpanElement;
    const pClientCompany = document.getElementById('p-client-company') as HTMLSpanElement;
    const pClientCompanyRef = document.getElementById('p-client-company-ref') as HTMLSpanElement;
    const pClientAddress = document.getElementById('p-client-address') as HTMLSpanElement;
    const pWarrantyText = document.getElementById('p-warranty-text') as HTMLSpanElement;
    const pSignClientCompany = document.getElementById('p-sign-client-company') as HTMLSpanElement;
    const pSignClientName = document.getElementById('p-sign-client-name') as HTMLSpanElement;

    // Pihak Pertama Inputs
    const p1NameInput = document.getElementById('p1-name') as HTMLInputElement;
    const p1CompanyInput = document.getElementById('p1-company') as HTMLInputElement;
    const p1PositionInput = document.getElementById('p1-position') as HTMLInputElement;
    const compAddressInput = document.getElementById('comp-address') as HTMLInputElement;

    // Pihak Pertama Preview elements
    const pP1Name = document.getElementById('p-p1-name') as HTMLSpanElement;
    const pP1Position = document.getElementById('p-p1-position') as HTMLSpanElement;
    const pP1Company = document.getElementById('p-p1-company') as HTMLSpanElement;
    const pP1Address = document.getElementById('p-p1-address') as HTMLSpanElement;
    const pP1CompanyRef = document.getElementById('p-p1-company-ref') as HTMLSpanElement;
    const pSignP1Company = document.getElementById('p-sign-p1-company') as HTMLSpanElement;
    const pSignP1Name = document.getElementById('p-sign-p1-name') as HTMLSpanElement;
    const pSignP1Title = document.getElementById('p-sign-p1-title') as HTMLSpanElement;

    function updateMetadataPreview() {
      pBastNum.innerText = bastNumInput.value || '--';
      pBastDate.innerText = bastDateInput.value || '--';
      pBastCity.innerText = bastCityInput.value || '--';
      pProjName.innerText = bastProjInput.value || '--';
      pClientName.innerText = clientNameInput.value || '--';
      pClientCompany.innerText = clientCompanyInput.value || '--';
      pClientCompanyRef.innerText = clientCompanyInput.value || '--';
      pClientAddress.innerText = clientAddressInput.value || '--';
      pWarrantyText.innerText = warrantyInput.value || '--';
      pSignClientCompany.innerText = clientCompanyInput.value || 'Perusahaan Klien';
      pSignClientName.innerText = clientNameInput.value || 'Nama Representatif';

      // Update Pihak Pertama Preview
      if (pP1Name) pP1Name.innerText = p1NameInput.value || '--';
      if (pP1Position) pP1Position.innerText = p1PositionInput.value || '--';
      if (pP1Company) pP1Company.innerText = p1CompanyInput.value || '--';
      if (pP1Address) pP1Address.innerText = compAddressInput.value || '--';
      if (pP1CompanyRef) pP1CompanyRef.innerText = p1CompanyInput.value || '--';
      if (pSignP1Company) pSignP1Company.innerText = p1CompanyInput.value || '--';
      if (pSignP1Name) pSignP1Name.innerText = p1NameInput.value || '--';
      if (pSignP1Title) pSignP1Title.innerText = p1PositionInput.value || '--';

      const days = ["Minggu", "Senin", "Selasa", "Rabu", "Kamis", "Jumat", "Sabtu"];
      const dateVal = new Date();
      document.getElementById('p-bast-day')!.innerText = days[dateVal.getDay()];
    }

    function renderItemsEditor() {
      itemsContainer.innerHTML = '';
      currentItems.forEach((item, index) => {
        const div = document.createElement('div');
        div.className = "space-y-2 bg-slate-900/60 p-3 rounded-lg border border-slate-800";
        div.innerHTML = `
          <div class="flex items-center justify-between">
            <input type="text" class="item-title bg-slate-950 border border-slate-800 rounded px-2 py-1 text-xs text-white focus:outline-none font-bold w-[75%]" value="${item.title}" placeholder="Nama deliverable" data-index="${index}" />
            <button type="button" class="btn-delete-item text-rose-500 hover:text-rose-400 p-1 cursor-pointer select-none" data-index="${index}">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
            </button>
          </div>
          <textarea class="item-desc w-full bg-slate-950 border border-slate-800 rounded px-2 py-1 text-xs text-slate-350 focus:outline-none h-14" placeholder="Keterangan deliverable" data-index="${index}">${item.desc}</textarea>
        `;
        itemsContainer.appendChild(div);
      });

      // Bind
      document.querySelectorAll('.item-title').forEach(el => {
        el.addEventListener('input', (e) => {
          const idx = parseInt((e.target as HTMLInputElement).getAttribute('data-index')!);
          currentItems[idx].title = (e.target as HTMLInputElement).value;
          updatePreviewTable();
        });
      });
      document.querySelectorAll('.item-desc').forEach(el => {
        el.addEventListener('input', (e) => {
          const idx = parseInt((e.target as HTMLTextAreaElement).getAttribute('data-index')!);
          currentItems[idx].desc = (e.target as HTMLTextAreaElement).value;
          updatePreviewTable();
        });
      });
      document.querySelectorAll('.btn-delete-item').forEach(el => {
        el.addEventListener('click', (e) => {
          const idx = parseInt((e.currentTarget as HTMLButtonElement).getAttribute('data-index')!);
          currentItems.splice(idx, 1);
          renderItemsEditor();
          updatePreviewTable();
        });
      });
    }

    function updatePreviewTable() {
      const tbody = document.getElementById('preview-items-body') as HTMLTableSectionElement;
      tbody.innerHTML = '';
      currentItems.forEach((item, idx) => {
        const row = document.createElement('tr');
        row.className = "border-b border-slate-200";
        row.innerHTML = `
          <td class="p-2 border-r border-slate-300 text-center font-mono font-bold">${idx + 1}</td>
          <td class="p-2 border-r border-slate-300 font-bold text-slate-800">${item.title || '--'}</td>
          <td class="p-2 text-slate-650">${item.desc || '--'}</td>
        `;
        tbody.appendChild(row);
      });
    }

    function loadPreset(key: 'full') {
      const config = presets[key];
      bastNumInput.value = config.number;
      bastCityInput.value = config.city;
      bastProjInput.value = config.project;
      clientNameInput.value = config.clientName;
      clientCompanyInput.value = config.clientCompany;
      clientAddressInput.value = config.clientAddress;
      warrantyInput.value = config.warranty;

      const today = new Date();
      const monthNames = ["Januari", "Februari", "Maret", "April", "Mei", "Juni", "Juli", "Agustus", "September", "Oktober", "November", "Desember"];
      bastDateInput.value = `${today.getDate()} ${monthNames[today.getMonth()]} ${today.getFullYear()}`;

      currentItems = JSON.parse(JSON.stringify(config.items));

      renderItemsEditor();
      updatePreviewTable();
      updateMetadataPreview();

      document.getElementById(`preset-bast-${key}`)!.className = "px-2 py-2 rounded-lg bg-blue-600/10 hover:bg-blue-600/20 border border-blue-500/30 text-xs font-bold text-blue-400 transition-all hover:scale-[1.01] cursor-pointer";
    }

    // Bind listeners
    [bastNumInput, bastDateInput, bastCityInput, bastProjInput, clientNameInput, clientCompanyInput, clientAddressInput, warrantyInput, p1NameInput, p1CompanyInput, p1PositionInput, compAddressInput].forEach(el => {
      el.addEventListener('input', updateMetadataPreview);
    });

    btnAddItem.addEventListener('click', () => {
      currentItems.push({ title: 'Aset Baru', desc: '' });
      renderItemsEditor();
      updatePreviewTable();
    });

    document.getElementById('preset-bast-full')!.addEventListener('click', () => loadPreset('full'));

    document.getElementById('btn-download-pdf')!.addEventListener('click', () => window.print());

    document.getElementById('btn-download-word')!.addEventListener('click', () => {
      const filename = `BAST-${clientCompanyInput.value.replace(/\s+/g, '_') || 'LUMOVELO'}.doc`;
      const content = document.getElementById('paper-preview')!.innerHTML;

      const tempDiv = document.createElement('div');
      tempDiv.innerHTML = content;

      // Convert Signature block layout to table
      const signatureBlock = tempDiv.querySelector('#p-signature-block');
      if (signatureBlock) {
        const leftCol = signatureBlock.children[0]?.innerHTML || '';
        const rightCol = signatureBlock.children[1]?.innerHTML || '';
        signatureBlock.outerHTML = `
          <table style="width: 100%; margin-top: 40px; border-collapse: collapse;">
            <tr style="border: none !important;">
              <td style="width: 45%; text-align: center; vertical-align: top; border: none !important;">${leftCol}</td>
              <td style="width: 10%; border: none !important;"></td>
              <td style="width: 45%; text-align: center; vertical-align: top; border: none !important;">${rightCol}</td>
            </tr>
          </table>
        `;
      }

      const finalHtmlContent = tempDiv.innerHTML;

      const wordHtmlHeader = `<html xmlns:o='urn:schemas-microsoft-com:office:office' xmlns:w='urn:schemas-microsoft-com:office:word' xmlns='http://www.w3.org/TR/REC-html40'>
      <head>
      <title>Berita Acara Serah Terima (BAST)</title>
      <style>
        @page Section1 { size: 595.3pt 841.9pt; margin: 72pt; }
        div.Section1 { page: Section1; }
        body { font-family: 'Times New Roman', serif; font-size: 11pt; line-height: 1.35; }
        h1 { font-size: 13pt; font-weight: bold; text-align: center; text-transform: uppercase; margin-bottom: 20px; }
        table { width: 100%; border-collapse: collapse; margin-top: 10px; }
        th, td { border: 1px solid #cbd5e1; padding: 6px; font-size: 10pt; vertical-align: top; }
        th { background-color: #f8fafc; font-weight: bold; }
        .font-bold { font-weight: bold; }
        .underline { text-decoration: underline; }
      </style>
      </head>
      <body>
      <div class="Section1">
        ${finalHtmlContent}
      </div>
      </body>
      </html>`;

      const blob = new Blob(['\ufeff' + wordHtmlHeader], { type: 'application/msword' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = filename;
      a.click();
      URL.revokeObjectURL(url);
    });

    // Mobile Tabs
    const tabEditor = document.getElementById('tab-editor')!;
    const tabPreview = document.getElementById('tab-preview')!;
    const editorPanel = document.getElementById('editor-panel')!;
    const previewPanel = document.getElementById('preview-panel')!;

    tabEditor.addEventListener('click', () => {
      tabEditor.classList.add('border-blue-500', 'text-white');
      tabEditor.classList.remove('border-transparent', 'text-slate-400');
      tabPreview.classList.add('border-transparent', 'text-slate-400');
      tabPreview.classList.remove('border-blue-500', 'text-white');
      
      editorPanel.classList.remove('hidden');
      editorPanel.classList.add('block');
      previewPanel.classList.add('hidden');
      previewPanel.classList.remove('flex');
    });

    tabPreview.addEventListener('click', () => {
      tabPreview.classList.add('border-blue-500', 'text-white');
      tabPreview.classList.remove('border-transparent', 'text-slate-400');
      tabEditor.classList.add('border-transparent', 'text-slate-400');
      tabEditor.classList.remove('border-blue-500', 'text-white');
      
      previewPanel.classList.remove('hidden');
      previewPanel.classList.add('flex');
      editorPanel.classList.add('hidden');
      editorPanel.classList.remove('block');
    });

    // Dropdown Toggle
    const docBtn = document.getElementById('doc-selector-btn');
    const docMenu = document.getElementById('doc-selector-menu');
    if (docBtn && docMenu) {
      docBtn.onclick = (e) => {
        e.stopPropagation();
        docMenu.classList.toggle('hidden');
      };
      document.addEventListener('click', () => docMenu.classList.add('hidden'));
    }

    // Init
    loadPreset('full');
  </script>
</Layout>
