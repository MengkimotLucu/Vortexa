---
import '../styles/global.css';
import CursorGlow from '../components/CursorGlow.astro';
import WhatsAppFloating from '../components/WhatsAppFloating.astro';

interface Props {
  title?: string;
  description?: string;
  lang?: string;
}

const { 
  title = "LUMOVELO | Jasa Pembuatan Website Performa Tinggi, SEO & Integrasi AI Bandung", 
  description = "Agensi growth & software development terdepan di Bandung & Jakarta. Kami merekayasa solusi integrasi AI, otomatisasi bisnis, website headless performa tinggi, dan optimasi SEO organik untuk mendominasi pasar nasional hingga global.",
  lang = "id"
} = Astro.props;

const currentLocale = Astro.url.pathname.startsWith('/en/') || Astro.url.pathname === '/en' ? 'en' : 'id';
const isWorkspaceOrAdmin = Astro.url.pathname.includes('/admin') || Astro.url.pathname.includes('/workspace');

const getAlternates = (pathname: string) => {
  const cleanPath = pathname.endsWith('/') ? pathname : `${pathname}/`;
  
  // Explicit mapping pairs
  const pairs = [
    ['/', '/en/'],
    ['/tentang/', '/en/about-us/'],
    ['/karir/', '/en/careers/'],
    ['/kontak/', '/en/contact/'],
    ['/portofolio/', '/en/portfolio/']
  ];
  
  let idRelative = '';
  let enRelative = '';
  
  const matchedPair = pairs.find(pair => pair[0] === cleanPath || pair[1] === cleanPath);
  if (matchedPair) {
    idRelative = matchedPair[0];
    enRelative = matchedPair[1];
  } else {
    if (cleanPath.startsWith('/en/')) {
      enRelative = cleanPath;
      idRelative = cleanPath.replace(/^\/en/, '');
    } else {
      idRelative = cleanPath;
      enRelative = `/en${cleanPath}`;
    }
  }
  
  return {
    id: new URL(idRelative, 'https://lumovelo.agency').href,
    en: new URL(enRelative, 'https://lumovelo.agency').href,
  };
};

const canonicalURL = new URL(Astro.url.pathname, 'https://lumovelo.agency').href;
const alternates = getAlternates(Astro.url.pathname);
---

<!doctype html>
<html lang={currentLocale} class="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link class="astro-icon-favicon" rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang="id" href={alternates.id} />
    <link rel="alternate" hreflang="en" href={alternates.en} />
    <link rel="alternate" hreflang="x-default" href={alternates.id} />
    
    <!-- Google Tag Manager -->
    <script is:inline>
      window.addEventListener('load', () => {
        setTimeout(() => {
          (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
          new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
          j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
          'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
          })(window,document,'script','dataLayer','GTM-TKCVBB6F');
        }, 1000);
      });
    </script>
    <!-- End Google Tag Manager -->
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />

    <!-- Google Fonts: Plus Jakarta Sans -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    </noscript>

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://lumovelo.agency/" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/og-image.png" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content="/og-image.png" />
    
    <!-- Meta Pixel / Google Analytics placeholders -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-XXXXXXX');
    </script>

    <!-- JSON-LD Structured Data Schema -->
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "ProfessionalService",
        "name": "LUMOVELO",
        "image": "https://lumovelo.agency/og-image.png",
        "@id": "https://lumovelo.agency/#website",
        "url": "https://lumovelo.agency",
        "telephone": "+6285624353611",
        "priceRange": "$$",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Jl. Ir. H. Juanda No. 84",
          "addressLocality": "Bandung",
          "addressRegion": "Jawa Barat",
          "postalCode": "40132",
          "addressCountry": "ID"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": -6.8915,
          "longitude": 107.6106
        },
        "openingHoursSpecification": {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": [
            "Monday",
            "Tuesday",
            "Wednesday",
            "Thursday",
            "Friday",
            "Saturday"
          ],
          "opens": "09:00",
          "closes": "18:00"
        },
        "sameAs": [
          "https://github.com",
          "https://twitter.com",
          "https://linkedin.com",
          "https://instagram.com"
        ]
      }
    </script>
  </head>
  <body class="bg-white text-slate-900 min-h-screen selection:bg-blue-600/20 selection:text-blue-900">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-TKCVBB6F"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <slot />
    
    <!-- Aura cursor trail following mouse -->
    <CursorGlow />

    <!-- Floating WhatsApp contact button -->
    {!isWorkspaceOrAdmin && <WhatsAppFloating />}

    <!-- Scroll Reveal script -->
    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('revealed');
              observer.unobserve(entry.target);
            }
          });
        }, {
          threshold: 0.05,
          rootMargin: '0px 0px -40px 0px'
        });

        document.querySelectorAll('.reveal-on-scroll').forEach((el) => {
          observer.observe(el);
        });
      });
    </script>

    <!-- Custom Toast Notification System -->
    <script is:inline>
      window.showToast = function(message, type = 'success') {
        let container = document.getElementById('toast-container');
        if (!container) {
          container = document.createElement('div');
          container.id = 'toast-container';
          container.className = 'fixed bottom-6 right-6 z-[9999] flex flex-col gap-3 max-w-sm w-full pointer-events-none px-4 sm:px-0';
          document.body.appendChild(container);
        }

        const toast = document.createElement('div');
        toast.className = 'pointer-events-auto flex items-start gap-3 bg-slate-900/95 border text-slate-100 p-4 rounded-2xl shadow-2xl backdrop-blur-md transform translate-y-4 opacity-0 transition-all duration-300 ease-out';
        
        let icon = '';
        let borderClass = 'border-slate-800';
        
        if (type === 'success') {
          icon = `<div class="w-5 h-5 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 flex items-center justify-center shrink-0 text-xs font-bold">✓</div>`;
          borderClass = 'border-emerald-500/30';
        } else if (type === 'error') {
          icon = `<div class="w-5 h-5 rounded-full bg-rose-500/10 border border-rose-500/20 text-rose-400 flex items-center justify-center shrink-0 text-xs font-bold">!</div>`;
          borderClass = 'border-rose-500/30';
        } else {
          icon = `<div class="w-5 h-5 rounded-full bg-amber-500/10 border border-amber-500/20 text-amber-400 flex items-center justify-center shrink-0 text-xs font-bold">i</div>`;
          borderClass = 'border-amber-500/30';
        }

        toast.innerHTML = `
          ${icon}
          <div class="flex-1 text-[11px] font-medium leading-relaxed text-slate-200">${message}</div>
          <button class="text-slate-500 hover:text-slate-300 font-bold ml-2 shrink-0 cursor-pointer text-xs" onclick="this.parentElement.remove()">✕</button>
        `;

        toast.classList.add(borderClass);
        container.appendChild(toast);

        // Animate in
        setTimeout(() => {
          toast.classList.remove('translate-y-4', 'opacity-0');
        }, 10);

        // Auto remove
        setTimeout(() => {
          toast.classList.add('translate-y-4', 'opacity-0');
          setTimeout(() => {
            toast.remove();
          }, 300);
        }, 4000);
      };
    </script>
  </body>
</html>
